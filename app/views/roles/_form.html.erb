<%= form_with model: role, class: "mt-3" do |f| %>
  <%= render "shared/error_messages", object: role %>

  <div class="mb-3">
    <%= f.label :name, Role.human_attribute_name(:name), class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-4" style="display:flex; align-items:center; gap:0.6rem; padding:0.75rem 1rem; background:#f4f4f5; border-radius:8px; border:1px solid #e4e4e7;">
    <%= f.check_box :collaborator, id: "role_collaborator" %>
    <label for="role_collaborator" style="font-size:0.85rem; font-weight:600; color:#18181b; margin:0; cursor:pointer;">
      Perfil de colaborador
    </label>
    <span style="font-size:0.75rem; color:#71717a; margin-left:0.25rem;">— ao fazer login, redireciona para "Minha Escala"</span>
  </div>

  <fieldset class="mb-4">
    <legend class="fs-6 fw-semibold mb-2"><%= Permission.model_name.human(count: 2) %></legend>
    <div class="table-responsive">
      <table class="table table-bordered table-sm align-middle">
        <thead class="table-light">
          <tr>
            <th><%= t("labels.resource") %></th>
            <% Permission::ACTIONS.each do |action| %>
              <th class="text-center"><%= t("permission_actions.#{action}") %></th>
            <% end %>
            <% max_extra = Permission::EXTRA_ACTIONS.values.map(&:size).max || 0 %>
            <% max_extra.times do |i| %>
              <th class="text-center" style="color:#a1a1aa; font-size:0.8rem;">Extras</th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% Permission::RESOURCES.each do |resource| %>
            <% all_actions = Permission::ACTIONS + (Permission::EXTRA_ACTIONS[resource] || []) %>
            <tr>
              <td class="fw-medium">
                <%= t("activerecord.models.#{resource.singularize}", count: 2, default: resource.humanize) %>
              </td>
              <% Permission::ACTIONS.each do |action| %>
                <td class="text-center">
                  <% value = "#{resource}:#{action}" %>
                  <% checked = role.permissions.any? { |p| p.resource == resource && p.action == action } %>
                  <%= check_box_tag "role[permission_keys][]", value, checked,
                      id: "perm_#{resource}_#{action}" %>
                </td>
              <% end %>
              <%# Ações extras específicas do recurso %>
              <% (Permission::EXTRA_ACTIONS[resource] || []).each do |action| %>
                <td class="text-center" title="<%= t("permission_actions.#{action}", default: action.humanize) %>">
                  <% value = "#{resource}:#{action}" %>
                  <% checked = role.permissions.any? { |p| p.resource == resource && p.action == action } %>
                  <%= check_box_tag "role[permission_keys][]", value, checked,
                      id: "perm_#{resource}_#{action}" %>
                  <div style="font-size:0.6rem; color:#a1a1aa; margin-top:1px;">
                    <%= t("permission_actions.#{action}", default: action.humanize) %>
                  </div>
                </td>
              <% end %>
              <%# Células vazias para recursos sem ações extras %>
              <% max_extra = Permission::EXTRA_ACTIONS.values.map(&:size).max || 0 %>
              <% extra_count = (Permission::EXTRA_ACTIONS[resource] || []).size %>
              <% (max_extra - extra_count).times do %>
                <td></td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <%# Hidden field para garantir que array vazio seja enviado quando nenhuma checkbox marcada %>
    <%= hidden_field_tag "role[permission_keys][]", "" %>
  </fieldset>

  <div class="d-flex gap-2">
    <%= f.submit t("actions.save"), class: "btn btn-primary" %>
    <%= link_to t("actions.cancel"), roles_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
