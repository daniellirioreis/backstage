<%= form_with model: role, class: "mt-3" do |f| %>
  <%= render "shared/error_messages", object: role %>

  <div class="mb-3">
    <%= f.label :name, Role.human_attribute_name(:name), class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <fieldset class="mb-4">
    <legend class="fs-6 fw-semibold mb-2"><%= Permission.model_name.human(count: 2) %></legend>
    <div class="table-responsive">
      <table class="table table-bordered table-sm align-middle">
        <thead class="table-light">
          <tr>
            <th><%= t("labels.resource") %></th>
            <% Permission::ACTIONS.each do |action| %>
              <th class="text-center"><%= t("permission_actions.#{action}") %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% Permission::RESOURCES.each do |resource| %>
            <tr>
              <td class="fw-medium">
                <%= t("activerecord.models.#{resource.singularize}", count: 2, default: resource.humanize) %>
              </td>
              <% Permission::ACTIONS.each do |action| %>
                <td class="text-center">
                  <% value = "#{resource}:#{action}" %>
                  <% checked = role.permissions.any? { |p| p.resource == resource && p.action == action } %>
                  <%= check_box_tag "role[permission_keys][]", value, checked,
                      id: "perm_#{resource}_#{action}" %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <%# Hidden field para garantir que array vazio seja enviado quando nenhuma checkbox marcada %>
    <%= hidden_field_tag "role[permission_keys][]", "" %>
  </fieldset>

  <div class="d-flex gap-2">
    <%= f.submit t("actions.save"), class: "btn btn-primary" %>
    <%= link_to t("actions.cancel"), roles_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
