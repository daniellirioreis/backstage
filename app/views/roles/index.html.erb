<div class="page-header">
  <h1><%= Role.model_name.human(count: 2) %></h1>
  <%= link_to new_role_path, class: "btn-primary" do %>
    <i class="bi bi-plus"></i> <%= t("actions.new", model: Role.model_name.human) %>
  <% end %>
</div>

<table class="data-table">
  <thead>
    <tr>
      <th><%= Role.human_attribute_name(:name) %></th>
      <th><%= t("labels.permissions_count") %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @roles.each do |role| %>
      <tr>
        <td style="font-weight: 500;"><%= role.name %></td>
        <td style="color: #71717a;"><%= role.permissions.count %></td>
        <td class="td-actions">
          <%= link_to edit_role_path(role), class: "btn-secondary" do %><i class="bi bi-pencil"></i><% end %>
          <%= button_to role_path(role), method: :delete,
              form: { data: { turbo_confirm: t("confirms.delete") } },
              class: "btn-danger" do %><i class="bi bi-trash"></i><% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
