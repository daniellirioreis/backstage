<div class="d-flex justify-content-between align-items-center mb-3">
  <h1><%= Role.model_name.human(count: 2) %></h1>
  <%= link_to t("actions.new", model: Role.model_name.human), new_role_path, class: "btn btn-primary" %>
</div>

<table class="table table-hover">
  <thead class="table-dark">
    <tr>
      <th><%= Role.human_attribute_name(:name) %></th>
      <th><%= t("labels.permissions_count") %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @roles.each do |role| %>
      <tr>
        <td><%= role.name %></td>
        <td><%= role.permissions.count %></td>
        <td class="text-end">
          <%= link_to t("actions.edit"), edit_role_path(role), class: "btn btn-sm btn-outline-secondary" %>
          <%= button_to t("actions.delete"), role_path(role), method: :delete,
              form: { data: { turbo_confirm: t("confirms.delete") } },
              class: "btn btn-sm btn-outline-danger" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
