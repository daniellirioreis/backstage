<div class="page-header">
  <div style="display:flex; align-items:center; gap:0.75rem;">
    <%= link_to shifts_path, class:"btn-secondary", style:"padding:0.35rem 0.6rem;" do %>
      <i class="bi bi-arrow-left"></i>
    <% end %>
    <h1>Timeline da Escala</h1>
  </div>
  <div style="display:flex; gap:0.5rem; align-items:center;">
    <%# Toggle setores / colaboradores %>
    <div style="display:flex; border:1px solid #e4e4e7; border-radius:7px; overflow:hidden;">
      <%= link_to timeline_shifts_path(date: @date, view: "sectors"),
            style: "font-size:0.75rem; padding:0.3rem 0.7rem; text-decoration:none; white-space:nowrap; #{@view_mode == 'sectors' ? 'background:#18181b; color:#fff; font-weight:600;' : 'background:#fff; color:#71717a;'}" do %>
        <i class="bi bi-grid-3x3-gap"></i> Setores
      <% end %>
      <%= link_to timeline_shifts_path(date: @date, view: "collaborators"),
            style: "font-size:0.75rem; padding:0.3rem 0.7rem; text-decoration:none; white-space:nowrap; #{@view_mode == 'collaborators' ? 'background:#18181b; color:#fff; font-weight:600;' : 'background:#fff; color:#71717a;'}" do %>
        <i class="bi bi-person-lines-fill"></i> Colaboradores
      <% end %>
    </div>
    <% if policy(Shift).print? %>
      <%= link_to print_shifts_path, class:"btn-secondary" do %>
        <i class="bi bi-printer"></i> Imprimir
      <% end %>
    <% end %>
    <%= link_to new_shift_path, class:"btn-primary" do %>
      <i class="bi bi-plus"></i> Nova Escala
    <% end %>
  </div>
</div>

<%# Seletor de data %>
<div class="content-card" style="margin-bottom:1.25rem; padding:1rem 1.25rem;">
  <div style="display:flex; align-items:center; gap:1rem; flex-wrap:wrap;">
    <span style="font-size:0.82rem; font-weight:600; color:#71717a; white-space:nowrap;">
      <i class="bi bi-calendar3"></i> Data:
    </span>
    <div style="display:flex; gap:0.4rem; flex-wrap:wrap;">
      <% @available_dates.each do |d| %>
        <%= link_to l(d, format: :short), timeline_shifts_path(date: d, view: @view_mode),
            style: "font-size:0.78rem; padding:0.25rem 0.65rem; border-radius:6px; border:1px solid #{d == @date ? '#18181b' : '#e4e4e7'}; background:#{d == @date ? '#18181b' : 'transparent'}; color:#{d == @date ? '#fff' : '#3f3f46'}; text-decoration:none; white-space:nowrap;" %>
      <% end %>
    </div>
    <% if @event %>
      <span style="font-size:0.75rem; color:#a1a1aa; margin-left:auto;">
        <%= @event.name %> · <%= l(@event.start_date, format: :short) %> → <%= l(@event.end_date, format: :short) %>
      </span>
    <% end %>
  </div>
</div>

<% if @sectors_data.empty? %>
  <div class="content-card" style="text-align:center; padding:3rem; color:#a1a1aa;">
    <i class="bi bi-calendar-x" style="font-size:2rem; display:block; margin-bottom:0.5rem;"></i>
    <p style="margin:0; font-size:0.88rem;">Nenhuma escala cadastrada para <%= l(@date, format: :long) %>.</p>
  </div>
<% elsif @view_mode == "collaborators" %>

<%# ── Vista por Colaborador ── %>
<div class="content-card" style="padding:0; overflow-x:auto;">

  <%# Cabeçalho de horas %>
  <div style="display:flex; border-bottom:1.5px solid #18181b; background:#fafaf9; min-width:700px;">
    <div style="width:200px; flex-shrink:0; padding:0.5rem 1rem; font-size:0.65rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:#a1a1aa; border-right:1px solid #e4e4e7;">
      Colaborador
    </div>
    <div style="flex:1; position:relative; height:32px;">
      <% (0..23).each do |h| %>
        <div style="position:absolute; left:<%= (h / 24.0 * 100).round(2) %>%; top:0; bottom:0; display:flex; align-items:center;">
          <span style="font-size:0.62rem; font-weight:600; color:#a1a1aa; padding-left:3px; white-space:nowrap;"><%= "%02d" % h %>h</span>
        </div>
        <% if h > 0 %>
          <div style="position:absolute; left:<%= (h / 24.0 * 100).round(2) %>%; top:0; bottom:0; border-left:1px solid #e4e4e7;"></div>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Uma linha por colaborador %>
  <% @users_data.each do |user, user_shifts| %>
    <%
      checked_in = @checked_in_ids.include?(user.id)

      # Calcula lanes de barras sem sobreposição
      bars = []
      user_shifts.each do |s|
        started_before = s.date < @date
        ends_after     = s.end_date.present? && s.end_date > @date
        end_t          = s.end_time
        end_min_of_day   = end_t.hour * 60 + end_t.min
        start_min_of_day = s.start_time.hour * 60 + s.start_time.min
        single_overnight = !started_before && !ends_after && end_min_of_day < start_min_of_day
        eff_start_min  = started_before ? 0 : start_min_of_day
        eff_end_min    = (ends_after || single_overnight) ? 1440 : end_min_of_day
        sector_idx     = @sector_color_index[s.team&.sector&.id] || 0
        bars << {
          shift: s, start_min: eff_start_min, end_min: eff_end_min,
          overnight: single_overnight, started_before: started_before, ends_after: ends_after,
          sector_idx: sector_idx
        }
      end

      # Distribui barras em lanes sem sobreposição
      user_lanes = []
      bars.each do |bar|
        placed = false
        user_lanes.each do |lane|
          if lane.none? { |b| b[:start_min] < bar[:end_min] && bar[:start_min] < b[:end_min] }
            lane << bar; placed = true; break
          end
        end
        user_lanes << [bar] unless placed
      end
      row_height = [user_lanes.size * 36 + 8, 44].max
    %>

    <div style="display:flex; border-bottom:1px solid #e4e4e7; min-width:700px; min-height:<%= row_height %>px;">

      <%# Coluna do colaborador %>
      <div style="width:200px; flex-shrink:0; border-right:1px solid #e4e4e7; display:flex; align-items:center; padding:0.5rem 0.85rem; gap:0.55rem; background:#fafaf9; min-height:<%= row_height %>px;">
        <%# Avatar %>
        <div style="width:28px; height:28px; border-radius:50%; overflow:hidden; flex-shrink:0; border:1.5px solid <%= checked_in ? '#86efac' : '#e4e4e7' %>; background:#f4f4f5; display:flex; align-items:center; justify-content:center;">
          <% if user.avatar.attached? %>
            <%= image_tag user.avatar, style:"width:100%;height:100%;object-fit:cover;" %>
          <% else %>
            <span style="font-size:0.5rem; font-weight:700; color:#52525b;"><%= user.name.split.map(&:first).first(2).join.upcase %></span>
          <% end %>
        </div>
        <div style="min-width:0;">
          <div style="font-size:0.77rem; font-weight:600; color:<%= checked_in ? '#15803d' : '#18181b' %>; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
            <%= user.name.split.first %> <%= user.name.split.last %>
            <% if checked_in %>
              <span style="font-size:0.55rem; background:#dcfce7; color:#15803d; border:1px solid #86efac; border-radius:3px; padding:0 3px; margin-left:2px;">✓</span>
            <% end %>
          </div>
          <div style="font-size:0.65rem; color:#a1a1aa; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
            <%= user_shifts.map { |s| s.team&.name }.compact.uniq.first(2).join(", ") %>
          </div>
        </div>
      </div>

      <%# Área de barras %>
      <div style="flex:1; position:relative; min-height:<%= row_height %>px;">
        <%# Linhas verticais de hora %>
        <% (1..23).each do |h| %>
          <div style="position:absolute; left:<%= (h / 24.0 * 100).round(2) %>%; top:0; bottom:0; border-left:1px solid #f4f4f5;"></div>
        <% end %>

        <%# Barras por lane %>
        <% user_lanes.each_with_index do |lane, lane_idx| %>
          <% bar_top = lane_idx * 36 + 6 %>
          <% lane.each do |bar| %>
            <% s     = bar[:shift] %>
            <% left  = (bar[:start_min] / 1440.0 * 100).round(2) %>
            <% width = [(bar[:end_min] - bar[:start_min]) / 1440.0 * 100, 100.0 - left].min.round(2) %>
            <% color = timeline_colors[bar[:sector_idx] % timeline_colors.size] %>
            <% start_str = s.start_time.strftime("%H:%M") %>
            <% end_str   = s.end_time.strftime("%H:%M") %>
            <div class="tl-bar tl-collab-bar"
                 data-team="<%= s.team&.name %>"
                 data-sector="<%= s.team&.sector&.name %>"
                 data-hours="<%= start_str %>–<%= end_str %><%= bar[:overnight] ? ' +1' : '' %>"
                 data-user-name="<%= user.name %>"
                 data-user-id="<%= user.id %>"
                 style="position:absolute; left:<%= left %>%; width:<%= width %>%; top:<%= bar_top %>px; height:28px; background:<%= color %>; border-radius:5px; opacity:0.88; display:flex; align-items:center; padding:0 8px; overflow:hidden; min-width:4px; cursor:pointer;">
              <% if width > 4 %>
                <div style="display:flex; align-items:center; gap:4px; overflow:hidden; pointer-events:none; width:100%;">
                  <span style="font-size:0.68rem; color:#fff; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; line-height:1.2; flex:1; min-width:0;">
                    <span style="opacity:0.65; font-weight:400;"><%= s.team&.sector&.name %> ·</span>
                    <%= s.team&.name %>
                    <span style="opacity:0.75; font-weight:400;"> <%= start_str %>–<%= end_str %><% if bar[:overnight] %> +1<% end %></span>
                  </span>
                </div>
              <% end %>
            </div>
            <% if bar[:overnight] && !bar[:started_before] && !bar[:ends_after] %>
              <% end_w = timeline_bar_width(Time.parse("00:00"), s.end_time) %>
              <div style="position:absolute; left:0; width:<%= end_w %>%; top:<%= bar_top %>px; height:28px; background:<%= color %>; border-radius:5px; opacity:0.45; min-width:4px; pointer-events:none;"></div>
            <% end %>
          <% end %>
        <% end %>

        <% if @date == Date.today %>
          <div class="now-line" style="position:absolute; top:0; bottom:0; border-left:2px solid #ef4444; z-index:5; pointer-events:none;"></div>
        <% end %>
      </div>

    </div>
  <% end %>

</div>

<%# Legenda de setores %>
<div style="display:flex; gap:1rem; flex-wrap:wrap; margin-top:1rem; align-items:center;">
  <span style="font-size:0.72rem; color:#a1a1aa; font-weight:600;">Setores:</span>
  <% @sectors_data.each_with_index do |(sector, _), sidx| %>
    <div style="display:flex; align-items:center; gap:0.35rem;">
      <span style="width:10px; height:10px; border-radius:50%; background:<%= timeline_colors[sidx % timeline_colors.size] %>; flex-shrink:0;"></span>
      <span style="font-size:0.72rem; color:#52525b;"><%= sector.name %></span>
    </div>
  <% end %>
  <% if @date == Date.today %>
    <div style="display:flex; align-items:center; gap:0.35rem; margin-left:auto;">
      <span style="width:12px; height:2px; background:#ef4444;"></span>
      <span style="font-size:0.72rem; color:#a1a1aa;">agora</span>
    </div>
  <% end %>
</div>

<%# Popover simples para a view colaborador %>
<div id="tl-collab-popover" style="display:none; position:fixed; z-index:9999; background:#fff; border:1px solid #e4e4e7; border-radius:10px; box-shadow:0 8px 24px rgba(0,0,0,0.14); width:240px; pointer-events:auto;">
  <div style="padding:10px 12px 8px; border-bottom:1px solid #e4e4e7; display:flex; align-items:flex-start; justify-content:space-between; gap:8px;">
    <div>
      <div id="tcp-team" style="font-size:0.8rem;font-weight:700;color:#18181b;"></div>
      <div id="tcp-hours" style="font-size:0.72rem;color:#71717a;margin-top:1px;"></div>
    </div>
    <button id="tcp-close" style="background:none;border:none;cursor:pointer;color:#a1a1aa;font-size:1rem;line-height:1;padding:0;flex-shrink:0;">×</button>
  </div>
  <div id="tcp-body" style="padding:8px 12px; font-size:0.78rem; color:#52525b;"></div>
</div>

<script>
(function() {
  var cpop = document.getElementById('tl-collab-popover');
  if (!cpop) return;
  var cpopTeam  = document.getElementById('tcp-team');
  var cpopHours = document.getElementById('tcp-hours');
  var cpopBody  = document.getElementById('tcp-body');
  var cpopClose = document.getElementById('tcp-close');
  var activeBar = null;

  function closeCPopover() {
    cpop.style.display = 'none';
    if (activeBar) { activeBar.classList.remove('active-popover'); activeBar = null; }
  }

  function openCPopover(bar) {
    if (activeBar === bar) { closeCPopover(); return; }
    if (activeBar) activeBar.classList.remove('active-popover');
    activeBar = bar;
    bar.classList.add('active-popover');

    cpopTeam.textContent  = bar.getAttribute('data-team') || '';
    cpopHours.textContent = (bar.getAttribute('data-sector') || '') + ' · ' + (bar.getAttribute('data-hours') || '');
    cpopBody.innerHTML    = '<span style="color:#a1a1aa;">Colaborador:</span> ' + (bar.getAttribute('data-user-name') || '');

    var rect = bar.getBoundingClientRect();
    var x = rect.left;
    var y = rect.bottom + 6;
    if (x + 240 > window.innerWidth - 8) x = window.innerWidth - 248;
    if (x < 8) x = 8;
    cpop.style.left    = x + 'px';
    cpop.style.top     = y + 'px';
    cpop.style.display = 'block';
  }

  cpopClose.addEventListener('click', function(e) { e.stopPropagation(); closeCPopover(); });

  document.addEventListener('click', function(e) {
    var bar = e.target.closest ? e.target.closest('.tl-collab-bar') : null;
    if (bar) { e.stopPropagation(); openCPopover(bar); return; }
    if (!e.target.closest('#tl-collab-popover')) closeCPopover();
  });

  document.addEventListener('turbo:before-visit', closeCPopover);
})();
</script>

<% else %>

<div class="content-card" style="padding:0; overflow-x:auto;">

  <%# Cabeçalho de horas %>
  <div style="display:flex; border-bottom:1.5px solid #18181b; background:#fafaf9; min-width:700px;">
    <div style="width:160px; flex-shrink:0; padding:0.5rem 1rem; font-size:0.65rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:#a1a1aa; border-right:1px solid #e4e4e7;">
      Setor
    </div>
    <div style="flex:1; position:relative; height:32px;">
      <% (0..23).each do |h| %>
        <div style="position:absolute; left:<%= (h / 24.0 * 100).round(2) %>%; top:0; bottom:0; display:flex; align-items:center;">
          <span style="font-size:0.62rem; font-weight:600; color:#a1a1aa; padding-left:3px; white-space:nowrap;"><%= "%02d" % h %>h</span>
        </div>
        <% if h > 0 %>
          <div style="position:absolute; left:<%= (h / 24.0 * 100).round(2) %>%; top:0; bottom:0; border-left:1px solid #e4e4e7;"></div>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Uma linha por setor %>
  <% @sectors_data.each_with_index do |(sector, teams_data), sidx| %>
    <% color = timeline_colors[sidx % timeline_colors.size] %>

    <%# Detecta sobreposições para empilhar verticalmente %>
    <%
      # Cada equipe vira uma "faixa" vertical dentro da linha
      # Agrupa equipes que se sobrepõem em sub-linhas (lanes)
      lanes = []
      teams_data.each do |(team, team_shifts)|
        time_groups = team_shifts.group_by { |s| [s.start_time.strftime("%H:%M"), s.end_time.strftime("%H:%M")] }
        time_groups.each do |(times, group_shifts)|
          s         = group_shifts.first
          end_t     = s.end_time

          # Verifica se o turno começou num dia anterior ao visualizado
          started_before = s.date < @date
          # Verifica se o turno termina num dia posterior ao visualizado
          ends_after = s.end_date.present? && s.end_date > @date

          # Horário efetivo de início para a barra deste dia
          eff_start_min = started_before ? 0 : (s.start_time.hour * 60 + s.start_time.min)

          # Turno overnight de dia único (sem end_date, horário fim < início)
          # Usa comparação por minutos para evitar problema de TimeWithZone comparando UTC
          end_min_of_day   = end_t.hour * 60 + end_t.min
          start_min_of_day = s.start_time.hour * 60 + s.start_time.min
          single_overnight = !started_before && !ends_after && end_min_of_day < start_min_of_day

          # Horário efetivo de fim para a barra deste dia
          eff_end_min = if ends_after || single_overnight
            1440
          else
            end_t.hour * 60 + end_t.min
          end

          bar = { team: team, times: times, group_shifts: group_shifts,
                  start_min: eff_start_min, end_min: eff_end_min,
                  overnight: single_overnight, started_before: started_before, ends_after: ends_after }

          # Tenta colocar na primeira lane sem sobreposição
          placed = false
          lanes.each do |lane|
            if lane.none? { |b| b[:start_min] < bar[:end_min] && bar[:start_min] < b[:end_min] }
              lane << bar
              placed = true
              break
            end
          end
          lanes << [bar] unless placed
        end
      end
      row_height = [lanes.size * 36 + 8, 44].max
    %>

    <div style="display:flex; border-bottom:1px solid #e4e4e7; min-width:700px; min-height:<%= row_height %>px;" class="timeline-row">

      <%# Nome do setor %>
      <div style="width:160px; flex-shrink:0; border-right:1px solid #e4e4e7; display:flex; align-items:center; padding:0 1rem; background:#fafaf9; min-height:<%= row_height %>px;">
        <div style="display:flex; align-items:center; gap:0.4rem;">
          <span style="width:8px; height:8px; border-radius:50%; background:<%= color %>; flex-shrink:0;"></span>
          <span style="font-size:0.78rem; font-weight:600; color:#3f3f46;"><%= sector.name %></span>
        </div>
      </div>

      <%# Área de barras %>
      <div style="flex:1; position:relative; min-height:<%= row_height %>px;">
        <%# Linhas verticais de hora %>
        <% (1..23).each do |h| %>
          <div style="position:absolute; left:<%= (h / 24.0 * 100).round(2) %>%; top:0; bottom:0; border-left:1px solid #f4f4f5;"></div>
        <% end %>

        <%# Barras posicionadas por lane %>
        <% lanes.each_with_index do |lane, lane_idx| %>
          <% bar_top = lane_idx * 36 + 6 %>
          <% lane.each do |bar| %>
            <% left  = (bar[:start_min] / 1440.0 * 100).round(2) %>
            <% width = [(bar[:end_min] - bar[:start_min]) / 1440.0 * 100, 100.0 - left].min.round(2) %>

            <%
              coord = bar[:team].coordinator
              coord_name    = coord&.name.to_s
              coord_initials = coord_name.split.map(&:first).first(2).join.upcase
              coord_avatar  = coord&.avatar&.attached? ? url_for(coord.avatar) : nil
            %>
            <div class="tl-bar"
                 data-team="<%= bar[:team].name %>"
                 data-hours="<%= bar[:times][0] %>–<%= bar[:times][1] %><%= bar[:overnight] ? ' +1' : '' %>"
                 data-members="<%= bar[:group_shifts].map { |s| "#{s.user.name}::#{s.user_id}" }.join('||') %>"
                 data-coord-id="<%= coord&.id %>"
                 data-coord-name="<%= coord_name %>"
                 data-coord-initials="<%= coord_initials %>"
                 data-coord-avatar="<%= coord_avatar %>"
                 data-coord-checked="<%= coord && @checked_in_ids.include?(coord.id) %>"
                 style="position:absolute; left:<%= left %>%; width:<%= [width, 100.0 - left].min %>%; top:<%= bar_top %>px; height:28px; background:<%= color %>; border-radius:5px; opacity:0.88; display:flex; align-items:center; padding:0 8px; overflow:hidden; min-width:4px; cursor:default;">
              <% if width > 4 %>
                <div style="display:flex; align-items:center; gap:5px; overflow:hidden; pointer-events:none; width:100%;">
                  <%# Avatar do coordenador %>
                  <% if coord %>
                    <div style="width:20px; height:20px; border-radius:50%; overflow:hidden; border:1.5px solid rgba(255,255,255,0.5); flex-shrink:0; background:rgba(0,0,0,0.2); display:flex; align-items:center; justify-content:center; font-size:0.45rem; font-weight:700; color:#fff;">
                      <% if coord.avatar.attached? %>
                        <%= image_tag coord.avatar, style:"width:100%;height:100%;object-fit:cover;" %>
                      <% else %>
                        <%= coord_initials %>
                      <% end %>
                    </div>
                  <% end %>
                  <%# Nome da equipe + horário %>
                  <span style="font-size:0.68rem; color:#fff; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; line-height:1.2; flex:1; min-width:0;">
                    <%= bar[:team].name %>
                    <span style="opacity:0.75; font-weight:400;"> <%= bar[:times][0] %>–<%= bar[:times][1] %><% if bar[:overnight] %> +1<% end %></span>
                  </span>
                  <%# Contador de colaboradores %>
                  <span style="opacity:0.85; font-weight:500; background:rgba(0,0,0,0.18); border-radius:3px; padding:0 4px; font-size:0.6rem; color:#fff; white-space:nowrap; flex-shrink:0;">
                    <i class="bi bi-people-fill" style="font-family:'bootstrap-icons'; font-size:0.55rem;"></i> <%= bar[:group_shifts].size %>
                  </span>
                </div>
              <% end %>
            </div>

            <%# Barra fantasma: só para turnos overnight de dia único (cruzam meia-noite sem end_date) %>
            <% if bar[:overnight] && !bar[:started_before] && !bar[:ends_after] %>
              <% end_w = timeline_bar_width(Time.parse("00:00"), bar[:group_shifts].first.end_time) %>
              <div style="position:absolute; left:0; width:<%= end_w %>%; top:<%= bar_top %>px; height:28px; background:<%= color %>; border-radius:5px; opacity:0.45; min-width:4px; pointer-events:none;"></div>
            <% end %>
          <% end %>
        <% end %>

        <% if @date == Date.today %>
          <div class="now-line" style="position:absolute; top:0; bottom:0; border-left:2px solid #ef4444; z-index:5; pointer-events:none;"></div>
        <% end %>
      </div>

    </div>
  <% end %>

</div>

<%# Legenda %>
<div style="display:flex; gap:1rem; flex-wrap:wrap; margin-top:1rem; align-items:center;">
  <span style="font-size:0.72rem; color:#a1a1aa; font-weight:600;">Setores:</span>
  <% @sectors_data.each_with_index do |(sector, _), sidx| %>
    <div style="display:flex; align-items:center; gap:0.35rem;">
      <span style="width:10px; height:10px; border-radius:50%; background:<%= timeline_colors[sidx % timeline_colors.size] %>; flex-shrink:0;"></span>
      <span style="font-size:0.72rem; color:#52525b;"><%= sector.name %></span>
    </div>
  <% end %>
  <% if @date == Date.today %>
    <div style="display:flex; align-items:center; gap:0.35rem; margin-left:auto;">
      <span style="width:12px; height:2px; background:#ef4444;"></span>
      <span style="font-size:0.72rem; color:#a1a1aa;">agora</span>
    </div>
  <% end %>
</div>

<div id="tl-popover" style="display:none; position:fixed; z-index:9999; background:#fff; border:1px solid #e4e4e7; border-radius:10px; box-shadow:0 8px 24px rgba(0,0,0,0.14); width:280px; max-height:420px; display:none; flex-direction:column; overflow:hidden;">
  <div id="tl-popover-header" style="padding:10px 12px 8px; border-bottom:1px solid #e4e4e7; flex-shrink:0; display:flex; align-items:flex-start; justify-content:space-between; gap:8px;">
    <div>
      <div id="tl-popover-team" style="font-size:0.8rem;font-weight:700;color:#18181b;"></div>
      <div id="tl-popover-hours" style="font-size:0.72rem;color:#71717a;margin-top:1px;"></div>
    </div>
    <button id="tl-popover-close" style="background:none;border:none;cursor:pointer;color:#a1a1aa;font-size:1rem;line-height:1;padding:0;flex-shrink:0;" title="Fechar">×</button>
  </div>
  <div id="tl-popover-search-wrap" style="padding:7px 10px 6px; border-bottom:1px solid #f4f4f5; flex-shrink:0;">
    <input id="tl-popover-search" type="text" placeholder="Buscar colaborador..." autocomplete="off" style="width:100%; box-sizing:border-box; font-size:0.75rem; padding:5px 8px; border:1px solid #e4e4e7; border-radius:6px; outline:none; color:#18181b; background:#fafafa;">
  </div>
  <div id="tl-popover-body" style="overflow-y:auto; flex:1; padding:8px 12px;"></div>
</div>

<style>
  .tl-bar { cursor: pointer; }
  .tl-bar:hover { opacity: 1 !important; filter: brightness(1.08); }
  .tl-bar.active-popover { opacity: 1 !important; outline: 2px solid rgba(255,255,255,0.7); outline-offset: 1px; }
</style>

<script>
  (function() {
    function initTimeline() {
      <% if @date == Date.today %>
      var now = new Date();
      var pct = ((now.getHours() * 60 + now.getMinutes()) / 1440 * 100).toFixed(2);
      document.querySelectorAll('.now-line').forEach(function(el) { el.style.left = pct + '%'; });
      <% end %>

      var checkedIds = new Set(<%= raw @checked_in_ids.to_a.to_json %>);
      var pop = document.getElementById('tl-popover');
      if (!pop) return;
      var popBody   = document.getElementById('tl-popover-body');
      var popTeam   = document.getElementById('tl-popover-team');
      var popHours  = document.getElementById('tl-popover-hours');
      var popClose  = document.getElementById('tl-popover-close');
      var popSearch = document.getElementById('tl-popover-search');
      var activeBar = null;
      var allMembers = [];   // cache dos membros do popover atual

      function renderMembers(filter) {
        var q = (filter || '').toLowerCase().trim();
        var filtered = q ? allMembers.filter(function(e) { return e.split('::')[0].toLowerCase().indexOf(q) !== -1; }) : allMembers;

        var html = '';
        if (filtered.length === 0) {
          html = '<div style="font-size:0.75rem;color:#a1a1aa;text-align:center;padding:8px 0;">Nenhum resultado</div>';
        } else {
          var checkedCount = filtered.filter(function(e) { return checkedIds.has(parseInt(e.split('::')[1], 10)); }).length;
          html += '<div style="font-size:0.62rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:#a1a1aa;margin-bottom:4px;">'
               + 'Colaboradores <span style="font-weight:400;color:#a1a1aa;">(' + checkedCount + '/' + filtered.length + ' check-in)</span></div>';
          filtered.forEach(function(entry) {
            var parts   = entry.split('::');
            var name    = parts[0];
            var userId  = parts[1];
            var checked = checkedIds.has(parseInt(userId, 10));
            html += '<div style="font-size:0.75rem;color:' + (checked ? '#15803d' : '#3f3f46') + ';padding:3px 0;display:flex;align-items:center;gap:6px;">'
                  + (checked
                      ? '<span style="width:16px;height:16px;border-radius:50%;background:#dcfce7;border:1px solid #86efac;display:flex;align-items:center;justify-content:center;font-size:0.6rem;color:#16a34a;flex-shrink:0;">✓</span>'
                      : '<span style="width:6px;height:6px;border-radius:50%;background:#d4d4d8;flex-shrink:0;margin-left:5px;"></span>')
                  + name + '</div>';
          });
        }
        popBody.innerHTML = html;
      }

      popSearch.addEventListener('input', function() { renderMembers(popSearch.value); });
      popSearch.addEventListener('click', function(e) { e.stopPropagation(); });

      function closePopover() {
        pop.style.display = 'none';
        popSearch.value = '';
        allMembers = [];
        if (activeBar) { activeBar.classList.remove('active-popover'); activeBar = null; }
      }

      function positionPopover(bar) {
        var rect = bar.getBoundingClientRect();
        var x = rect.left;
        var y = rect.bottom + 6;
        // Ajuste horizontal se sair da janela
        if (x + 280 > window.innerWidth - 8) x = window.innerWidth - 288;
        if (x < 8) x = 8;
        // Ajuste vertical: abre para cima se não couber abaixo
        pop.style.left = x + 'px';
        pop.style.top  = y + 'px';
      }

      function openPopover(bar) {
        if (activeBar === bar) { closePopover(); return; }
        if (activeBar) activeBar.classList.remove('active-popover');
        activeBar = bar;
        bar.classList.add('active-popover');

        var team         = bar.getAttribute('data-team') || '';
        var hours        = bar.getAttribute('data-hours') || '';
        var raw          = bar.getAttribute('data-members') || '';
        var members      = raw ? raw.split('||').filter(function(e) { return e.split('::')[1] !== coordId; }).sort(function(a, b) { return a.split('::')[0].localeCompare(b.split('::')[0], 'pt-BR'); }) : [];
        var coordId      = bar.getAttribute('data-coord-id') || '';
        var coordName    = bar.getAttribute('data-coord-name') || '';
        var coordInit    = bar.getAttribute('data-coord-initials') || '';
        var coordAvtr    = bar.getAttribute('data-coord-avatar') || '';
        var coordChecked = bar.getAttribute('data-coord-checked') === 'true';

        popTeam.textContent  = team;
        popHours.textContent = hours;
        popSearch.value = '';

        var html = '';

        // Coordenador
        if (coordName) {
          var borderColor = coordChecked ? '#86efac' : '#e4e4e7';
          var avatarHtml  = coordAvtr
            ? '<img src="' + coordAvtr + '" style="width:26px;height:26px;border-radius:50%;object-fit:cover;border:1.5px solid ' + borderColor + ';flex-shrink:0;">'
            : '<div style="width:26px;height:26px;border-radius:50%;background:' + (coordChecked ? '#dcfce7' : '#f4f4f5') + ';border:1px solid ' + borderColor + ';display:flex;align-items:center;justify-content:center;font-size:0.55rem;font-weight:700;color:' + (coordChecked ? '#15803d' : '#71717a') + ';flex-shrink:0;">' + coordInit + '</div>';
          var checkBadge  = coordChecked
            ? '<span style="margin-left:auto;background:#dcfce7;border-radius:4px;padding:1px 6px;font-size:0.6rem;font-weight:600;color:#15803d;white-space:nowrap;">✓ check-in</span>'
            : '';
          html += '<div style="font-size:0.62rem;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:#a1a1aa;margin-bottom:4px;">Coordenador(a)</div>'
               + '<div style="display:flex;align-items:center;gap:7px;padding:5px 0 7px;border-bottom:1px solid #f4f4f5;margin-bottom:6px;">'
               + avatarHtml
               + '<span style="font-size:0.78rem;font-weight:600;color:' + (coordChecked ? '#15803d' : '#18181b') + ';flex:1;min-width:0;">' + coordName + '</span>'
               + checkBadge + '</div>';
        }

        popBody.innerHTML = html;

        // Colaboradores — armazenados em allMembers para busca
        allMembers = members;
        if (members.length) renderMembers('');
        pop.style.display = 'flex';
        positionPopover(bar);
      }

      popClose.addEventListener('click', function(e) { e.stopPropagation(); closePopover(); });

      // Clique nas barras (apenas setor view — ignora barras de colaborador)
      document.addEventListener('click', function(e) {
        var bar = e.target.closest ? e.target.closest('.tl-bar') : null;
        if (bar && !bar.classList.contains('tl-collab-bar')) { e.stopPropagation(); openPopover(bar); return; }
        if (!e.target.closest('#tl-popover')) closePopover();
      });

      // Fechar ao navegar
      document.addEventListener('turbo:before-visit', closePopover);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTimeline);
    } else {
      initTimeline();
    }
    // Compatibilidade com Turbo
    document.addEventListener('turbo:load', initTimeline);
  })();
</script>

<% end %>
