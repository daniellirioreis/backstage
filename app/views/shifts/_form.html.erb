<%= form_with model: shift, class: "mt-3" do |f| %>
  <%= render "shared/error_messages", object: shift %>

  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <%= f.label :date, Shift.human_attribute_name(:date), class: "form-label" %>
      <%= f.date_field :date, class: "form-control" %>
    </div>
    <div class="col-md-4">
      <%= f.label :start_time, Shift.human_attribute_name(:start_time), class: "form-label" %>
      <%= f.time_field :start_time, class: "form-control" %>
    </div>
    <div class="col-md-4">
      <%= f.label :end_time, Shift.human_attribute_name(:end_time), class: "form-label" %>
      <%= f.time_field :end_time, class: "form-control" %>
    </div>
    <div class="col-md-6">
      <%= f.label :user_id, User.model_name.human, class: "form-label" %>
      <%= f.collection_select :user_id, User.order(:name), :id, :name,
          { include_blank: "— Selecione —" }, class: "form-select" %>
    </div>
    <div class="col-md-6">
      <%= f.label :sector_id, Sector.model_name.human, class: "form-label" %>
      <%= f.collection_select :sector_id,
          Sector.includes(team: :event).order("events.name, teams.name, sectors.name").references(team: :event),
          :id, ->(s) { "#{s.team.event.name} › #{s.team.name} › #{s.name}" },
          { include_blank: "— Selecione —" }, class: "form-select" %>
    </div>
    <div class="col-md-12">
      <div class="form-check">
        <%= f.check_box :has_radio, class: "form-check-input" %>
        <%= f.label :has_radio, Shift.human_attribute_name(:has_radio), class: "form-check-label" %>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit t("actions.save"), class: "btn btn-primary" %>
    <%= link_to t("actions.cancel"), shifts_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
