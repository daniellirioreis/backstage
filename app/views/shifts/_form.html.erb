<%= form_with model: shift, local: true do |f| %>
  <%= render "shared/error_messages", object: shift %>

  <div class="content-card" style="margin-bottom: 1rem;">
    <h3 style="font-size: 0.82rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #71717a; margin: 0 0 1rem;">Equipe / Colaborador</h3>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
      <div>
        <label class="form-label">Equipe</label>
        <%= f.select :team_id,
            options_from_collection_for_select(@teams, :id, ->(t) { "#{t.sector.name} › #{t.name}" }, shift.team_id),
            { include_blank: "— Sem equipe —" },
            class: "form-control" %>
      </div>
      <div>
        <label class="form-label"><%= User.model_name.human %></label>
        <%= f.select :user_id,
            options_from_collection_for_select(@all_users, :id, :name, shift.user_id),
            { include_blank: "— Selecione —" },
            class: "form-control" %>
      </div>
    </div>

    <div>
      <label class="form-label"><%= Sector.model_name.human %></label>
      <%= f.select :sector_id,
          options_from_collection_for_select(@sectors, :id, :name, shift.sector_id),
          { include_blank: "— Selecione —" },
          class: "form-control" %>
    </div>
  </div>

  <div class="content-card" style="margin-bottom: 1rem;">
    <h3 style="font-size: 0.82rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #71717a; margin: 0 0 1rem;">Período</h3>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
      <div>
        <label class="form-label">Data início</label>
        <%= f.date_field :date, class: "form-control" %>
      </div>
      <div>
        <label class="form-label">Data fim <span style="font-weight: 400; color: #a1a1aa;">(opcional — para turnos multi-dia)</span></label>
        <%= f.date_field :end_date, class: "form-control" %>
      </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
      <div>
        <label class="form-label">Hora início</label>
        <%= f.time_field :start_time, class: "form-control" %>
      </div>
      <div>
        <label class="form-label">
          Hora fim
          <span style="font-weight: 400; color: #a1a1aa;">(pode ser menor que início para turnos overnight)</span>
        </label>
        <%= f.time_field :end_time, class: "form-control" %>
      </div>
    </div>

  </div>

  <div style="display: flex; gap: 0.5rem;">
    <%= f.submit t("actions.save"), class: "btn-primary" %>
    <%= link_to t("actions.cancel"), :back, class: "btn-secondary" %>
  </div>
<% end %>
