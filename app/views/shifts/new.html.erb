<div class="page-header">
  <h1>Nova Escala</h1>
</div>

<%# ── Step 1: seleção de equipe + dias ───────────────────────────────────── %>
<%= form_with url: new_shift_path, method: :get, local: true do |f| %>
  <%= hidden_field_tag :modal, params[:modal] if params[:modal].present? %>

  <%# Dias do evento (cards clicáveis) — aparece se event_days estiver configurado %>
  <% if @event_days.any? %>
    <%
      # Dias já selecionados (vêm dos params na volta de erro/reload)
      selected_dates = [params[:date], params[:end_date]].compact.map { |d| Date.parse(d) rescue nil }.compact
      if selected_dates.size == 2 && selected_dates[0] <= selected_dates[1]
        selected_dates = (selected_dates[0]..selected_dates[1]).to_a
      end
    %>
    <div class="content-card" style="margin-bottom: 1rem;">
      <h3 style="font-size: 0.82rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #71717a; margin: 0 0 0.9rem;">
        <i class="bi bi-calendar3"></i> Dias do evento
        <span style="font-size:0.7rem; font-weight:400; color:#a1a1aa; margin-left:0.25rem;">— selecione os dias desta escala</span>
      </h3>

      <div id="day-cards" style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-bottom:0.5rem;">
        <% @event_days.each do |ed| %>
          <%
            is_selected = selected_dates.include?(ed.date)
            hrs = ed.hours.to_f
            hrs_label = hrs == hrs.to_i ? "#{hrs.to_i}h" : "#{hrs}h"
            dow = I18n.l(ed.date, format: "%a")
          %>
          <button type="button"
                  class="day-card <%= 'day-card--selected' if is_selected %>"
                  data-date="<%= ed.date %>"
                  data-hours="<%= hrs %>"
                  onclick="toggleDay(this)"
                  style="
                    display:flex; flex-direction:column; align-items:center;
                    padding:0.55rem 0.9rem; border-radius:8px; cursor:pointer;
                    border:2px solid <%= is_selected ? '#7c3aed' : '#e4e4e7' %>;
                    background:<%= is_selected ? '#f5f3ff' : '#fff' %>;
                    transition: all 0.15s ease;
                    min-width:72px;
                  ">
            <span style="font-size:0.68rem; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; color:<%= is_selected ? '#7c3aed' : '#71717a' %>;">
              <%= dow %>
            </span>
            <span style="font-size:1rem; font-weight:700; color:<%= is_selected ? '#7c3aed' : '#18181b' %>; line-height:1.2;">
              <%= ed.date.day %>/<%= ed.date.month.to_s.rjust(2,'0') %>
            </span>
            <span style="font-size:0.68rem; color:<%= is_selected ? '#7c3aed' : '#a1a1aa' %>; margin-top:1px;">
              <%= hrs_label %>
            </span>
          </button>
        <% end %>
      </div>

      <div id="day-summary" style="font-size:0.78rem; color:#71717a; min-height:1.2em;"></div>

      <%# Hidden inputs derivados da seleção %>
      <input type="hidden" id="hidden_date"     name="date"     value="<%= params[:date] %>">
      <input type="hidden" id="hidden_end_date" name="end_date" value="<%= params[:end_date] %>">
    </div>

  <% else %>
    <%# Fallback: inputs livres de data %>
    <div class="content-card" style="margin-bottom: 1rem;">
      <h3 style="font-size: 0.82rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #71717a; margin: 0 0 1rem;">
        <i class="bi bi-calendar3"></i> Período
      </h3>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div>
          <label class="form-label">
            Data início <span style="color: #ef4444;">*</span>
            <% if @event %>
              <span style="font-weight: 400; color: #a1a1aa;">(<%= l(@event.start_date, format: :short) %> → <%= l(@event.end_date, format: :short) %>)</span>
            <% end %>
          </label>
          <input type="date" name="date" value="<%= params[:date] %>" class="form-control" required
                 <% if @event %> min="<%= @event.start_date %>" max="<%= @event.end_date %>" <% end %>>
        </div>
        <div>
          <label class="form-label">Data fim <span style="color: #a1a1aa; font-weight: 400;">(opcional)</span></label>
          <input type="date" name="end_date" value="<%= params[:end_date] %>" class="form-control"
                 <% if @event %> min="<%= @event.start_date %>" max="<%= @event.end_date %>" <% end %>>
        </div>
      </div>
    </div>
  <% end %>

  <%# Equipe %>
  <div class="content-card" style="margin-bottom: 1rem;">
    <h3 style="font-size: 0.82rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #71717a; margin: 0 0 1rem;">
      <i class="bi bi-people"></i> Equipe
    </h3>
    <% selected_team = @teams.find { |t| t.id.to_s == params[:team_id].to_s } %>
    <% if selected_team %>
      <input type="text" class="form-control" value="<%= selected_team.sector.name %> › <%= selected_team.name %>" disabled
             style="background: #f9fafb; color: #71717a; cursor: not-allowed;">
      <input type="hidden" name="team_id" value="<%= selected_team.id %>">
    <% else %>
      <div data-controller="team-autocomplete"
           data-team-autocomplete-url-value="<%= search_teams_path %>"
           data-team-autocomplete-existing-value="{}"
           style="position: relative;">
        <div data-team-autocomplete-target="selected"></div>
        <input type="text"
               data-team-autocomplete-target="input"
               data-action="input->team-autocomplete#search"
               class="form-control"
               placeholder="Buscar equipe por nome ou setor..."
               autocomplete="off">
        <div data-team-autocomplete-target="dropdown" class="autocomplete-dropdown" style="display: none;"></div>
        <input type="hidden" data-team-autocomplete-target="hidden" name="team_id" value="">
      </div>
    <% end %>
  </div>

  <button type="submit" class="btn-primary" id="step1-submit"
          <%= 'disabled' if @event_days.any? && params[:date].blank? %>>
    <i class="bi bi-arrow-right"></i> Ver colaboradores
  </button>
<% end %>

<%# ── Step 2: colaboradores + horários ───────────────────────────────────── %>
<%# Só mostra se a equipe E a data foram selecionadas (ou re-render pós erro) %>
<% if @selected_team.present? && (params[:date].present? || @submitted_members.present?) %>
  <% if @shift_errors&.any? %>
    <div style="background: #fef2f2; border: 1px solid #fca5a5; border-radius: 8px; padding: 1rem 1.25rem; margin-top: 1rem;">
      <div style="font-weight: 700; color: #dc2626; font-size: 0.88rem; margin-bottom: 0.5rem;">
        <i class="bi bi-exclamation-circle-fill"></i>
        <%= @shift_errors.size %> turno(s) não foram salvos:
        <% if @shift_created.to_i > 0 %>
          <span style="color: #15803d; font-weight: 500; margin-left: 0.5rem;">
            <i class="bi bi-check-circle-fill"></i> <%= @shift_created %> salvo(s) com sucesso.
          </span>
        <% end %>
      </div>
      <% @shift_errors.each do |err| %>
        <div style="font-size: 0.82rem; color: #991b1b; padding: 4px 0;">
          <strong><%= err[:name] %>:</strong>
          <ul style="margin: 2px 0 0 1rem; padding: 0;">
            <% err[:messages].each do |msg| %><li><%= msg %></li><% end %>
          </ul>
        </div>
      <% end %>
      <% if @shift_skipped&.any? %>
        <div style="font-size: 0.78rem; color: #a1a1aa; margin-top: 0.4rem;">
          Sem horário (ignorados): <%= @shift_skipped.join(', ') %>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @team_has_shifts && @shift_errors.blank? %>
    <div style="background: #fef3c7; border: 1px solid #fcd34d; border-radius: 8px; padding: 1rem 1.25rem; margin-top: 1rem; display: flex; align-items: flex-start; gap: 0.75rem;">
      <i class="bi bi-exclamation-triangle-fill" style="color: #f59e0b; font-size: 1.1rem; flex-shrink: 0; margin-top: 1px;"></i>
      <div>
        <div style="font-weight: 600; color: #92400e; font-size: 0.88rem;">Esta equipe já possui escala definida</div>
        <div style="font-size: 0.82rem; color: #92400e; margin-top: 0.2rem;">
          Para alterar, acesse a
          <%= link_to "página da equipe", team_path(@selected_team), style: "color: #92400e; font-weight: 600;" %>
          ou a
          <%= link_to "listagem de escalas", shifts_path, style: "color: #92400e; font-weight: 600;" %>
          e edite os turnos existentes.
        </div>
      </div>
    </div>
  <% else %>
    <%= form_with url: shifts_path, method: :post, local: true, data: { turbo: false } do |f| %>
      <input type="hidden" name="team_id"  value="<%= @selected_team.id %>">
      <input type="hidden" name="date"     value="<%= params[:date] %>">
      <input type="hidden" name="end_date" value="<%= params[:end_date] %>">
      <%= hidden_field_tag :modal, params[:modal] if params[:modal].present? %>

      <%# Período selecionado (display) %>
      <% if @event_days.any? %>
        <%
          d_start = Date.parse(params[:date]) rescue nil
          d_end   = params[:end_date].present? ? (Date.parse(params[:end_date]) rescue nil) : nil
          days_range = d_start && d_end && d_end > d_start ? (d_start..d_end).to_a : [d_start].compact
          matching_days = @event_days.select { |ed| days_range.include?(ed.date) }
          total_h = matching_days.sum { |ed| ed.hours.to_f }
        %>
        <div class="content-card" style="margin-top: 1rem; margin-bottom: 1rem; padding: 0.85rem 1.25rem;">
          <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:0.5rem;">
            <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
              <span style="font-size:0.75rem; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; color:#71717a;">
                <i class="bi bi-calendar3"></i> Dias selecionados
              </span>
              <% matching_days.each do |ed| %>
                <span style="font-size:0.75rem; font-weight:600; background:#f5f3ff; color:#7c3aed; border:1px solid #ddd6fe; border-radius:5px; padding:2px 8px;">
                  <%= I18n.l(ed.date, format: "%a %d/%m") %> · <%= ed.hours.to_f == ed.hours.to_f.to_i ? ed.hours.to_i : ed.hours %>h
                </span>
              <% end %>
            </div>
            <% if total_h > 0 %>
              <span style="font-size:0.78rem; font-weight:700; color:#7c3aed;">
                <%= total_h.to_f == total_h.to_i ? total_h.to_i : total_h %>h total
              </span>
            <% end %>
          </div>
        </div>
      <% end %>

      <%= render "shifts/members_table",
            team: @selected_team,
            team_members: @team_members,
            selected_days: @selected_days,
            existing_shifts: {},
            submitted_members: @submitted_members %>

      <div style="display: flex; gap: 0.5rem;">
        <button type="submit" class="btn-primary">
          <i class="bi bi-calendar-check"></i> Salvar Escala
        </button>
        <% if params[:modal] == "1" %>
          <button type="button" class="btn-secondary" onclick="window.parent.closeShiftModal()">Cancelar</button>
        <% else %>
          <%= link_to "Cancelar", shifts_path, class: "btn-secondary" %>
        <% end %>
      </div>
    <% end %>
  <% end %>
<% end %>

<script>
(function () {
  var selectedDates = [];

  // Inicializa com valores já presentes nos hidden inputs (reload após erro)
  var hiddenDate    = document.getElementById("hidden_date");
  var hiddenEndDate = document.getElementById("hidden_end_date");
  if (hiddenDate && hiddenDate.value) {
    var startD = new Date(hiddenDate.value + "T00:00:00");
    var endD   = hiddenEndDate && hiddenEndDate.value
                   ? new Date(hiddenEndDate.value + "T00:00:00")
                   : startD;
    var cur = new Date(startD);
    while (cur <= endD) {
      selectedDates.push(cur.toISOString().slice(0, 10));
      cur.setDate(cur.getDate() + 1);
    }
  }

  function isoDate(btn) { return btn.dataset.date; }

  function updateUI() {
    // Atualiza visual dos cards
    document.querySelectorAll(".day-card").forEach(function (btn) {
      var sel = selectedDates.includes(isoDate(btn));
      btn.style.borderColor  = sel ? "#7c3aed" : "#e4e4e7";
      btn.style.background   = sel ? "#f5f3ff" : "#fff";
      btn.querySelectorAll("span").forEach(function (s) {
        s.style.color = sel ? "#7c3aed" : (s.style.color === "rgb(24, 24, 27)" ? "#18181b" : "#71717a");
      });
    });

    // Hidden inputs
    if (!hiddenDate) return;
    if (selectedDates.length === 0) {
      hiddenDate.value    = "";
      hiddenEndDate.value = "";
    } else {
      var sorted = selectedDates.slice().sort();
      hiddenDate.value    = sorted[0];
      hiddenEndDate.value = sorted.length > 1 ? sorted[sorted.length - 1] : "";
    }

    // Resumo
    var summary = document.getElementById("day-summary");
    if (summary) {
      summary.textContent = selectedDates.length === 0
        ? "Nenhum dia selecionado"
        : selectedDates.length + " dia(s) selecionado(s)";
    }

    // Habilita/desabilita submit
    var btn = document.getElementById("step1-submit");
    if (btn) btn.disabled = selectedDates.length === 0;
  }

  window.toggleDay = function (btn) {
    var d   = isoDate(btn);
    var idx = selectedDates.indexOf(d);
    if (idx === -1) selectedDates.push(d);
    else            selectedDates.splice(idx, 1);
    updateUI();
  };

  // Inicializa os cards com estado correto
  updateUI();
})();
</script>
