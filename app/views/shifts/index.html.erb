<div class="page-header">
  <h1><%= Shift.model_name.human(count: 2) %></h1>
  <% if policy(Shift).new? %>
    <%= link_to new_shift_path, class: "btn-primary" do %>
      <i class="bi bi-plus"></i> <%= t("actions.new", model: Shift.model_name.human) %>
    <% end %>
  <% end %>
</div>

<table class="data-table">
  <thead>
    <tr>
      <th><%= Shift.human_attribute_name(:date) %></th>
      <th><%= Shift.human_attribute_name(:start_time) %></th>
      <th><%= Shift.human_attribute_name(:end_time) %></th>
      <th><%= User.model_name.human %></th>
      <th><%= Sector.model_name.human %></th>
      <th><%= Shift.human_attribute_name(:has_radio) %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @shifts.each do |shift| %>
      <tr>
        <td style="font-weight: 500;"><%= l(shift.date, format: :short) %></td>
        <td style="color: #71717a; font-family: monospace;"><%= shift.start_time.strftime("%H:%M") %></td>
        <td style="color: #71717a; font-family: monospace;"><%= shift.end_time.strftime("%H:%M") %></td>
        <td><%= shift.user.name %></td>
        <td style="color: #71717a;"><%= shift.sector.name %></td>
        <td>
          <% if shift.has_radio? %>
            <span class="badge-status badge-active"><i class="bi bi-reception-4"></i> Sim</span>
          <% else %>
            <span style="color: #a1a1aa; font-size: 0.8rem;">—</span>
          <% end %>
        </td>
        <td class="td-actions">
          <% if policy(shift).edit? %>
            <%= link_to edit_shift_path(shift), class: "btn-secondary" do %><i class="bi bi-pencil"></i><% end %>
          <% end %>
          <% if policy(shift).destroy? %>
            <%= button_to shift_path(shift), method: :delete,
                form: { data: { turbo_confirm: t("confirms.delete") } },
                class: "btn-danger" do %><i class="bi bi-trash"></i><% end %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
