<div class="page-header">
  <h1><%= Shift.model_name.human(count: 2) %></h1>
  <div style="display: flex; gap: 0.5rem;">
    <% if policy(Shift).timeline? %>
      <%= link_to timeline_shifts_path, class: "btn-secondary" do %>
        <i class="bi bi-bar-chart-steps"></i> Timeline
      <% end %>
    <% end %>
    <% if policy(Shift).print? %>
      <%= link_to print_shifts_path, class: "btn-secondary" do %>
        <i class="bi bi-printer"></i> Imprimir Escala
      <% end %>
    <% end %>
    <% if policy(Shift).new? %>
      <%= link_to new_shift_path, class: "btn-primary" do %>
        <i class="bi bi-plus"></i> <%= t("actions.new", model: Shift.model_name.human) %>
      <% end %>
    <% end %>
  </div>
</div>

<% if @shifts_by_team.empty? %>
  <div class="content-card" style="text-align: center; padding: 2.5rem; color: #a1a1aa;">
    <i class="bi bi-calendar3" style="font-size: 2rem; display: block; margin-bottom: 0.5rem;"></i>
    <p style="margin: 0; font-size: 0.88rem;">Nenhuma escala cadastrada.</p>
  </div>
<% else %>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 1.25rem;">
    <% @shifts_by_team.each do |team, shifts| %>
      <div class="content-card" style="display: flex; flex-direction: column; gap: 0; height: 420px;">

        <%# Header do card %>
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
          <div>
            <% if team %>
              <div style="font-size: 0.68rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; color: #a1a1aa; margin-bottom: 0.15rem;">
                <i class="bi bi-grid-3x3-gap" style="font-size: 0.6rem;"></i> <%= team.sector.name %>
              </div>
              <h2 style="font-size: 1rem; font-weight: 700; color: #18181b; margin: 0 0 0.3rem;">
                <%= link_to team.name, team_path(team), style: "color: inherit; text-decoration: none;" %>
              </h2>
              <% if team.coordinator %>
                <div style="display: flex; align-items: center; gap: 0.35rem;">
                  <div style="width: 18px; height: 18px; border-radius: 50%; overflow: hidden; background: #fef3c7; border: 1px solid #fcd34d; display: flex; align-items: center; justify-content: center; font-size: 0.45rem; font-weight: 700; color: #92400e; flex-shrink: 0;">
                    <% if team.coordinator.avatar.attached? %>
                      <%= image_tag team.coordinator.avatar, style: "width:100%;height:100%;object-fit:cover;" %>
                    <% else %>
                      <%= team.coordinator.name.split.map(&:first).first(2).join.upcase %>
                    <% end %>
                  </div>
                  <span style="font-size: 0.72rem; color: #92400e; font-weight: 500;">
                    <i class="bi bi-star-fill" style="font-size: 0.55rem;"></i> <%= team.coordinator.name.split.first %>
                  </span>
                </div>
              <% end %>
            <% else %>
              <h2 style="font-size: 1rem; font-weight: 700; color: #71717a; margin: 0;">Sem equipe</h2>
            <% end %>
          </div>
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <span style="background: #f4f4f5; border-radius: 20px; padding: 0.2rem 0.65rem; font-size: 0.72rem; font-weight: 600; color: #71717a;">
              <%= shifts.size %> turno<%= shifts.size == 1 ? "" : "s" %>
            </span>
            <% if team && policy(shifts.first).edit? %>
              <%= link_to edit_team_shifts_path(team_id: team.id), class: "btn-secondary", style: "padding: 0.25rem 0.55rem; font-size: 0.78rem;", title: "Editar escala da equipe" do %>
                <i class="bi bi-pencil"></i> Editar
              <% end %>
            <% end %>
          </div>
        </div>

        <%# Lista de turnos agrupada por data %>
        <div style="overflow-y: auto; flex: 1;">
        <% shifts.group_by(&:date).each do |date, day_shifts| %>
          <div style="margin-bottom: 0.75rem;">
            <div style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: #52525b; background: #f4f4f5; border-radius: 5px; padding: 0.25rem 0.6rem; margin-bottom: 0.4rem;">
              <i class="bi bi-calendar3" style="font-size: 0.6rem;"></i>
              <%= l(date, format: :short) %>
              <% end_dates = day_shifts.map(&:end_date).compact.select { |d| d > date } %>
              <% if end_dates.any? %>
                <span style="font-weight: 400; color: #a1a1aa;"> → <%= l(end_dates.max, format: :short) %></span>
              <% end %>
            </div>

            <% day_shifts.each do |shift| %>
              <div style="display: flex; align-items: center; gap: 0.6rem; padding: 0.4rem 0.5rem; border-radius: 6px; border: 1px solid #f4f4f5; margin-bottom: 0.3rem;">
                <%# Avatar %>
                <div style="width: 28px; height: 28px; border-radius: 50%; overflow: hidden; background: #f4f4f5; border: 1px solid #e4e4e7; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                  <% if shift.user.avatar.attached? %>
                    <%= image_tag shift.user.avatar, style: "width:100%;height:100%;object-fit:cover;" %>
                  <% else %>
                    <span style="font-size: 0.52rem; font-weight: 700; color: #52525b;">
                      <%= shift.user.name.split.map(&:first).first(2).join.upcase %>
                    </span>
                  <% end %>
                </div>

                <%# Nome %>
                <div style="flex: 1; min-width: 0;">
                  <div style="font-size: 0.83rem; font-weight: 500; color: #18181b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                    <%= shift.user.name %>
                  </div>
                  <div style="font-size: 0.72rem; font-family: monospace; color: #71717a;">
                    <%= shift.start_time.strftime("%H:%M") %> → <%= shift.end_time.strftime("%H:%M") %>
                    <% if shift.overnight? %>
                      <span style="font-size: 0.6rem; background: #fef3c7; color: #92400e; border: 1px solid #fcd34d; border-radius: 3px; padding: 0 3px; font-family: sans-serif;">overnight</span>
                    <% end %>
                  </div>
                  <% code = @credential_map&.dig([shift.team_id, shift.user_id]) %>
                  <% if code.present? %>
                    <div style="font-size: 0.65rem; font-family: monospace; color: #a1a1aa; letter-spacing: 0.03em; margin-top: 1px;">
                      <i class="bi bi-person-badge" style="font-family: 'bootstrap-icons';"></i> <%= code %>
                    </div>
                  <% end %>
                </div>

                <%# Ações %>
                <div style="display: flex; gap: 0.25rem; flex-shrink: 0;">
                  <% if policy(shift).edit? %>
                    <%= link_to edit_shift_path(shift), class: "btn-secondary", style: "padding: 0.25rem 0.45rem; font-size: 0.75rem;" do %>
                      <i class="bi bi-pencil"></i>
                    <% end %>
                  <% end %>
                  <% if policy(shift).destroy? %>
                    <%= button_to shift_path(shift), method: :delete,
                        form: { data: { turbo_confirm: t("confirms.delete") } },
                        class: "btn-danger", style: "padding: 0.25rem 0.45rem; font-size: 0.75rem;" do %>
                      <i class="bi bi-trash"></i>
                    <% end %>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
        </div>

      </div>
    <% end %>
  </div>
<% end %>
