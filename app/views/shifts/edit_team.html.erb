<div class="page-header">
  <div>
    <h1>Editar Escala</h1>
    <div style="font-size: 0.78rem; color: #71717a; margin-top: 0.15rem;">
      <i class="bi bi-grid-3x3-gap" style="font-size: 0.7rem;"></i> <%= @selected_team.sector.name %> ·
      <strong><%= @selected_team.name %></strong>
    </div>
  </div>
  <%= link_to shifts_path, class: "btn-secondary" do %>
    <i class="bi bi-arrow-left"></i> Voltar
  <% end %>
</div>

<%# Erros %>
<% if @update_errors&.any? %>
  <div style="background: #fef2f2; border: 1px solid #fca5a5; border-radius: 8px; padding: 1rem 1.25rem; margin-bottom: 1rem;">
    <div style="font-weight: 700; color: #dc2626; font-size: 0.88rem; margin-bottom: 0.5rem;">
      <i class="bi bi-exclamation-circle-fill"></i> <%= @update_errors.size %> turno(s) com erro:
    </div>
    <% @update_errors.each do |err| %>
      <div style="font-size: 0.82rem; color: #991b1b; padding: 2px 0;">
        <strong><%= err[:name] %>:</strong> <%= err[:messages].join(', ') %>
      </div>
    <% end %>
  </div>
<% end %>

<%= form_with url: update_team_shifts_path, method: :patch, local: true do |f| %>
  <input type="hidden" name="team_id" value="<%= @selected_team.id %>">

  <%# Período %>
  <div class="content-card" style="margin-bottom: 1rem;">
    <h3 style="font-size: 0.82rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #71717a; margin: 0 0 1rem;">
      <i class="bi bi-calendar3"></i> Período
    </h3>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
      <div>
        <label class="form-label">
          Data início <span style="color: #ef4444;">*</span>
          <% if @event %>
            <span style="font-weight: 400; color: #a1a1aa;">(<%= l(@event.start_date, format: :short) %> → <%= l(@event.end_date, format: :short) %>)</span>
          <% end %>
        </label>
        <input type="date" name="date"
               value="<%= @ref_date || params[:date] %>"
               class="form-control" required
               <% if @event %> min="<%= @event.start_date %>" max="<%= @event.end_date %>" <% end %>>
      </div>
      <div>
        <label class="form-label">Data fim <span style="color: #a1a1aa; font-weight: 400;">(opcional)</span></label>
        <input type="date" name="end_date"
               value="<%= @ref_end_date || params[:end_date] %>"
               class="form-control"
               <% if @event %> min="<%= @event.start_date %>" max="<%= @event.end_date %>" <% end %>>
      </div>
    </div>
  </div>

  <%# Colaboradores %>
  <div class="content-card" style="margin-bottom: 1.5rem;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
      <h3 style="font-size: 0.82rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #71717a; margin: 0;">
        <i class="bi bi-people"></i> Colaboradores — <strong style="color: #18181b;"><%= @selected_team.name %></strong>
      </h3>
      <div style="display: flex; gap: 0.5rem; align-items: center;">
        <label style="font-size: 0.78rem; color: #71717a; margin: 0;">Horário padrão:</label>
        <input type="time" id="bulk_start"
               style="font-size: 0.82rem; padding: 0.3rem 0.5rem; border: 1px solid #e4e4e7; border-radius: 6px; color: #18181b;"
               oninput="document.querySelectorAll('.col-start').forEach(i=>i.value=this.value)">
        <span style="color: #a1a1aa;">→</span>
        <input type="time" id="bulk_end"
               style="font-size: 0.82rem; padding: 0.3rem 0.5rem; border: 1px solid #e4e4e7; border-radius: 6px; color: #18181b;"
               oninput="document.querySelectorAll('.col-end').forEach(i=>i.value=this.value)">
        <span style="font-size: 0.72rem; color: #a1a1aa;">(aplica a todos)</span>
      </div>
    </div>

    <% if @team_members.empty? %>
      <div style="text-align: center; color: #a1a1aa; font-size: 0.85rem; padding: 1.5rem;">
        Nenhum colaborador nesta equipe.
      </div>
    <% else %>
      <table class="data-table">
        <thead>
          <tr>
            <th style="width: 36px;">
              <input type="checkbox" id="check_all" checked
                     style="width: 15px; height: 15px; cursor: pointer;"
                     onchange="document.querySelectorAll('.member-check').forEach(c=>c.checked=this.checked)">
            </th>
            <th>Colaborador</th>
            <th style="width: 130px;">Hora início</th>
            <th style="width: 130px;">Hora fim</th>
            <th style="width: 80px; color: #a1a1aa;">Status</th>
          </tr>
        </thead>
        <tbody>
          <% @team_members.each do |tm| %>
            <% existing = @existing_shifts[tm.user_id] %>
            <%
              submitted = @submitted_members&.dig(tm.user_id.to_s)
              start_val = submitted&.dig(:start_time) || existing&.start_time&.strftime("%H:%M") || ""
              end_val   = submitted&.dig(:end_time)   || existing&.end_time&.strftime("%H:%M")   || ""
              was_checked = @submitted_members.nil? || submitted&.dig(:selected) == "1"
            %>
            <tr>
              <td>
                <input type="checkbox" name="members[<%= tm.user_id %>][selected]" value="1"
                       class="member-check" <%= "checked" if was_checked %>
                       style="width: 15px; height: 15px; cursor: pointer;">
              </td>
              <td>
                <div style="display: flex; align-items: center; gap: 0.6rem;">
                  <div style="width: 30px; height: 30px; border-radius: 50%; overflow: hidden; background: #f4f4f5; border: 1px solid #e4e4e7; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <% if tm.user.avatar.attached? %>
                      <%= image_tag tm.user.avatar, style: "width:100%;height:100%;object-fit:cover;" %>
                    <% else %>
                      <span style="font-size: 0.58rem; font-weight: 700; color: #52525b;">
                        <%= tm.user.name.split.map(&:first).first(2).join.upcase %>
                      </span>
                    <% end %>
                  </div>
                  <div>
                    <div style="font-size: 0.85rem; font-weight: 500; color: #18181b;">
                      <%= tm.user.name %>
                      <% if tm.user_id == @selected_team.coordinator_id %>
                        <span style="font-size: 0.62rem; background: #fef3c7; color: #92400e; border: 1px solid #fcd34d; border-radius: 4px; padding: 1px 5px;">Coord.</span>
                      <% end %>
                    </div>
                    <div style="font-size: 0.72rem; color: #a1a1aa;"><%= tm.user.phone %></div>
                  </div>
                </div>
              </td>
              <td>
                <input type="time" name="members[<%= tm.user_id %>][start_time]"
                       value="<%= start_val %>"
                       class="col-start form-control" style="padding: 0.3rem 0.5rem; font-size: 0.82rem;">
              </td>
              <td>
                <input type="time" name="members[<%= tm.user_id %>][end_time]"
                       value="<%= end_val %>"
                       class="col-end form-control" style="padding: 0.3rem 0.5rem; font-size: 0.82rem;">
              </td>
              <td style="text-align: center;">
                <% if existing %>
                  <span style="display: inline-flex; align-items: center; gap: 3px; background: #dcfce7; border: 1px solid #86efac; border-radius: 5px; padding: 1px 7px; font-size: 0.65rem; font-weight: 600; color: #15803d;">
                    <i class="bi bi-check2"></i> salvo
                  </span>
                <% else %>
                  <span style="display: inline-flex; align-items: center; gap: 3px; background: #fef3c7; border: 1px solid #fcd34d; border-radius: 5px; padding: 1px 7px; font-size: 0.65rem; font-weight: 600; color: #92400e;">
                    <i class="bi bi-plus"></i> novo
                  </span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>

  <div style="display: flex; gap: 0.5rem;">
    <button type="submit" class="btn-primary">
      <i class="bi bi-calendar-check"></i> Salvar Alterações
    </button>
    <%= link_to "Cancelar", shifts_path, class: "btn-secondary" %>
  </div>
<% end %>
