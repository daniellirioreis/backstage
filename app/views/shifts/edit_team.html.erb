<% uid = @selected_team.id %>

<%= turbo_frame_tag "shift-frame-#{uid}" do %>

<%# ── Cabeçalho — oculto quando embutido em frame ── %>
<% unless @in_frame %>
  <div class="page-header">
    <div>
      <h1>Editar Escala</h1>
      <div style="font-size: 0.78rem; color: #71717a; margin-top: 0.15rem;">
        <i class="bi bi-grid-3x3-gap" style="font-size: 0.7rem;"></i> <%= @selected_team.sector.name %> ·
        <strong><%= @selected_team.name %></strong>
      </div>
    </div>
    <% back_path = params[:wizard] == "1" ? schedules_event_setup_path(@event) : shifts_path %>
    <%= link_to back_path, class: "btn-secondary", data: { turbo_frame: "_top" } do %>
      <i class="bi bi-arrow-left"></i> Voltar
    <% end %>
  </div>
<% end %>

<%# ── Erros ── %>
<% if @update_errors&.any? %>
  <div style="background:#fef2f2; border:1px solid #fca5a5; border-radius:8px; padding:1rem 1.25rem; margin-bottom:1rem;">
    <div style="font-weight:700; color:#dc2626; font-size:0.88rem; margin-bottom:0.5rem;">
      <i class="bi bi-exclamation-circle-fill"></i> <%= @update_errors.size %> turno(s) com erro:
    </div>
    <% @update_errors.each do |err| %>
      <div style="font-size:0.82rem; color:#991b1b; padding:2px 0;">
        <strong><%= err[:name] %>:</strong> <%= err[:messages].join(', ') %>
      </div>
    <% end %>
  </div>
<% end %>

<%# ── PASSO 1: Seleção de dias ── %>
<% if @event_days.any? %>
  <%
    selected_date_strs = @selected_days.map { |ed| ed.date.to_s }
  %>
  <%# Sem local:true → Turbo trata o GET e atualiza só o frame %>
  <%= form_with url: edit_team_shifts_path, method: :get do %>
    <input type="hidden" name="team_id" value="<%= uid %>">
    <% if params[:modal].present? %>
      <input type="hidden" name="modal"  value="<%= params[:modal] %>">
    <% end %>
    <% if params[:wizard].present? %>
      <input type="hidden" name="wizard" value="<%= params[:wizard] %>">
    <% end %>

    <div class="content-card" style="margin-bottom:1rem;">
      <h3 style="font-size:0.82rem; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; color:#71717a; margin:0 0 0.9rem;">
        <i class="bi bi-calendar3"></i> Dias do evento
        <span style="font-size:0.7rem; font-weight:400; color:#a1a1aa; margin-left:0.25rem;">— selecione e clique em <strong style="color:#7c3aed;">Confirmar</strong></span>
      </h3>

      <div style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-bottom:0.75rem;">
        <% @event_days.each do |ed| %>
          <%
            is_sel    = selected_date_strs.include?(ed.date.to_s)
            hrs_label = ed.hours.to_f == ed.hours.to_i ? "#{ed.hours.to_i}h" : "#{ed.hours}h"
            dow       = I18n.l(ed.date, format: "%a")
          %>
          <button type="button"
                  data-date="<%= ed.date %>"
                  onclick="toggleDay_<%= uid %>(this)"
                  style="
                    display:flex; flex-direction:column; align-items:center;
                    padding:0.55rem 0.9rem; border-radius:8px; cursor:pointer;
                    border:2px solid <%= is_sel ? '#7c3aed' : '#e4e4e7' %>;
                    background:<%= is_sel ? '#f5f3ff' : '#fff' %>;
                    min-width:72px; transition:all 0.15s ease;">
            <span style="font-size:0.68rem; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; color:<%= is_sel ? '#7c3aed' : '#71717a' %>;">
              <%= dow %>
            </span>
            <span style="font-size:1rem; font-weight:700; color:<%= is_sel ? '#7c3aed' : '#18181b' %>; line-height:1.2;">
              <%= ed.date.day %>/<%= ed.date.month.to_s.rjust(2,'0') %>
            </span>
            <span style="font-size:0.68rem; color:<%= is_sel ? '#7c3aed' : '#a1a1aa' %>; margin-top:1px;">
              <%= hrs_label %>
            </span>
          </button>
        <% end %>
      </div>

      <input type="hidden" id="hidden_date_<%= uid %>"     name="date"     value="<%= @selected_days.first&.date %>">
      <input type="hidden" id="hidden_end_date_<%= uid %>" name="end_date" value="<%= @selected_days.size > 1 ? @selected_days.last.date : '' %>">

      <div style="display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap;">
        <span id="day-summary-<%= uid %>" style="font-size:0.78rem; color:#71717a; min-height:1.2em;">
          <%= @selected_days.any? ? "#{@selected_days.size} dia(s) selecionado(s)" : "Nenhum dia selecionado" %>
        </span>
        <button type="submit" id="confirm-days-btn-<%= uid %>" class="btn-secondary"
                style="font-size:0.78rem; padding:0.3rem 0.75rem;"
                <%= 'disabled' if @selected_days.empty? %>>
          <i class="bi bi-arrow-clockwise"></i> Confirmar seleção
        </button>
      </div>
    </div>
  <% end %>
<% end %>

<%# ── PASSO 2: Tabela + Salvar (só aparece após confirmar dia) ── %>
<% show_table = @selected_days.any? || @event_days.empty? %>

<% if show_table %>
  <%= form_with url: update_team_shifts_path, method: :patch, local: true, data: { turbo: false } do |f| %>
    <input type="hidden" name="team_id" value="<%= uid %>">
    <%= hidden_field_tag :modal,  params[:modal]  if params[:modal].present? %>
    <%= hidden_field_tag :wizard, params[:wizard] if params[:wizard].present? %>

    <% if @event_days.empty? %>
      <div class="content-card" style="margin-bottom:1rem;">
        <h3 style="font-size:0.82rem; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; color:#71717a; margin:0 0 1rem;">
          <i class="bi bi-calendar3"></i> Período
        </h3>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
          <div>
            <label class="form-label">
              Data início <span style="color:#ef4444;">*</span>
              <% if @event %>
                <span style="font-weight:400; color:#a1a1aa;">(<%= l(@event.start_date, format: :short) %> → <%= l(@event.end_date, format: :short) %>)</span>
              <% end %>
            </label>
            <input type="date" name="date" value="<%= @ref_date || params[:date] %>" class="form-control" required
                   <% if @event %> min="<%= @event.start_date %>" max="<%= @event.end_date %>" <% end %>>
          </div>
          <div>
            <label class="form-label">Data fim <span style="color:#a1a1aa; font-weight:400;">(opcional)</span></label>
            <input type="date" name="end_date" value="<%= @ref_end_date || params[:end_date] %>" class="form-control"
                   <% if @event %> min="<%= @event.start_date %>" max="<%= @event.end_date %>" <% end %>>
          </div>
        </div>
      </div>
    <% else %>
      <input type="hidden" name="date"     value="<%= @selected_days.first&.date || params[:date] %>">
      <input type="hidden" name="end_date" value="<%= @selected_days.size > 1 ? @selected_days.last.date : '' %>">
    <% end %>

    <% if @selected_days.any? %>
      <% total_h = @selected_days.sum { |ed| ed.hours.to_f } %>
      <div class="content-card" style="margin-bottom:1rem; padding:0.85rem 1.25rem;">
        <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:0.5rem;">
          <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
            <span style="font-size:0.75rem; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; color:#71717a;">
              <i class="bi bi-calendar3"></i> Editando dias:
            </span>
            <% @selected_days.each do |ed| %>
              <span style="font-size:0.75rem; font-weight:600; background:#f5f3ff; color:#7c3aed; border:1px solid #ddd6fe; border-radius:5px; padding:2px 8px;">
                <%= I18n.l(ed.date, format: "%a %d/%m") %> · <%= ed.hours.to_f == ed.hours.to_i ? ed.hours.to_i : ed.hours %>h
              </span>
            <% end %>
          </div>
          <% if total_h > 0 %>
            <span style="font-size:0.78rem; font-weight:700; color:#7c3aed;">
              <%= total_h.to_f == total_h.to_i ? total_h.to_i : total_h %>h total
            </span>
          <% end %>
        </div>
      </div>
    <% end %>

    <%= render "shifts/members_table",
          team: @selected_team,
          team_members: @team_members,
          selected_days: @selected_days,
          existing_shifts: @existing_shifts,
          submitted_members: @submitted_members %>

    <div style="display:flex; align-items:center; gap:0.75rem; margin-top:0.75rem; flex-wrap:wrap;">
      <button type="submit" id="save-shifts-btn-<%= uid %>" class="btn-primary" disabled
              style="opacity:0.5; cursor:not-allowed; transition:opacity 0.2s;">
        <i class="bi bi-calendar-check"></i> Salvar Alterações
      </button>
      <span id="unsaved-badge-<%= uid %>"
            style="display:none; font-size:0.72rem; font-weight:600; color:#92400e; background:#fef3c7; border:1px solid #fcd34d; border-radius:5px; padding:2px 9px;">
        <i class="bi bi-circle-fill" style="font-size:0.45rem; vertical-align:middle;"></i> Alterações não salvas
      </span>
      <% if params[:modal] == "1" %>
        <button type="button" class="btn-secondary" onclick="window.parent.closeShiftModal()">Cancelar</button>
      <% elsif params[:wizard] == "1" %>
        <%= link_to "Cancelar", schedules_event_setup_path(@event), class: "btn-secondary", data: { turbo_frame: "_top" } %>
      <% else %>
        <%= link_to "Cancelar", shifts_path, class: "btn-secondary" %>
      <% end %>
    </div>
  <% end %>

  <script>
  (function () {
    var uid    = <%= uid %>;
    var btn    = document.getElementById('save-shifts-btn-' + uid);
    var badge  = document.getElementById('unsaved-badge-' + uid);
    var form   = btn && btn.closest('form');
    if (!btn || !form) return;

    // Activa o botão e mostra badge quando qualquer campo muda
    function markDirty() {
      btn.disabled = false;
      btn.style.opacity = '1';
      btn.style.cursor  = 'pointer';
      if (badge) badge.style.display = 'inline-flex';
    }

    // Verifica se há ao menos uma hora preenchida (col-start ou col-end)
    function hasAnyTime() {
      return Array.from(form.querySelectorAll('.col-start, .col-end')).some(function(i) {
        return i.value && i.value !== '--:--';
      });
    }

    form.addEventListener('input', function (e) {
      var el = e.target;
      // Reage a: checkboxes de membro, qualquer input de horário
      if (el.classList.contains('member-check') || el.classList.contains('col-start') || el.classList.contains('col-end')) {
        if (hasAnyTime()) markDirty();
      }
    });

    form.addEventListener('change', function (e) {
      var el = e.target;
      if (el.classList.contains('member-check') || el.classList.contains('col-start') || el.classList.contains('col-end')) {
        if (hasAnyTime()) markDirty();
      }
    });

    // Ao submeter, desabilita o botão e remove badge (evita double-submit)
    form.addEventListener('submit', function () {
      btn.disabled = true;
      btn.style.opacity = '0.6';
      btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Salvando…';
      if (badge) badge.style.display = 'none';
    });

    // Se já há horários salvos na página, habilita o botão imediatamente (edição de escala existente)
    if (hasAnyTime()) {
      btn.disabled = false;
      btn.style.opacity = '1';
      btn.style.cursor  = 'pointer';
    }
  })();
  </script>
<% else %>
  <%# Nenhum dia confirmado: instrução para selecionar %>
  <div style="background:#f5f3ff; border:1px dashed #c4b5fd; border-radius:10px; padding:1.5rem; text-align:center; color:#7c3aed; font-size:0.85rem; margin-top:0.5rem;">
    <i class="bi bi-hand-index-thumb" style="font-size:1.4rem; display:block; margin-bottom:0.4rem;"></i>
    Selecione um ou mais dias acima e clique em <strong>Confirmar seleção</strong> para configurar os horários.
  </div>
<% end %>

<% if @event_days.any? %>
<script>
(function () {
  var uid  = <%= uid %>;
  // Escopo: o turbo-frame desta equipe (evita conflito entre frames de equipes diferentes)
  var frame = document.getElementById('shift-frame-' + uid) || document;

  var hiddenDate    = frame.querySelector('#hidden_date_'     + uid);
  var hiddenEndDate = frame.querySelector('#hidden_end_date_' + uid);

  var selectedDates = <%= raw @selected_days.map { |ed| ed.date.to_s }.to_json %>;

  function updateUI() {
    frame.querySelectorAll("[data-date]").forEach(function (btn) {
      var sel = selectedDates.includes(btn.dataset.date);
      btn.style.borderColor = sel ? "#7c3aed" : "#e4e4e7";
      btn.style.background  = sel ? "#f5f3ff" : "#fff";
      btn.querySelectorAll("span").forEach(function (s) {
        if (s.style.fontSize === "1rem") {
          s.style.color = sel ? "#7c3aed" : "#18181b";
        } else {
          s.style.color = sel ? "#7c3aed" : (s.style.textTransform === "uppercase" ? "#71717a" : "#a1a1aa");
        }
      });
    });

    if (hiddenDate) {
      var sorted = selectedDates.slice().sort();
      hiddenDate.value    = sorted[0] || "";
      hiddenEndDate.value = sorted.length > 1 ? sorted[sorted.length - 1] : "";
    }

    var summary = frame.querySelector('#day-summary-' + uid);
    if (summary) {
      summary.textContent = selectedDates.length === 0
        ? "Nenhum dia selecionado"
        : selectedDates.length + " dia(s) selecionado(s)";
    }

    var confirmBtn = frame.querySelector('#confirm-days-btn-' + uid);
    if (confirmBtn) confirmBtn.disabled = selectedDates.length === 0;
  }

  window['toggleDay_' + uid] = function (btn) {
    var d   = btn.dataset.date;
    var idx = selectedDates.indexOf(d);
    if (idx === -1) selectedDates.push(d);
    else            selectedDates.splice(idx, 1);
    updateUI();
  };

  updateUI();
})();
</script>
<% end %>

<% end %><%# /turbo_frame_tag %>
