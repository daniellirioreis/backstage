<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <title><%= @print_title || "Relatório · Backstage" %></title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
      body { font-family: Arial, Helvetica, sans-serif; font-size: 10px; color: #18181b; background: #fff; }
      table { border-collapse: collapse; width: 100%; }
      th, td { border: 1px solid #e4e4e7; padding: 5px 8px; }
      th { background: #f4f4f5; font-weight: 700; text-align: left; }
    </style>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
