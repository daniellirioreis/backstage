<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <title>Credencial · Backstage</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: Arial, Helvetica, sans-serif;
        background: #1a1a1a;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 0;
      }

      .badge-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      .lanyard-clip {
        width: 22px;
        height: 9px;
        background: #27272a;
        border: 1px solid #3f3f46;
        border-radius: 3px;
      }

      .lanyard {
        width: 2px;
        height: 44px;
        background: #4ade80;
      }

      .badge {
        width: 100mm;
        border-radius: 18px;
        overflow: hidden;
      }

      .badge-header {
        background: #0d0d0d;
        padding: 14px 18px 12px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 3px solid #4ade80;
      }

      .badge-brand {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: #f4f4f5;
      }

      .badge-event-name {
        font-size: 10px;
        font-weight: 700;
        color: #4ade80;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-align: right;
      }

      .badge-event-date {
        font-size: 9px;
        color: #52525b;
        margin-top: 2px;
        text-align: right;
      }

      .badge-body {
        background: #f5f5f4;
        padding: 22px 18px 18px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
      }

      .badge-photo {
        width: 88px;
        height: 88px;
        border-radius: 50%;
        border: 3px solid #0d0d0d;
        overflow: hidden;
        background: #e4e4e7;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .badge-photo img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .badge-photo-initials {
        font-size: 28px;
        font-weight: 700;
        color: #a1a1aa;
      }

      .badge-info {
        text-align: center;
        width: 100%;
      }

      .badge-name {
        font-size: 15px;
        font-weight: 800;
        color: #18181b;
        line-height: 1.2;
      }

      .badge-role-chip {
        display: inline-block;
        margin-top: 6px;
        padding: 3px 12px;
        border-radius: 20px;
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #fff;
      }

      .badge-team-info {
        margin-top: 8px;
        font-size: 10px;
        color: #52525b;
        line-height: 1.5;
      }

      .badge-cpf {
        font-size: 10px;
        color: #a1a1aa;
        font-family: monospace;
        letter-spacing: 0.05em;
        margin-top: 3px;
      }

      .badge-divider {
        width: 100%;
        height: 1px;
        background: #e4e4e7;
      }

      .badge-footer {
        background: #0d0d0d;
        padding: 12px 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
      }

      .badge-meta { text-align: right; }
      .badge-meta-label {
        font-size: 8px;
        color: #3f3f46;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      .badge-meta-value {
        font-size: 10px;
        color: #a1a1aa;
        font-family: monospace;
        margin-top: 1px;
      }
    </style>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
