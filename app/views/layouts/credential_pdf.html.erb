<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <title>Credenciais · Backstage</title>
    <% cfg = @badge_config || BadgeConfig.defaults %>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: Arial, Helvetica, sans-serif; background: #fff; }

      .badge { width: 100%; height: 100%; margin: 0; border-radius: 0; overflow: hidden; display: -webkit-box; display: flex; -webkit-box-orient: vertical; flex-direction: column; }
      .badge-header { background: <%= cfg.header_footer_color %>; padding: 9px 12px 8px; display: -webkit-box; display: flex; -webkit-box-align: center; align-items: center; -webkit-box-pack: justify; justify-content: space-between; border-bottom: 3px solid <%= cfg.event_name_color %>; flex-shrink: 0; }
      .badge-brand { font-size: 8px; font-weight: 800; letter-spacing: 0.2em; text-transform: uppercase; color: #f4f4f5; }
      .badge-event-name { font-size: <%= cfg.event_name_font_size %>px; font-weight: 700; color: <%= cfg.event_name_color %>; text-transform: uppercase; text-align: right; }
      .badge-event-date { font-size: <%= cfg.event_date_font_size %>px; color: <%= cfg.event_name_color %>; margin-top: 1px; text-align: right; }
      .badge-body { background: <%= cfg.body_color %>; padding: 12px 12px 10px; text-align: center; -webkit-box-flex: 1; flex: 1; }
      .badge-photo { width: <%= cfg.photo_size %>px; height: <%= cfg.photo_size %>px; border-radius: 50%; border: 2px solid #0d0d0d; overflow: hidden; background: #e4e4e7; margin: 0 auto 8px; display: -webkit-box; display: flex; -webkit-box-align: center; align-items: center; -webkit-box-pack: center; justify-content: center; }
      .badge-photo img { width: 100%; height: 100%; object-fit: cover; }
      .badge-photo-initials { font-size: <%= (cfg.photo_size * 0.3).round %>px; font-weight: 700; color: #a1a1aa; }
      .badge-name { font-size: <%= cfg.name_font_size %>px; font-weight: 800; color: <%= cfg.name_color %>; margin: 0 0 6px; }
      .badge-role-chip { display: inline-block; padding: 3px 12px; border-radius: 20px; font-size: <%= cfg.role_chip_font_size %>px; font-weight: 700; text-transform: uppercase; color: #fff; margin-bottom: 6px; }
      .badge-team-info { font-size: <%= cfg.team_info_font_size %>px; color: <%= cfg.team_info_color %>; margin-bottom: 2px; }
      .badge-cpf { font-size: 8px; color: #a1a1aa; font-family: monospace; }
      .badge-divider { height: 1px; background: #e4e4e7; margin: 8px 0 0; }
      .badge-footer { background: <%= cfg.header_footer_color %>; padding: 8px 12px; display: -webkit-box; display: flex; -webkit-box-align: center; align-items: center; -webkit-box-pack: justify; justify-content: space-between; flex-shrink: 0; }
      .badge-meta { text-align: right; }
      .badge-meta-label { font-size: 6px; color: #3f3f46; text-transform: uppercase; letter-spacing: 0.06em; display: block; }
      .badge-meta-value { font-size: 8px; color: #a1a1aa; font-family: monospace; display: block; }
      .badge-credential-code { font-size: <%= cfg.credential_code_font_size %>px; color: <%= cfg.credential_code_color %>; font-family: monospace; font-weight: 700; display: block; letter-spacing: 0.04em; }
    </style>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
