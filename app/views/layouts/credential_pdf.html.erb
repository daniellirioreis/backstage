<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <title>Credenciais · Backstage</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }

      body { font-family: Arial, Helvetica, sans-serif; background: #fff; }

      .a4-page {
        width: 200mm;
        height: 287mm;
        page-break-after: always;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6mm;
        align-content: center;
        justify-items: center;
        padding: 4mm;
      }

      .badge-wrap { display: flex; flex-direction: column; align-items: center; }
      .lanyard-clip { width: 18px; height: 7px; background: #27272a; border: 1px solid #3f3f46; border-radius: 3px; }
      .lanyard { width: 2px; height: 28px; background: #4ade80; }
      .badge { width: 90mm; border-radius: 12px; overflow: hidden; }
      .badge-header { background: #0d0d0d; padding: 9px 12px 8px; display: flex; align-items: center; justify-content: space-between; border-bottom: 3px solid #4ade80; }
      .badge-brand { font-size: 8px; font-weight: 800; letter-spacing: 0.2em; text-transform: uppercase; color: #f4f4f5; }
      .badge-event-name { font-size: 8px; font-weight: 700; color: #4ade80; letter-spacing: 0.05em; text-transform: uppercase; text-align: right; }
      .badge-event-date { font-size: 6px; color: #52525b; margin-top: 1px; text-align: right; }
      .badge-body { background: #f5f5f4; padding: 12px 12px 10px; display: flex; flex-direction: column; align-items: center; gap: 8px; }
      .badge-photo { width: 60px; height: 60px; border-radius: 50%; border: 2px solid #0d0d0d; overflow: hidden; background: #e4e4e7; display: flex; align-items: center; justify-content: center; }
      .badge-photo img { width: 100%; height: 100%; object-fit: cover; }
      .badge-photo-initials { font-size: 18px; font-weight: 700; color: #a1a1aa; }
      .badge-info { text-align: center; width: 100%; }
      .badge-name { font-size: 12px; font-weight: 800; color: #18181b; line-height: 1.2; }
      .badge-role-chip { display: inline-block; margin-top: 4px; padding: 2px 8px; border-radius: 20px; font-size: 7px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #fff; }
      .badge-team-info { margin-top: 5px; font-size: 8px; color: #52525b; line-height: 1.4; }
      .badge-cpf { font-size: 8px; color: #a1a1aa; font-family: monospace; letter-spacing: 0.04em; margin-top: 2px; }
      .badge-divider { width: 100%; height: 1px; background: #e4e4e7; }
      .badge-footer { background: #0d0d0d; padding: 8px 12px; display: flex; align-items: center; justify-content: space-between; gap: 8px; }
      .badge-meta { text-align: right; }
      .badge-meta-label { font-size: 6px; color: #3f3f46; text-transform: uppercase; letter-spacing: 0.06em; }
      .badge-meta-value { font-size: 8px; color: #a1a1aa; font-family: monospace; margin-top: 1px; }
    </style>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
