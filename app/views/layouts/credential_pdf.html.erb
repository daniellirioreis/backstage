<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <title>Credenciais · Backstage</title>
    <% cfg = @badge_config || BadgeConfig.defaults %>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: Arial, Helvetica, sans-serif; }

      /* min-height em mm — não depende de herança height:100% */
      .badge         { position: relative; width: 100%; min-height: 123.5mm; background: <%= cfg.body_color %>; }

      /* Top bar */
      .badge-top-bar { height: 4px; }

      /* Header */
      .badge-header      { background: <%= cfg.header_footer_color %>; padding: 9px 12px 8px; border-bottom: 3px solid <%= cfg.event_name_color %>; overflow: hidden; }
      .badge-brand       { float: left; font-size: 8px; font-weight: 800; letter-spacing: 0.2em; text-transform: uppercase; color: #f4f4f5; }
      .badge-event-info  { float: right; text-align: right; }
      .badge-event-name  { font-size: <%= cfg.event_name_font_size %>px; font-weight: 700; color: <%= cfg.event_name_color %>; text-transform: uppercase; }
      .badge-event-date  { font-size: <%= cfg.event_date_font_size %>px; color: #a1a1aa; margin-top: 1px; }
      .badge-clearfix    { clear: both; }

      /* Body — padding-bottom reserva espaço para o footer fixo */
      .badge-body        { padding: 12px 12px 75px; text-align: center; }
      .badge-photo       { width: <%= cfg.photo_size %>px; height: <%= cfg.photo_size %>px; border-radius: 50%; border: 2px solid #0d0d0d; overflow: hidden; background: #e4e4e7; margin: 0 auto 8px; }
      .badge-photo img   { width: 100%; height: 100%; object-fit: cover; }
      .badge-photo-initials { font-size: <%= (cfg.photo_size * 0.3).round %>px; font-weight: 700; color: #a1a1aa; line-height: <%= cfg.photo_size %>px; display: block; }
      .badge-name        { font-size: <%= cfg.name_font_size %>px; font-weight: 800; color: <%= cfg.name_color %>; margin: 0 0 6px; }
      .badge-role-chip   { display: inline-block; padding: 3px 12px; border-radius: 20px; font-size: <%= cfg.role_chip_font_size %>px; font-weight: 700; text-transform: uppercase; color: #fff; margin-bottom: 6px; }
      .badge-team-info   { font-size: <%= cfg.team_info_font_size %>px; color: <%= cfg.team_info_color %>; margin-bottom: 2px; }
      .badge-cpf         { font-size: 8px; color: #a1a1aa; font-family: monospace; }
      .badge-divider     { height: 1px; background: #e4e4e7; margin: 8px 0 0; }

      /* Footer — fixo no fundo via position:absolute */
      .badge-footer      { position: absolute; bottom: 0; left: 0; right: 0; background: <%= cfg.header_footer_color %>; padding: 8px 12px; overflow: hidden; }
      .badge-footer-qr   { float: left; }
      .badge-meta        { float: right; text-align: right; }
      .badge-meta-label  { font-size: 6px; color: #71717a; text-transform: uppercase; letter-spacing: 0.06em; display: block; }
      .badge-meta-value  { font-size: 8px; color: #a1a1aa; font-family: monospace; display: block; }
      .badge-credential-code { font-size: <%= cfg.credential_code_font_size %>px; color: <%= cfg.credential_code_color %>; font-family: monospace; font-weight: 700; display: block; letter-spacing: 0.04em; }
    </style>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
