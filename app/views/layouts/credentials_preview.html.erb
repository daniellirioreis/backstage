<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Credenciais · <%= @team&.name || @event&.name %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }

      body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }

      /* ── Tela ── */
      body { background: #3a3a3a; min-height: 100vh; }

      .toolbar {
        position: fixed; top: 0; left: 0; right: 0; z-index: 100;
        background: #1a1a1a; border-bottom: 1px solid #2a2a2a;
        padding: 0.6rem 1.5rem; display: flex; align-items: center; gap: 0.75rem;
      }
      .toolbar-title { color: #a1a1aa; font-size: 0.82rem; flex: 1; }
      .toolbar-title strong { color: #f4f4f5; }
      .btn-back { background: #27272a; color: #a1a1aa; border: 1px solid #3f3f46; border-radius: 7px; padding: 0.4rem 1rem; font-size: 0.82rem; font-weight: 500; display: inline-flex; align-items: center; gap: 0.4rem; text-decoration: none; }
      .btn-print { background: #4ade80; color: #0d0d0d; border: none; border-radius: 7px; padding: 0.4rem 1rem; font-size: 0.82rem; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 0.4rem; }
      .btn-pdf { background: #dc2626; color: #fff; border: none; border-radius: 7px; padding: 0.4rem 1rem; font-size: 0.82rem; font-weight: 600; display: inline-flex; align-items: center; gap: 0.4rem; text-decoration: none; }

      .pages-wrapper { padding: 80px 0 40px; display: flex; flex-direction: column; align-items: center; gap: 24px; }

      .a4-page {
        width: 210mm; min-height: 297mm; background: white;
        box-shadow: 0 4px 24px rgba(0,0,0,0.4);
      }

      .badge-grid {
        width: 100%; height: 297mm;
        display: flex; flex-wrap: wrap;
      }

      .badge-cell {
        width: 50%; height: 50%;
        display: flex; align-items: center; justify-content: center;
        padding: 6mm;
      }

      /* ── Badge ── */
      .badge { width: 100%; max-width: 88mm; border-radius: 14px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.25); }
      .badge-header { background: #0d0d0d; padding: 10px 14px 9px; display: flex; align-items: center; justify-content: space-between; border-bottom: 3px solid #4ade80; }
      .badge-brand { font-size: 8px; font-weight: 800; letter-spacing: 0.2em; text-transform: uppercase; color: #f4f4f5; }
      .badge-event-name { font-size: 8px; font-weight: 700; color: #4ade80; letter-spacing: 0.06em; text-transform: uppercase; text-align: right; }
      .badge-event-date { font-size: 7px; color: #52525b; margin-top: 1px; text-align: right; }
      .badge-body { background: #f5f5f4; padding: 14px 12px 10px; display: flex; flex-direction: column; align-items: center; gap: 8px; }
      .badge-photo { width: 64px; height: 64px; border-radius: 50%; border: 2px solid #0d0d0d; overflow: hidden; background: #e4e4e7; display: flex; align-items: center; justify-content: center; }
      .badge-photo img { width: 100%; height: 100%; object-fit: cover; }
      .badge-photo-initials { font-size: 20px; font-weight: 700; color: #a1a1aa; }
      .badge-info { text-align: center; width: 100%; }
      .badge-name { font-size: 12px; font-weight: 800; color: #18181b; line-height: 1.2; }
      .badge-role-chip { display: inline-block; margin-top: 4px; padding: 2px 8px; border-radius: 20px; font-size: 7px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #fff; }
      .badge-team-info { margin-top: 5px; font-size: 8px; color: #52525b; line-height: 1.4; }
      .badge-cpf { font-size: 8px; color: #a1a1aa; font-family: monospace; margin-top: 2px; }
      .badge-divider { width: 100%; height: 1px; background: #e4e4e7; }
      .badge-footer { background: #0d0d0d; padding: 8px 12px; display: flex; align-items: center; justify-content: space-between; gap: 8px; }
      .badge-meta { text-align: right; }
      .badge-meta-label { font-size: 6px; color: #3f3f46; text-transform: uppercase; letter-spacing: 0.06em; }
      .badge-meta-value { font-size: 8px; color: #a1a1aa; font-family: monospace; margin-top: 1px; }

      /* ── Impressão ── */
      @page { size: A4 portrait; margin: 0; }

      @media print {
        body { background: white !important; }
        .toolbar { display: none !important; }
        .pages-wrapper { padding: 0 !important; gap: 0 !important; }

        .a4-page {
          box-shadow: none !important;
          page-break-after: always !important;
          break-after: page !important;
          width: 210mm !important;
          height: 297mm !important;
          min-height: unset !important;
          overflow: hidden !important;
        }

        .badge-grid {
          width: 210mm !important;
          height: 297mm !important;
        }

        .badge-cell {
          width: 105mm !important;
          height: 148.5mm !important;
          padding: 5mm !important;
        }

        .badge { box-shadow: none !important; }
      }
    </style>
  </head>
  <body>
    <div class="toolbar">
      <%= link_to teams_path, class: "btn-back" do %>
        <i class="bi bi-arrow-left"></i> Voltar
      <% end %>
      <span class="toolbar-title">
        Credenciais · <strong><%= @team&.name || @event&.name %></strong> · <%= @members.size %> pessoas
      </span>
      <button class="btn-print" onclick="window.print()">
        <i class="bi bi-printer"></i> Imprimir
      </button>
    </div>

    <div class="pages-wrapper">
      <%= yield %>
    </div>
  </body>
</html>
