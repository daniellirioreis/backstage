<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Credenciais · <%= @team.name %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background: #3a3a3a;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        min-height: 100vh;
      }

      /* Toolbar fixa no topo */
      .toolbar {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 100;
        background: #1a1a1a;
        border-bottom: 1px solid #2a2a2a;
        padding: 0.6rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .toolbar-title {
        color: #a1a1aa;
        font-size: 0.82rem;
        flex: 1;
      }

      .toolbar-title strong { color: #f4f4f5; }

      .btn-back {
        background: #27272a;
        color: #a1a1aa;
        border: 1px solid #3f3f46;
        border-radius: 7px;
        padding: 0.4rem 1rem;
        font-size: 0.82rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        text-decoration: none;
      }

      .btn-print {
        background: #4ade80;
        color: #0d0d0d;
        border: none;
        border-radius: 7px;
        padding: 0.4rem 1rem;
        font-size: 0.82rem;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
      }

      .btn-pdf {
        background: #dc2626;
        color: #fff;
        border: none;
        border-radius: 7px;
        padding: 0.4rem 1rem;
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        text-decoration: none;
      }

      /* Área de páginas */
      .pages-wrapper {
        padding: 80px 0 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 24px;
      }

      /* Folha A4 simulada */
      .a4-page {
        width: 210mm;
        min-height: 297mm;
        background: white;
        box-shadow: 0 4px 24px rgba(0,0,0,0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
      }

      /* Badge styles */
      .badge-wrap { display: flex; flex-direction: column; align-items: center; }
      .lanyard-clip { width: 22px; height: 9px; background: #27272a; border: 1px solid #3f3f46; border-radius: 3px; }
      .lanyard { width: 2px; height: 44px; background: #4ade80; }
      .badge { width: 260px; border-radius: 16px; overflow: hidden; box-shadow: 0 8px 32px rgba(0,0,0,0.18); }
      .badge-header { background: #0d0d0d; padding: 12px 16px 10px; display: flex; align-items: center; justify-content: space-between; border-bottom: 3px solid #4ade80; }
      .badge-brand { font-size: 9px; font-weight: 800; letter-spacing: 0.22em; text-transform: uppercase; color: #f4f4f5; }
      .badge-event-name { font-size: 9px; font-weight: 700; color: #4ade80; letter-spacing: 0.06em; text-transform: uppercase; text-align: right; }
      .badge-event-date { font-size: 7px; color: #52525b; margin-top: 2px; text-align: right; }
      .badge-body { background: #f5f5f4; padding: 16px 14px 14px; display: flex; flex-direction: column; align-items: center; gap: 10px; }
      .badge-photo { width: 76px; height: 76px; border-radius: 50%; border: 3px solid #0d0d0d; overflow: hidden; background: #e4e4e7; display: flex; align-items: center; justify-content: center; }
      .badge-photo img { width: 100%; height: 100%; object-fit: cover; }
      .badge-photo-initials { font-size: 24px; font-weight: 700; color: #a1a1aa; }
      .badge-info { text-align: center; width: 100%; }
      .badge-name { font-size: 14px; font-weight: 800; color: #18181b; line-height: 1.2; }
      .badge-role-chip { display: inline-block; margin-top: 5px; padding: 2px 10px; border-radius: 20px; font-size: 8px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #fff; }
      .badge-team-info { margin-top: 6px; font-size: 9px; color: #52525b; line-height: 1.4; }
      .badge-cpf { font-size: 9px; color: #a1a1aa; font-family: monospace; letter-spacing: 0.05em; margin-top: 2px; }
      .badge-divider { width: 100%; height: 1px; background: #e4e4e7; }
      .badge-footer { background: #0d0d0d; padding: 10px 14px; display: flex; align-items: center; justify-content: space-between; gap: 10px; }
      .badge-meta { text-align: right; }
      .badge-meta-label { font-size: 7px; color: #3f3f46; text-transform: uppercase; letter-spacing: 0.08em; }
      .badge-meta-value { font-size: 9px; color: #a1a1aa; font-family: monospace; margin-top: 1px; }

      /* Número de página */
      .page-number {
        position: absolute;
        bottom: 12px;
        right: 16px;
        font-size: 10px;
        color: #a1a1aa;
      }

      @media print {
        body { background: white; }
        .toolbar { display: none; }
        .pages-wrapper { padding: 0; gap: 0; }
        .a4-page { box-shadow: none; page-break-after: always; }
        .page-number { display: none; }
      }
    </style>
  </head>
  <body>
    <div class="toolbar">
      <%= link_to teams_path, class: "btn-back" do %>
        <i class="bi bi-arrow-left"></i> Voltar
      <% end %>
      <span class="toolbar-title">
        Credenciais · <strong><%= @team.name %></strong> · <%= @members.size %> pessoas
      </span>
      <button class="btn-print" onclick="window.print()">
        <i class="bi bi-printer"></i> Imprimir
      </button>
      <%= link_to credentials_team_path(@team, format: :pdf), class: "btn-pdf" do %>
        <i class="bi bi-file-earmark-pdf"></i> Baixar PDF
      <% end %>
    </div>

    <div class="pages-wrapper">
      <%= yield %>
    </div>
  </body>
</html>
