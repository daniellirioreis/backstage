<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Credencial · Backstage</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background: #1a1a1a;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Inter", sans-serif;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        gap: 1.5rem;
        padding: 2rem;
      }

      .print-actions {
        display: flex;
        gap: 0.75rem;
      }

      .btn-print {
        background: #4ade80;
        color: #0d0d0d;
        border: none;
        border-radius: 7px;
        padding: 0.5rem 1.25rem;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        text-decoration: none;
      }

      .btn-pdf {
        background: #dc2626;
        color: #fff;
        border: none;
        border-radius: 7px;
        padding: 0.5rem 1.25rem;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        text-decoration: none;
      }

      .btn-back {
        background: #27272a;
        color: #a1a1aa;
        border: 1px solid #3f3f46;
        border-radius: 7px;
        padding: 0.5rem 1.25rem;
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        text-decoration: none;
      }

      @media print {
        body { background: white; padding: 0; justify-content: flex-start; }
        .print-actions { display: none; }
        .badge-wrap { margin: 0; }
      }
    </style>
  </head>
  <body>
    <div class="print-actions">
      <%= link_to users_path, class: "btn-back" do %>
        <i class="bi bi-arrow-left"></i> Voltar
      <% end %>
      <button class="btn-print" onclick="window.print()">
        <i class="bi bi-printer"></i> Imprimir
      </button>
      <%= link_to credential_user_path(@user, format: :pdf), class: "btn-pdf" do %>
        <i class="bi bi-file-earmark-pdf"></i> Baixar PDF
      <% end %>
    </div>

    <%= yield %>
  </body>
</html>
