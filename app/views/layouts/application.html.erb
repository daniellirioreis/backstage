<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="turbo-cache-control" content="no-cache">
    <title>Backstage</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.min.css">
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if user_signed_in? %>
      <aside class="sidebar">
        <div class="sidebar-brand">Backstage</div>

        <nav>
          <div class="sidebar-section">Geral</div>
          <%= link_to root_path, class: "sidebar-link #{current_page?(root_path) ? 'active' : ''}" do %>
            <i class="bi bi-grid-1x2"></i> <%= t("nav.home") %>
          <% end %>

          <% if policy(Event).index? %>
            <div class="sidebar-section">Operações</div>
            <%= link_to events_path, class: "sidebar-link #{controller_name == 'events' ? 'active' : ''}" do %>
              <i class="bi bi-calendar-event"></i> <%= Event.model_name.human(count: 2) %>
            <% end %>
          <% end %>

          <% if policy(Team).index? %>
            <%= link_to teams_path, class: "sidebar-link #{controller_name == 'teams' ? 'active' : ''}" do %>
              <i class="bi bi-people"></i> <%= Team.model_name.human(count: 2) %>
            <% end %>
          <% end %>

          <% if policy(Sector).index? %>
            <%= link_to sectors_path, class: "sidebar-link #{controller_name == 'sectors' ? 'active' : ''}" do %>
              <i class="bi bi-diagram-3"></i> <%= Sector.model_name.human(count: 2) %>
            <% end %>
          <% end %>

          <% if policy(Shift).index? %>
            <%= link_to shifts_path, class: "sidebar-link #{controller_name == 'shifts' ? 'active' : ''}" do %>
              <i class="bi bi-clock"></i> <%= Shift.model_name.human(count: 2) %>
            <% end %>
          <% end %>

          <% if policy(Vehicle).index? %>
            <%= link_to vehicles_path, class: "sidebar-link #{controller_name == 'vehicles' ? 'active' : ''}" do %>
              <i class="bi bi-car-front"></i> <%= Vehicle.model_name.human(count: 2) %>
            <% end %>
          <% end %>

          <% if policy(User).index? || current_user.admin? %>
            <div class="sidebar-section">Administração</div>
          <% end %>

          <% if policy(User).index? %>
            <%= link_to users_path, class: "sidebar-link #{controller_name == 'users' ? 'active' : ''}" do %>
              <i class="bi bi-person"></i> <%= User.model_name.human(count: 2) %>
            <% end %>
          <% end %>

          <% if current_user.admin? %>
            <%= link_to roles_path, class: "sidebar-link #{controller_name == 'roles' ? 'active' : ''}" do %>
              <i class="bi bi-shield-check"></i> <%= Role.model_name.human(count: 2) %>
            <% end %>
          <% end %>
        </nav>

        <div class="sidebar-footer">
          <div class="sidebar-user">
            <div class="sidebar-avatar"><%= current_user.name.first.upcase %></div>
            <span class="sidebar-username"><%= current_user.name.split.first %></span>
          </div>
          <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "sidebar-signout" do %>
            <i class="bi bi-box-arrow-left"></i> <%= t("nav.sign_out") %>
          <% end %>
        </div>
      </aside>

      <main class="main-content">
        <%# ── Barra de evento ativo ──────────────────────────────────────── %>
        <% if current_event %>
          <div class="event-bar">
            <span class="event-bar-label">Evento</span>
            <span class="event-bar-sep">·</span>
            <span class="event-bar-name"><%= current_event.name %></span>
            <span class="event-bar-badge badge-<%= current_event.status %>"><%= t("event_statuses.#{current_event.status}") %></span>
            <% if current_event.location.present? %>
              <span class="event-bar-sep">·</span>
              <span style="color: #71717a;"><i class="bi bi-geo-alt"></i> <%= current_event.location %></span>
            <% end %>
            <%= link_to select_event_path, class: "event-bar-change" do %>
              <i class="bi bi-arrow-left-right"></i> Trocar
            <% end %>
          </div>
        <% end %>

        <div class="main-inner">
          <% if notice %>
            <div class="flash-notice"><i class="bi bi-check-circle"></i> <%= notice %></div>
          <% end %>
          <% if alert %>
            <div class="flash-alert"><i class="bi bi-exclamation-circle"></i> <%= alert %></div>
          <% end %>

          <%= yield %>
        </div>
      </main>

    <% else %>
      <div class="auth-wrapper">
        <%= yield %>
      </div>
    <% end %>
  </body>
</html>
