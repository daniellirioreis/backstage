<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="turbo-cache-control" content="no-cache">
    <title>Backstage</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
      <div class="container">
        <%= link_to "Backstage", root_path, class: "navbar-brand" %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
          <span class="navbar-toggler-icon"></span>
        </button>
        <% if user_signed_in? %>
          <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav me-auto">
              <li class="nav-item">
                <%= link_to t("nav.home"), root_path, class: "nav-link" %>
              </li>
              <% if policy(Event).index? %>
                <li class="nav-item">
                  <%= link_to Event.model_name.human(count: 2), events_path, class: "nav-link" %>
                </li>
              <% end %>
              <% if policy(Team).index? %>
                <li class="nav-item">
                  <%= link_to Team.model_name.human(count: 2), teams_path, class: "nav-link" %>
                </li>
              <% end %>
              <% if policy(Sector).index? %>
                <li class="nav-item">
                  <%= link_to Sector.model_name.human(count: 2), sectors_path, class: "nav-link" %>
                </li>
              <% end %>
              <% if policy(Shift).index? %>
                <li class="nav-item">
                  <%= link_to Shift.model_name.human(count: 2), shifts_path, class: "nav-link" %>
                </li>
              <% end %>
              <% if policy(Vehicle).index? %>
                <li class="nav-item">
                  <%= link_to Vehicle.model_name.human(count: 2), vehicles_path, class: "nav-link" %>
                </li>
              <% end %>
              <% if policy(User).index? %>
                <li class="nav-item">
                  <%= link_to User.model_name.human(count: 2), users_path, class: "nav-link" %>
                </li>
              <% end %>
              <% if current_user.admin? %>
                <li class="nav-item">
                  <%= link_to Role.model_name.human(count: 2), roles_path, class: "nav-link" %>
                </li>
              <% end %>
            </ul>
            <ul class="navbar-nav ms-auto align-items-center">
              <li class="nav-item">
                <span class="nav-link text-light"><%= current_user.name %></span>
              </li>
              <li class="nav-item">
                <%= link_to t("nav.sign_out"), destroy_user_session_path,
                            data: { turbo_method: :delete }, class: "nav-link" %>
              </li>
            </ul>
          </div>
        <% end %>
      </div>
    </nav>

    <main class="container">
      <% if notice %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <%= notice %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>
      <% if alert %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <%= alert %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
