<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="turbo-cache-control" content="no-cache">
    <title>Backstage</title>

    <%# PWA %>
    <link rel="manifest" href="/manifest.webmanifest">
    <meta name="theme-color" content="#18181b">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Backstage">
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png">
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.min.css">
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if user_signed_in? %>
      <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>
      <aside class="sidebar" id="mainSidebar">
        <%
          user_company = current_user.company_users.includes(:company).first&.company
          company_logo = user_company&.logo&.attached? ? user_company.logo : nil
        %>
        <div class="sidebar-brand" style="display:flex; flex-direction:column; align-items:center; gap:0.4rem; padding:1.1rem 1.25rem 0.9rem; position:relative;">
          <% if company_logo %>
            <%= image_tag company_logo, style: "max-width:160px; max-height:80px; object-fit:contain;" %>
          <% else %>
            <%= render "shared/logo", size: :sm, stacked: false %>
            <span style="font-size:0.7rem; font-weight:600; letter-spacing:0.08em; color:#a1a1aa;">Backstage</span>
          <% end %>
          <button class="sidebar-close" onclick="closeSidebar()" type="button" aria-label="Fechar menu">
            <i class="bi bi-x-lg"></i>
          </button>
        </div>

        <nav>
          <% show_home        = policy(:dashboard).index? %>
          <% show_my_schedule = policy(current_user).my_schedule? %>
          <% if current_user.coordinator? %>
            <%# Sidebar focada para coordenadores — só o essencial %>
            <div class="sidebar-section">Minha equipe</div>
            <% coord_team = Team.find_by(coordinator_id: current_user.id) %>
            <% if coord_team %>
              <%= link_to panel_team_path(coord_team), class: "sidebar-link #{controller_name == 'teams' && action_name == 'panel' ? 'active' : ''}" do %>
                <i class="bi bi-grid-1x2"></i> Painel da equipe
              <% end %>
              <% if policy(:attendance).scan? %>
                <%= link_to scan_attendances_path, class: "sidebar-link #{controller_name == 'attendances' && action_name == 'scan' ? 'active' : ''}" do %>
                  <i class="bi bi-qr-code-scan"></i> Check-in
                <% end %>
              <% end %>
              <% if current_user.can?("teams", "credentials") %>
                <%= link_to credentials_team_path(coord_team), class: "sidebar-link #{controller_name == 'teams' && action_name == 'credentials' ? 'active' : ''}" do %>
                  <i class="bi bi-person-badge"></i> Credenciais
                <% end %>
              <% end %>
            <% end %>
          <% elsif show_home || show_my_schedule %>
            <div class="sidebar-section">Geral</div>
            <% if show_home %>
              <%= link_to root_path, class: "sidebar-link #{current_page?(root_path) ? 'active' : ''}" do %>
                <i class="bi bi-grid-1x2"></i> <%= t("nav.home") %>
              <% end %>
            <% end %>
            <% if show_my_schedule %>
              <%= link_to my_schedule_user_path(current_user), class: "sidebar-link #{controller_name == 'users' && action_name == 'my_schedule' ? 'active' : ''}" do %>
                <i class="bi bi-calendar-week"></i> <%= t("permission_actions.my_schedule") %>
              <% end %>
            <% end %>
            <% if Team.exists?(coordinator_id: current_user.id) %>
              <%= link_to coordinator_teams_path, class: "sidebar-link #{controller_name == 'teams' && action_name == 'coordinator' ? 'active' : ''}" do %>
                <i class="bi bi-grid-1x2"></i> Minhas Equipes
              <% end %>
            <% end %>
          <% end %>

          <% if policy(Event).index? %>
            <div class="sidebar-section">Evento</div>
            <%= link_to events_path, class: "sidebar-link #{controller_name == 'events' && controller_path != 'events/setup' ? 'active' : ''}" do %>
              <i class="bi bi-calendar-event"></i> <%= Event.model_name.human(count: 2) %>
            <% end %>
            <% if current_event && policy(current_event).update? %>
              <%= link_to sectors_event_setup_path(current_event),
                    class: "sidebar-link #{controller_path == 'events/setup' ? 'active' : ''}" do %>
                <i class="bi bi-sliders"></i> Configurar evento
              <% end %>
            <% end %>
          <% end %>

          <% if policy(Shift).index? %>
            <div class="sidebar-section">Operações</div>
            <%= link_to timeline_shifts_path, class: "sidebar-link #{controller_name == 'shifts' && action_name == 'timeline' ? 'active' : ''}" do %>
              <i class="bi bi-calendar-range"></i> Timeline
            <% end %>
          <% end %>

          <% if policy(:attendance).scan? %>
            <%= link_to scan_attendances_path, class: "sidebar-link #{controller_name == 'attendances' && action_name == 'scan' ? 'active' : ''}" do %>
              <i class="bi bi-qr-code-scan"></i> Check-in
            <% end %>
          <% end %>

          <% if policy(:attendance).index? %>
            <%= link_to attendances_path, class: "sidebar-link #{controller_name == 'attendances' && action_name != 'scan' ? 'active' : ''}" do %>
              <i class="bi bi-person-check"></i> Presenças
            <% end %>
          <% end %>

          <% if policy(Vehicle).index? %>
            <%= link_to vehicles_path, class: "sidebar-link #{controller_name == 'vehicles' ? 'active' : ''}" do %>
              <i class="bi bi-car-front"></i> <%= Vehicle.model_name.human(count: 2) %>
            <% end %>
          <% end %>

          <% if policy(:report).closing? %>
            <% event_closed = current_event&.closed? %>
            <%= link_to reports_closing_path,
                  class: "sidebar-link #{controller_path == 'reports/closing' ? 'active' : ''} #{event_closed ? '' : 'sidebar-link--locked'}",
                  title: event_closed ? nil : "Disponível apenas após encerrar o evento" do %>
              <i class="bi bi-receipt"></i> <%= t("nav.closing") %>
              <% unless event_closed %>
                <i class="bi bi-lock-fill" style="font-size:0.65rem; margin-left:auto; opacity:0.45;"></i>
              <% end %>
            <% end %>
          <% end %>

          <%# Relatórios operacionais %>
          <% show_att = policy(:report).attendance_report?
             show_abs = policy(:report).absences_report?
             show_hrs = policy(:report).hours_worked_report?
             show_sec = policy(:report).sector_summary_report? %>
          <% if show_att || show_abs || show_hrs || show_sec %>
            <div class="sidebar-section"><%= t("nav.reports") %></div>
            <% if show_att %>
              <%= link_to reports_attendance_path, class: "sidebar-link #{controller_path == 'reports/attendance' ? 'active' : ''}" do %>
                <i class="bi bi-person-check"></i> <%= t("nav.report_attendance") %>
              <% end %>
            <% end %>
            <% if show_abs %>
              <%= link_to reports_absences_path, class: "sidebar-link #{controller_path == 'reports/absences' ? 'active' : ''}" do %>
                <i class="bi bi-person-x"></i> <%= t("nav.report_absences") %>
              <% end %>
            <% end %>
            <% if show_hrs %>
              <%= link_to reports_hours_worked_path, class: "sidebar-link #{controller_path == 'reports/hours_worked' ? 'active' : ''}" do %>
                <i class="bi bi-clock-history"></i> <%= t("nav.report_hours_worked") %>
              <% end %>
            <% end %>
            <% if show_sec %>
              <%= link_to reports_sector_summary_path, class: "sidebar-link #{controller_path == 'reports/sector_summary' ? 'active' : ''}" do %>
                <i class="bi bi-diagram-3"></i> <%= t("nav.report_sector_summary") %>
              <% end %>
            <% end %>
          <% end %>

          <% if policy(User).index? || current_user.admin? || policy(EventFunction.new).index? %>
            <div class="sidebar-section">Administração</div>
          <% end %>
          <% if policy(EventFunction.new).index? %>
            <%= link_to event_functions_path, class: "sidebar-link #{controller_name == 'event_functions' ? 'active' : ''}" do %>
              <i class="bi bi-briefcase"></i> Funções
            <% end %>
          <% end %>

          <% if policy(User).index? %>
            <%= link_to users_path, class: "sidebar-link #{controller_name == 'users' ? 'active' : ''}" do %>
              <i class="bi bi-person"></i> <%= User.model_name.human(count: 2) %>
            <% end %>
          <% end %>

          <% if current_user.admin? %>
            <%= link_to plans_path, class: "sidebar-link #{controller_name == 'plans' ? 'active' : ''}" do %>
              <i class="bi bi-box"></i> Planos
            <% end %>
          <% end %>
          <% if !current_user.admin? && !current_user.role&.collaborator? && !current_user.coordinator? %>
            <%= link_to subscription_path, class: "sidebar-link #{controller_name == 'subscriptions' ? 'active' : ''}" do %>
              <i class="bi bi-credit-card"></i> Assinatura
              <% sub_status = current_user.companies.first&.subscription_status %>
              <% if sub_status == "overdue" %>
                <span style="margin-left:auto;background:#fef2f2;border:1px solid #fca5a5;color:#dc2626;font-size:0.65rem;font-weight:800;border-radius:99px;padding:1px 7px;">ATRASO</span>
              <% elsif sub_status == "pending" %>
                <span style="margin-left:auto;background:#fff7ed;border:1px solid #fed7aa;color:#b45309;font-size:0.65rem;font-weight:800;border-radius:99px;padding:1px 7px;">PEND.</span>
              <% end %>
            <% end %>
          <% end %>
          <% if policy(Role).index? %>
            <%= link_to roles_path, class: "sidebar-link #{controller_name == 'roles' ? 'active' : ''}" do %>
              <i class="bi bi-shield-check"></i> <%= Role.model_name.human(count: 2) %>
            <% end %>
          <% end %>

          <% if policy(Company).index? %>
            <%= link_to companies_path, class: "sidebar-link #{controller_name == 'companies' ? 'active' : ''}" do %>
              <i class="bi bi-building"></i> <%= Company.model_name.human(count: 2) %>
            <% end %>
          <% end %>

          <% if policy(:invitation).index? %>
            <%= link_to invitations_path, class: "sidebar-link #{controller_name == 'invitations' ? 'active' : ''}" do %>
              <i class="bi bi-envelope"></i> Convites
            <% end %>
          <% end %>
        </nav>

        <div class="sidebar-footer">
          <div class="sidebar-user-menu" id="sidebarUserMenu">
            <button class="sidebar-user-trigger" onclick="document.getElementById('sidebarUserMenu').classList.toggle('open')" type="button">
              <div class="sidebar-avatar">
                <% if current_user.avatar.attached? %>
                  <%= image_tag current_user.avatar, style: "width:100%;height:100%;object-fit:cover;border-radius:50%;" %>
                <% else %>
                  <%= current_user.name.first.upcase %>
                <% end %>
              </div>
              <span class="sidebar-username">
                <%= current_user.name.split.first %>
                <% if current_user.role.present? %>
                  <span class="sidebar-userrole"><%= current_user.role.name.capitalize %></span>
                <% end %>
              </span>
              <i class="bi bi-chevron-up sidebar-user-chevron"></i>
            </button>

            <div class="sidebar-user-dropdown">
              <div class="sidebar-user-dropdown-name"><%= current_user.name %></div>
              <%= link_to edit_user_path(current_user), class: "sidebar-user-dropdown-item" do %>
                <i class="bi bi-person-gear"></i> Editar perfil
              <% end %>
              <% if policy(current_user).my_schedule? %>
                <%= link_to my_schedule_user_path(current_user), class: "sidebar-user-dropdown-item" do %>
                  <i class="bi bi-calendar-week"></i> <%= t("permission_actions.my_schedule") %>
                <% end %>
              <% end %>
              <%= button_to destroy_user_session_path, method: :delete,
                    data: { turbo: false },
                    class: "sidebar-user-dropdown-item sidebar-user-dropdown-signout",
                    form: { style: "display:contents;" } do %>
                <i class="bi bi-box-arrow-left"></i> <%= t("nav.sign_out") %>
              <% end %>
            </div>
          </div>
        </div>

        <script>
          document.addEventListener("click", function(e) {
            var menu = document.getElementById("sidebarUserMenu");
            if (menu && !menu.contains(e.target)) menu.classList.remove("open");
          });
        </script>
      </aside>

      <main class="main-content">
        <%# ── Barra de evento ativo ──────────────────────────────────────── %>
        <% unless current_event %>
          <div class="mobile-topbar">
            <button class="sidebar-toggle" onclick="openSidebar()" type="button" aria-label="Abrir menu">
              <i class="bi bi-list"></i>
            </button>
            <span style="font-size:0.85rem;font-weight:700;color:#18181b;">Backstage</span>
          </div>
        <% end %>

        <% if current_event %>
          <div class="event-bar">
            <button class="sidebar-toggle" onclick="openSidebar()" type="button" aria-label="Abrir menu">
              <i class="bi bi-list"></i>
            </button>
            <span class="event-bar-label">Evento</span>
            <span class="event-bar-sep">·</span>
            <span class="event-bar-name"><%= current_event.name %></span>
            <span class="event-bar-badge badge-<%= current_event.status %>"><%= t("event_statuses.#{current_event.status}") %></span>
            <span class="event-bar-sep">·</span>
            <span class="event-bar-meta">
              <i class="bi bi-calendar3"></i>
              <%= l(current_event.start_date, format: :short) %> – <%= l(current_event.end_date, format: :short) %>
            </span>
            <% if current_event.location.present? %>
              <span class="event-bar-sep">·</span>
              <span class="event-bar-meta"><i class="bi bi-geo-alt"></i> <%= current_event.location %></span>
            <% end %>
            <% if current_event.draft? && policy(current_event).transition? %>
              <%= button_to transition_event_path(current_event), method: :patch,
                    class: "event-bar-activate",
                    form: { style: "display:contents;" },
                    data: { turbo_confirm: "Ativar o evento \"#{current_event.name}\"?" } do %>
                <i class="bi bi-play-fill"></i><span> Ativar</span>
              <% end %>
            <% end %>
            <%= link_to select_event_path(modal: 1, return_to: request.path), class: "event-bar-change" do %>
              <i class="bi bi-arrow-left-right"></i> Trocar
            <% end %>
          </div>
        <% end %>

        <div class="main-inner">
          <%= render "shared/subscription_banner" %>

          <% if notice %>
            <div class="flash-notice"><i class="bi bi-check-circle"></i> <%= notice %></div>
          <% end %>
          <% if alert %>
            <div class="flash-alert"><i class="bi bi-exclamation-circle"></i> <%= alert %></div>
          <% end %>

          <%= yield %>
        </div>

        <%# ── Bottom nav mobile (colaborador / coordenador) ─────────────────── %>
        <% if current_user.role&.collaborator? %>
          <nav class="mobile-bottom-nav" aria-label="Navegação rápida">
            <%= link_to my_schedule_user_path(current_user),
                  class: "mobile-nav-item #{controller_name == 'users' && action_name == 'my_schedule' ? 'active' : ''}" do %>
              <i class="bi bi-calendar2-week"></i>
              <span>Minha Escala</span>
            <% end %>
            <%= link_to root_path,
                  class: "mobile-nav-item #{current_page?(root_path) ? 'active' : ''}" do %>
              <i class="bi bi-house"></i>
              <span>Início</span>
            <% end %>
          </nav>
        <% elsif current_user.coordinator? %>
          <% coord_team = Team.find_by(coordinator_id: current_user.id) %>
          <nav class="mobile-bottom-nav" aria-label="Navegação rápida">
            <% if coord_team %>
              <%= link_to panel_team_path(coord_team),
                    class: "mobile-nav-item #{controller_name == 'teams' && action_name == 'panel' ? 'active' : ''}" do %>
                <i class="bi bi-people"></i>
                <span>Equipe</span>
              <% end %>
              <%= link_to scan_attendances_path,
                    class: "mobile-nav-item #{controller_name == 'attendances' && action_name == 'scan' ? 'active' : ''}" do %>
                <i class="bi bi-qr-code-scan"></i>
                <span>Check-in</span>
              <% end %>
              <%= link_to credentials_team_path(coord_team),
                    class: "mobile-nav-item #{controller_name == 'teams' && action_name == 'credentials' ? 'active' : ''}" do %>
                <i class="bi bi-person-badge"></i>
                <span>Credenciais</span>
              <% end %>
            <% end %>
            <%= link_to my_schedule_user_path(current_user),
                  class: "mobile-nav-item #{controller_name == 'users' && action_name == 'my_schedule' ? 'active' : ''}" do %>
              <i class="bi bi-calendar2-week"></i>
              <span>Escala</span>
            <% end %>
          </nav>
        <% end %>
      </main>

    <% else %>
      <div class="auth-wrapper">
        <%= yield %>
      </div>
    <% end %>
  <script>
    // ── Service Worker (PWA) ──────────────────────────────────────────────────
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js').catch(function() {});
    }

    // ── Loading button ────────────────────────────────────────────────────────
    // Desabilita o botão de submit e mostra "Salvando..." durante o envio
    function initLoadingButtons() {
      document.querySelectorAll('form:not([data-no-loading])').forEach(function(form) {
        if (form.dataset.loadingInit) return;
        form.dataset.loadingInit = '1';
        form.addEventListener('submit', function() {
          var btn = form.querySelector('[type="submit"]:not([data-no-loading])');
          if (!btn) return;
          var label = btn.dataset.loadingLabel || 'Salvando...';
          btn.dataset.originalText = btn.innerHTML;
          btn.innerHTML = '<i class="bi bi-arrow-repeat" style="animation:spin 0.8s linear infinite;display:inline-block;"></i>&nbsp;' + label;
          btn.disabled = true;
          btn.style.opacity = '0.75';
        });
      });
    }

    // Reativa botões em caso de erro de validação (Turbo re-renderiza o form)
    document.addEventListener('turbo:render', initLoadingButtons);
    document.addEventListener('turbo:load', initLoadingButtons);
    document.addEventListener('DOMContentLoaded', initLoadingButtons);

    // Se o Turbo cancelar ou der erro de rede, reativa o botão
    document.addEventListener('turbo:fetch-request-error', function() {
      document.querySelectorAll('[type="submit"][data-original-text]').forEach(function(btn) {
        btn.innerHTML = btn.dataset.originalText;
        btn.disabled = false;
        btn.style.opacity = '';
      });
    });
  </script>
  <script>
    function applyPhoneMask(input) {
      input.addEventListener("input", function(e) {
        var v = e.target.value.replace(/\D/g, "").slice(0, 11);
        if (v.length <= 10) {
          v = v.replace(/^(\d{2})(\d{4})(\d{0,4})/, function(_, a, b, c) {
            return c ? "(" + a + ") " + b + "-" + c : b ? "(" + a + ") " + b : a ? "(" + a : "";
          });
        } else {
          v = v.replace(/^(\d{2})(\d{5})(\d{0,4})/, function(_, a, b, c) {
            return c ? "(" + a + ") " + b + "-" + c : "(" + a + ") " + b;
          });
        }
        e.target.value = v;
      });
    }

    function applyCpfMask(input) {
      input.addEventListener("input", function(e) {
        var v = e.target.value.replace(/\D/g, "").slice(0, 11);
        v = v.replace(/^(\d{3})(\d{3})(\d{3})(\d{0,2})/, function(_, a, b, c, d) {
          if (d) return a + "." + b + "." + c + "-" + d;
          if (c) return a + "." + b + "." + c;
          if (b) return a + "." + b;
          return a;
        });
        e.target.value = v;
      });
    }

    function applyCnpjMask(input) {
      input.addEventListener("input", function(e) {
        var v = e.target.value.replace(/\D/g, "").slice(0, 14);
        if (v.length > 12)      v = v.replace(/^(\d{2})(\d{3})(\d{3})(\d{4})(\d{0,2})/, "$1.$2.$3/$4-$5");
        else if (v.length > 8)  v = v.replace(/^(\d{2})(\d{3})(\d{3})(\d{0,4})/, "$1.$2.$3/$4");
        else if (v.length > 5)  v = v.replace(/^(\d{2})(\d{3})(\d{0,3})/, "$1.$2.$3");
        else if (v.length > 2)  v = v.replace(/^(\d{2})(\d{0,3})/, "$1.$2");
        e.target.value = v;
      });
    }

    function initMasks() {
      document.querySelectorAll("[data-mask='phone']").forEach(applyPhoneMask);
      document.querySelectorAll("[data-mask='cpf']").forEach(applyCpfMask);
      document.querySelectorAll("[data-mask='cnpj']").forEach(applyCnpjMask);
    }

    document.addEventListener("DOMContentLoaded", initMasks);
    document.addEventListener("turbo:load", initMasks);
    document.addEventListener("turbo:render", initMasks);

    // ── Sidebar mobile ────────────────────────────────────────────────────────
    function openSidebar() {
      document.getElementById("mainSidebar")?.classList.add("sidebar--open");
      document.getElementById("sidebarOverlay")?.classList.add("sidebar--open");
      document.body.style.overflow = "hidden";
    }
    function closeSidebar() {
      document.getElementById("mainSidebar")?.classList.remove("sidebar--open");
      document.getElementById("sidebarOverlay")?.classList.remove("sidebar--open");
      document.body.style.overflow = "";
    }
    // Fecha ao navegar (Turbo)
    document.addEventListener("turbo:before-visit", closeSidebar);

    // ── Sidebar collapse (desktop) ────────────────────────────────────────────
    function toggleSidebarCollapse() {
      var collapsed = document.body.classList.toggle("sidebar-collapsed");
      localStorage.setItem("sidebarCollapsed", collapsed ? "1" : "0");
    }
    (function() {
      if (localStorage.getItem("sidebarCollapsed") === "1") {
        document.body.classList.add("sidebar-collapsed");
      }
    })();

    // ── Tabelas responsivas (mobile) ──────────────────────────────────────────
    function wrapTablesForMobile() {
      if (window.innerWidth > 768) return;
      document.querySelectorAll(".data-table").forEach(function(table) {
        if (table.closest(".table-responsive")) return;
        var wrap = document.createElement("div");
        wrap.className = "table-responsive";
        table.parentNode.insertBefore(wrap, table);
        wrap.appendChild(table);
      });
    }
    document.addEventListener("DOMContentLoaded", wrapTablesForMobile);
    document.addEventListener("turbo:load", wrapTablesForMobile);
    document.addEventListener("turbo:render", wrapTablesForMobile);
  </script>

  <%# ── Modal de confirmação customizado (substitui o alert() nativo do Turbo) ── %>
  <div id="confirm-modal" style="
    display:none; position:fixed; inset:0; z-index:9999;
    background:rgba(0,0,0,0.45); align-items:center; justify-content:center;
    padding:1rem;
  ">
    <div style="
      background:#fff; border-radius:12px; padding:1.75rem 1.5rem 1.25rem;
      max-width:380px; width:100%; box-shadow:0 8px 40px rgba(0,0,0,0.18);
      animation:confirmIn 0.18s ease;
    ">
      <div style="display:flex; align-items:flex-start; gap:0.85rem; margin-bottom:1.25rem;">
        <div style="
          width:36px; height:36px; border-radius:50%; background:#fef2f2;
          display:flex; align-items:center; justify-content:center; flex-shrink:0;
        ">
          <i class="bi bi-exclamation-triangle-fill" style="color:#dc2626; font-size:1rem;"></i>
        </div>
        <div>
          <div style="font-size:0.9rem; font-weight:700; color:#18181b; margin-bottom:0.3rem;">Confirmar ação</div>
          <div id="confirm-modal-message" style="font-size:0.83rem; color:#52525b; line-height:1.5;"></div>
        </div>
      </div>
      <div style="display:flex; justify-content:flex-end; gap:0.6rem;">
        <button id="confirm-modal-cancel"
          style="background:#f4f4f5; color:#3f3f46; border:none; border-radius:7px; padding:0.5rem 1.1rem; font-size:0.85rem; font-weight:600; cursor:pointer;">
          Cancelar
        </button>
        <button id="confirm-modal-ok"
          style="background:#dc2626; color:#fff; border:none; border-radius:7px; padding:0.5rem 1.25rem; font-size:0.85rem; font-weight:600; cursor:pointer;">
          Confirmar
        </button>
      </div>
    </div>
  </div>
  <style>
    @keyframes confirmIn {
      from { opacity:0; transform:scale(0.95) translateY(8px); }
      to   { opacity:1; transform:scale(1)    translateY(0);    }
    }
  </style>
  <script>
    document.addEventListener("turbo:load", function() {
    const Turbo = window.Turbo;
    const modal   = document.getElementById("confirm-modal");
    const message = document.getElementById("confirm-modal-message");
    const btnOk   = document.getElementById("confirm-modal-ok");
    const btnCancel = document.getElementById("confirm-modal-cancel");

    Turbo.config.confirmMethod = function(msg) {
      return new Promise(function(resolve) {
        message.textContent = msg;
        modal.style.display = "flex";

        function cleanup(result) {
          modal.style.display = "none";
          btnOk.removeEventListener("click", onOk);
          btnCancel.removeEventListener("click", onCancel);
          resolve(result);
        }
        function onOk()     { cleanup(true);  }
        function onCancel() { cleanup(false); }

        btnOk.addEventListener("click", onOk);
        btnCancel.addEventListener("click", onCancel);
        modal.addEventListener("click", function(e) {
          if (e.target === modal) cleanup(false);
        }, { once: true });
      });
    };
    }); // turbo:load
  </script>

  <% if user_signed_in? %>
    <button class="sidebar-toggle-btn" onclick="toggleSidebarCollapse()" title="Expandir/recolher menu" type="button">
      <i class="bi bi-layout-sidebar"></i>
    </button>
  <% end %>
  </body>
</html>
