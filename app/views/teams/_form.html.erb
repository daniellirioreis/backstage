<div class="content-card" style="max-width: 700px;">
  <%= form_with model: team do |f| %>
    <%= render "shared/error_messages", object: team %>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem;">
      <div>
        <%= f.label :sector_id, Sector.model_name.human, class: "form-label" %>
        <%= f.collection_select :sector_id, @sectors, :id, :name,
            { include_blank: "— Selecione —" },
            class: "form-control form-select",
            data: { controller: "tom-select", placeholder: "Buscar setor..." } %>
      </div>
      <div>
        <%= f.label :name, Team.human_attribute_name(:name), class: "form-label" %>
        <%= f.text_field :name, class: "form-control" %>
      </div>
    </div>

    <%# Coordenador + Canal de Rádio %>
    <div style="display: grid; grid-template-columns: 1fr auto; gap: 1rem; align-items: start; margin-bottom: 0.4rem;">
      <div class="form-label" style="margin: 0;">Coordenador</div>
      <div>
        <%= f.label :radio_channel, "Canal de Rádio", class: "form-label", style: "margin-bottom: 0.3rem; display: block;" %>
        <%= f.text_field :radio_channel, class: "form-control", placeholder: "ex: Canal 3", style: "width: 160px;" %>
      </div>
    </div>

    <div data-controller="autocomplete-single"
         data-autocomplete-single-url-value="<%= search_users_path %>"
         data-autocomplete-single-param-value="team[coordinator_id]"
         data-autocomplete-single-existing-value="<%= team.coordinator ? { id: team.coordinator.id, name: team.coordinator.name, cpf: team.coordinator.cpf.gsub(/(\d{3})(\d{3})(\d{3})(\d{2})/, '\1.\2.\3-\4') }.to_json : '{}'.to_json %>"
         style="position: relative; margin-bottom: 1.25rem;">

      <div data-autocomplete-single-target="selected"></div>

      <input type="text"
             data-autocomplete-single-target="input"
             data-action="input->autocomplete-single#search"
             class="form-control"
             placeholder="Buscar por nome ou CPF..."
             autocomplete="off">

      <div data-autocomplete-single-target="dropdown" class="autocomplete-dropdown" style="display: none;"></div>

      <input type="hidden"
             data-autocomplete-single-target="hidden"
             name="team[coordinator_id]"
             value="<%= team.coordinator_id %>">
    </div>

    <%# Colaboradores — multi autocomplete %>
    <div class="form-label" style="margin-bottom: 0.4rem;"><%= User.model_name.human(count: 2) %></div>

    <div data-controller="autocomplete"
         data-autocomplete-url-value="<%= search_users_path %>"
         data-autocomplete-param-value="team[user_ids][]"
         data-autocomplete-existing-value="<%= team.users.map { |u| { id: u.id, name: u.name, cpf: u.cpf.gsub(/(\d{3})(\d{3})(\d{3})(\d{2})/, '\1.\2.\3-\4') } }.to_json %>"
         style="position: relative;">

      <div data-autocomplete-target="tags" class="autocomplete-tags"></div>

      <input type="text"
             data-autocomplete-target="input"
             data-action="input->autocomplete#search"
             class="form-control"
             placeholder="Buscar por nome ou CPF..."
             autocomplete="off"
             style="margin-top: 0.5rem;">

      <div data-autocomplete-target="dropdown" class="autocomplete-dropdown" style="display: none;"></div>

      <p data-autocomplete-target="empty"
         style="font-size: 0.8rem; color: #a1a1aa; margin: 0.5rem 0 0; display: <%= team.users.any? ? 'none' : 'block' %>;">
        Nenhum colaborador adicionado.
      </p>

      <%= hidden_field_tag "team[user_ids][]", "" %>
    </div>

    <div style="display: flex; gap: 0.75rem; border-top: 1px solid #f4f4f5; padding-top: 1.25rem; margin-top: 1.25rem;">
      <%= f.submit t("actions.save"), class: "btn-primary" %>
      <%= link_to t("actions.cancel"), teams_path, class: "btn-secondary" %>
    </div>
  <% end %>
</div>
