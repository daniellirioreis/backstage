<%= form_with model: team, class: "mt-3" do |f| %>
  <%= render "shared/error_messages", object: team %>

  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <%= f.label :name, Team.human_attribute_name(:name), class: "form-label" %>
      <%= f.text_field :name, class: "form-control" %>
    </div>
    <div class="col-md-6">
      <%= f.label :event_id, Event.model_name.human, class: "form-label" %>
      <%= f.collection_select :event_id, Event.order(:name), :id, :name,
          { include_blank: "— Selecione —" }, class: "form-select" %>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit t("actions.save"), class: "btn btn-primary" %>
    <%= link_to t("actions.cancel"), teams_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
