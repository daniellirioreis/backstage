<% def avatar_tag(user, size: 40, color: "#71717a")
  initials = user.name.split.map(&:first).first(2).join.upcase
  if user.avatar.attached?
    tag.div(style: "width:#{size}px;height:#{size}px;border-radius:50%;overflow:hidden;flex-shrink:0;") do
      image_tag url_for(user.avatar), style: "width:100%;height:100%;object-fit:cover;"
    end
  else
    tag.div(initials, style: "width:#{size}px;height:#{size}px;border-radius:50%;background:#{color}22;display:flex;align-items:center;justify-content:center;font-size:#{(size*0.33).round}px;font-weight:700;color:#{color};flex-shrink:0;")
  end
end %>

<div class="page-header">
  <div style="display: flex; align-items: center; gap: 0.75rem;">
    <%= link_to teams_path, class: "btn-secondary", style: "padding: 0.35rem 0.6rem;" do %>
      <i class="bi bi-arrow-left"></i>
    <% end %>
    <div>
      <h1 style="margin: 0;"><%= @team.name %></h1>
      <div style="font-size: 0.82rem; color: #71717a; margin-top: 0.2rem;">
        <i class="bi bi-grid-3x3-gap"></i> <%= @team.sector.name %> &middot;
        <i class="bi bi-calendar-event"></i> <%= @team.sector.event.name %>
      </div>
    </div>
  </div>
  <div style="display: flex; gap: 0.5rem;">
    <% if policy(@team).panel? %>
      <%= link_to panel_team_path(@team), class: "btn-secondary" do %>
        <i class="bi bi-grid-1x2"></i> Painel
      <% end %>
    <% end %>
    <% if policy(@team).edit? %>
      <%= link_to edit_team_path(@team), class: "btn-secondary" do %>
        <i class="bi bi-pencil"></i> <%= t("actions.edit") %>
      <% end %>
    <% end %>
    <% if policy(@team).destroy? %>
      <%= button_to team_path(@team), method: :delete,
          form: { data: { turbo_confirm: t("confirms.delete") } },
          class: "btn-danger" do %>
        <i class="bi bi-trash"></i> <%= t("actions.delete") %>
      <% end %>
    <% end %>
  </div>
</div>

<%# ── Coordenador ──────────────────────────────────────────────────────────── %>
<% if @team.coordinator.present? %>
  <div class="content-card" style="margin-bottom: 1rem;">
    <h2 style="font-size: 0.9rem; font-weight: 600; color: #18181b; margin: 0 0 0.75rem;">
      <i class="bi bi-star-fill" style="color: #f59e0b;"></i> Coordenador
    </h2>
    <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.6rem 0.75rem; background: #fafaf9; border-radius: 8px; border: 1px solid #e7e5e4;">
      <div style="display: flex; align-items: center; gap: 0.75rem;">
        <%= avatar_tag(@team.coordinator, size: 40, color: "#f59e0b") %>
        <div>
          <div style="font-size: 0.88rem; font-weight: 600; color: #18181b;"><%= @team.coordinator.name %></div>
          <div style="font-size: 0.75rem; color: #71717a; display: flex; align-items: center; gap: 0.5rem;">
            <span><%= @team.coordinator.role&.name&.humanize || "—" %></span>
            <% if @team.radio_channel.present? %>
              <span style="color: #d4d4d8;">·</span>
              <span><i class="bi bi-broadcast"></i> <%= @team.radio_channel %></span>
            <% end %>
          </div>
        </div>
      </div>
      <% coord_membership = @memberships.find { |m| m.coordinator? } %>
      <% if coord_membership&.credential_code.present? %>
        <div style="text-align: right;">
          <div style="font-size: 0.7rem; color: #a1a1aa; text-transform: uppercase; letter-spacing: 0.05em;">Credencial</div>
          <div style="font-family: monospace; font-size: 0.82rem; font-weight: 700; color: #18181b; background: #f4f4f5; padding: 2px 8px; border-radius: 4px;">
            <%= coord_membership.full_credential_code %>
          </div>
        </div>
      <% else %>
        <span style="font-size: 0.75rem; color: #a1a1aa; font-style: italic;">sem código gerado</span>
      <% end %>
    </div>
  </div>
<% end %>


<%# ── Colaboradores ────────────────────────────────────────────────────────── %>
<div class="content-card">
  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
    <h2 style="font-size: 0.9rem; font-weight: 600; color: #18181b; margin: 0;">
      <i class="bi bi-people"></i> <%= User.model_name.human(count: 2) %>
      <span style="font-size: 0.8rem; font-weight: 400; color: #a1a1aa; margin-left: 0.25rem;">(<%= @memberships.size %>)</span>
    </h2>
  </div>
  <% if @memberships.any? %>
    <table class="data-table">
      <thead>
        <tr>
          <th style="width: 48px;"></th>
          <th><%= User.human_attribute_name(:name) %></th>
          <th>Função no Evento</th>
          <th>Credencial</th>
        </tr>
      </thead>
      <tbody>
        <% @memberships.each do |tm| %>
          <tr>
            <td style="padding: 0.4rem 0.5rem;">
              <%= avatar_tag(tm.user, size: 34, color: "#71717a") %>
            </td>
            <td style="font-weight: 500;"><%= tm.user.name %></td>
            <td>
              <% if @event_functions.any? %>
                <%= form_with url: set_function_team_path(@team, membership_id: tm.id), method: :patch, local: true, style: "display:inline;" do |f| %>
                  <%= select_tag :event_function_id,
                        options_for_select(
                          @event_functions.map { |ef| ["#{ef.name} · R$#{format('%.2f', ef.hourly_rate)}/h", ef.id] },
                          tm.event_function_id
                        ),
                        include_blank: "— Sem função —",
                        onchange: "this.form.submit()",
                        class: "form-control form-select",
                        style: "font-size:0.78rem;padding:0.2rem 0.5rem;height:auto;width:auto;min-width:160px;display:inline-block;" %>
                <% end %>
              <% elsif tm.event_function.present? %>
                <span style="font-size:0.8rem;color:#16a34a;font-weight:500;"><%= tm.event_function.name %></span>
              <% else %>
                <span style="font-size:0.75rem;color:#a1a1aa;">—</span>
              <% end %>
            </td>
            <td>
              <% if tm.credential_code.present? %>
                <span style="font-family: monospace; font-size: 0.82rem; font-weight: 700; background: #f4f4f5; padding: 2px 8px; border-radius: 4px; color: #18181b;">
                  <%= tm.full_credential_code %>
                </span>
              <% else %>
                <span style="font-size: 0.75rem; color: #a1a1aa; font-style: italic;">sem código</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div style="text-align: center; color: #a1a1aa; font-size: 0.85rem; padding: 1.5rem;">
      <i class="bi bi-people" style="font-size: 1.25rem; display: block; margin-bottom: 0.4rem;"></i>
      Nenhum colaborador na equipe
    </div>
  <% end %>
</div>

