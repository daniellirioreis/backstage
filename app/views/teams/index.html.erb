<div class="page-header">
  <h1><%= Team.model_name.human(count: 2) %></h1>
  <% if policy(Team).new? %>
    <%= link_to new_team_path, class: "btn-primary" do %>
      <i class="bi bi-plus"></i> <%= t("actions.new", model: Team.model_name.human) %>
    <% end %>
  <% end %>
</div>

<%# Campo de busca %>
<div class="content-card" style="margin-bottom: 0.75rem; padding: 0.6rem 1rem; display: flex; align-items: center; gap: 0.6rem;">
  <i class="bi bi-search" style="color: #a1a1aa; font-size: 0.9rem; flex-shrink: 0;"></i>
  <input id="teams-search" type="text" placeholder="Buscar colaborador, coordenador ou equipe..."
    autocomplete="off" style="flex: 1; border: none; outline: none; font-size: 0.85rem; color: #18181b; background: transparent;">
  <span id="teams-search-count" style="font-size: 0.75rem; color: #a1a1aa; white-space: nowrap; display: none;"></span>
  <button id="teams-search-clear" type="button" style="background: none; border: none; cursor: pointer; color: #a1a1aa; padding: 0; font-size: 1rem; line-height: 1; display: none;">×</button>
</div>

<%# Filtro de setor %>
<div class="content-card" style="margin-bottom: 1rem; padding: 0.75rem 1rem;">
  <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
    <span style="font-size: 0.78rem; font-weight: 600; color: #71717a; white-space: nowrap;">
      <i class="bi bi-grid-3x3-gap"></i> Setor:
    </span>
    <%= link_to "Todos", teams_path,
        style: "font-size: 0.78rem; padding: 0.25rem 0.65rem; border-radius: 6px; border: 1px solid #{params[:sector_id].blank? ? '#18181b' : '#e4e4e7'}; background: #{params[:sector_id].blank? ? '#18181b' : 'transparent'}; color: #{params[:sector_id].blank? ? '#fff' : '#3f3f46'}; text-decoration: none; white-space: nowrap;" %>
    <% @sectors.each do |sector| %>
      <%= link_to sector.name, teams_path(sector_id: sector.id),
          style: "font-size: 0.78rem; padding: 0.25rem 0.65rem; border-radius: 6px; border: 1px solid #{params[:sector_id].to_s == sector.id.to_s ? '#18181b' : '#e4e4e7'}; background: #{params[:sector_id].to_s == sector.id.to_s ? '#18181b' : 'transparent'}; color: #{params[:sector_id].to_s == sector.id.to_s ? '#fff' : '#3f3f46'}; text-decoration: none; white-space: nowrap;" %>
    <% end %>
    <% if params[:sector_id].present? %>
      <span style="font-size: 0.75rem; color: #a1a1aa; margin-left: auto;">
        <%= @teams.size %> equipe<%= @teams.size == 1 ? "" : "s" %>
      </span>
    <% end %>
  </div>
</div>

<% if @teams.empty? %>
  <div class="content-card" style="text-align: center; padding: 3rem; color: #a1a1aa;">
    <i class="bi bi-people" style="font-size: 2.5rem; display: block; margin-bottom: 0.75rem;"></i>
    <p style="margin: 0; font-size: 0.9rem;">Nenhuma equipe cadastrada para este evento.</p>
  </div>
<% else %>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem;">
    <% @teams.each do |team| %>
      <% memberships = team.team_memberships.reject { |tm| tm.user_id == team.coordinator_id } %>
      <% search_text = ([team.name, team.sector.name, team.coordinator&.name] + memberships.map { |tm| tm.user.name }).compact.join(" ").downcase %>
      <div class="content-card team-card" data-search="<%= search_text %>" style="padding: 1.25rem; display: flex; flex-direction: column; gap: 0.9rem;">

        <%# Header do card: nome da equipe + coordenador + ações %>
        <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem;">
          <div style="min-width: 0; flex: 1;">
            <h3 style="font-size: 0.92rem; font-weight: 600; color: #18181b; margin: 0 0 0.25rem;">
              <%= team.name %>
            </h3>
            <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
              <span style="font-size: 0.75rem; color: #71717a;">
                <i class="bi bi-grid-3x3-gap"></i> <%= team.sector.name %>
              </span>
              <% if team.coordinator %>
                <span style="color: #d4d4d8; font-size: 0.7rem;">·</span>
                <div style="display: flex; align-items: center; gap: 0.35rem;">
                  <div style="width: 20px; height: 20px; border-radius: 50%; overflow: hidden; background: #dcfce7; border: 1px solid #86efac; display: flex; align-items: center; justify-content: center; font-size: 0.5rem; font-weight: 700; color: #15803d; flex-shrink: 0;">
                    <% if team.coordinator.avatar.attached? %>
                      <%= image_tag team.coordinator.avatar, style: "width: 100%; height: 100%; object-fit: cover;" %>
                    <% else %>
                      <%= team.coordinator.name.split.map(&:first).first(2).join.upcase %>
                    <% end %>
                  </div>
                  <span style="font-size: 0.75rem; color: #15803d; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 120px;">
                    <i class="bi bi-star-fill" style="font-size: 0.6rem;"></i> <%= team.coordinator.name.split.first %>
                  </span>
                  <% if team.radio_channel.present? %>
                    <span style="display: inline-flex; align-items: center; gap: 0.25rem; background: #fef3c7; border: 1px solid #fcd34d; border-radius: 5px; padding: 1px 7px; font-size: 0.7rem; font-weight: 600; color: #92400e; white-space: nowrap;">
                      <i class="bi bi-broadcast" style="font-size: 0.65rem;"></i> <%= team.radio_channel %>
                    </span>
                  <% end %>
                </div>
              <% end %>
            </div>
            <div style="margin-top: 0.4rem;">
              <% if @teams_with_shifts.include?(team.id) %>
                <span style="display: inline-flex; align-items: center; gap: 0.25rem; background: #dcfce7; border: 1px solid #86efac; border-radius: 5px; padding: 1px 7px; font-size: 0.65rem; font-weight: 600; color: #15803d;">
                  <i class="bi bi-calendar-check" style="font-size: 0.6rem;"></i> Escala definida
                </span>
              <% else %>
                <span style="display: inline-flex; align-items: center; gap: 0.25rem; background: #fef2f2; border: 1px solid #fca5a5; border-radius: 5px; padding: 1px 7px; font-size: 0.65rem; font-weight: 600; color: #dc2626;">
                  <i class="bi bi-calendar-x" style="font-size: 0.6rem;"></i> Sem escala
                </span>
              <% end %>
            </div>
          </div>
          <div style="display: flex; gap: 0.4rem; flex-shrink: 0;">
            <% if policy(team).show? %>
              <%= link_to credentials_team_path(team, format: :pdf), class: "btn-secondary", style: "padding: 0.3rem 0.55rem;", title: "Baixar credenciais da equipe" do %>
                <i class="bi bi-file-earmark-pdf"></i>
              <% end %>
              <%= link_to team_path(team), class: "btn-secondary", style: "padding: 0.3rem 0.55rem;" do %>
                <i class="bi bi-eye"></i>
              <% end %>
            <% end %>
            <% if policy(team).edit? %>
              <%= link_to edit_team_path(team), class: "btn-secondary", style: "padding: 0.3rem 0.55rem;" do %>
                <i class="bi bi-pencil"></i>
              <% end %>
            <% end %>
            <% if policy(team).destroy? %>
              <%= button_to team_path(team), method: :delete,
                  form: { data: { turbo_confirm: t("confirms.delete") } },
                  class: "btn-danger", style: "padding: 0.3rem 0.55rem;" do %>
                <i class="bi bi-trash"></i>
              <% end %>
            <% end %>
          </div>
        </div>

        <%# Colaboradores %>
        <div>
          <div style="font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: #71717a; margin-bottom: 0.5rem;">
            <i class="bi bi-person"></i> <%= memberships.size %> <%= memberships.size == 1 ? "colaborador" : "colaboradores" %>
          </div>
          <% if memberships.any? %>
            <div style="display: flex; flex-direction: column; gap: 0; max-height: 180px; overflow-y: auto;">
              <% memberships.each do |tm| %>
                <% user = tm.user %>
                <div class="member-row" data-member-name="<%= user.name.downcase %>" style="display: flex; align-items: center; gap: 0.6rem; padding: 0.35rem 0; border-bottom: 1px solid #f4f4f5;">
                  <div style="width: 28px; height: 28px; border-radius: 50%; overflow: hidden; background: #f4f4f5; border: 1px solid #e4e4e7; display: flex; align-items: center; justify-content: center; font-size: 0.6rem; font-weight: 600; color: #52525b; flex-shrink: 0;">
                    <% if user.avatar.attached? %>
                      <%= image_tag user.avatar, style: "width: 100%; height: 100%; object-fit: cover;" %>
                    <% else %>
                      <%= user.name.split.map(&:first).first(2).join.upcase %>
                    <% end %>
                  </div>
                  <div style="min-width: 0; flex: 1;">
                    <div style="font-size: 0.8rem; font-weight: 500; color: #18181b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                      <%= user.name %>
                    </div>
                    <% if tm.credential_code.present? %>
                      <div style="font-size: 0.68rem; color: #71717a; font-family: monospace; letter-spacing: 0.04em;">
                        <%= tm.credential_code %>
                      </div>
                    <% end %>
                  </div>
                  <%= link_to credential_user_path(user, format: :pdf), title: "Baixar credencial",
                      style: "color: #a1a1aa; font-size: 0.95rem; flex-shrink: 0; line-height: 1; text-decoration: none;" do %>
                    <i class="bi bi-person-badge"></i>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <span style="font-size: 0.8rem; color: #a1a1aa;">Sem colaboradores</span>
          <% end %>
        </div>

      </div>
    <% end %>
  </div>
<% end %>

<script>
(function() {
  var input    = document.getElementById("teams-search");
  var countEl  = document.getElementById("teams-search-count");
  var clearBtn = document.getElementById("teams-search-clear");
  if (!input) return;

  function applySearch() {
    var q = input.value.trim().toLowerCase();
    var cards = document.querySelectorAll(".team-card");
    var visible = 0;

    cards.forEach(function(card) {
      var searchText = card.getAttribute("data-search") || "";
      var memberRows = card.querySelectorAll(".member-row");

      if (!q) {
        card.style.display = "";
        memberRows.forEach(function(r) { r.style.display = ""; r.style.background = ""; });
        visible++;
        return;
      }

      if (searchText.indexOf(q) === -1) { card.style.display = "none"; return; }

      card.style.display = "";
      visible++;

      // Destaca membros que coincidem; mantém os outros visíveis mas sem destaque
      memberRows.forEach(function(r) {
        var name = r.getAttribute("data-member-name") || "";
        r.style.background = name.indexOf(q) !== -1 ? "#f0fdf4" : "";
      });
    });

    if (q) {
      countEl.textContent  = visible + (visible === 1 ? " equipe" : " equipes");
      countEl.style.display = "";
      clearBtn.style.display = "";
    } else {
      countEl.style.display  = "none";
      clearBtn.style.display = "none";
    }
  }

  input.addEventListener("input", applySearch);
  clearBtn.addEventListener("click", function() { input.value = ""; applySearch(); input.focus(); });
})();
</script>
