<% if params[:notice].present? %>
  <div style="background:#f0fdf4;border:1px solid #86efac;border-radius:8px;padding:0.75rem 1rem;margin-bottom:1rem;font-size:0.85rem;color:#15803d;display:flex;align-items:center;gap:0.5rem;">
    <i class="bi bi-check-circle-fill"></i> <%= params[:notice] %>
  </div>
<% end %>

<div class="page-header">
  <h1><%= Team.model_name.human(count: 2) %></h1>
  <div style="display:flex;gap:0.5rem;">
    <% if policy(Team).edit? %>
      <button onclick="openImportModal(null)" class="btn-secondary">
        <i class="bi bi-people-fill"></i> Importar Colaboradores
      </button>
    <% end %>
    <% if policy(Team).new? %>
      <%= link_to new_team_path, class: "btn-primary" do %>
        <i class="bi bi-plus"></i> <%= t("actions.new", model: Team.model_name.human) %>
      <% end %>
    <% end %>
  </div>
</div>

<%# Campo de busca %>
<div class="content-card" style="margin-bottom: 0.75rem; padding: 0.6rem 1rem; display: flex; align-items: center; gap: 0.6rem;">
  <i class="bi bi-search" style="color: #a1a1aa; font-size: 0.9rem; flex-shrink: 0;"></i>
  <input id="teams-search" type="text" placeholder="Buscar colaborador, coordenador ou equipe..."
    autocomplete="off" style="flex: 1; border: none; outline: none; font-size: 0.85rem; color: #18181b; background: transparent;">
  <span id="teams-search-count" style="font-size: 0.75rem; color: #a1a1aa; white-space: nowrap; display: none;"></span>
  <button id="teams-search-clear" type="button" style="background: none; border: none; cursor: pointer; color: #a1a1aa; padding: 0; font-size: 1rem; line-height: 1; display: none;">×</button>
</div>

<%# Filtros %>
<% active_filters = params.permit(:sector_id, :without_shifts, :without_coordinator) %>
<div class="content-card" style="margin-bottom: 1rem; padding: 0.75rem 1rem; display: flex; flex-direction: column; gap: 0.6rem;">

  <%# Setor %>
  <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
    <span style="font-size: 0.78rem; font-weight: 600; color: #71717a; white-space: nowrap; min-width: 72px;">
      <i class="bi bi-grid-3x3-gap"></i> Setor:
    </span>
    <% no_sector = params[:sector_id].blank? %>
    <%= link_to "Todos", teams_path(active_filters.except(:sector_id)),
        style: "font-size:0.78rem;padding:0.25rem 0.65rem;border-radius:6px;border:1px solid #{no_sector ? '#18181b' : '#e4e4e7'};background:#{no_sector ? '#18181b' : 'transparent'};color:#{no_sector ? '#fff' : '#3f3f46'};text-decoration:none;white-space:nowrap;" %>
    <% @sectors.each do |sector| %>
      <% active = params[:sector_id].to_s == sector.id.to_s %>
      <%= link_to sector.name, teams_path(active_filters.merge(sector_id: sector.id)),
          style: "font-size:0.78rem;padding:0.25rem 0.65rem;border-radius:6px;border:1px solid #{active ? '#18181b' : '#e4e4e7'};background:#{active ? '#18181b' : 'transparent'};color:#{active ? '#fff' : '#3f3f46'};text-decoration:none;white-space:nowrap;" %>
    <% end %>
  </div>

  <%# Situação %>
  <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
    <span style="font-size: 0.78rem; font-weight: 600; color: #71717a; white-space: nowrap; min-width: 72px;">
      <i class="bi bi-funnel"></i> Filtros:
    </span>

    <% without_shifts_on = params[:without_shifts] == "1" %>
    <% toggle_shifts = without_shifts_on ? active_filters.except(:without_shifts) : active_filters.merge(without_shifts: "1") %>
    <%= link_to teams_path(toggle_shifts),
        style: "font-size:0.78rem;padding:0.25rem 0.65rem;border-radius:6px;border:1px solid #{without_shifts_on ? '#dc2626' : '#e4e4e7'};background:#{without_shifts_on ? '#fef2f2' : 'transparent'};color:#{without_shifts_on ? '#dc2626' : '#3f3f46'};text-decoration:none;white-space:nowrap;display:inline-flex;align-items:center;gap:0.3rem;" do %>
      <i class="bi bi-calendar-x" style="font-size:0.7rem;"></i> Sem escala
    <% end %>

    <% without_coord_on = params[:without_coordinator] == "1" %>
    <% toggle_coord = without_coord_on ? active_filters.except(:without_coordinator) : active_filters.merge(without_coordinator: "1") %>
    <%= link_to teams_path(toggle_coord),
        style: "font-size:0.78rem;padding:0.25rem 0.65rem;border-radius:6px;border:1px solid #{without_coord_on ? '#d97706' : '#e4e4e7'};background:#{without_coord_on ? '#fffbeb' : 'transparent'};color:#{without_coord_on ? '#d97706' : '#3f3f46'};text-decoration:none;white-space:nowrap;display:inline-flex;align-items:center;gap:0.3rem;" do %>
      <i class="bi bi-person-x" style="font-size:0.7rem;"></i> Sem coordenador
    <% end %>

    <% any_filter = params[:sector_id].present? || without_shifts_on || without_coord_on %>
    <% if any_filter %>
      <span style="font-size:0.75rem;color:#a1a1aa;">
        <%= @teams.size %> equipe<%= @teams.size == 1 ? "" : "s" %>
      </span>
      <%= link_to "× Limpar", teams_path, style: "font-size:0.75rem;color:#a1a1aa;text-decoration:none;margin-left:0.25rem;" %>
    <% end %>
  </div>

</div>

<% if @teams.empty? %>
  <div class="content-card" style="text-align: center; padding: 3rem; color: #a1a1aa;">
    <i class="bi bi-people" style="font-size: 2.5rem; display: block; margin-bottom: 0.75rem;"></i>
    <p style="margin: 0; font-size: 0.9rem;">Nenhuma equipe cadastrada para este evento.</p>
  </div>
<% else %>
  <div style="max-height: calc(100vh - 280px); overflow-y: auto; padding-right: 2px;">
  <% @teams.group_by(&:sector).each do |sector, teams| %>
    <div class="content-card team-sector-group" style="margin-bottom: 1rem; padding: 0; overflow: hidden;">

      <%# Header do setor %>
      <% s_planned  = (@sector_function_data&.dig(:planned,  sector.id.to_s) || {}) %>
      <% s_assigned = (@sector_function_data&.dig(:assigned, sector.id.to_s) || {}) %>
      <div style="padding: 0.55rem 1rem; background: #18181b; border-bottom: 1px solid #27272a; display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
        <i class="bi bi-grid-3x3-gap" style="color: #71717a; font-size: 0.8rem;"></i>
        <span style="font-size: 0.78rem; font-weight: 700; color: #f4f4f5; text-transform: uppercase; letter-spacing: 0.06em;"><%= sector.name %></span>
        <span style="font-size: 0.72rem; color: #71717a;"><%= teams.size %> equipe<%= teams.size == 1 ? "" : "s" %></span>

        <% if s_planned.any? %>
          <span style="color:#3f3f46; margin: 0 0.1rem;">·</span>
          <% s_planned.each do |fn_id, qty| %>
            <% ef   = @event_functions_map[fn_id] %>
            <% done = [s_assigned[fn_id] || 0, 0].max %>
            <% color, bg = done >= qty ? ['#4ade80','rgba(74,222,128,0.15)'] : done > 0 ? ['#fb923c','rgba(251,146,60,0.15)'] : ['#71717a','rgba(255,255,255,0.07)'] %>
            <span style="font-size:0.68rem; font-weight:600; color:<%= color %>; background:<%= bg %>; border:1px solid <%= color %>33; border-radius:4px; padding:1px 6px; white-space:nowrap;">
              <%= ef&.name || "Função #{fn_id}" %> <%= done %>/<%= qty %>
            </span>
          <% end %>
        <% end %>
      </div>

      <%# Linhas de equipe %>
      <% teams.each_with_index do |team, i| %>
        <% memberships = team.team_memberships.reject { |tm| tm.user_id == team.coordinator_id } %>
        <% search_text = ([team.name, sector.name, team.coordinator&.name] + memberships.map { |tm| tm.user.name }).compact.join(" ").downcase %>
        <div class="team-card" data-search="<%= search_text %>"
             style="display: flex; align-items: center; gap: 1rem; padding: 0.75rem 1rem; <%= i < teams.size - 1 ? 'border-bottom: 1px solid #f4f4f5;' : '' %>">

          <%# Dados para o popover %>
          <% popover_members = [] %>
          <% if team.coordinator %>
            <% u = team.coordinator %>
            <% popover_members << { name: u.name, initials: u.name.split.map(&:first).first(2).join.upcase, avatar_url: (url_for(u.avatar) if u.avatar.attached?), coordinator: true, credential: team.coordinator_full_credential_code, function: nil } %>
          <% end %>
          <% memberships.each do |tm| %>
            <% u = tm.user %>
            <% popover_members << { name: u.name, initials: u.name.split.map(&:first).first(2).join.upcase, avatar_url: (url_for(u.avatar) if u.avatar.attached?), coordinator: false, credential: tm.full_credential_code, function: tm.event_function&.name } %>
          <% end %>

          <%# Nome + coordenador %>
          <div style="flex: 1; min-width: 0;">
            <div style="font-size: 0.88rem; font-weight: 600; color: #18181b; margin-bottom: 0.2rem;">
              <span class="team-popover-trigger"
                    data-team-name="<%= h team.name %>"
                    data-team-url="<%= team_path(team) %>"
                    data-members="<%= h popover_members.to_json %>"
                    style="cursor: pointer; color: inherit; text-decoration: none; border-bottom: 1px dashed #d4d4d8;">
                <%= team.name %>
              </span>
            </div>
            <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
              <% if team.coordinator %>
                <div style="display: flex; align-items: center; gap: 0.3rem;">
                  <div style="width: 18px; height: 18px; border-radius: 50%; overflow: hidden; background: #dcfce7; border: 1px solid #86efac; display: flex; align-items: center; justify-content: center; font-size: 0.45rem; font-weight: 700; color: #15803d; flex-shrink: 0;">
                    <% if team.coordinator.avatar.attached? %>
                      <%= image_tag team.coordinator.avatar, style: "width: 100%; height: 100%; object-fit: cover;" %>
                    <% else %>
                      <%= team.coordinator.name.split.map(&:first).first(2).join.upcase %>
                    <% end %>
                  </div>
                  <span style="font-size: 0.73rem; color: #15803d; font-weight: 500;">
                    <i class="bi bi-star-fill" style="font-size: 0.55rem;"></i> <%= team.coordinator.name %>
                  </span>
                </div>
              <% end %>
              <% if team.radio_channel.present? %>
                <span style="display: inline-flex; align-items: center; gap: 0.2rem; background: #fef3c7; border: 1px solid #fcd34d; border-radius: 4px; padding: 1px 6px; font-size: 0.68rem; font-weight: 600; color: #92400e;">
                  <i class="bi bi-broadcast" style="font-size: 0.6rem;"></i> <%= team.radio_channel %>
                </span>
              <% end %>
              <%# Contagem por função %>
              <% fn_counts = memberships.group_by { |tm| tm.event_function&.name }.sort_by { |name, _| name.to_s } %>
              <% fn_counts.each do |fn_name, fms| %>
                <span style="display:inline-flex;align-items:center;gap:0.2rem;background:#f5f3ff;border:1px solid #ddd6fe;border-radius:4px;padding:1px 6px;font-size:0.67rem;font-weight:600;color:#6d28d9;">
                  <%= fms.size %> <%= fn_name || "s/ função" %>
                </span>
              <% end %>
              <% if @teams_with_shifts.include?(team.id) %>
                <span onclick="openShiftModal('<%= edit_team_shifts_path(team_id: team.id, modal: 1) %>')"
                      style="display: inline-flex; align-items: center; gap: 0.2rem; background: #f0fdf4; border: 1px solid #86efac; border-radius: 4px; padding: 1px 6px; font-size: 0.68rem; font-weight: 600; color: #15803d; cursor: pointer;">
                  <i class="bi bi-calendar-check" style="font-size: 0.6rem;"></i> Com escala
                </span>
              <% else %>
                <span onclick="openShiftModal('<%= new_shift_path(team_id: team.id, modal: 1) %>')"
                      style="display: inline-flex; align-items: center; gap: 0.2rem; background: #fef2f2; border: 1px solid #fca5a5; border-radius: 4px; padding: 1px 6px; font-size: 0.68rem; font-weight: 600; color: #dc2626; cursor: pointer;">
                  <i class="bi bi-calendar-x" style="font-size: 0.6rem;"></i> Sem escala
                </span>
              <% end %>
            </div>
          </div>

          <%# Avatares dos membros %>
          <div style="display: flex; align-items: center; gap: 0.35rem; flex-shrink: 0;">
            <% if memberships.any? %>
              <div style="display: flex;">
                <% memberships.first(5).each_with_index do |tm, j| %>
                  <% user = tm.user %>
                  <div class="member-row" data-member-name="<%= user.name.downcase %>"
                       title="<%= user.name %>"
                       style="width: 28px; height: 28px; border-radius: 50%; overflow: hidden; background: #f4f4f5; border: 2px solid #fff; display: flex; align-items: center; justify-content: center; font-size: 0.55rem; font-weight: 700; color: #52525b; flex-shrink: 0; margin-left: <%= j > 0 ? '-8px' : '0' %>; z-index: <%= 10 - j %>; position: relative;">
                    <% if user.avatar.attached? %>
                      <%= image_tag user.avatar, style: "width: 100%; height: 100%; object-fit: cover;" %>
                    <% else %>
                      <%= user.name.split.map(&:first).first(2).join.upcase %>
                    <% end %>
                  </div>
                <% end %>
                <% if memberships.size > 5 %>
                  <div style="width: 28px; height: 28px; border-radius: 50%; background: #f4f4f5; border: 2px solid #fff; display: flex; align-items: center; justify-content: center; font-size: 0.6rem; font-weight: 700; color: #71717a; flex-shrink: 0; margin-left: -8px; position: relative; z-index: 1;">
                    +<%= memberships.size - 5 %>
                  </div>
                <% end %>
              </div>
              <span style="font-size: 0.75rem; color: #71717a; margin-left: 0.25rem;"><%= memberships.size %></span>
            <% else %>
              <span style="font-size: 0.75rem; color: #a1a1aa;">Sem membros</span>
            <% end %>
          </div>

          <%# Ações %>
          <div style="display: flex; gap: 0.35rem; flex-shrink: 0;">
            <% if policy(team).show? %>
              <%= link_to credentials_team_path(team, format: :pdf), class: "btn-secondary", style: "padding: 0.25rem 0.5rem; font-size: 0.8rem;", title: "Credenciais PDF" do %>
                <i class="bi bi-file-earmark-pdf"></i>
              <% end %>
            <% end %>
            <% if policy(team).edit? %>
              <%= link_to edit_team_path(team), class: "btn-secondary", style: "padding: 0.25rem 0.5rem; font-size: 0.8rem;" do %>
                <i class="bi bi-pencil"></i>
              <% end %>
            <% end %>
            <% if policy(team).destroy? %>
              <%= button_to team_path(team), method: :delete,
                  form: { data: { turbo_confirm: t("confirms.delete") } },
                  class: "btn-danger", style: "padding: 0.25rem 0.5rem; font-size: 0.8rem;" do %>
                <i class="bi bi-trash"></i>
              <% end %>
            <% end %>
          </div>

        </div>
      <% end %>
    </div>
  <% end %>
  </div>
<% end %>

<script>
(function() {
  var input    = document.getElementById("teams-search");
  var countEl  = document.getElementById("teams-search-count");
  var clearBtn = document.getElementById("teams-search-clear");
  if (!input) return;

  function applySearch() {
    var q = input.value.trim().toLowerCase();
    var cards = document.querySelectorAll(".team-card");
    var visible = 0;

    cards.forEach(function(card) {
      var searchText = card.getAttribute("data-search") || "";
      var memberRows = card.querySelectorAll(".member-row");

      if (!q) {
        card.style.display = "";
        memberRows.forEach(function(r) { r.style.display = ""; r.style.background = ""; });
        visible++;
        return;
      }

      if (searchText.indexOf(q) === -1) { card.style.display = "none"; return; }

      card.style.display = "";
      visible++;

      // Destaca membros que coincidem; mantém os outros visíveis mas sem destaque
      memberRows.forEach(function(r) {
        var name = r.getAttribute("data-member-name") || "";
        r.style.background = name.indexOf(q) !== -1 ? "#f0fdf4" : "";
      });
    });

    if (q) {
      countEl.textContent  = visible + (visible === 1 ? " equipe" : " equipes");
      countEl.style.display = "";
      clearBtn.style.display = "";
    } else {
      countEl.style.display  = "none";
      clearBtn.style.display = "none";
    }
  }

  input.addEventListener("input", applySearch);
  clearBtn.addEventListener("click", function() { input.value = ""; applySearch(); input.focus(); });
})();
</script>

<%# ─── Popover de membros ────────────────────────────────────────────── %>
<div id="team-popover" style="display:none; position:fixed; z-index:999; background:#fff; border:1px solid #e4e4e7; border-radius:10px; box-shadow:0 8px 24px rgba(0,0,0,0.12); width:460px; padding:0; overflow:hidden;">
  <div id="team-popover-header" style="padding:0.65rem 0.9rem; background:#f9fafb; border-bottom:1px solid #e4e4e7;">
    <div style="font-size:0.85rem; font-weight:700; color:#18181b;" id="team-popover-title"></div>
    <a id="team-popover-link" href="#" style="font-size:0.72rem; color:#71717a; text-decoration:none;">
      <i class="bi bi-arrow-right"></i> Ver detalhes
    </a>
  </div>
  <div id="team-popover-body" style="max-height:280px; overflow-y:auto; padding:0.4rem 0;"></div>
</div>

<script>
(function() {
  var popover   = document.getElementById("team-popover");
  var titleEl   = document.getElementById("team-popover-title");
  var linkEl    = document.getElementById("team-popover-link");
  var bodyEl    = document.getElementById("team-popover-body");
  var activeBtn = null;

  function closePopover() {
    popover.style.display = "none";
    activeBtn = null;
  }

  function openPopover(trigger) {
    var members  = JSON.parse(trigger.getAttribute("data-members") || "[]");
    var teamName = trigger.getAttribute("data-team-name");
    var teamUrl  = trigger.getAttribute("data-team-url");

    titleEl.textContent = teamName;
    linkEl.href = teamUrl;

    if (members.length === 0) {
      bodyEl.innerHTML = '<div style="padding:0.75rem 0.9rem;font-size:0.8rem;color:#a1a1aa;">Sem membros cadastrados</div>';
    } else {
      bodyEl.innerHTML = members.map(function(m) {
        var avatar = m.avatar_url
          ? '<img src="' + m.avatar_url + '" style="width:100%;height:100%;object-fit:cover;">'
          : '<span style="font-size:0.55rem;font-weight:700;">' + m.initials + '</span>';
        var bg    = m.coordinator ? '#dcfce7' : '#f4f4f5';
        var color = m.coordinator ? '#15803d' : '#52525b';
        var badge = m.coordinator
          ? '<span style="font-size:0.6rem;background:#fef3c7;color:#92400e;border:1px solid #fcd34d;border-radius:3px;padding:0 4px;margin-left:4px;">Coord.</span>'
          : '';
        var fnBadge = m.function
          ? '<span style="font-size:0.6rem;color:#7c3aed;font-weight:600;background:#f5f3ff;border:1px solid #ddd6fe;border-radius:3px;padding:0 4px;margin-left:4px;">' + m.function + '</span>'
          : '';
        var credential = m.credential
          ? '<span style="font-family:monospace;font-size:0.72rem;font-weight:700;background:#f4f4f5;color:#18181b;padding:1px 6px;border-radius:4px;white-space:nowrap;flex-shrink:0;">' + m.credential + '</span>'
          : '<span style="font-size:0.7rem;color:#d4d4d8;">sem código</span>';
        return '<div style="display:flex;align-items:center;gap:0.6rem;padding:0.45rem 0.9rem;">'
          + '<div style="width:30px;height:30px;border-radius:50%;overflow:hidden;background:' + bg + ';display:flex;align-items:center;justify-content:center;font-size:0.55rem;font-weight:700;color:' + color + ';flex-shrink:0;">' + avatar + '</div>'
          + '<div style="flex:1;min-width:0;font-size:0.8rem;font-weight:500;color:#18181b;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + m.name + badge + fnBadge + '</div>'
          + credential
          + '</div>';
      }).join('<div style="height:1px;background:#f4f4f5;margin:0 0.9rem;"></div>');
    }

    // Posicionar fixo abaixo do trigger (position:fixed usa coordenadas do viewport)
    var rect = trigger.getBoundingClientRect();
    popover.style.display = "block";
    var pw   = popover.offsetWidth;
    var left = rect.left;
    var top  = rect.bottom + 6;

    // Evitar sair pela direita
    if (left + pw > window.innerWidth - 12) left = window.innerWidth - pw - 12;
    if (left < 8) left = 8;

    popover.style.left = left + "px";
    popover.style.top  = top  + "px";
    activeBtn = trigger;
  }

  document.addEventListener("click", function(e) {
    var trigger = e.target.closest(".team-popover-trigger");
    if (trigger) {
      e.preventDefault();
      if (activeBtn === trigger) { closePopover(); return; }
      openPopover(trigger);
      return;
    }
    if (!popover.contains(e.target)) closePopover();
  });

  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape") closePopover();
  });
})();
</script>

<%# ─── Modal de nova escala ──────────────────────────────────────────── %>
<div id="shift-modal-backdrop" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:1100; align-items:center; justify-content:center;">
  <div style="background:#fff; border-radius:12px; box-shadow:0 16px 48px rgba(0,0,0,0.2); width:95%; max-width:900px; height:85vh; display:flex; flex-direction:column; overflow:hidden;">
    <div style="display:flex; align-items:center; justify-content:space-between; padding:0.9rem 1.25rem; border-bottom:1px solid #e4e4e7; flex-shrink:0;">
      <div style="font-size:0.95rem; font-weight:700; color:#18181b;"><i class="bi bi-calendar-plus"></i> Nova Escala</div>
      <button onclick="closeShiftModal()" style="background:none; border:none; cursor:pointer; color:#a1a1aa; font-size:1.4rem; line-height:1; padding:0;">×</button>
    </div>
    <iframe id="shift-modal-iframe" src="" style="flex:1; border:none; width:100%;"></iframe>
  </div>
</div>

<script>
  window.openShiftModal = function(url) {
    var backdrop = document.getElementById("shift-modal-backdrop");
    document.getElementById("shift-modal-iframe").src = url;
    backdrop.style.display = "flex";
  };
  window.closeShiftModal = function() {
    document.getElementById("shift-modal-backdrop").style.display = "none";
    document.getElementById("shift-modal-iframe").src = "";
  };
  document.getElementById("shift-modal-backdrop").addEventListener("click", function(e) {
    if (e.target === this) closeShiftModal();
  });
  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape") closeShiftModal();
  });
</script>

<%# ─── Modal de importação de colaboradores ─────────────────────────── %>
<% preset_import_team = params[:import_team_id].present? ? Team.find_by(id: params[:import_team_id]) : nil %>
<% current_event_teams = policy_scope(Team).joins(:sector).where(sectors: { event_id: current_event.id }).includes(:sector).order("sectors.name, teams.name") %>
<% all_events = Event.where.not(id: current_event.id).order(created_at: :desc) %>

<%# O modal está sempre no DOM; JS controla visibilidade %>
<div id="import-modal-backdrop" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:1000;align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:12px;box-shadow:0 16px 48px rgba(0,0,0,0.18);width:100%;max-width:540px;max-height:92vh;display:flex;flex-direction:column;overflow:hidden;">

    <%# Header %>
    <div style="padding:1.1rem 1.5rem 0.9rem;border-bottom:1px solid #e4e4e7;display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-shrink:0;">
      <div>
        <div style="font-size:1rem;font-weight:700;color:#18181b;"><i class="bi bi-people-fill"></i> Importar Colaboradores</div>
        <div id="import-header-subtitle" style="font-size:0.78rem;color:#71717a;margin-top:3px;"></div>
      </div>
      <button id="import-close-btn" style="background:none;border:none;cursor:pointer;color:#a1a1aa;font-size:1.3rem;line-height:1;padding:0;flex-shrink:0;">×</button>
    </div>

    <%# Body %>
    <div style="padding:1.25rem 1.5rem;overflow-y:auto;flex:1;display:flex;flex-direction:column;gap:1rem;">

      <%# Passo 0: selecionar equipe DESTINO (só quando aberto pelo botão) %>
      <div id="import-step-target" style="display:none;">
        <label class="form-label"><i class="bi bi-bullseye"></i> Equipe de destino <span style="color:#ef4444;">*</span></label>
        <select id="import-target-select" class="form-control form-select"
                onchange="onTargetTeamChange(this.value, this.options[this.selectedIndex].text)">
          <option value="">— Selecione a equipe que receberá os colaboradores —</option>
          <% current_event_teams.each do |t| %>
            <option value="<%= t.id %>"><%= t.sector.name %> › <%= t.name %></option>
          <% end %>
        </select>
      </div>

      <%# Passo 1: selecionar evento de origem %>
      <div id="import-step-event" style="display:none;">
        <label class="form-label"><i class="bi bi-calendar-event"></i> Evento de origem</label>
        <select id="import-event-select" class="form-control form-select" onchange="loadImportTeams(this.value)">
          <option value="">— Selecione um evento —</option>
          <% all_events.each do |ev| %>
            <option value="<%= ev.id %>"><%= ev.name %></option>
          <% end %>
        </select>
      </div>

      <%# Passo 2: selecionar equipe de origem %>
      <div id="import-step-source-team" style="display:none;">
        <label class="form-label"><i class="bi bi-people"></i> Equipe de origem</label>
        <select id="import-team-select" class="form-control form-select" onchange="loadImportMembers(this.value)">
          <option value="">— Selecione uma equipe —</option>
        </select>
      </div>

      <%# Passo 3: lista de membros %>
      <div id="import-step-members" style="display:none;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem;">
          <div id="import-members-title" style="font-size:0.82rem;font-weight:600;color:#18181b;"></div>
          <label style="font-size:0.75rem;color:#71717a;cursor:pointer;display:flex;align-items:center;gap:0.35rem;">
            <input type="checkbox" id="import-select-all"
                   onchange="document.querySelectorAll('.import-cb:not(:disabled)').forEach(c=>c.checked=this.checked)"
                   style="width:14px;height:14px;"> Todos
          </label>
        </div>
        <div id="import-members-list" style="border:1px solid #e4e4e7;border-radius:8px;max-height:240px;overflow-y:auto;margin-bottom:0.75rem;"></div>
        <div id="import-hidden-fields"></div>
        <div style="display:flex;gap:0.5rem;">
          <button type="button" class="btn-primary" onclick="submitImport()">
            <i class="bi bi-person-plus"></i> Importar selecionados
          </button>
          <button type="button" class="btn-secondary" id="import-skip-btn">Pular</button>
        </div>
      </div>

    </div>
  </div>
</div>

<%# Form oculto para submit %>
<form id="import-form" method="post" style="display:none;">
  <input type="hidden" name="_method" value="post">
  <input type="hidden" name="<%= request.forgery_protection_token_value rescue 'authenticity_token' %>" value="">
  <input type="hidden" name="authenticity_token" id="import-csrf" value="<%= form_authenticity_token %>">
</form>

<script>
(function() {
  var backdrop       = document.getElementById("import-modal-backdrop");
  var subtitle       = document.getElementById("import-header-subtitle");
  var stepTarget     = document.getElementById("import-step-target");
  var stepEvent      = document.getElementById("import-step-event");
  var stepSourceTeam = document.getElementById("import-step-source-team");
  var stepMembers    = document.getElementById("import-step-members");

  var sourceTeamsUrl   = "<%= import_source_teams_teams_path %>";
  var sourceMembersUrl = "<%= import_source_members_teams_path %>";
  var importBaseUrl    = "<%= import_members_team_path('__ID__') %>".replace('__ID__', '');

  var targetTeamId   = null;
  var targetTeamName = null;

  function closeModal() {
    backdrop.style.display = "none";
    history.replaceState(null, '', location.pathname);
  }

  document.getElementById("import-close-btn").addEventListener("click", closeModal);
  document.getElementById("import-skip-btn").addEventListener("click", closeModal);

  // Abrir modal: com equipe pré-definida (pós-criação) ou sem (botão)
  window.openImportModal = function(teamId, teamName) {
    // Reset
    [stepTarget, stepEvent, stepSourceTeam, stepMembers].forEach(function(s) { s.style.display = "none"; });
    document.getElementById("import-event-select").value = "";
    document.getElementById("import-team-select").innerHTML = '<option value="">— Selecione uma equipe —</option>';
    document.getElementById("import-members-list").innerHTML = "";

    if (teamId) {
      targetTeamId   = teamId;
      targetTeamName = teamName;
      subtitle.innerHTML = 'Destino: <strong style="color:#18181b;">' + teamName + '</strong>';
      stepEvent.style.display = "block";
    } else {
      targetTeamId   = null;
      targetTeamName = null;
      subtitle.textContent = "Selecione a equipe de destino";
      stepTarget.style.display = "block";
    }

    backdrop.style.display = "flex";
  };

  window.onTargetTeamChange = function(id, label) {
    if (!id) return;
    targetTeamId   = id;
    targetTeamName = label;
    subtitle.innerHTML = 'Destino: <strong style="color:#18181b;">' + label + '</strong>';
    stepEvent.style.display = "block";
  };

  window.loadImportTeams = function(eventId) {
    if (!eventId) { stepSourceTeam.style.display = "none"; stepMembers.style.display = "none"; return; }
    fetch(sourceTeamsUrl + "?event_id=" + eventId)
      .then(function(r) { return r.json(); })
      .then(function(teams) {
        var sel = document.getElementById("import-team-select");
        sel.innerHTML = '<option value="">— Selecione uma equipe —</option>';
        teams.forEach(function(t) {
          sel.innerHTML += '<option value="' + t.id + '">' + t.label + '</option>';
        });
        stepSourceTeam.style.display = "block";
        stepMembers.style.display = "none";
      });
  };

  window.loadImportMembers = function(sourceTeamId) {
    if (!sourceTeamId || !targetTeamId) { stepMembers.style.display = "none"; return; }
    fetch(sourceMembersUrl + "?source_team_id=" + sourceTeamId + "&target_team_id=" + targetTeamId)
      .then(function(r) { return r.json(); })
      .then(function(members) {
        document.getElementById("import-members-title").textContent =
          members.length + " colaborador" + (members.length === 1 ? "" : "es") + " encontrado" + (members.length === 1 ? "" : "s");
        document.getElementById("import-members-list").innerHTML = members.map(function(m) {
          var avatar = m.avatar_url
            ? '<img src="' + m.avatar_url + '" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">'
            : '<span style="font-size:0.55rem;font-weight:700;color:#52525b;">' + m.initials + '</span>';
          var badge   = m.coordinator ? '<span style="font-size:0.6rem;background:#fef3c7;color:#92400e;border:1px solid #fcd34d;border-radius:4px;padding:1px 5px;margin-left:4px;">Coord.</span>' : '';
          var already = m.already ? '<span style="font-size:0.65rem;color:#a1a1aa;margin-left:auto;white-space:nowrap;flex-shrink:0;">já na equipe</span>' : '';
          return '<label style="display:flex;align-items:center;gap:0.65rem;padding:0.55rem 0.9rem;border-bottom:1px solid #f4f4f5;cursor:' + (m.already ? 'default' : 'pointer') + ';background:' + (m.already ? '#fafafa' : 'transparent') + ';">'
            + '<input type="checkbox" class="import-cb" data-user-id="' + m.id + '" ' + (m.already ? 'disabled' : 'checked') + ' style="width:14px;height:14px;flex-shrink:0;">'
            + '<div style="width:30px;height:30px;border-radius:50%;overflow:hidden;background:#f4f4f5;border:1px solid #e4e4e7;display:flex;align-items:center;justify-content:center;flex-shrink:0;">' + avatar + '</div>'
            + '<div style="flex:1;min-width:0;">'
              + '<div style="font-size:0.83rem;font-weight:500;color:' + (m.already ? '#a1a1aa' : '#18181b') + ';white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + m.name + badge + '</div>'
              + '<div style="font-size:0.7rem;color:#a1a1aa;">' + (m.phone || '') + '</div>'
            + '</div>' + already + '</label>';
        }).join("");
        stepMembers.style.display = "block";
        document.getElementById("import-select-all").checked = true;
      });
  };

  window.submitImport = function() {
    if (!targetTeamId) return;
    var form = document.getElementById("import-form");
    form.action = "/teams/" + targetTeamId + "/import_members";
    // Limpa campos dinâmicos anteriores
    form.querySelectorAll(".dyn-field").forEach(function(el) { el.remove(); });
    document.querySelectorAll(".import-cb:checked:not(:disabled)").forEach(function(cb) {
      var inp = document.createElement("input");
      inp.type = "hidden"; inp.name = "user_ids[]"; inp.value = cb.getAttribute("data-user-id");
      inp.className = "dyn-field";
      form.appendChild(inp);
    });
    form.submit();
  };

  // Auto-abrir se veio pós-criação
  <% if preset_import_team %>
    openImportModal(<%= preset_import_team.id %>, "<%= j preset_import_team.name %>");
  <% end %>
})();
</script>
