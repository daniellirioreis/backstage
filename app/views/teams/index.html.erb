<div class="page-header">
  <h1><%= Team.model_name.human(count: 2) %></h1>
  <% if policy(Team).new? %>
    <%= link_to new_team_path, class: "btn-primary" do %>
      <i class="bi bi-plus"></i> <%= t("actions.new", model: Team.model_name.human) %>
    <% end %>
  <% end %>
</div>

<% if @teams.empty? %>
  <div class="content-card" style="text-align: center; padding: 3rem; color: #a1a1aa;">
    <i class="bi bi-people" style="font-size: 2.5rem; display: block; margin-bottom: 0.75rem;"></i>
    <p style="margin: 0; font-size: 0.9rem;">Nenhuma equipe cadastrada para este evento.</p>
  </div>
<% else %>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem;">
    <% @teams.each do |team| %>
      <% members = team.coordinator ? team.users.reject { |u| u.id == team.coordinator_id } : team.users %>
      <div class="content-card" style="padding: 1.25rem; display: flex; flex-direction: column; gap: 0.9rem;">

        <%# Header do card %>
        <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem;">
          <div>
            <h3 style="font-size: 0.92rem; font-weight: 600; color: #18181b; margin: 0 0 0.2rem;">
              <%= team.name %>
            </h3>
            <span style="font-size: 0.75rem; color: #71717a;">
              <i class="bi bi-grid-3x3-gap"></i> <%= team.sector.name %>
            </span>
          </div>
          <div style="display: flex; gap: 0.4rem; flex-shrink: 0;">
            <% if policy(team).show? %>
              <%= link_to team_path(team), class: "btn-secondary", style: "padding: 0.3rem 0.55rem;" do %>
                <i class="bi bi-eye"></i>
              <% end %>
            <% end %>
            <% if policy(team).edit? %>
              <%= link_to edit_team_path(team), class: "btn-secondary", style: "padding: 0.3rem 0.55rem;" do %>
                <i class="bi bi-pencil"></i>
              <% end %>
            <% end %>
            <% if policy(team).destroy? %>
              <%= button_to team_path(team), method: :delete,
                  form: { data: { turbo_confirm: t("confirms.delete") } },
                  class: "btn-danger", style: "padding: 0.3rem 0.55rem;" do %>
                <i class="bi bi-trash"></i>
              <% end %>
            <% end %>
          </div>
        </div>

        <%# Coordenador %>
        <% if team.coordinator %>
          <div style="background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px; padding: 0.6rem 0.75rem; display: flex; align-items: center; gap: 0.6rem;">
            <div style="width: 30px; height: 30px; border-radius: 50%; background: #dcfce7; border: 1px solid #86efac;
                        display: flex; align-items: center; justify-content: center;
                        font-size: 0.62rem; font-weight: 700; color: #15803d; flex-shrink: 0;">
              <%= team.coordinator.name.split.map(&:first).first(2).join.upcase %>
            </div>
            <div style="min-width: 0;">
              <div style="font-size: 0.68rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: #15803d; margin-bottom: 0.1rem;">
                <i class="bi bi-star-fill"></i> Coordenador
              </div>
              <div style="font-size: 0.82rem; font-weight: 500; color: #18181b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                <%= team.coordinator.name %>
              </div>
              <div style="font-size: 0.72rem; color: #71717a; font-family: monospace;">
                <%= team.coordinator.cpf.gsub(/(\d{3})(\d{3})(\d{3})(\d{2})/, '\1.\2.\3-\4') %>
              </div>
            </div>
          </div>
        <% end %>

        <%# Colaboradores %>
        <div>
          <div style="font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: #71717a; margin-bottom: 0.5rem;">
            <i class="bi bi-person"></i> <%= members.size %> <%= members.size == 1 ? "colaborador" : "colaboradores" %>
          </div>
          <% if members.any? %>
            <div style="display: flex; flex-direction: column; gap: 0;">
              <% members.each do |user| %>
                <div style="display: flex; align-items: center; gap: 0.6rem; padding: 0.35rem 0; border-bottom: 1px solid #f4f4f5;">
                  <div style="width: 26px; height: 26px; border-radius: 50%; background: #f4f4f5; border: 1px solid #e4e4e7;
                              display: flex; align-items: center; justify-content: center;
                              font-size: 0.6rem; font-weight: 600; color: #52525b; flex-shrink: 0;">
                    <%= user.name.split.map(&:first).first(2).join.upcase %>
                  </div>
                  <div style="min-width: 0;">
                    <div style="font-size: 0.8rem; font-weight: 500; color: #18181b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                      <%= user.name %>
                    </div>
                    <div style="font-size: 0.7rem; color: #a1a1aa; font-family: monospace;">
                      <%= user.cpf.gsub(/(\d{3})(\d{3})(\d{3})(\d{2})/, '\1.\2.\3-\4') %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <span style="font-size: 0.8rem; color: #a1a1aa;">Sem colaboradores</span>
          <% end %>
        </div>

      </div>
    <% end %>
  </div>
<% end %>
