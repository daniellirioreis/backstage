<div class="page-header">
  <h1><%= Team.model_name.human(count: 2) %></h1>
  <% if policy(Team).new? %>
    <%= link_to new_team_path, class: "btn-primary" do %>
      <i class="bi bi-plus"></i> <%= t("actions.new", model: Team.model_name.human) %>
    <% end %>
  <% end %>
</div>

<table class="data-table">
  <thead>
    <tr>
      <th><%= Team.human_attribute_name(:name) %></th>
      <th><%= Event.model_name.human %></th>
      <th><%= Sector.model_name.human(count: 2) %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @teams.each do |team| %>
      <tr>
        <td><%= link_to team.name, team_path(team), style: "color: #18181b; font-weight: 500; text-decoration: none;" %></td>
        <td style="color: #71717a;"><%= team.event.name %></td>
        <td style="color: #71717a;"><%= team.sectors.size %></td>
        <td class="td-actions">
          <% if policy(team).edit? %>
            <%= link_to edit_team_path(team), class: "btn-secondary" do %><i class="bi bi-pencil"></i><% end %>
          <% end %>
          <% if policy(team).destroy? %>
            <%= button_to team_path(team), method: :delete,
                form: { data: { turbo_confirm: t("confirms.delete") } },
                class: "btn-danger" do %><i class="bi bi-trash"></i><% end %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
