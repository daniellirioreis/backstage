<div class="d-flex justify-content-between align-items-center mb-3">
  <h1><%= Team.model_name.human(count: 2) %></h1>
  <% if policy(Team).new? %>
    <%= link_to t("actions.new", model: Team.model_name.human), new_team_path, class: "btn btn-primary" %>
  <% end %>
</div>

<table class="table table-hover">
  <thead class="table-dark">
    <tr>
      <th><%= Team.human_attribute_name(:name) %></th>
      <th><%= Event.model_name.human %></th>
      <th><%= Sector.model_name.human(count: 2) %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @teams.each do |team| %>
      <tr>
        <td><%= link_to team.name, team_path(team) %></td>
        <td><%= team.event.name %></td>
        <td><%= team.sectors.size %></td>
        <td class="text-end">
          <% if policy(team).edit? %>
            <%= link_to t("actions.edit"), edit_team_path(team), class: "btn btn-sm btn-outline-secondary" %>
          <% end %>
          <% if policy(team).destroy? %>
            <%= button_to t("actions.delete"), team_path(team), method: :delete,
                form: { data: { turbo_confirm: t("confirms.delete") } },
                class: "btn btn-sm btn-outline-danger" %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
