<% @members.each_slice(4).with_index do |group, page_idx| %>
<div style="page-break-after: always; width: 100%; overflow: hidden;">
  <% group.each do |m| %>
  <% user = m[:user]; is_coordinator = m[:is_coordinator]; avatar_b64 = m[:avatar_base64] %>
  <div style="float: left; width: 50%; padding: 8mm; box-sizing: border-box; text-align: center;">
    <div class="badge">
      <div style="height:4px;background:<%= is_coordinator ? '#4ade80' : '#27272a' %>;"></div>
      <div class="badge-header">
        <span class="badge-brand">Backstage</span>
        <div>
          <% if current_event %>
            <div class="badge-event-name"><%= current_event.name %></div>
            <div class="badge-event-date"><%= l(current_event.start_date, format: :short) %> a <%= l(current_event.end_date, format: :short) %><% if current_event.location.present? %> &middot; <%= current_event.location %><% end %></div>
          <% end %>
        </div>
      </div>
      <div class="badge-body">
        <div class="badge-photo">
          <% if avatar_b64 %>
            <img src="<%= avatar_b64 %>">
          <% else %>
            <span class="badge-photo-initials"><%= user.name.split.map(&:first).first(2).join.upcase %></span>
          <% end %>
        </div>
        <div class="badge-name"><%= user.name %></div>
        <div class="badge-role-chip" style="background:<%= is_coordinator ? '#15803d' : '#18181b' %>;"><%= is_coordinator ? "Coordenador" : "Colaborador" %></div>
        <div class="badge-team-info"><strong><%= @team.sector.name %></strong> &middot; <%= @team.name %></div>
        <div class="badge-cpf"><%= user.cpf.gsub(/(\d{3})(\d{3})(\d{3})(\d{2})/, '\1.\2.\3-\4') %></div>
        <div class="badge-divider"></div>
      </div>
      <div class="badge-footer">
        <svg width="32" height="32" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
          <rect width="48" height="48" fill="#0d0d0d"/>
          <rect x="4" y="4" width="16" height="16" fill="none" stroke="#4ade80" stroke-width="2"/>
          <rect x="7" y="7" width="10" height="10" fill="#4ade80"/>
          <rect x="28" y="4" width="16" height="16" fill="none" stroke="#4ade80" stroke-width="2"/>
          <rect x="31" y="7" width="10" height="10" fill="#4ade80"/>
          <rect x="4" y="28" width="16" height="16" fill="none" stroke="#4ade80" stroke-width="2"/>
          <rect x="7" y="31" width="10" height="10" fill="#4ade80"/>
          <rect x="28" y="28" width="4" height="4" fill="#4ade80"/>
          <rect x="34" y="28" width="4" height="4" fill="#4ade80"/>
          <rect x="40" y="28" width="4" height="4" fill="#4ade80"/>
          <rect x="28" y="34" width="4" height="4" fill="#4ade80"/>
          <rect x="34" y="34" width="4" height="4" fill="#4ade80"/>
          <rect x="28" y="40" width="4" height="4" fill="#4ade80"/>
          <rect x="40" y="40" width="4" height="4" fill="#4ade80"/>
          <rect x="34" y="40" width="4" height="4" fill="#4ade80"/>
          <rect x="40" y="34" width="4" height="4" fill="#4ade80"/>
        </svg>
        <div class="badge-meta">
          <span class="badge-meta-label">ID Credencial</span>
          <span class="badge-meta-value">#<%= "BBY%04d" % user.id %></span>
          <span class="badge-meta-label" style="margin-top:2px;">Acesso</span>
          <span class="badge-meta-value">Todos os dias</span>
        </div>
      </div>
    </div>
  </div>
  <% end %>
</div>
<% end %>
