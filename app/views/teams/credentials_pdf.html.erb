<% cfg = @badge_config || BadgeConfig.defaults %>
<% @members.each_slice(4) do |group| %>
<div style="page-break-after: always; height: 257mm; display: -webkit-box; display: flex; -webkit-box-orient: vertical; flex-direction: column; -webkit-box-align: center; align-items: center; -webkit-box-pack: center; justify-content: center;">
  <% group.each_slice(2).each_with_index do |row, row_idx| %>
  <div style="display: -webkit-box; display: flex; -webkit-box-pack: center; justify-content: center;<%= row_idx > 0 ? ' margin-top: 10mm;' : '' %>">
    <% row.each_with_index do |m, col_idx| %>
    <% user = m[:user]; is_coordinator = m[:is_coordinator]; avatar_b64 = m[:avatar_base64]; credential_code = m[:credential_code] %>
    <div style="width: 80mm; height: 123.5mm; overflow: hidden;<%= col_idx > 0 ? ' margin-left: 10mm;' : '' %>">
      <div class="badge">
        <div style="height:4px;background:<%= is_coordinator ? '#4ade80' : '#27272a' %>;flex-shrink:0;"></div>
        <div class="badge-header">
          <span class="badge-brand">Backstage</span>
          <div>
            <% if current_event %>
              <div class="badge-event-name"><%= current_event.name %></div>
              <div class="badge-event-date"><%= l(current_event.start_date, format: :short) %> a <%= l(current_event.end_date, format: :short) %><% if current_event.location.present? %> &middot; <%= current_event.location %><% end %></div>
            <% end %>
          </div>
        </div>
        <div class="badge-body">
          <div class="badge-photo">
            <% if avatar_b64 %>
              <img src="<%= avatar_b64 %>">
            <% else %>
              <span class="badge-photo-initials"><%= user.name.split.map(&:first).first(2).join.upcase %></span>
            <% end %>
          </div>
          <div class="badge-name"><%= user.name %></div>
          <div class="badge-role-chip" style="background:<%= is_coordinator ? '#15803d' : '#18181b' %>;"><%= is_coordinator ? "Coordenador" : "Colaborador" %></div>
          <div class="badge-team-info"><strong><%= @team.sector.name %></strong> &middot; <%= @team.name %></div>
          <div class="badge-cpf"><%= user.cpf.gsub(/(\d{3})(\d{3})(\d{3})(\d{2})/, '\1.\2.\3-\4') %></div>
          <div class="badge-divider"></div>
        </div>
        <div class="badge-footer">
          <%= badge_qr_svg(credential_code || "BBY%04d" % user.id, pixel_size: 48, color: cfg.event_name_color, bg: cfg.header_footer_color) %>
          <div class="badge-meta">
            <% if credential_code.present? %>
              <span class="badge-meta-label">Credencial</span>
              <span class="badge-credential-code"><%= credential_code %></span>
            <% end %>
            <span class="badge-meta-label" style="margin-top: 3px;">Acesso</span>
            <span class="badge-meta-value">Todos os dias</span>
          </div>
        </div>
      </div>
    </div>
    <% end %>
  </div>
  <% end %>
</div>
<% end %>
