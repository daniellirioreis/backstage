<div class="page-header">
  <div style="display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap;">
    <h1 style="margin:0;">Planos</h1>
    <%= link_to new_plan_path, class: "btn-primary" do %>
      <i class="bi bi-plus-lg"></i> Novo plano
    <% end %>
  </div>
</div>

<% if @plans.empty? %>
  <div class="content-card" style="text-align:center; padding:3rem; color:#a1a1aa;">
    <i class="bi bi-box" style="font-size:2rem; display:block; margin-bottom:0.5rem;"></i>
    <p style="margin:0; font-size:0.88rem;">Nenhum plano cadastrado.</p>
  </div>
<% else %>
  <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:1rem;">
    <% @plans.each do |plan| %>
      <div class="content-card" style="padding:1.25rem;">
        <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:0.5rem; margin-bottom:1rem;">
          <div>
            <div style="font-size:1rem; font-weight:700; color:#18181b;"><%= plan.name %></div>
            <% if plan.price.to_f > 0 %>
              <div style="font-size:1.1rem; font-weight:800; color:#7c3aed; margin-top:0.15rem; line-height:1;">
                R$ <%= "%.2f" % plan.price %><span style="font-size:0.7rem; font-weight:400; color:#71717a;">/mês</span>
              </div>
            <% else %>
              <div style="font-size:0.78rem; font-weight:600; color:#16a34a; margin-top:0.15rem;">Gratuito</div>
            <% end %>
            <% if plan.description.present? %>
              <div style="font-size:0.75rem; color:#71717a; margin-top:0.2rem;"><%= plan.description %></div>
            <% end %>
          </div>
          <div style="display:flex; gap:0.4rem; flex-shrink:0;">
            <%= link_to edit_plan_path(plan), class:"btn-secondary", style:"padding:0.25rem 0.6rem; font-size:0.75rem;" do %>
              <i class="bi bi-pencil"></i>
            <% end %>
            <%= button_to plan_path(plan), method: :delete, form: { data: { turbo_confirm: "Excluir plano \"#{plan.name}\"?" } },
                class:"btn-secondary", style:"padding:0.25rem 0.6rem; font-size:0.75rem; color:#ef4444; border-color:#fca5a5;" do %>
              <i class="bi bi-trash"></i>
            <% end %>
          </div>
        </div>

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; margin-bottom:1rem;">
          <div style="background:#f4f4f5; border-radius:8px; padding:0.6rem 0.75rem; text-align:center;">
            <div style="font-size:1.25rem; font-weight:800; color:#18181b; line-height:1;"><%= plan.events_limit_label %></div>
            <div style="font-size:0.65rem; color:#71717a; margin-top:0.2rem; text-transform:uppercase; letter-spacing:0.06em;">Eventos</div>
          </div>
          <div style="background:#f4f4f5; border-radius:8px; padding:0.6rem 0.75rem; text-align:center;">
            <div style="font-size:1.25rem; font-weight:800; color:#18181b; line-height:1;"><%= plan.members_limit_label %></div>
            <div style="font-size:0.65rem; color:#71717a; margin-top:0.2rem; text-transform:uppercase; letter-spacing:0.06em;">Colaboradores</div>
          </div>
        </div>

        <div style="font-size:0.72rem; color:#71717a;">
          <i class="bi bi-building"></i>
          <%= plan.companies.count %> empresa<%= plan.companies.count == 1 ? "" : "s" %> neste plano
        </div>
      </div>
    <% end %>
  </div>
<% end %>
