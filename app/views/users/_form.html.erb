<%= form_with model: user, class: "mt-3" do |f| %>
  <%= render "shared/error_messages", object: user %>

  <div class="row g-3 mb-3">
    <div class="col-md-6">
      <%= f.label :name, User.human_attribute_name(:name), class: "form-label" %>
      <%= f.text_field :name, class: "form-control" %>
    </div>
    <div class="col-md-6">
      <%= f.label :email, User.human_attribute_name(:email), class: "form-label" %>
      <%= f.email_field :email, class: "form-control" %>
    </div>
    <div class="col-md-4">
      <%= f.label :cpf, User.human_attribute_name(:cpf), class: "form-label" %>
      <%= f.text_field :cpf, class: "form-control", maxlength: 11, placeholder: "Somente números" %>
    </div>
    <div class="col-md-4">
      <%= f.label :phone, User.human_attribute_name(:phone), class: "form-label" %>
      <%= f.text_field :phone, class: "form-control" %>
    </div>
    <div class="col-md-4">
      <%= f.label :role_id, User.human_attribute_name(:role), class: "form-label" %>
      <%= f.collection_select :role_id, Role.order(:name), :id, :name,
          { include_blank: "— Sem perfil —" }, class: "form-select" %>
    </div>
  </div>

  <hr>
  <p class="text-muted small">
    <%= user.new_record? ? "Defina uma senha para o colaborador." : "Deixe em branco para manter a senha atual." %>
  </p>
  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <%= f.label :password, User.human_attribute_name(:password), class: "form-label" %>
      <%= f.password_field :password, class: "form-control", autocomplete: "new-password" %>
    </div>
    <div class="col-md-6">
      <%= f.label :password_confirmation, User.human_attribute_name(:password_confirmation), class: "form-label" %>
      <%= f.password_field :password_confirmation, class: "form-control", autocomplete: "new-password" %>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit t("actions.save"), class: "btn btn-primary" %>
    <%= link_to t("actions.cancel"), users_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
