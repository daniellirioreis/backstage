<div class="content-card" style="max-width: 700px;">
  <%= form_with model: user,
      multipart: true,
      data: { controller: "user-form", action: "submit->user-form#submit" } do |f| %>
    <%= render "shared/error_messages", object: user %>

    <%# Avatar %>
    <div style="display: flex; align-items: center; gap: 1.25rem; margin-bottom: 1.5rem; padding-bottom: 1.25rem; border-bottom: 1px solid #f4f4f5;">
      <div id="avatar-preview" style="width: 72px; height: 72px; border-radius: 50%; overflow: hidden; background: #f4f4f5; border: 1px solid #e4e4e7; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
        <% if user.avatar.attached? && user.avatar.blob&.persisted? %>
          <%= image_tag user.avatar, style: "width: 100%; height: 100%; object-fit: cover;" %>
        <% else %>
          <span style="font-size: 1.5rem; font-weight: 600; color: #a1a1aa;">
            <%= user.name.present? ? user.name.first.upcase : "?" %>
          </span>
        <% end %>
      </div>
      <div>
        <%= f.label :avatar, "Foto do colaborador", class: "form-label", style: "margin-bottom: 0.4rem;" %>
        <%= f.file_field :avatar, accept: "image/*", class: "form-control",
            style: "font-size: 0.82rem;",
            onchange: "
              const file = this.files[0];
              if (file) {
                const reader = new FileReader();
                reader.onload = e => {
                  document.getElementById('avatar-preview').innerHTML =
                    '<img src=\"' + e.target.result + '\" style=\"width:100%;height:100%;object-fit:cover;\">';
                };
                reader.readAsDataURL(file);
              }
            " %>
        <% if user.avatar.attached? && user.avatar.blob&.persisted? %>
          <div style="margin-top: 0.4rem; font-size: 0.75rem; color: #a1a1aa;">
            <%= f.check_box :remove_avatar %> Remover foto atual
          </div>
        <% end %>
      </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">

      <div>
        <%= f.label :name, User.human_attribute_name(:name), class: "form-label" %>
        <%= f.text_field :name, class: "form-control",
            data: { user_form_target: "name" } %>
        <span class="field-error" data-user-form-target="nameError"></span>
      </div>

      <div>
        <%= f.label :email, User.human_attribute_name(:email), class: "form-label" %>
        <%= f.email_field :email, class: "form-control",
            data: { user_form_target: "email" } %>
        <span class="field-error" data-user-form-target="emailError"></span>
      </div>

      <div data-controller="cpf">
        <%= f.label :cpf, User.human_attribute_name(:cpf), class: "form-label" %>
        <%= f.text_field :cpf, class: "form-control",
            maxlength: 14,
            placeholder: "000.000.000-00",
            inputmode: "numeric",
            data: { cpf_target: "field", action: "input->cpf#mask", user_form_target: "cpf" },
            value: user.cpf.present? ? user.cpf.gsub(/(\d{3})(\d{3})(\d{3})(\d{2})/, '\1.\2.\3-\4') : "" %>
        <span class="field-error" data-user-form-target="cpfError"></span>
      </div>

      <div>
        <%= f.label :phone, User.human_attribute_name(:phone), class: "form-label" %>
        <%= f.text_field :phone, class: "form-control", placeholder: "(11) 99999-9999", data: { mask: "phone" } %>
      </div>

      <% if current_user.admin? || policy(User).create? %>
        <div style="grid-column: 1 / -1;">
          <%= f.label :role_id, User.human_attribute_name(:role), class: "form-label" %>
          <%= f.collection_select :role_id, Role.order(:name), :id, :name,
              { include_blank: "— Selecione um perfil —" },
              class: "form-control form-select",
              data: { user_form_target: "role" } %>
          <span class="field-error" data-user-form-target="roleError"></span>
        </div>
      <% end %>

    </div>

    <div style="border-top: 1px solid #f4f4f5; padding-top: 1rem; margin-top: 0.5rem;">
      <% if user.new_record? %>
        <%# Toggle: definir senha agora ou gerar automaticamente %>
        <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; margin-bottom: 0.75rem; width: fit-content;">
          <input type="checkbox" id="toggle_set_password" onchange="togglePasswordFields(this.checked)"
                 style="width: 15px; height: 15px;">
          <span style="font-size: 0.82rem; color: #18181b; font-weight: 500;">Definir senha agora</span>
        </label>
        <p id="password_auto_hint" style="font-size: 0.78rem; color: #71717a; margin-bottom: 0.75rem;">
          Uma senha aleatória será gerada. O colaborador poderá redefini-la depois.
        </p>
        <div id="password_fields" style="display: none;">
      <% else %>
        <p style="font-size: 0.8rem; color: #71717a; margin-bottom: 0.75rem;">
          Deixe em branco para manter a senha atual.
        </p>
        <div id="password_fields">
      <% end %>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
          <div>
            <%= f.label :password, User.human_attribute_name(:password), class: "form-label" %>
            <%= f.password_field :password, class: "form-control", autocomplete: "new-password" %>
          </div>
          <div>
            <%= f.label :password_confirmation, User.human_attribute_name(:password_confirmation), class: "form-label" %>
            <%= f.password_field :password_confirmation, class: "form-control", autocomplete: "new-password" %>
          </div>
        </div>
      </div>
    </div>

    <% if user.new_record? %>
      <script>
        function togglePasswordFields(show) {
          document.getElementById('password_fields').style.display = show ? 'block' : 'none';
          document.getElementById('password_auto_hint').style.display = show ? 'none' : 'block';
        }
      </script>
    <% end %>

    <div style="display: flex; gap: 0.75rem; border-top: 1px solid #f4f4f5; padding-top: 1.25rem;">
      <%= f.submit t("actions.save"), class: "btn-primary" %>
      <%= link_to t("actions.cancel"), users_path, class: "btn-secondary" %>
    </div>
  <% end %>
</div>
