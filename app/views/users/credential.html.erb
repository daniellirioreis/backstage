<div class="badge">
    <div style="height:5px;background:<%= @is_coordinator ? '#4ade80' : '#27272a' %>;"></div>

    <div class="badge-header">
      <div class="badge-brand">Backstage</div>
      <div>
        <% if @event %>
          <div class="badge-event-name"><%= @event.name %></div>
          <div class="badge-event-date">
            <%= l(@event.start_date, format: :short) %> a <%= l(@event.end_date, format: :short) %>
            <% if @event.location.present? %> &middot; <%= @event.location %><% end %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="badge-body">
      <div class="badge-photo">
        <% if @user.avatar.attached? %>
          <%= image_tag @user.avatar, style: "width:100%;height:100%;object-fit:cover;" %>
        <% else %>
          <span class="badge-photo-initials"><%= @user.name.split.map(&:first).first(2).join.upcase %></span>
        <% end %>
      </div>

      <div class="badge-info">
        <div class="badge-name"><%= @user.name %></div>
        <div class="badge-role-chip" style="background:<%= @is_coordinator ? '#15803d' : '#18181b' %>;">
          <%= @is_coordinator ? "Coordenador" : "Colaborador" %>
        </div>
        <% if @team %>
          <div class="badge-team-info">
            <strong><%= @team.sector.name %></strong> &middot; <%= @team.name %>
          </div>
        <% end %>
        <div class="badge-cpf">
          <%= @user.cpf.gsub(/(\d{3})(\d{3})(\d{3})(\d{2})/, '\1.\2.\3-\4') %>
        </div>
      </div>

      <div class="badge-divider"></div>
    </div>

    <div class="badge-footer">
      <svg width="44" height="44" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
        <rect width="48" height="48" fill="#0d0d0d"/>
        <rect x="4" y="4" width="16" height="16" fill="none" stroke="#4ade80" stroke-width="2"/>
        <rect x="7" y="7" width="10" height="10" fill="#4ade80"/>
        <rect x="28" y="4" width="16" height="16" fill="none" stroke="#4ade80" stroke-width="2"/>
        <rect x="31" y="7" width="10" height="10" fill="#4ade80"/>
        <rect x="4" y="28" width="16" height="16" fill="none" stroke="#4ade80" stroke-width="2"/>
        <rect x="7" y="31" width="10" height="10" fill="#4ade80"/>
        <rect x="28" y="28" width="4" height="4" fill="#4ade80"/>
        <rect x="34" y="28" width="4" height="4" fill="#4ade80"/>
        <rect x="40" y="28" width="4" height="4" fill="#4ade80"/>
        <rect x="28" y="34" width="4" height="4" fill="#4ade80"/>
        <rect x="34" y="34" width="4" height="4" fill="#4ade80"/>
        <rect x="28" y="40" width="4" height="4" fill="#4ade80"/>
        <rect x="40" y="40" width="4" height="4" fill="#4ade80"/>
        <rect x="34" y="40" width="4" height="4" fill="#4ade80"/>
        <rect x="40" y="34" width="4" height="4" fill="#4ade80"/>
      </svg>
      <div class="badge-meta">
        <div class="badge-meta-label">ID Credencial</div>
        <div class="badge-meta-value">#<%= "BBY%04d" % @user.id %></div>
        <div class="badge-meta-label" style="margin-top:3px;">Acesso</div>
        <div class="badge-meta-value">Todos os dias</div>
      </div>
    </div>
  </div>
</div>
