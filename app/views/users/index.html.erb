<div class="page-header">
  <h1><%= User.model_name.human(count: 2) %></h1>
  <% if policy(User).new? %>
    <%= link_to new_user_path, class: "btn-primary" do %>
      <i class="bi bi-plus"></i> <%= t("actions.new", model: User.model_name.human) %>
    <% end %>
  <% end %>
</div>

<table class="data-table">
  <thead>
    <tr>
      <th><%= User.human_attribute_name(:name) %></th>
      <th><%= User.human_attribute_name(:email) %></th>
      <th><%= User.human_attribute_name(:cpf) %></th>
      <th><%= User.human_attribute_name(:phone) %></th>
      <th><%= User.human_attribute_name(:role) %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td>
          <div style="display: flex; align-items: center; gap: 0.6rem;">
            <div style="width: 32px; height: 32px; border-radius: 50%; overflow: hidden; background: #f4f4f5; border: 1px solid #e4e4e7; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <% if user.avatar.attached? %>
                <%= image_tag user.avatar, style: "width: 100%; height: 100%; object-fit: cover;" %>
              <% else %>
                <span style="font-size: 0.65rem; font-weight: 600; color: #52525b;">
                  <%= user.name.split.map(&:first).first(2).join.upcase %>
                </span>
              <% end %>
            </div>
            <span style="font-weight: 500; color: #18181b;"><%= user.name %></span>
          </div>
        </td>
        <td style="color: #71717a;"><%= user.email %></td>
        <td style="color: #71717a; font-family: monospace; font-size: 0.8rem;"><%= user.cpf %></td>
        <td style="color: #71717a;"><%= user.phone %></td>
        <td>
          <% if user.role %>
            <span class="badge-status badge-active"><%= user.role.name %></span>
          <% else %>
            <span style="color: #a1a1aa; font-size: 0.8rem;">—</span>
          <% end %>
        </td>
        <td class="td-actions">
          <% if policy(user).show? %>
            <%= link_to credential_user_path(user), class: "btn-secondary", title: "Ver credencial", target: "_blank" do %><i class="bi bi-person-badge"></i><% end %>
          <% end %>
          <% if policy(user).edit? %>
            <%= link_to edit_user_path(user), class: "btn-secondary" do %><i class="bi bi-pencil"></i><% end %>
          <% end %>
          <% if policy(user).destroy? %>
            <%= button_to user_path(user), method: :delete,
                form: { data: { turbo_confirm: t("confirms.delete") } },
                class: "btn-danger" do %><i class="bi bi-trash"></i><% end %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
