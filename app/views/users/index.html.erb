<div class="page-header">
  <div>
    <h1 style="margin: 0;"><%= User.model_name.human(count: 2) %></h1>
    <div style="font-size: 0.8rem; color: #a1a1aa; margin-top: 0.2rem;"><%= @total %> encontrado<%= @total == 1 ? "" : "s" %></div>
  </div>
  <div style="display:flex; gap:0.5rem; align-items:center;">
    <% if current_user.admin? %>
      <%= link_to new_invitation_path, style: "display:inline-flex; align-items:center; gap:0.35rem; background:#fff; color:#18181b; border:1px solid #d1d5db; border-radius:8px; padding:0.45rem 0.9rem; font-size:0.82rem; font-weight:500; text-decoration:none;" do %>
        <i class="bi bi-envelope-plus"></i> Convidar
      <% end %>
    <% end %>
    <% if policy(User).new? %>
      <%= link_to new_user_path, class: "btn-primary" do %>
        <i class="bi bi-plus"></i> <%= t("actions.new", model: User.model_name.human) %>
      <% end %>
    <% end %>
  </div>
</div>

<%# ── Filtros ────────────────────────────────────────────────────────────── %>
<%= form_with url: users_path, method: :get, local: true, style: "margin-bottom: 1.25rem;" do |f| %>
  <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: flex-end;">

    <%# Busca %>
    <div style="flex: 1; min-width: 200px;">
      <label style="display: block; font-size: 0.72rem; font-weight: 600; color: #71717a; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.3rem;">Buscar</label>
      <%= f.text_field :q, value: params[:q], placeholder: "Nome ou CPF…",
          class: "form-control", style: "margin: 0;" %>
    </div>

    <%# Perfil %>
    <div style="min-width: 160px;">
      <label style="display: block; font-size: 0.72rem; font-weight: 600; color: #71717a; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.3rem;">Perfil</label>
      <%= f.select :role_id,
          options_from_collection_for_select(@roles, :id, :name, params[:role_id]),
          { include_blank: "Todos" },
          class: "form-control", style: "margin: 0;" %>
    </div>

    <%# Empresa — só aparece se houver mais de uma %>
    <% if @companies.size > 1 %>
      <div style="min-width: 180px;">
        <label style="display: block; font-size: 0.72rem; font-weight: 600; color: #71717a; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.3rem;">Empresa</label>
        <%= f.select :company_id,
            options_from_collection_for_select(@companies, :id, :name, params[:company_id]),
            { include_blank: "Todas" },
            class: "form-control", style: "margin: 0;" %>
      </div>
    <% end %>

    <%# Botões %>
    <div style="display: flex; gap: 0.5rem; padding-bottom: 1px;">
      <%= f.submit "Filtrar", class: "btn-primary" %>
      <% if params[:q].present? || params[:role_id].present? || params[:company_id].present? %>
        <%= link_to users_path, class: "btn-secondary" do %>
          <i class="bi bi-x"></i> Limpar
        <% end %>
      <% end %>
    </div>

  </div>
<% end %>

<% if @users.empty? %>
  <div class="content-card">
    <%= render "shared/empty_state",
          icon: "bi-person-badge",
          title: "Nenhum colaborador encontrado",
          description: "Convide colaboradores pelo link de convite para que apareçam aqui.",
          action_label: "Convidar colaborador",
          action_path: new_invitation_path,
          action_policy: policy(:invitation).create? %>
  </div>
<% else %>
<table class="data-table">
  <thead>
    <tr>
      <th><%= User.human_attribute_name(:name) %></th>
      <th><%= User.human_attribute_name(:email) %></th>
      <th><%= User.human_attribute_name(:cpf) %></th>
      <th><%= User.human_attribute_name(:phone) %></th>
      <th><%= User.human_attribute_name(:role) %></th>
      <th><%= Company.model_name.human(count: 2) %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td>
          <div style="display: flex; align-items: center; gap: 0.6rem;">
            <div style="width: 32px; height: 32px; border-radius: 50%; overflow: hidden; background: #f4f4f5; border: 1px solid #e4e4e7; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <% if user.avatar.attached? %>
                <%= image_tag user.avatar, style: "width: 100%; height: 100%; object-fit: cover;" %>
              <% else %>
                <span style="font-size: 0.65rem; font-weight: 600; color: #52525b;">
                  <%= user.name.split.map(&:first).first(2).join.upcase %>
                </span>
              <% end %>
            </div>
            <span style="font-weight: 500; color: #18181b;"><%= user.name %></span>
          </div>
        </td>
        <td style="color: #71717a;"><%= user.email %></td>
        <td style="color: #71717a; font-family: monospace; font-size: 0.8rem;"><%= user.cpf %></td>
        <td style="color: #71717a;"><%= user.phone %></td>
        <td>
          <% if user.role %>
            <span class="badge-status badge-active"><%= user.role.name %></span>
          <% else %>
            <span style="color: #a1a1aa; font-size: 0.8rem;">—</span>
          <% end %>
        </td>
        <td>
          <% user.companies.each do |company| %>
            <span style="display:inline-flex; align-items:center; gap:0.25rem; background:#f4f4f5; border:1px solid #e4e4e7; border-radius:5px; padding:2px 8px; font-size:0.72rem; font-weight:600; color:#52525b; margin-right:2px;">
              <i class="bi bi-building" style="font-size:0.65rem;"></i> <%= company.name %>
            </span>
          <% end %>
          <% if user.companies.empty? %>
            <span style="color:#a1a1aa; font-size:0.8rem;">—</span>
          <% end %>
        </td>
        <td class="td-actions">
          <% if policy(user).my_schedule? %>
            <%= link_to my_schedule_user_path(user), class: "btn-secondary", title: t("permission_actions.my_schedule") do %><i class="bi bi-calendar-week"></i><% end %>
          <% end %>
          <% if policy(user).show? %>
            <%= link_to credential_user_path(user, format: :pdf), class: "btn-secondary", title: "Baixar credencial" do %><i class="bi bi-person-badge"></i><% end %>
          <% end %>
          <% if policy(user).edit? %>
            <%= link_to edit_user_path(user), class: "btn-secondary" do %><i class="bi bi-pencil"></i><% end %>
          <% end %>
          <% if policy(user).destroy? %>
            <%= button_to user_path(user), method: :delete,
                form: { data: { turbo_confirm: t("confirms.delete") } },
                class: "btn-danger" do %><i class="bi bi-trash"></i><% end %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
<% end %>

<%# Paginação %>
<% if @users.total_pages > 1 %>
  <div style="display:flex; justify-content:center; align-items:center; gap:0.4rem; margin-top:1.5rem;">
    <%= will_paginate @users,
        previous_label: "‹ Anterior",
        next_label:     "Próximo ›",
        inner_window:   2,
        outer_window:   1,
        renderer:       "BackstagePaginationRenderer" %>
  </div>
<% end %>
