<style>
  .badge-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    font-family: Arial, Helvetica, sans-serif;
  }

  .lanyard-clip {
    width: 22px;
    height: 9px;
    background: #27272a;
    border: 1px solid #3f3f46;
    border-radius: 3px;
  }

  .lanyard {
    width: 2px;
    height: 44px;
    background: #4ade80;
  }

  .badge {
    width: 300px;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0,0,0,0.6);
  }

  .badge-stripe {
    height: 6px;
    background: <%= @is_coordinator ? '#4ade80' : '#27272a' %>;
  }

  .badge-header {
    background: #0d0d0d;
    padding: 14px 18px 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 3px solid #4ade80;
  }

  .badge-brand {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #f4f4f5;
  }

  .badge-event-name {
    font-size: 10px;
    font-weight: 700;
    color: #4ade80;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: right;
  }

  .badge-event-date {
    font-size: 9px;
    color: #52525b;
    margin-top: 2px;
    text-align: right;
  }

  .badge-body {
    background: #f5f5f4;
    padding: 22px 18px 18px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .badge-photo {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    border: 3px solid #0d0d0d;
    overflow: hidden;
    background: #e4e4e7;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .badge-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .badge-photo-initials {
    font-size: 28px;
    font-weight: 700;
    color: #a1a1aa;
  }

  .badge-info {
    text-align: center;
    width: 100%;
  }

  .badge-name {
    font-size: 15px;
    font-weight: 800;
    color: #18181b;
    line-height: 1.2;
  }

  .badge-role-chip {
    display: inline-block;
    margin-top: 6px;
    padding: 3px 12px;
    border-radius: 20px;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
    background: <%= @is_coordinator ? '#15803d' : '#18181b' %>;
  }

  .badge-team-info {
    margin-top: 8px;
    font-size: 10px;
    color: #52525b;
    line-height: 1.5;
  }

  .badge-cpf {
    font-size: 10px;
    color: #a1a1aa;
    font-family: monospace;
    letter-spacing: 0.05em;
    margin-top: 3px;
  }

  .badge-divider {
    width: 100%;
    height: 1px;
    background: #e4e4e7;
  }

  .badge-footer {
    background: #0d0d0d;
    padding: 12px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
  }

  .badge-meta { text-align: right; }
  .badge-meta-label {
    font-size: 8px;
    color: #3f3f46;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .badge-meta-value {
    font-size: 10px;
    color: #a1a1aa;
    font-family: monospace;
    margin-top: 1px;
  }
</style>

<div class="badge-wrap">
  <div class="lanyard-clip"></div>
  <div class="lanyard"></div>

  <div class="badge">
    <div class="badge-stripe"></div>

    <div class="badge-header">
      <div class="badge-brand">Backstage</div>
      <div>
        <% if current_event %>
          <div class="badge-event-name"><%= current_event.name %></div>
          <div class="badge-event-date">
            <%= l(current_event.start_date, format: :short) %> a <%= l(current_event.end_date, format: :short) %>
            <% if current_event.location.present? %> &middot; <%= current_event.location %><% end %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="badge-body">
      <div class="badge-photo">
        <% if @user.avatar.attached? %>
          <%= image_tag url_for(@user.avatar), style: "width: 100%; height: 100%; object-fit: cover;" %>
        <% else %>
          <span class="badge-photo-initials">
            <%= @user.name.split.map(&:first).first(2).join.upcase %>
          </span>
        <% end %>
      </div>

      <div class="badge-info">
        <div class="badge-name"><%= @user.name %></div>
        <div class="badge-role-chip">
          <%= @is_coordinator ? "Coordenador" : "Colaborador" %>
        </div>

        <% if @team %>
          <div class="badge-team-info">
            <strong><%= @team.sector.name %></strong> &middot; <%= @team.name %>
          </div>
        <% end %>

        <div class="badge-cpf">
          <%= @user.cpf.gsub(/(\d{3})(\d{3})(\d{3})(\d{2})/, '\1.\2.\3-\4') %>
        </div>
      </div>

      <div class="badge-divider"></div>
    </div>

    <div class="badge-footer">
      <svg width="52" height="52" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
        <rect width="48" height="48" fill="#0d0d0d"/>
        <rect x="4" y="4" width="16" height="16" fill="none" stroke="#4ade80" stroke-width="2"/>
        <rect x="7" y="7" width="10" height="10" fill="#4ade80"/>
        <rect x="28" y="4" width="16" height="16" fill="none" stroke="#4ade80" stroke-width="2"/>
        <rect x="31" y="7" width="10" height="10" fill="#4ade80"/>
        <rect x="4" y="28" width="16" height="16" fill="none" stroke="#4ade80" stroke-width="2"/>
        <rect x="7" y="31" width="10" height="10" fill="#4ade80"/>
        <rect x="28" y="28" width="4" height="4" fill="#4ade80"/>
        <rect x="34" y="28" width="4" height="4" fill="#4ade80"/>
        <rect x="40" y="28" width="4" height="4" fill="#4ade80"/>
        <rect x="28" y="34" width="4" height="4" fill="#4ade80"/>
        <rect x="34" y="34" width="4" height="4" fill="#4ade80"/>
        <rect x="28" y="40" width="4" height="4" fill="#4ade80"/>
        <rect x="40" y="40" width="4" height="4" fill="#4ade80"/>
        <rect x="34" y="40" width="4" height="4" fill="#4ade80"/>
        <rect x="40" y="34" width="4" height="4" fill="#4ade80"/>
      </svg>

      <div class="badge-meta">
        <div class="badge-meta-label">ID Credencial</div>
        <div class="badge-meta-value">#<%= "BBY%04d" % @user.id %></div>
        <div class="badge-meta-label" style="margin-top: 4px;">Acesso</div>
        <div class="badge-meta-value">Todos os dias</div>
      </div>
    </div>
  </div>
</div>
