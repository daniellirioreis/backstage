<% cfg = @badge_config || BadgeConfig.defaults %>
<% layout = cfg.layout.presence || "classic" %>
<% chip_label = @is_coordinator ? "Coordenador" : (@function_name.presence || "Colaborador") %>
<%= render "shared/badge_layouts/#{layout}",
    user: @user,
    event: @event,
    team: @team,
    cfg: cfg,
    is_coordinator: @is_coordinator,
    avatar_base64: @avatar_base64,
    credential_code: @credential_code,
    chip_label: chip_label %>
