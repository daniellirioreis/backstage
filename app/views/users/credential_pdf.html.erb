<div class="badge">
    <div class="badge-stripe" style="height:6px;background:<%= @is_coordinator ? '#4ade80' : '#27272a' %>;"></div>

    <div class="badge-header">
      <div class="badge-brand">Backstage</div>
      <div>
        <% if current_event %>
          <div class="badge-event-name"><%= current_event.name %></div>
          <div class="badge-event-date">
            <%= l(current_event.start_date, format: :short) %> a <%= l(current_event.end_date, format: :short) %>
            <% if current_event.location.present? %> &middot; <%= current_event.location %><% end %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="badge-body">
      <div class="badge-photo">
        <% if @avatar_base64 %>
          <img src="<%= @avatar_base64 %>">
        <% else %>
          <span class="badge-photo-initials"><%= @user.name.split.map(&:first).first(2).join.upcase %></span>
        <% end %>
      </div>

      <div class="badge-info">
        <div class="badge-name"><%= @user.name %></div>
        <div class="badge-role-chip" style="background:<%= @is_coordinator ? '#15803d' : '#18181b' %>;">
          <%= @is_coordinator ? "Coordenador" : "Colaborador" %>
        </div>
        <% if @team %>
          <div class="badge-team-info">
            <strong><%= @team.sector.name %></strong> &middot; <%= @team.name %>
          </div>
        <% end %>
        <div class="badge-cpf">
          <%= @user.cpf.gsub(/(\d{3})(\d{3})(\d{3})(\d{2})/, '\1.\2.\3-\4') %>
        </div>
      </div>

      <div class="badge-divider"></div>
    </div>

    <div class="badge-footer">
      <%= badge_qr_svg("BBY%04d" % @user.id, pixel_size: 52) %>
      <div class="badge-meta">
        <div class="badge-meta-label">Acesso</div>
        <div class="badge-meta-value">Todos os dias</div>
      </div>
    </div>
  </div>
</div>
