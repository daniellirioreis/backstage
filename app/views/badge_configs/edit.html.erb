<%# ── Cabeçalho ──────────────────────────────────────────────────────────── %>
<div class="page-header">
  <div style="display: flex; align-items: center; gap: 0.75rem;">
    <%= link_to event_path(@event), class: "btn-secondary", style: "padding: 0.35rem 0.6rem;" do %>
      <i class="bi bi-arrow-left"></i>
    <% end %>
    <div>
      <h1 style="margin: 0; font-size: 1.1rem;"><%= t("badge_config.title") %></h1>
      <div style="font-size: 0.82rem; color: #71717a; margin-top: 0.1rem;">
        <i class="bi bi-calendar3"></i> <%= @event.name %>
      </div>
    </div>
  </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: start;">

  <%# ── Formulário de configuração ──────────────────────────────────────── %>
  <div>
    <%= form_with model: [@event, @badge_config], url: event_badge_config_path(@event), method: :patch do |f| %>

      <%# ── Seletor de layout ──────────────────────────────────── %>
      <div class="content-card" style="padding: 1.5rem; margin-bottom: 1rem;">
        <h2 class="cfg-section" style="margin-bottom: 1rem;">Layout da Credencial</h2>
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.6rem;">
          <% BadgeConfig::LAYOUTS.each do |lyt| %>
            <% active = (@badge_config.layout.presence || "classic") == lyt %>
            <label style="cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:0.35rem;">
              <%= f.radio_button :layout, lyt, style: "display:none;", id: "layout_#{lyt}" %>
              <div style="width:100%;border-radius:8px;border:2px solid <%= active ? '#4ade80' : '#27272a' %>;background:<%= active ? '#052e16' : '#18181b' %>;padding:0.5rem 0.35rem;text-align:center;transition:border-color 0.15s;" class="layout-card" data-layout="<%= lyt %>">
                <div style="font-size:1.2rem;margin-bottom:2px;">
                  <% icons = { "classic" => "bi-credit-card", "onda_hexagono" => "bi-hexagon", "diagonal_losango" => "bi-diamond", "onda_dupla_retangulo" => "bi-square-rounded", "arco_octogono" => "bi-octagon", "tag_cordao" => "bi-tag", "pvc_bold" => "bi-badge-hd", "congresso" => "bi-person-badge", "minimalista" => "bi-card-text", "bold_tipografico" => "bi-type-bold", "dark_premium" => "bi-stars" } %>
                  <i class="bi <%= icons[lyt] || 'bi-credit-card' %>" style="color:<%= active ? '#4ade80' : '#71717a' %>;"></i>
                </div>
                <div style="font-size:0.6rem;font-weight:600;color:<%= active ? '#4ade80' : '#71717a' %>;line-height:1.2;"><%= lyt.gsub("_", " ").capitalize %></div>
              </div>
            </label>
          <% end %>
        </div>
      </div>

      <div class="content-card" style="padding: 1.5rem; display: flex; flex-direction: column; gap: 1.25rem;">

        <%# ── Cabeçalho ── %>
        <h2 class="cfg-section">Cabeçalho</h2>

        <div class="badge-config-field">
          <label>Fundo do cabeçalho e rodapé</label>
          <div class="cfg-color-row">
            <%= f.color_field :header_footer_color, value: @badge_config.header_footer_color, id: "input-header-footer-color", class: "cfg-color-input" %>
            <span id="val-header-footer-color" class="cfg-hex"><%= @badge_config.header_footer_color %></span>
          </div>
        </div>

        <div class="badge-config-field">
          <label>Nome do evento</label>
          <div class="cfg-row">
            <div class="cfg-slider-wrap">
              <%= f.range_field :event_name_font_size, min: 6, max: 20, step: 1 %>
              <span class="range-val" id="val-event-name-size"><%= @badge_config.event_name_font_size %>px</span>
            </div>
            <div class="cfg-color-row">
              <%= f.color_field :event_name_color, value: @badge_config.event_name_color, id: "input-event-name-color", class: "cfg-color-input" %>
              <span id="val-event-name-color" class="cfg-hex"><%= @badge_config.event_name_color %></span>
            </div>
          </div>
        </div>

        <div class="badge-config-field">
          <label>Data / local <span class="cfg-hint">(mesma cor do nome do evento)</span></label>
          <div class="cfg-slider-wrap">
            <%= f.range_field :event_date_font_size, min: 4, max: 14, step: 1 %>
            <span class="range-val" id="val-event-date-size"><%= @badge_config.event_date_font_size %>px</span>
          </div>
        </div>

        <%# ── Corpo ── %>
        <h2 class="cfg-section" style="border-top: 1px solid #f4f4f5; padding-top: 1rem;">Corpo</h2>

        <div class="badge-config-field">
          <label>Fundo da credencial</label>
          <div class="cfg-color-row">
            <%= f.color_field :body_color, value: @badge_config.body_color, id: "input-body-color", class: "cfg-color-input" %>
            <span id="val-body-color" class="cfg-hex"><%= @badge_config.body_color %></span>
          </div>
        </div>

        <div class="badge-config-field">
          <label>Foto</label>
          <div class="cfg-slider-wrap">
            <%= f.range_field :photo_size, min: 40, max: 160, step: 1, data: { target: "photo_size" } %>
            <span class="range-val" id="val-photo-size"><%= @badge_config.photo_size %>px</span>
          </div>
        </div>

        <div class="badge-config-field">
          <label>Nome do colaborador</label>
          <div class="cfg-row">
            <div class="cfg-slider-wrap">
              <%= f.range_field :name_font_size, min: 10, max: 36, step: 1 %>
              <span class="range-val" id="val-name-size"><%= @badge_config.name_font_size %>px</span>
            </div>
            <div class="cfg-color-row">
              <%= f.color_field :name_color, value: @badge_config.name_color, id: "input-name-color", class: "cfg-color-input" %>
              <span id="val-name-color" class="cfg-hex"><%= @badge_config.name_color %></span>
            </div>
          </div>
        </div>

        <div class="badge-config-field">
          <label>Cargo</label>
          <div class="cfg-slider-wrap">
            <%= f.range_field :role_chip_font_size, min: 6, max: 20, step: 1 %>
            <span class="range-val" id="val-chip-size"><%= @badge_config.role_chip_font_size %>px</span>
          </div>
        </div>

        <div class="badge-config-field">
          <label>Equipe / setor</label>
          <div class="cfg-row">
            <div class="cfg-slider-wrap">
              <%= f.range_field :team_info_font_size, min: 6, max: 20, step: 1 %>
              <span class="range-val" id="val-team-size"><%= @badge_config.team_info_font_size %>px</span>
            </div>
            <div class="cfg-color-row">
              <%= f.color_field :team_info_color, value: @badge_config.team_info_color, id: "input-team-info-color", class: "cfg-color-input" %>
              <span id="val-team-info-color" class="cfg-hex"><%= @badge_config.team_info_color %></span>
            </div>
          </div>
        </div>

        <%# ── Rodapé ── %>
        <h2 class="cfg-section" style="border-top: 1px solid #f4f4f5; padding-top: 1rem;">Código da Credencial</h2>

        <div class="badge-config-field">
          <label>Fonte do código</label>
          <div class="cfg-row">
            <div class="cfg-slider-wrap">
              <%= f.range_field :credential_code_font_size, min: 5, max: 14, step: 1 %>
              <span class="range-val" id="val-credential-code-size"><%= @badge_config.credential_code_font_size %>px</span>
            </div>
            <div class="cfg-color-row">
              <%= f.color_field :credential_code_color, value: @badge_config.credential_code_color, id: "input-credential-code-color", class: "cfg-color-input" %>
              <span id="val-credential-code-color" class="cfg-hex"><%= @badge_config.credential_code_color %></span>
            </div>
          </div>
        </div>

      </div>

      <div style="margin-top: 1rem; display: flex; justify-content: flex-end;">
        <%= f.submit "Salvar configuração", class: "btn-primary" %>
      </div>

    <% end %>
  </div>

  <%# ── Prévia ao vivo ───────────────────────────────────────────────────── %>
  <div style="position: sticky; top: 1.5rem;">
    <div style="font-size: 0.82rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #71717a; margin-bottom: 0.75rem;">
      <i class="bi bi-eye"></i> Prévia
    </div>

    <div style="background: #e4e4e7; border-radius: 12px; padding: 2rem; display: flex; justify-content: center;">
      <%# zoom afeta o layout real — sem gap na parte inferior %>
      <div style="border-radius: 10px; box-shadow: 0 4px 20px rgba(0,0,0,0.3); overflow: hidden; flex-shrink: 0;">
        <div id="badge-preview-wrapper" style="width: 260px; zoom: 0.923; display: block;">
          <%= render "shared/badge_layouts/#{@badge_config.layout.presence || 'classic'}",
              user: current_user,
              event: @event,
              team: nil,
              cfg: @badge_config,
              is_coordinator: false,
              avatar_base64: nil,
              credential_code: "PREV-2026",
              chip_label: "Colaborador" %>
        </div>
      </div>
    </div>
  </div>

</div>

<style>
  .badge-config-field { display: flex; flex-direction: column; gap: 0.4rem; }
  .badge-config-field label { font-size: 0.82rem; font-weight: 600; color: #3f3f46; }
  .cfg-section { font-size: 0.9rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #71717a; margin: 0; }
  .cfg-hint { font-size: 0.72rem; font-weight: 400; color: #a1a1aa; text-transform: none; letter-spacing: 0; }
  .cfg-row { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
  .cfg-slider-wrap { display: flex; align-items: center; gap: 0.5rem; flex: 1; min-width: 0; }
  .cfg-slider-wrap input[type=range] { flex: 1; min-width: 0; }
  .cfg-color-row { display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; }
  .cfg-color-input { width: 36px; height: 30px; border: none; border-radius: 6px; cursor: pointer; padding: 2px; }
  .cfg-hex { font-size: 0.78rem; font-weight: 600; color: #18181b; font-family: monospace; }
  .range-val { font-size: 0.82rem; font-weight: 600; color: #18181b; min-width: 34px; text-align: right; flex-shrink: 0; }
</style>

<script>
  document.addEventListener("turbo:load", function () {
    const previewBaseUrl = "<%= preview_event_badge_config_path(@event) %>";
    const wrapper = document.getElementById("badge-preview-wrapper");
    let currentLayout = "<%= @badge_config.layout.presence || 'classic' %>";
    let debounceTimer = null;

    // ── Collect current form values for live preview ──────────
    function getFormParams() {
      const map = [
        ["event_name_color",          "badge_config[event_name_color]"],
        ["header_footer_color",       "badge_config[header_footer_color]"],
        ["body_color",                "badge_config[body_color]"],
        ["name_color",                "badge_config[name_color]"],
        ["team_info_color",           "badge_config[team_info_color]"],
        ["credential_code_color",     "badge_config[credential_code_color]"],
        ["photo_size",                "badge_config[photo_size]"],
        ["name_font_size",            "badge_config[name_font_size]"],
        ["role_chip_font_size",       "badge_config[role_chip_font_size]"],
        ["team_info_font_size",       "badge_config[team_info_font_size]"],
        ["event_name_font_size",      "badge_config[event_name_font_size]"],
        ["event_date_font_size",      "badge_config[event_date_font_size]"],
        ["credential_code_font_size", "badge_config[credential_code_font_size]"],
      ];
      const p = new URLSearchParams();
      map.forEach(([key, name]) => {
        const el = document.querySelector(`[name="${name}"]`);
        if (el) p.set(key, el.value);
      });
      return p;
    }

    // ── Fetch and inject preview HTML ─────────────────────────
    function fetchPreview(layout) {
      currentLayout = layout;
      if (!wrapper) return;
      const params = getFormParams();
      params.set("layout", layout);
      wrapper.style.opacity = "0.45";
      wrapper.style.transition = "opacity 0.12s";
      fetch(previewBaseUrl + "?" + params.toString(), {
        headers: { "Accept": "text/html", "X-Requested-With": "XMLHttpRequest" }
      })
        .then(r => r.text())
        .then(html => {
          wrapper.innerHTML = html;
          wrapper.style.opacity = "1";
        })
        .catch(() => { wrapper.style.opacity = "1"; });
    }

    function debouncedPreview() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => fetchPreview(currentLayout), 380);
    }

    // ── Layout card selector ──────────────────────────────────
    document.querySelectorAll(".layout-card").forEach(function (card) {
      card.closest("label").addEventListener("click", function () {
        const lyt = card.dataset.layout;
        document.querySelectorAll(".layout-card").forEach(function (c) {
          const active = c.dataset.layout === lyt;
          c.style.borderColor = active ? "#4ade80" : "#27272a";
          c.style.background  = active ? "#052e16" : "#18181b";
          const icon  = c.querySelector("i");
          const label = c.querySelector("div:last-child");
          if (icon)  icon.style.color  = active ? "#4ade80" : "#71717a";
          if (label) label.style.color = active ? "#4ade80" : "#71717a";
        });
        fetchPreview(lyt);
      });
    });

    // ── Sliders — update display value + debounced preview ────
    [
      ["badge_config[photo_size]",                "val-photo-size"           ],
      ["badge_config[event_name_font_size]",      "val-event-name-size"      ],
      ["badge_config[event_date_font_size]",      "val-event-date-size"      ],
      ["badge_config[name_font_size]",            "val-name-size"            ],
      ["badge_config[role_chip_font_size]",       "val-chip-size"            ],
      ["badge_config[team_info_font_size]",       "val-team-size"            ],
      ["badge_config[credential_code_font_size]", "val-credential-code-size" ],
    ].forEach(([name, valId]) => {
      const input = document.querySelector(`input[name="${name}"]`);
      const valEl = document.getElementById(valId);
      if (!input) return;
      input.addEventListener("input", () => {
        if (valEl) valEl.textContent = input.value + "px";
        debouncedPreview();
      });
    });

    // ── Color pickers — update hex display + debounced preview ─
    [
      ["input-event-name-color",      "val-event-name-color"      ],
      ["input-header-footer-color",   "val-header-footer-color"   ],
      ["input-body-color",            "val-body-color"            ],
      ["input-name-color",            "val-name-color"            ],
      ["input-team-info-color",       "val-team-info-color"       ],
      ["input-credential-code-color", "val-credential-code-color" ],
    ].forEach(([id, valId]) => {
      const input = document.getElementById(id);
      const valEl = document.getElementById(valId);
      if (!input) return;
      input.addEventListener("input", () => {
        if (valEl) valEl.textContent = input.value;
        debouncedPreview();
      });
    });
  });
</script>
