<div class="page-header">
  <h1><%= Vehicle.model_name.human(count: 2) %></h1>
  <% if policy(Vehicle).new? %>
    <%= link_to new_vehicle_path, class: "btn-primary" do %>
      <i class="bi bi-plus"></i> <%= t("actions.new", model: Vehicle.model_name.human) %>
    <% end %>
  <% end %>
</div>

<table class="data-table">
  <thead>
    <tr>
      <th><%= Vehicle.human_attribute_name(:license_plate) %></th>
      <th><%= Vehicle.human_attribute_name(:model) %></th>
      <th><%= Vehicle.human_attribute_name(:color) %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @vehicles.each do |vehicle| %>
      <tr>
        <td style="font-family: monospace; font-weight: 600; letter-spacing: 0.05em;"><%= vehicle.license_plate.upcase %></td>
        <td><%= vehicle.model %></td>
        <td style="color: #71717a;"><%= vehicle.color %></td>
        <td class="td-actions">
          <% if policy(vehicle).edit? %>
            <%= link_to edit_vehicle_path(vehicle), class: "btn-secondary" do %><i class="bi bi-pencil"></i><% end %>
          <% end %>
          <% if policy(vehicle).destroy? %>
            <%= button_to vehicle_path(vehicle), method: :delete,
                form: { data: { turbo_confirm: t("confirms.delete") } },
                class: "btn-danger" do %><i class="bi bi-trash"></i><% end %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
