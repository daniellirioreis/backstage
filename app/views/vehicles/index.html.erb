<div class="d-flex justify-content-between align-items-center mb-3">
  <h1><%= Vehicle.model_name.human(count: 2) %></h1>
  <% if policy(Vehicle).new? %>
    <%= link_to t("actions.new", model: Vehicle.model_name.human), new_vehicle_path, class: "btn btn-primary" %>
  <% end %>
</div>

<table class="table table-hover">
  <thead class="table-dark">
    <tr>
      <th><%= Vehicle.human_attribute_name(:license_plate) %></th>
      <th><%= Vehicle.human_attribute_name(:model) %></th>
      <th><%= Vehicle.human_attribute_name(:color) %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @vehicles.each do |vehicle| %>
      <tr>
        <td><strong><%= vehicle.license_plate %></strong></td>
        <td><%= vehicle.model %></td>
        <td><%= vehicle.color %></td>
        <td class="text-end">
          <% if policy(vehicle).edit? %>
            <%= link_to t("actions.edit"), edit_vehicle_path(vehicle), class: "btn btn-sm btn-outline-secondary" %>
          <% end %>
          <% if policy(vehicle).destroy? %>
            <%= button_to t("actions.delete"), vehicle_path(vehicle), method: :delete,
                form: { data: { turbo_confirm: t("confirms.delete") } },
                class: "btn btn-sm btn-outline-danger" %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
