<div class="page-header">
  <h1><%= Vehicle.model_name.human(count: 2) %></h1>
  <% if policy(Vehicle).new? %>
    <%= link_to new_vehicle_path, class: "btn-primary" do %>
      <i class="bi bi-plus"></i> <%= t("actions.new", model: Vehicle.model_name.human) %>
    <% end %>
  <% end %>
</div>

<%= form_with url: vehicles_path, method: :get, local: true do %>
  <div class="content-card" style="margin-bottom:0.75rem; padding:0.6rem 1rem; display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
    <i class="bi bi-search" style="color:#a1a1aa; font-size:0.9rem; flex-shrink:0;"></i>
    <input type="text" name="plate" value="<%= @q_plate %>" placeholder="Placa..." autocomplete="off"
           style="width:110px; flex-shrink:0; border:1px solid #e4e4e7; border-radius:6px; padding:0.3rem 0.6rem; font-size:0.83rem; font-family:monospace; outline:none; text-transform:uppercase;">
    <input type="text" name="model" value="<%= @q_model %>" placeholder="Modelo..." autocomplete="off"
           style="width:140px; flex-shrink:0; border:1px solid #e4e4e7; border-radius:6px; padding:0.3rem 0.6rem; font-size:0.83rem; outline:none;">
    <input type="text" name="color" value="<%= @q_color %>" placeholder="Cor..." autocomplete="off"
           style="width:110px; flex-shrink:0; border:1px solid #e4e4e7; border-radius:6px; padding:0.3rem 0.6rem; font-size:0.83rem; outline:none;">
    <button type="submit" class="btn-primary" style="padding:0.3rem 0.8rem; font-size:0.8rem;">Filtrar</button>
    <% if @q_plate.present? || @q_model.present? || @q_color.present? %>
      <%= link_to "× Limpar", vehicles_path, style:"font-size:0.8rem; color:#a1a1aa; text-decoration:none;" %>
    <% end %>
  </div>
<% end %>

<table class="data-table">
  <thead>
    <tr>
      <th><%= Vehicle.human_attribute_name(:license_plate) %></th>
      <th><%= Vehicle.human_attribute_name(:model) %></th>
      <th><%= Vehicle.human_attribute_name(:color) %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @vehicles.each do |vehicle| %>
      <tr>
        <td style="font-family: monospace; font-weight: 600; letter-spacing: 0.05em;"><%= vehicle.license_plate.upcase %></td>
        <td><%= vehicle.model %></td>
        <td style="color: #71717a;"><%= vehicle.color %></td>
        <td class="td-actions">
          <% if policy(vehicle).edit? %>
            <%= link_to edit_vehicle_path(vehicle), class: "btn-secondary" do %><i class="bi bi-pencil"></i><% end %>
          <% end %>
          <% if policy(vehicle).destroy? %>
            <%= button_to vehicle_path(vehicle), method: :delete,
                form: { data: { turbo_confirm: t("confirms.delete") } },
                class: "btn-danger" do %><i class="bi bi-trash"></i><% end %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @vehicles.total_pages > 1 %>
  <div style="display:flex; justify-content:center; align-items:center; gap:0.4rem; margin-top:1.5rem;">
    <%= will_paginate @vehicles,
        previous_label: "‹ Anterior",
        next_label:     "Próximo ›",
        inner_window:   2,
        outer_window:   1,
        renderer:       "BackstagePaginationRenderer" %>
  </div>
<% end %>
