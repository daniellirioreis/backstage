<%= form_with model: vehicle, class: "mt-3" do |f| %>
  <%= render "shared/error_messages", object: vehicle %>

  <div class="row g-3 mb-4">
    <div class="col-md-5">
      <%= f.label :model, Vehicle.human_attribute_name(:model), class: "form-label" %>
      <%= f.text_field :model, class: "form-control" %>
    </div>
    <div class="col-md-4">
      <%= f.label :color, Vehicle.human_attribute_name(:color), class: "form-label" %>
      <%= f.text_field :color, class: "form-control" %>
    </div>
    <div class="col-md-3">
      <%= f.label :license_plate, Vehicle.human_attribute_name(:license_plate), class: "form-label" %>
      <%= f.text_field :license_plate, class: "form-control text-uppercase" %>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit t("actions.save"), class: "btn btn-primary" %>
    <%= link_to t("actions.cancel"), vehicles_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
