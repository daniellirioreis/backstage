<div class="page-header">
  <h1><%= t("folha_escala.title") %> &mdash; <%= @event.name %></h1>
</div>

<div class="content-card" style="max-width: 560px;">

  <div class="mb-3">
    <label class="form-label"><%= t("folha_escala.filter.date") %></label>
    <select id="fe_date" class="form-select" onchange="atualizarLink()">
      <option value=""><%= t("folha_escala.filter.all_dates") %></option>
      <% @available_dates.each do |d| %>
        <option value="<%= d %>"><%= l(d, format: :long) %></option>
      <% end %>
    </select>
  </div>

  <div class="mb-3">
    <label class="form-label"><%= t("folha_escala.filter.sector") %></label>
    <select id="fe_sector_id" class="form-select" onchange="filtrarEquipes(); atualizarLink()">
      <option value=""><%= t("folha_escala.filter.all_sectors") %></option>
      <% @sectors.each do |s| %>
        <option value="<%= s.id %>"><%= s.name %></option>
      <% end %>
    </select>
  </div>

  <div class="mb-4">
    <label class="form-label"><%= t("folha_escala.filter.team") %></label>
    <select id="fe_team_id" class="form-select" onchange="atualizarLink()">
      <option value=""><%= t("folha_escala.filter.all_teams") %></option>
      <% @sectors.each do |s| %>
        <% s.teams.order(:name).each do |tm| %>
          <option value="<%= tm.id %>" data-sector="<%= s.id %>"><%= tm.name %></option>
        <% end %>
      <% end %>
    </select>
  </div>

  <div class="d-flex gap-2">
    <a id="fe-pdf-link"
       href="<%= folha_escala_event_path(@event, format: :pdf) %>"
       target="_blank"
       data-turbo="false"
       class="btn-primary">
      <i class="bi bi-file-earmark-pdf"></i>
      <%= t("folha_escala.filter.generate") %>
    </a>
    <%= link_to event_path(@event), class: "btn-secondary" do %>
      <%= t("actions.cancel") %>
    <% end %>
  </div>

</div>

<script>
  var feBase = "<%= folha_escala_event_path(@event, format: :pdf) %>";

  function filtrarEquipes() {
    var sectorId = document.getElementById("fe_sector_id").value;
    var teamSelect = document.getElementById("fe_team_id");
    var options = teamSelect.querySelectorAll("option[data-sector]");

    // reset
    teamSelect.value = "";

    options.forEach(function(opt) {
      if (!sectorId || opt.dataset.sector === sectorId) {
        opt.style.display = "";
      } else {
        opt.style.display = "none";
        if (opt.selected) opt.selected = false;
      }
    });
  }

  function atualizarLink() {
    var params = new URLSearchParams();
    var sector = document.getElementById("fe_sector_id").value;
    var date   = document.getElementById("fe_date").value;
    var team   = document.getElementById("fe_team_id").value;
    if (sector) params.append("sector_id", sector);
    if (date)   params.append("date",      date);
    if (team)   params.append("team_id",   team);
    var query = params.toString();
    document.getElementById("fe-pdf-link").href = feBase + (query ? "?" + query : "");
  }
</script>
