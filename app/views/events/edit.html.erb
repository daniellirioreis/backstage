<div class="page-header">
  <h1>Editar evento</h1>
  <p style="color:#71717a;margin-top:0.3rem;font-size:0.88rem;">
    <strong><%= @event.name %></strong>
    <% if @event.event_type.present? %>
      &middot; <%= I18n.t("event_types.#{@event.event_type}", default: @event.event_type.humanize) %>
    <% end %>
    &middot; <%= @event.start_date&.strftime("%d/%m/%Y") %>
    <% if @event.end_date && @event.end_date != @event.start_date %>
      – <%= @event.end_date.strftime("%d/%m/%Y") %>
    <% end %>
  </p>
</div>

<%= render "events/setup/wizard_nav", current_step: 1, event: @event %>

<%= render "form", event: @event %>
