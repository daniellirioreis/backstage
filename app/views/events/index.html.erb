<div class="page-header">
  <h1><%= Event.model_name.human(count: 2) %></h1>
  <% if policy(Event).new? %>
    <%= link_to new_event_path, class: "btn-primary" do %>
      <i class="bi bi-plus"></i> <%= t("actions.new", model: Event.model_name.human) %>
    <% end %>
  <% end %>
</div>

<% if @events.empty? %>
  <div class="content-card" style="text-align: center; padding: 3rem; color: #a1a1aa;">
    <i class="bi bi-calendar-event" style="font-size: 2.5rem; display: block; margin-bottom: 0.75rem;"></i>
    <p style="margin: 0; font-size: 0.9rem;">Nenhum evento cadastrado ainda.</p>
  </div>
<% else %>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem;">
    <% @events.each do |event| %>
      <div class="content-card" style="padding: 0; overflow: hidden; display: flex; flex-direction: column;">

        <%# Faixa de status colorida %>
        <div style="height: 4px; background: <%= event.active? ? '#4ade80' : event.draft? ? '#d4d4d8' : '#27272a' %>;"></div>

        <div style="padding: 1.25rem; display: flex; flex-direction: column; gap: 1rem; flex: 1;">

          <%# Nome e badge %>
          <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem;">
            <h3 style="font-size: 0.95rem; font-weight: 600; color: #18181b; margin: 0; line-height: 1.35;">
              <%= event.name %>
            </h3>
            <span class="badge-status badge-<%= event.status %>" style="flex-shrink: 0;">
              <%= t("event_statuses.#{event.status}") %>
            </span>
          </div>

          <%# Empresa %>
          <% if event.company.present? %>
            <div style="display: flex; align-items: center; gap: 0.45rem; color: #52525b; font-size: 0.82rem; font-weight: 600;">
              <i class="bi bi-building" style="opacity:0.6;"></i>
              <span>Produzido por: <%= event.company.name %></span>
            </div>
          <% end %>

          <%# Local %>
          <% if event.location.present? %>
            <div style="display: flex; align-items: center; gap: 0.45rem; color: #71717a; font-size: 0.82rem;">
              <i class="bi bi-geo-alt"></i>
              <span><%= event.location %></span>
            </div>
          <% end %>

          <%# Datas %>
          <div style="display: flex; align-items: center; gap: 0.45rem; color: #71717a; font-size: 0.82rem;">
            <i class="bi bi-calendar3"></i>
            <span><%= l(event.start_date, format: :short) %> → <%= l(event.end_date, format: :short) %></span>
          </div>

          <%# Setores e equipes %>
          <% total_teams = event.sectors.sum { |s| s.teams.size } %>
          <div style="display: flex; gap: 1rem;">
            <div style="display: flex; align-items: center; gap: 0.45rem; color: #71717a; font-size: 0.82rem;">
              <i class="bi bi-grid-3x3-gap"></i>
              <span><%= event.sectors.size %> <%= event.sectors.size == 1 ? "setor" : "setores" %></span>
            </div>
            <div style="display: flex; align-items: center; gap: 0.45rem; color: #71717a; font-size: 0.82rem;">
              <i class="bi bi-people"></i>
              <span><%= total_teams %> <%= total_teams == 1 ? "equipe" : "equipes" %></span>
            </div>
          </div>

          <%# Ações %>
          <div style="display: flex; gap: 0.5rem; border-top: 1px solid #f4f4f5; padding-top: 1rem; margin-top: auto;">
            <% if policy(event).show? %>
              <%= link_to event_path(event), class: "btn-secondary", style: "flex: 1; justify-content: center;" do %>
                <i class="bi bi-eye"></i> Visualizar
              <% end %>
            <% end %>
            <% if policy(event).edit? %>
              <%= link_to edit_event_path(event), class: "btn-secondary", style: "padding: 0.4rem 0.7rem;" do %>
                <i class="bi bi-pencil"></i>
              <% end %>
            <% end %>
            <% if policy(event).destroy? %>
              <%= button_to event_path(event), method: :delete,
                  form: { data: { turbo_confirm: t("confirms.delete") } },
                  class: "btn-danger", style: "padding: 0.4rem 0.7rem;" do %>
                <i class="bi bi-trash"></i>
              <% end %>
            <% end %>
          </div>

        </div>
      </div>
    <% end %>
  </div>
<% end %>
