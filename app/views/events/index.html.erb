<div class="page-header">
  <h1><%= Event.model_name.human(count: 2) %></h1>
  <% if policy(Event).new? %>
    <%= link_to new_event_path, class: "btn-primary" do %>
      <i class="bi bi-plus"></i> <%= t("actions.new", model: Event.model_name.human) %>
    <% end %>
  <% end %>
</div>

<table class="data-table">
  <thead>
    <tr>
      <th><%= Event.human_attribute_name(:name) %></th>
      <th><%= Event.human_attribute_name(:location) %></th>
      <th><%= Event.human_attribute_name(:start_date) %></th>
      <th><%= Event.human_attribute_name(:end_date) %></th>
      <th><%= Event.human_attribute_name(:status) %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @events.each do |event| %>
      <tr>
        <td><%= link_to event.name, event_path(event), style: "color: #18181b; font-weight: 500; text-decoration: none;" %></td>
        <td style="color: #71717a;"><%= event.location %></td>
        <td style="color: #71717a;"><%= l(event.start_date, format: :short) %></td>
        <td style="color: #71717a;"><%= l(event.end_date, format: :short) %></td>
        <td><span class="badge-status badge-<%= event.status %>"><%= t("event_statuses.#{event.status}") %></span></td>
        <td class="td-actions">
          <% if policy(event).edit? %>
            <%= link_to edit_event_path(event), class: "btn-secondary" do %><i class="bi bi-pencil"></i><% end %>
          <% end %>
          <% if policy(event).destroy? %>
            <%= button_to event_path(event), method: :delete,
                form: { data: { turbo_confirm: t("confirms.delete") } },
                class: "btn-danger" do %><i class="bi bi-trash"></i><% end %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
