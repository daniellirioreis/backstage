<div class="d-flex justify-content-between align-items-center mb-3">
  <h1><%= @event.name %></h1>
  <div class="d-flex gap-2">
    <% if policy(@event).edit? %>
      <%= link_to t("actions.edit"), edit_event_path(@event), class: "btn btn-outline-secondary" %>
    <% end %>
    <%= link_to t("actions.cancel"), events_path, class: "btn btn-outline-secondary" %>
  </div>
</div>

<dl class="row mb-4">
  <dt class="col-sm-3"><%= Event.human_attribute_name(:location) %></dt>
  <dd class="col-sm-9"><%= @event.location %></dd>
  <dt class="col-sm-3"><%= Event.human_attribute_name(:start_date) %></dt>
  <dd class="col-sm-9"><%= l(@event.start_date, format: :long) %></dd>
  <dt class="col-sm-3"><%= Event.human_attribute_name(:end_date) %></dt>
  <dd class="col-sm-9"><%= l(@event.end_date, format: :long) %></dd>
  <dt class="col-sm-3"><%= Event.human_attribute_name(:status) %></dt>
  <dd class="col-sm-9"><span class="badge <%= event_status_badge(@event) %>"><%= t("event_statuses.#{@event.status}") %></span></dd>
</dl>

<div class="d-flex justify-content-between align-items-center mb-2">
  <h2 class="h5"><%= Team.model_name.human(count: 2) %></h2>
  <% if policy(Team).new? %>
    <%= link_to t("actions.new", model: Team.model_name.human), new_team_path(event_id: @event.id), class: "btn btn-sm btn-primary" %>
  <% end %>
</div>
<ul class="list-group">
  <% @teams.each do |team| %>
    <li class="list-group-item d-flex justify-content-between align-items-center">
      <%= link_to team.name, team_path(team) %>
      <span class="badge bg-secondary"><%= team.sectors.size %> <%= Sector.model_name.human(count: team.sectors.size) %></span>
    </li>
  <% end %>
</ul>
