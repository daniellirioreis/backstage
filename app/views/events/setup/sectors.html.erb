<div class="page-header">
  <h1>Configurar Setores</h1>
  <p style="color:#71717a;margin-top:0.3rem;font-size:0.88rem;">
    <strong><%= @event.name %></strong> &middot; Organize as áreas de trabalho do evento
  </p>
</div>

<%= render "wizard_nav", current_step: 2, event: @event %>

<%# ── Setores já criados ──────────────────────────────────────────────────── %>
<% if @sectors.any? %>
  <div class="content-card" style="margin-bottom:1rem;">
    <div style="font-size:0.82rem;font-weight:700;color:#52525b;margin-bottom:0.65rem;">
      <i class="bi bi-check-circle" style="color:#16a34a;"></i>
      Setores adicionados (<%= @sectors.count %>)
    </div>
    <div style="display:flex;flex-wrap:wrap;gap:0.4rem;">
      <% @sectors.each do |s| %>
        <span style="display:inline-flex;align-items:center;gap:0.35rem;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:20px;padding:3px 10px;font-size:0.78rem;color:#166534;">
          <i class="bi bi-building" style="font-size:0.72rem;"></i>
          <%= s.name %>
          <% if s.sector_type.present? %>
            <span style="color:#6b7280;">&middot; <%= s.sector_type_label %></span>
          <% end %>
        </span>
      <% end %>
    </div>
  </div>
<% end %>

<%# ── Formulário ──────────────────────────────────────────────────────────── %>
<div class="content-card">
  <div style="font-size:0.88rem;font-weight:700;color:#18181b;margin-bottom:0.2rem;">
    <i class="bi bi-plus-circle"></i>
    <%= @sectors.any? ? "Adicionar mais setores" : "Adicionar setores" %>
  </div>
  <p style="font-size:0.78rem;color:#71717a;margin-bottom:1.1rem;">
    Cada setor agrupa equipes de um mesmo tipo de trabalho (ex: Segurança, Som, Palco).
  </p>

  <% if @event_functions.none? %>
    <div style="background:#fefce8;border:1px solid #fef08a;border-radius:8px;padding:0.65rem 0.9rem;font-size:0.78rem;color:#713f12;margin-bottom:1rem;">
      <i class="bi bi-info-circle"></i>
      Nenhuma função definida neste evento. Para alocar funções por setor,
      <%= link_to "edite o evento", edit_event_path(@event), style: "color:#92400e;font-weight:600;" %>
      e adicione as funções e valores antes.
    </div>
  <% end %>

  <%= form_with url: sectors_event_setup_path(@event), method: :post, local: true do |f| %>
    <div id="sector-rows">
      <%# 3 linhas iniciais com índice explícito %>
      <% 3.times do |i| %>
        <%= render "sector_row", idx: i, event_functions: @event_functions %>
      <% end %>
    </div>

    <%# Template para JS (ERB renderiza @event_functions aqui) %>
    <template id="sector-row-template">
      <%= render "sector_row", idx: "__SECTOR_IDX__", event_functions: @event_functions %>
    </template>

    <button type="button" onclick="addSectorRow()" class="btn-secondary"
            style="font-size:0.82rem;margin-top:0.5rem;margin-bottom:1.5rem;">
      <i class="bi bi-plus"></i> Adicionar linha
    </button>

    <div style="display:flex;align-items:center;justify-content:space-between;
                border-top:1px solid #f4f4f5;padding-top:1.25rem;gap:1rem;">
      <%= link_to teams_event_setup_path(@event),
            style: "font-size:0.82rem;color:#71717a;text-decoration:none;" do %>
        Pular esta etapa <i class="bi bi-arrow-right"></i>
      <% end %>
      <div style="display:flex;gap:0.6rem;">
        <%= link_to "Cancelar", event_path(@event), class: "btn-secondary" %>
        <%= f.submit "Próximo: Equipes →", class: "btn-primary" %>
      </div>
    </div>
  <% end %>
</div>

<script>
(function () {
  var sectorIdx = <%= Time.now.to_i %>;

  window.addSectorRow = function () {
    var tpl  = document.getElementById("sector-row-template").content.cloneNode(true);
    var row  = tpl.querySelector(".sector-row");
    var idx  = sectorIdx++;
    row.innerHTML = row.innerHTML.replace(/__SECTOR_IDX__/g, idx);
    document.getElementById("sector-rows").appendChild(row);
    document.getElementById("sector-rows").lastElementChild
      .querySelector("input[type=text]").focus();
  };

  window.removeSectorRow = function (btn) {
    var rows = document.querySelectorAll("#sector-rows .sector-row");
    if (rows.length <= 1) {
      var row = btn.closest(".sector-row");
      row.querySelector("input[type=text]").value = "";
      row.querySelector("select").value = "";
      return;
    }
    btn.closest(".sector-row").remove();
  };
})();
</script>
