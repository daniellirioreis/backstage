<%# Locals: current_step (integer 1..3), event %>
<% steps = [
  { n: 1, label: "Dados do evento" },
  { n: 2, label: "Setores" },
  { n: 3, label: "Equipes" }
] %>
<div style="display:flex;align-items:center;gap:0;margin-bottom:1.75rem;background:#f9f9fb;border:1px solid #e4e4e7;border-radius:12px;padding:1rem 1.5rem;">
  <% steps.each_with_index do |step, i| %>
    <%
      done    = step[:n] < current_step
      active  = step[:n] == current_step
      pending = step[:n] > current_step
    %>
    <div style="display:flex;align-items:center;gap:0.6rem;flex:1;">
      <%# Step circle %>
      <div style="
        width:28px;height:28px;border-radius:50%;flex-shrink:0;
        display:flex;align-items:center;justify-content:center;font-size:0.78rem;font-weight:700;
        <%= done    ? 'background:#16a34a;color:white;'         : '' %>
        <%= active  ? 'background:#18181b;color:white;'         : '' %>
        <%= pending ? 'background:#e4e4e7;color:#a1a1aa;'       : '' %>
      ">
        <%= done ? raw('<i class="bi bi-check" style="font-size:0.9rem;"></i>') : step[:n] %>
      </div>
      <%# Step label %>
      <span style="
        font-size:0.82rem;font-weight:<%= active ? '700' : '500' %>;
        color:<%= done ? '#16a34a' : active ? '#18181b' : '#a1a1aa' %>;
        white-space:nowrap;
      "><%= step[:label] %></span>
    </div>
    <%# Arrow separator %>
    <% unless i == steps.length - 1 %>
      <div style="flex-shrink:0;padding:0 0.5rem;color:#d4d4d8;font-size:0.75rem;">
        <i class="bi bi-chevron-right"></i>
      </div>
    <% end %>
  <% end %>
</div>
