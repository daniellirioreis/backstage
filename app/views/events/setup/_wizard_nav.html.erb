<% if guide %>
  <div style="background:<%= guide[:bg] %>;border:1px solid <%= guide[:border] %>;border-radius:12px;padding:0.85rem 1.1rem;margin-bottom:1.75rem;display:flex;align-items:center;gap:1rem;">
    <div style="flex:1;min-width:0;">
      <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.65rem;">
        <i class="bi <%= guide[:icon] %>" style="color:<%= guide[:color] %>;font-size:1rem;"></i>
        <span style="font-size:0.82rem;font-weight:700;color:<%= guide[:color] %>;"><%= guide[:title] %></span>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:0.45rem;">
        <% guide[:items].each do |item| %>
          <div style="display:flex;align-items:flex-start;gap:0.5rem;font-size:0.75rem;color:#374151;line-height:1.5;">
            <i class="bi <%= item[:icon] %>" style="color:<%= guide[:color] %>;margin-top:2px;flex-shrink:0;"></i>
            <span><%= raw(item[:text]) %></span>
          </div>
        <% end %>
      </div>
    </div>
    <div style="flex-shrink:0;opacity:0.9;">
      <%= raw(guide[:svg]) %>
    </div>
  </div>
<% end %>
