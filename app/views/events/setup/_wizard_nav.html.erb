<%# Locals: current_step (1..4), event %>
<% edit_mode = event&.persisted? %>
<% step_paths = edit_mode ? [
  edit_event_path(event),
  sectors_event_setup_path(event),
  teams_event_setup_path(event),
  schedules_event_setup_path(event)
] : [nil, nil, nil, nil] %>
<% steps = [
  { n: 1, label: "Dados do evento" },
  { n: 2, label: "Setores" },
  { n: 3, label: "Equipes" },
  { n: 4, label: "Escalas" }
] %>

<div style="display:flex;align-items:center;background:#f9f9fb;border:1px solid #e4e4e7;border-radius:12px;padding:14px 20px;margin-bottom:1.75rem;">
  <% steps.each_with_index do |step, i| %>
    <% done    = step[:n] < current_step %>
    <% active  = step[:n] == current_step %>
    <% pending = step[:n] > current_step %>
    <% path    = step_paths[i] %>
    <% clickable = edit_mode && !active && path.present? %>

    <div style="display:flex;align-items:center;gap:0.6rem;flex:1;">
      <%# Circle %>
      <div style="
        width:28px;height:28px;border-radius:50%;flex-shrink:0;
        display:flex;align-items:center;justify-content:center;font-size:0.78rem;font-weight:600;
        <%= done    ? 'background:#16a34a;color:#fff;'   : '' %>
        <%= active  ? 'background:#18181b;color:#fff;'   : '' %>
        <%= pending ? 'background:#e4e4e7;color:#a1a1aa;' : '' %>
      ">
        <%= done ? raw('<i class="bi bi-check" style="font-size:0.9rem;"></i>') : step[:n] %>
      </div>

      <%# Label — link if clickable, span otherwise %>
      <% label_style = "font-size:0.82rem;white-space:nowrap;font-weight:#{active ? '700' : '500'};color:#{done ? '#16a34a' : active ? '#18181b' : '#a1a1aa'};" %>
      <% if clickable %>
        <%= link_to step[:label], path,
            style: label_style + "text-decoration:none;",
            title: "Ir para #{step[:label].downcase}" %>
      <% else %>
        <span style="<%= label_style %>"><%= step[:label] %></span>
      <% end %>
    </div>

    <% unless i == steps.length - 1 %>
      <div style="flex-shrink:0;padding:0 0.5rem;color:#d4d4d8;font-size:0.75rem;">
        <i class="bi bi-chevron-right"></i>
      </div>
    <% end %>
  <% end %>
</div>
