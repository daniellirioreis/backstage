<div class="page-header">
  <div>
    <h1>Relatório de Fechamento</h1>
    <div style="font-size:0.78rem;color:#71717a;margin-top:0.15rem;">
      <i class="bi bi-calendar-event" style="font-size:0.7rem;"></i> <%= @event.name %>
    </div>
  </div>
  <div style="display:flex;gap:0.5rem;">
    <%= link_to reports_fechamento_print_path(basis: @basis), class: "btn-secondary" do %>
      <i class="bi bi-printer"></i> Imprimir PDF
    <% end %>
  </div>
</div>

<%# Toggle de modo %>
<div class="content-card" style="padding:0.75rem 1rem;margin-bottom:1rem;display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;">
  <span style="font-size:0.78rem;font-weight:700;color:#71717a;">Base de cálculo:</span>
  <div style="display:flex;gap:4px;background:#f4f4f5;border-radius:10px;padding:4px;">
    <%= link_to reports_fechamento_path(basis: "shifts"),
        style: "font-size:0.8rem;font-weight:700;padding:0.3rem 0.9rem;border-radius:7px;text-decoration:none;transition:all 0.15s;" +
               (@basis == "shifts" ? "background:#18181b;color:#fff;" : "color:#71717a;") do %>
      <i class="bi bi-calendar2-week"></i> Escalas cadastradas
    <% end %>
    <%= link_to reports_fechamento_path(basis: "attendance"),
        style: "font-size:0.8rem;font-weight:700;padding:0.3rem 0.9rem;border-radius:7px;text-decoration:none;transition:all 0.15s;" +
               (@basis == "attendance" ? "background:#18181b;color:#fff;" : "color:#71717a;") do %>
      <i class="bi bi-qr-code-scan"></i> Check-in / Check-out
    <% end %>
  </div>
  <% if @basis == "attendance" %>
    <span style="font-size:0.72rem;color:#a1a1aa;">Considera apenas colaboradores com check-in e check-out registrados.</span>
  <% end %>
</div>

<% if @rows.empty? %>
  <div class="content-card" style="text-align:center;padding:3rem;color:#a1a1aa;">
    <i class="bi bi-clipboard-x" style="font-size:2rem;display:block;margin-bottom:0.75rem;"></i>
    <p style="margin:0;font-size:0.9rem;">
      <% if @basis == "attendance" %>
        Nenhum colaborador com check-in e check-out registrados.
      <% else %>
        Nenhum turno cadastrado para este evento.
      <% end %>
    </p>
  </div>
<% else %>

<%# Resumo por função %>
<% by_function = @rows.group_by { |r| r[:function_name] }.sort_by { |fn, _| fn.to_s } %>
<div class="content-card" style="margin-bottom:1rem;padding:1rem 1.25rem;">
  <div style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#71717a;margin-bottom:0.75rem;">
    <i class="bi bi-bar-chart-fill"></i> Resumo por Função
  </div>
  <div style="display:flex;flex-wrap:wrap;gap:0.75rem;">
    <% by_function.each do |fn_name, fn_rows| %>
      <% fn_hours = fn_rows.sum { |r| r[:total_hours] } %>
      <% fn_total = fn_rows.sum { |r| r[:total_value] } %>
      <div style="background:#f9fafb;border:1px solid #e4e4e7;border-radius:8px;padding:0.6rem 1rem;min-width:160px;">
        <div style="font-size:0.72rem;font-weight:700;color:#7c3aed;margin-bottom:0.25rem;"><%= fn_name %></div>
        <div style="font-size:0.78rem;color:#3f3f46;"><%= fn_rows.size %> pessoa<%= fn_rows.size == 1 ? "" : "s" %> · <%= format_hours(fn_hours) %></div>
        <div style="font-size:0.85rem;font-weight:700;color:#18181b;margin-top:0.1rem;">R$ <%= "%.2f" % fn_total %></div>
      </div>
    <% end %>
    <div style="background:#18181b;border-radius:8px;padding:0.6rem 1rem;min-width:160px;">
      <div style="font-size:0.72rem;font-weight:700;color:#a1a1aa;margin-bottom:0.25rem;">TOTAL GERAL</div>
      <div style="font-size:0.78rem;color:#d4d4d8;"><%= @rows.size %> pessoas · <%= format_hours(@rows.sum { |r| r[:total_hours] }) %></div>
      <div style="font-size:0.85rem;font-weight:700;color:#fff;margin-top:0.1rem;">R$ <%= "%.2f" % @grand_total %></div>
    </div>
  </div>
</div>

<%# Tabela detalhada %>
<div class="content-card" style="padding:0;overflow:hidden;">
  <table class="data-table" style="width:100%;">
    <thead>
      <tr>
        <th>Colaborador</th>
        <th>Função</th>
        <% if @basis == "attendance" %>
          <th style="text-align:center;">Data</th>
          <th style="text-align:center;">Check-in</th>
          <th style="text-align:center;">Check-out</th>
        <% else %>
          <th style="text-align:center;">Turnos</th>
        <% end %>
        <th style="text-align:right;">Total Horas</th>
        <th style="text-align:right;">Valor/h</th>
        <th style="text-align:right;">Total</th>
      </tr>
    </thead>
    <tbody>
      <% @rows.each do |row| %>
        <tr>
          <td>
            <div style="font-size:0.85rem;font-weight:600;color:#18181b;"><%= row[:user].name %></div>
            <div style="font-size:0.72rem;color:#a1a1aa;"><%= row[:user].cpf.gsub(/(\d{3})(\d{3})(\d{3})(\d{2})/, '\1.\2.\3-\4') %></div>
          </td>
          <td>
            <span style="font-size:0.75rem;font-weight:600;color:#7c3aed;background:#f5f3ff;border:1px solid #ddd6fe;border-radius:4px;padding:2px 7px;">
              <%= row[:function_name] %>
            </span>
          </td>
          <% if @basis == "attendance" %>
            <td style="text-align:center;">
              <% row[:entries].each do |entry| %>
                <div style="font-size:0.75rem;color:#52525b;"><%= entry[:date] %></div>
              <% end %>
            </td>
            <td style="text-align:center;">
              <% row[:entries].each do |entry| %>
                <div style="display:inline-flex;align-items:center;gap:0.25rem;background:#dcfce7;border:1px solid #86efac;border-radius:5px;padding:2px 8px;margin-bottom:2px;">
                  <i class="bi bi-box-arrow-in-right" style="color:#16a34a;font-size:0.65rem;"></i>
                  <span style="font-size:0.75rem;font-weight:600;color:#15803d;"><%= entry[:checked_in] %></span>
                </div>
              <% end %>
            </td>
            <td style="text-align:center;">
              <% row[:entries].each do |entry| %>
                <div style="display:inline-flex;align-items:center;gap:0.25rem;background:#fff7ed;border:1px solid #fed7aa;border-radius:5px;padding:2px 8px;margin-bottom:2px;">
                  <i class="bi bi-box-arrow-right" style="color:#c2410c;font-size:0.65rem;"></i>
                  <span style="font-size:0.75rem;font-weight:600;color:#c2410c;"><%= entry[:checked_out] %></span>
                </div>
              <% end %>
            </td>
          <% else %>
            <td style="text-align:center;">
              <div style="display:flex;flex-direction:column;gap:2px;align-items:center;">
                <% row[:entries].each do |entry| %>
                  <span style="font-size:0.7rem;color:#52525b;white-space:nowrap;">
                    <%= entry[:label] %>
                    <span style="color:#a1a1aa;font-weight:600;"> <%= format_hours(entry[:hours]) %></span>
                  </span>
                <% end %>
              </div>
            </td>
          <% end %>
          <td style="text-align:right;">
            <span style="font-size:0.85rem;font-weight:600;color:#18181b;"><%= format_hours(row[:total_hours]) %></span>
          </td>
          <td style="text-align:right;">
            <span style="font-size:0.82rem;color:#52525b;">
              <% if row[:hourly_rate] > 0 %>R$ <%= "%.2f" % row[:hourly_rate] %><% else %><span style="color:#d4d4d8;">—</span><% end %>
            </span>
          </td>
          <td style="text-align:right;">
            <% if row[:total_value] > 0 %>
              <span style="font-size:0.9rem;font-weight:700;color:#15803d;">R$ <%= "%.2f" % row[:total_value] %></span>
            <% else %>
              <span style="color:#d4d4d8;font-size:0.82rem;">—</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
    <tfoot>
      <tr style="background:#f9fafb;border-top:2px solid #18181b;">
        <td colspan="<%= @basis == 'attendance' ? 5 : 3 %>" style="font-size:0.82rem;font-weight:700;color:#18181b;padding:0.75rem 1rem;">
          Total — <%= @rows.size %> colaboradore<%= @rows.size == 1 ? "" : "s" %>
        </td>
        <td style="text-align:right;font-size:0.85rem;font-weight:700;color:#18181b;">
          <%= format_hours(@rows.sum { |r| r[:total_hours] }) %>
        </td>
        <td></td>
        <td style="text-align:right;font-size:0.95rem;font-weight:700;color:#15803d;">
          R$ <%= "%.2f" % @grand_total %>
        </td>
      </tr>
    </tfoot>
  </table>
</div>

<% end %>

<%# Pendentes de checkout (só no modo attendance) %>
<% if @basis == "attendance" && @pending_rows.present? %>
<div class="content-card" style="margin-top:1rem;padding:0;overflow:hidden;">
  <div style="padding:0.75rem 1rem;border-bottom:1px solid #e4e4e7;display:flex;align-items:center;gap:0.5rem;">
    <i class="bi bi-hourglass-split" style="color:#d97706;"></i>
    <span style="font-size:0.8rem;font-weight:700;color:#d97706;">Aguardando checkout (<%= @pending_rows.size %>)</span>
  </div>
  <table class="data-table" style="width:100%;">
    <thead>
      <tr>
        <th>Colaborador</th>
        <th>Função</th>
        <th style="text-align:center;">Check-in</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% @pending_rows.each do |row| %>
        <tr>
          <td style="font-size:0.85rem;font-weight:600;color:#18181b;"><%= row[:user].name %></td>
          <td>
            <span style="font-size:0.75rem;font-weight:600;color:#7c3aed;background:#f5f3ff;border:1px solid #ddd6fe;border-radius:4px;padding:2px 7px;">
              <%= row[:function_name] %>
            </span>
          </td>
          <td style="text-align:center;">
            <div style="display:inline-flex;align-items:center;gap:0.35rem;background:#dcfce7;border:1px solid #86efac;border-radius:6px;padding:3px 10px;">
              <i class="bi bi-box-arrow-in-right" style="color:#16a34a;font-size:0.7rem;"></i>
              <span style="font-size:0.78rem;font-weight:600;color:#15803d;"><%= l(row[:checked_in_at], format: :short) %></span>
            </div>
          </td>
          <td style="font-size:0.75rem;color:#d97706;font-weight:600;">
            <i class="bi bi-dash-circle"></i> Sem checkout
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% end %>

<style>
@media print {
  .page-header button, .sidebar, nav { display: none !important; }
  body { background: #fff !important; }
  .content-card { box-shadow: none !important; border: 1px solid #e4e4e7 !important; }
}
</style>
