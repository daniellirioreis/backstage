<%
  event    = @payment.event
  user     = @payment.user
  paid_by  = @payment.paid_by
  company  = event.company
  pdf_mode = local_assigns.fetch(:pdf_mode, false)
%>
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <title>Comprovante de Pagamento - <%= user.name %></title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
    body { font-family: Arial, Helvetica, sans-serif; font-size: 11px; color: #18181b; background: #fff; }

    .page { max-width: 700px; margin: 0 auto; padding: 40px 48px; }

    /* Cabecalho */
    .header { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 3px solid #18181b; padding-bottom: 20px; margin-bottom: 24px; }
    .header-left h1 { font-size: 22px; font-weight: 900; color: #18181b; letter-spacing: -0.5px; }
    .header-left p  { font-size: 11px; color: #71717a; margin-top: 3px; }
    .header-right   { text-align: right; }
    .logo-box { width: 60px; height: 60px; object-fit: contain; border-radius: 8px; }
    .logo-placeholder { width: 60px; height: 60px; background: #18181b; border-radius: 8px; display: flex; align-items: center; justify-content: center; }
    .logo-placeholder span { color: #fff; font-size: 22px; font-weight: 900; }

    /* Numero do comprovante */
    .receipt-id { background: #f4f4f5; border: 1px solid #e4e4e7; border-radius: 8px; padding: 10px 16px; margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center; }
    .receipt-id .label { font-size: 10px; font-weight: 700; color: #71717a; text-transform: uppercase; letter-spacing: 0.08em; }
    .receipt-id .value { font-size: 13px; font-weight: 800; color: #18181b; font-family: monospace; }
    .receipt-id .date  { font-size: 10px; color: #71717a; }

    /* Secoes */
    .section { margin-bottom: 20px; }
    .section-title { font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: #71717a; border-bottom: 1px solid #e4e4e7; padding-bottom: 4px; margin-bottom: 12px; }

    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }

    .field .label { font-size: 9px; font-weight: 700; color: #a1a1aa; text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 2px; }
    .field .value { font-size: 12px; font-weight: 600; color: #18181b; }
    .field .value.large { font-size: 20px; font-weight: 900; color: #15803d; }

    /* Badge de status */
    .badge-paid { display: inline-flex; align-items: center; gap: 5px; background: #dcfce7; border: 1.5px solid #86efac; border-radius: 20px; padding: 4px 12px; font-size: 11px; font-weight: 800; color: #15803d; }
    .badge-method { display: inline-block; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 6px; padding: 3px 10px; font-size: 10px; font-weight: 700; color: #166534; }

    /* Valor destaque */
    .valor-box { background: linear-gradient(135deg, #18181b 0%, #3f3f46 100%); border-radius: 12px; padding: 20px 24px; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; }
    .valor-box .label { font-size: 10px; font-weight: 700; color: #a1a1aa; text-transform: uppercase; letter-spacing: 0.1em; }
    .valor-box .amount { font-size: 28px; font-weight: 900; color: #4ade80; font-family: Arial, sans-serif; }
    .valor-box .details { text-align: right; }
    .valor-box .detail-line { font-size: 10px; color: #d4d4d8; margin-top: 2px; }

    /* Observacoes */
    .notes-box { background: #fafafa; border: 1px solid #e4e4e7; border-radius: 8px; padding: 10px 14px; font-size: 11px; color: #52525b; font-style: italic; }

    /* Assinaturas */
    .signatures { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 40px; }
    .sig-block { text-align: center; }
    .sig-line  { border-top: 1.5px solid #18181b; padding-top: 6px; margin-top: 40px; }
    .sig-name  { font-size: 11px; font-weight: 700; color: #18181b; }
    .sig-role  { font-size: 9px; color: #71717a; margin-top: 2px; }

    /* Rodape */
    .footer { margin-top: 32px; padding-top: 14px; border-top: 1px dashed #e4e4e7; display: flex; justify-content: space-between; align-items: center; }
    .footer-left  { font-size: 9px; color: #a1a1aa; }
    .footer-right { font-size: 9px; color: #a1a1aa; text-align: right; }

    @media print {
      body { background: #fff !important; }
      .page { padding: 20px 24px; }
      .no-print { display: none !important; }
    }
  </style>
</head>
<body>

<% unless pdf_mode %>
<div style="background:#18181b;padding:10px 48px;display:flex;justify-content:space-between;align-items:center;gap:1rem;" class="no-print">
  <span style="color:#a1a1aa;font-size:0.8rem;">Comprovante de Pagamento</span>
  <div style="display:flex;gap:8px;">
    <%= link_to receipt_pdf_reports_payment_path(@payment), style:"font-size:0.8rem;background:#4ade80;color:#18181b;border-radius:6px;padding:6px 16px;text-decoration:none;font-weight:700;display:inline-flex;align-items:center;gap:6px;" do %><i class="bi bi-download"></i> Baixar PDF<% end %>
    <button onclick="window.print()" style="font-size:0.8rem;background:#3f3f46;color:#fff;border:none;border-radius:6px;padding:6px 16px;cursor:pointer;font-weight:700;display:inline-flex;align-items:center;gap:6px;"><i class="bi bi-printer"></i> Imprimir</button>
    <button onclick="window.close()" style="font-size:0.8rem;background:none;color:#a1a1aa;border:1px solid #3f3f46;border-radius:6px;padding:6px 12px;cursor:pointer;">Fechar</button>
  </div>
</div>
<% end %>
<div class="page">

  <%# Cabecalho %>
  <div class="header">
    <div class="header-left">
      <h1>Comprovante de Pagamento</h1>
      <p><%= event.name %><% if event.code.present? %> &middot; <%= event.code %><% end %></p>
      <% if event.location.present? %>
        <p style="margin-top:1px;color:#a1a1aa;font-size:10px;"><%= event.location %></p>
      <% end %>
    </div>
    <div class="header-right">
      <% if company&.logo&.attached? %>
        <%= image_tag company.logo, class: "logo-box", style: "width:60px;height:60px;object-fit:contain;border-radius:8px;" %>
      <% elsif company %>
        <div class="logo-placeholder">
          <span><%= company.name.first(1).upcase %></span>
        </div>
      <% end %>
      <% if company %>
        <div style="font-size:10px;font-weight:700;color:#18181b;margin-top:6px;"><%= company.name %></div>
        <% if company.cnpj.present? %>
          <div style="font-size:9px;color:#71717a;">CNPJ: <%= company.cnpj %></div>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Numero do comprovante %>
  <div class="receipt-id">
    <div>
      <div class="label">Numero do Comprovante</div>
      <div class="value">CPG-<%= @payment.id.to_s.rjust(8, "0") %></div>
    </div>
    <div style="text-align:right;">
      <div class="label">Emitido em</div>
      <div class="date" style="font-size:12px;font-weight:700;color:#18181b;"><%= l(@payment.paid_at.to_date, format: :long) %></div>
      <div class="date">Registrado por: <%= paid_by.name %></div>
    </div>
    <div>
      <span class="badge-paid">&#10003; PAGO</span>
    </div>
  </div>

  <%# Valor em destaque %>
  <div class="valor-box">
    <div>
      <div class="label">Valor Total Pago</div>
      <div class="amount">R$ <%= "%.2f" % @payment.amount %></div>
      <span class="badge-method" style="margin-top:6px;display:inline-block;"><%= @payment.method_label %></span>
    </div>
    <div class="details">
      <% if @payment.hours.present? && @payment.hours > 0 %>
        <div class="detail-line"><%= "%.2f" % @payment.hours %>h trabalhadas</div>
      <% end %>
      <% if @payment.hourly_rate.present? && @payment.hourly_rate > 0 %>
        <div class="detail-line">R$ <%= "%.2f" % @payment.hourly_rate %>/hora</div>
      <% end %>
      <div class="detail-line" style="margin-top:6px;font-size:9px;color:#71717a;">
        Base: <%= @payment.basis == "shifts" ? "Escalas cadastradas" : "Check-in / Check-out" %>
      </div>
    </div>
  </div>

  <%# Dados do colaborador %>
  <div class="section">
    <div class="section-title">Dados do Colaborador</div>
    <div class="grid-2">
      <div class="field">
        <div class="label">Nome Completo</div>
        <div class="value"><%= user.name %></div>
      </div>
      <div class="field">
        <div class="label">CPF</div>
        <div class="value"><%= user.cpf.to_s.gsub(/(\d{3})(\d{3})(\d{3})(\d{2})/, '\1.\2.\3-\4') %></div>
      </div>
      <div class="field">
        <div class="label">Funcao no Evento</div>
        <div class="value"><%= @payment.function_name.presence || "—" %></div>
      </div>
      <% if user.email.present? %>
        <div class="field">
          <div class="label">E-mail</div>
          <div class="value"><%= user.email %></div>
        </div>
      <% end %>
    </div>
  </div>

  <%# Dados do evento %>
  <div class="section">
    <div class="section-title">Dados do Evento</div>
    <div class="grid-3">
      <div class="field">
        <div class="label">Evento</div>
        <div class="value"><%= event.name %></div>
      </div>
      <% if event.start_date.present? %>
        <div class="field">
          <div class="label">Periodo</div>
          <div class="value">
            <%= l(event.start_date, format: :short) %>
            <% if event.end_date != event.start_date %>
              &rarr; <%= l(event.end_date, format: :short) %>
            <% end %>
          </div>
        </div>
      <% end %>
      <% if event.location.present? %>
        <div class="field">
          <div class="label">Local</div>
          <div class="value"><%= event.location %></div>
        </div>
      <% end %>
    </div>
  </div>

  <%# Observacoes %>
  <% if @payment.notes.present? %>
    <div class="section">
      <div class="section-title">Observacoes</div>
      <div class="notes-box"><%= @payment.notes %></div>
    </div>
  <% end %>

  <%# Assinaturas %>
  <div class="signatures">
    <div class="sig-block">
      <div class="sig-line">
        <div class="sig-name"><%= paid_by.name %></div>
        <div class="sig-role">Responsavel pelo Pagamento</div>
        <% if company %>
          <div class="sig-role"><%= company.name %></div>
        <% end %>
      </div>
    </div>
    <div class="sig-block">
      <div class="sig-line">
        <div class="sig-name"><%= user.name %></div>
        <div class="sig-role">Colaborador Beneficiario</div>
        <div class="sig-role">CPF: <%= user.cpf.to_s.gsub(/(\d{3})(\d{3})(\d{3})(\d{2})/, '\1.\2.\3-\4') %></div>
      </div>
    </div>
  </div>

  <%# Rodape %>
  <div class="footer">
    <div class="footer-left">
      Gerado em <%= l(Time.current.to_date, format: :long) %><br>
      Sistema Backstage &middot; Gestao de Eventos
    </div>
    <div class="footer-right">
      Comprovante n&ordm; CPG-<%= @payment.id.to_s.rjust(8, "0") %><br>
      <strong><%= event.name %></strong>
    </div>
  </div>

</div>
</body>
</html>
