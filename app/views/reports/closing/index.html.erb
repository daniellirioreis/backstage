            <% else %>
              <%= render partial: "reports/closing/payment_cell",
                         locals: { payment: payment, row: row, uid: row[:user].id,
                                   rate: row[:hourly_rate], basis: "cross", finalized: finalized,
                                   date: @selected_date } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
    <tfoot>
      <tr style="background:#f9fafb;border-top:2px solid #18181b;">
        <td colspan="2" style="font-size:0.82rem;font-weight:700;color:#18181b;padding:0.75rem 1rem;">
          Total — <%= @rows.size %> colaborador<%= @rows.size == 1 ? "" : "es" %>
