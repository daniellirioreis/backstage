    <span style="font-size:0.8rem;font-weight:700;color:#18181b;">Total: R$ <%= "%.2f" % @grand_total %></span>
    <span style="font-size:0.7rem;color:#a1a1aa;font-weight:400;">(estimativa pela base)</span>
  </div>
</div>

<div class="content-card" style="padding:0;overflow:hidden;">
  <div style="overflow-y:auto;max-height:calc(100vh - 280px);">
  <table class="data-table" style="width:100%;border:none;border-radius:0;">
    <thead>
      <tr>
        <th>Colaborador</th>
        <th>Função</th>
        <th style="text-align:center;">Hs. Escala</th>
        <th style="text-align:right;">Valor Orçado</th>
        <th style="text-align:center;">Check-in</th>
        <th style="text-align:center;">Check-out</th>
        <th style="text-align:right;">Hs. Trabalhadas</th>
        <th style="text-align:right;">Valor/h</th>
        <th style="text-align:right;">Hs. a Pagar</th>
        <th style="text-align:right;">Valor a ser Pago</th>
        <th style="text-align:center;">Base</th>
        <th style="text-align:center;min-width:190px;">Pagamento</th>
      </tr>
    </thead>
    <tbody>
      <% @rows.each do |row| %>
        <% payment = @payment_by_user_date[[row[:user].id, @selected_date]] %>
        <% row_bg = case row[:status]
                    when :absent       then "background:#fff5f5;"
                    when :unscheduled  then "background:#fffbeb;"
                    else ""
                    end %>
        <tr id="payment-row-<%= row[:user].id %>" data-name="<%= row[:user].name.downcase %>" style="<%= row_bg %>">
          <td style="vertical-align:middle;">
            <div style="display:flex;align-items:center;gap:6px;">
              <% dot_color = case row[:status]
                             when :present     then "#16a34a"
                             when :absent      then "#ef4444"
                             when :unscheduled then "#d97706"
                             end %>
              <span style="display:block;flex-shrink:0;width:8px;height:8px;border-radius:50%;background:<%= dot_color %>;"
                    title="<%= row[:status] == :present ? 'Presente' : row[:status] == :absent ? 'Ausente' : 'Não escalado' %>"></span>
              <div>
                <div style="font-size:0.85rem;font-weight:600;color:#18181b;"><%= row[:user].name %></div>
                <div style="font-size:0.72rem;color:#a1a1aa;"><%= row[:user].cpf.to_s.gsub(/(\d{3})(\d{3})(\d{3})(\d{2})/, '\1.\2.\3-\4') %></div>
              </div>
            </div>
          </td>
          <td>
            <span style="font-size:0.75rem;font-weight:600;color:#7c3aed;background:#f5f3ff;border:1px solid #ddd6fe;border-radius:4px;padding:2px 7px;">
              <%= row[:function_name] %>
            </span>
          </td>
          <%# Hs. Escala — horários da escala do dia %>
          <td style="text-align:center;">
            <% if row[:shift_entries].any? %>
              <div style="display:flex;flex-direction:column;gap:2px;align-items:center;">
                <span style="font-size:0.82rem;font-weight:700;color:#18181b;"><%= format_hours(row[:scheduled_hours]) %></span>
                <% row[:shift_entries].each do |se| %>
                  <span style="font-size:0.7rem;color:#7c3aed;white-space:nowrap;"><%= se[:start_time] %>–<%= se[:end_time] %></span>
                <% end %>
              </div>
            <% else %>
              <span style="color:#d4d4d8;font-size:0.8rem;">—</span>
            <% end %>
          </td>
          <%# Valor Orçado %>
          <td style="text-align:right;">
            <% if row[:scheduled_value].to_f > 0 %>
              <span style="font-size:0.82rem;color:#6366f1;font-weight:600;">R$ <%= "%.2f" % row[:scheduled_value] %></span>
            <% else %>
              <span style="color:#d4d4d8;font-size:0.8rem;">—</span>
            <% end %>
          </td>
          <%# Check-in %>
          <td style="text-align:center;">
            <% entry = row[:att_entries].first %>
            <% if entry %>
              <span style="font-size:0.82rem;color:#52525b;"><%= entry[:checked_in] || "—" %></span>
              <% if entry[:source] == "manual" %>
                <span style="display:inline-block;background:#fef9c3;color:#92400e;font-size:0.62rem;font-weight:700;padding:1px 5px;border-radius:99px;border:1px solid #fde68a;" title="Lançamento manual">M</span>
              <% end %>
            <% else %>
              <span style="color:#d4d4d8;font-size:0.8rem;">—</span>
            <% end %>
          </td>
          <%# Check-out %>
          <td style="text-align:center;">
            <% if entry %>
              <% if entry[:missing_checkout] %>
                <span style="font-size:0.75rem;color:#d97706;font-weight:600;" title="Checkout pendente">
                  <i class="bi bi-clock-history"></i> —
                </span>
              <% else %>
                <span style="font-size:0.82rem;color:#52525b;"><%= entry[:checked_out] || "—" %></span>
              <% end %>
            <% else %>
              <span style="color:#d4d4d8;font-size:0.8rem;">—</span>
            <% end %>
          </td>
          <%# Hs. Trabalhadas %>
          <td style="text-align:right;">
            <% if row[:status] == :absent %>
              <span style="color:#ef4444;font-size:0.8rem;">—</span>
            <% elsif row[:actual_hours].to_f > 0 %>
              <span style="font-size:0.82rem;color:#52525b;"><%= format_hours(row[:actual_hours]) %></span>
            <% else %>
              <span style="color:#d4d4d8;font-size:0.8rem;">—</span>
            <% end %>
          </td>
          <%# Valor/h %>
          <td style="text-align:right;">
            <span style="font-size:0.82rem;color:#52525b;">
              <% if row[:hourly_rate] > 0 %>R$ <%= "%.2f" % row[:hourly_rate] %><% else %>—<% end %>
            </span>
          </td>
          <%# Hs. a Pagar %>
          <td style="text-align:right;">
            <span style="font-size:0.85rem;font-weight:700;color:<%= row[:payable_hours] > 0 ? '#18181b' : '#d4d4d8' %>;">
              <%= format_hours(row[:payable_hours]) %>
            </span>
          </td>
          <%# Valor a ser Pago %>
          <td style="text-align:right;">
            <% if row[:total_value] > 0 %>
              <span style="font-size:0.9rem;font-weight:700;color:#15803d;">R$ <%= "%.2f" % row[:total_value] %></span>
            <% else %>
              <span style="color:#d4d4d8;font-size:0.82rem;">R$ 0,00</span>
            <% end %>
          </td>
          <%# Base %>
