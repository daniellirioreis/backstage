<%# ── Banner de fechamento finalizado ─────────────────────────────────────── %>
<% if current_event.closing_finalized_at? %>
  <div style="background:#f0fdf4;border:1px solid #86efac;border-radius:10px;padding:1rem 1.25rem;margin-bottom:1.25rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
    <div style="display:flex;align-items:center;gap:0.75rem;">
      <div style="width:36px;height:36px;background:#16a34a;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <i class="bi bi-check-circle-fill" style="color:#fff;font-size:1.1rem;"></i>
      </div>
      <div>
        <div style="font-size:0.9rem;font-weight:700;color:#15803d;">Fechamento finalizado</div>
        <div style="font-size:0.78rem;color:#16a34a;">
          Concluído em <%= l(current_event.closing_finalized_at, format: :short) %>
          por <strong><%= current_event.closing_finalized_by&.name || "—" %></strong>
        </div>
      </div>
    </div>
    <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;">
      <%= link_to reports_closing_print_path(basis: @basis, sector_id: @sector_id), class: "btn-secondary", style: "font-size:0.78rem;" do %>
        <i class="bi bi-printer"></i> Imprimir PDF
      <% end %>
      <% if policy(:report).reopen_closing? %>
        <%= button_to reports_closing_reopen_path,
            method: :post,
            style: "font-size:0.78rem;background:none;border:1px solid #86efac;color:#15803d;border-radius:7px;padding:0.35rem 0.85rem;cursor:pointer;font-weight:600;display:inline-flex;align-items:center;gap:0.3rem;",
            data: { turbo_confirm: "Reabrir o fechamento? Os pagamentos voltarão a ser editáveis." } do %>
          <i class="bi bi-arrow-counterclockwise"></i> Reabrir
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<div class="page-header">
  <div>
    <h1>Relatório de Fechamento</h1>
    <div style="font-size:0.78rem;color:#71717a;margin-top:0.15rem;">
      <i class="bi bi-calendar-event" style="font-size:0.7rem;"></i> <%= @event.name %>
    </div>
  </div>
  <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
    <%= link_to reports_closing_export_path(basis: @basis, sector_id: @sector_id), class: "btn-secondary" do %>
      <i class="bi bi-file-earmark-spreadsheet"></i> Exportar CSV
    <% end %>
    <% unless current_event.closing_finalized_at? %>
      <%= link_to reports_closing_print_path(basis: @basis, sector_id: @sector_id), class: "btn-secondary" do %>
        <i class="bi bi-printer"></i> Imprimir PDF
      <% end %>
      <% if policy(:report).finalize_closing? %>
        <%= button_to reports_closing_finalize_path,
            method: :post,
            style: "display:inline-flex;align-items:center;gap:0.4rem;background:#15803d;color:#fff;border:none;border-radius:7px;padding:0.45rem 1rem;font-size:0.82rem;font-weight:700;cursor:pointer;",
            data: { turbo_confirm: "Finalizar o fechamento de #{current_event.name}? Os pagamentos não poderão ser alterados após a finalização (somente admin pode reabrir)." } do %>
          <i class="bi bi-check-circle-fill"></i> Finalizar Fechamento
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>

<%# Barra de navegação + filtros %>
<div class="content-card" style="padding:0.75rem 1rem;margin-bottom:1rem;">

  <%# Linha 1: Filtros %>
  <%= form_with url: reports_closing_path, method: :get, data: { turbo: false }, style: "display:flex;align-items:center;gap:0.5rem;margin:0;flex-wrap:nowrap;" do |f| %>
    <%= f.hidden_field :basis, value: @basis %>

    <% if @available_dates&.any? %>
      <%= f.select :date,
          @available_dates.map { |d| [l(d, format: :short), d.to_s] },
          { selected: @selected_date, prompt: "📅 Selecione uma data" },
          onchange: "this.closest('form').submit()",
          style: "font-size:0.8rem;border:1px solid #e4e4e7;border-radius:7px;padding:0.3rem 0.6rem;color:#18181b;background:#fff;cursor:pointer;" %>
    <% end %>

    <% if @sectors.any? %>
      <%= f.select :sector_id,
          [["⚙ Todos os setores", ""]] + @sectors.map { |s| [s.name, s.id] },
          { selected: @sector_id },
          onchange: "this.closest('form').submit()",
          style: "font-size:0.8rem;border:1px solid #e4e4e7;border-radius:7px;padding:0.3rem 0.6rem;color:#18181b;background:#fff;cursor:pointer;" %>
    <% end %>

    <%= f.select :payment_status,
        [["💰 Todos", ""], ["✅ Pago", "paid"], ["⏳ Pendente", "pending"]],
        { selected: @payment_status },
        onchange: "this.closest('form').submit()",
        style: "font-size:0.8rem;border:1px solid #e4e4e7;border-radius:7px;padding:0.3rem 0.6rem;color:#18181b;background:#fff;cursor:pointer;" %>

    <%= f.text_field :collaborator,
        value: @collaborator_name,
        placeholder: "🔍 Colaborador",
        onchange: "this.closest('form').submit()",
        style: "font-size:0.8rem;border:1px solid #e4e4e7;border-radius:7px;padding:0.3rem 0.6rem;color:#18181b;background:#fff;min-width:0;width:160px;" %>
  <% end %>

  <%# Separador %>
  <div style="border-top:1px solid #f4f4f5;margin:0.65rem -1rem;"></div>

  <%# Linha 2: Base de cálculo %>
  <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;">
    <span style="font-size:0.78rem;font-weight:700;color:#71717a;">Base de cálculo:</span>
    <div style="display:flex;gap:4px;background:#f4f4f5;border-radius:10px;padding:4px;">
      <%= link_to reports_closing_path(basis: "cross", sector_id: @sector_id, date: @selected_date, collaborator: @collaborator_name, payment_status: @payment_status),
          style: "font-size:0.8rem;font-weight:700;padding:0.3rem 0.9rem;border-radius:7px;text-decoration:none;transition:all 0.15s;" +
                 (@basis == "cross" ? "background:#18181b;color:#fff;" : "color:#71717a;") do %>
        <i class="bi bi-intersect"></i> Cruzamento
      <% end %>
      <%= link_to reports_closing_path(basis: "attendance", sector_id: @sector_id, date: @selected_date, collaborator: @collaborator_name, payment_status: @payment_status),
          style: "font-size:0.8rem;font-weight:700;padding:0.3rem 0.9rem;border-radius:7px;text-decoration:none;transition:all 0.15s;" +
                 (@basis == "attendance" ? "background:#18181b;color:#fff;" : "color:#71717a;") do %>
        <i class="bi bi-qr-code-scan"></i> Check-in/out
      <% end %>
      <%= link_to reports_closing_path(basis: "shifts", sector_id: @sector_id, date: @selected_date, collaborator: @collaborator_name, payment_status: @payment_status),
          style: "font-size:0.8rem;font-weight:700;padding:0.3rem 0.9rem;border-radius:7px;text-decoration:none;transition:all 0.15s;" +
                 (@basis == "shifts" ? "background:#18181b;color:#fff;" : "color:#71717a;") do %>
        <i class="bi bi-calendar2-week"></i> Escalas
      <% end %>
      <%= link_to reports_closing_path(basis: "manual", sector_id: @sector_id, date: @selected_date, collaborator: @collaborator_name, payment_status: @payment_status),
          style: "font-size:0.8rem;font-weight:700;padding:0.3rem 0.9rem;border-radius:7px;text-decoration:none;transition:all 0.15s;" +
                 (@basis == "manual" ? "background:#18181b;color:#fff;" : "color:#71717a;") do %>
        <i class="bi bi-pencil-square"></i> Manual
      <% end %>
    </div>
  </div>

  <%# Info bar por base de cálculo %>
  <%
    basis_info = {
      "cross"      => { icon: "bi-intersect",
                        text: "<strong>Cruzamento escala × presença.</strong> Paga as horas reais (check-in/out) quando o colaborador compareceu, ou as horas escaladas quando fez check-in sem registrar saída. Ausentes não são pagos. Base recomendada para o fechamento." },
      "shifts"     => { icon: "bi-calendar2-week",
                        text: "<strong>Paga pelas horas cadastradas na escala,</strong> independente de presença. Útil quando o pagamento é fixo por turno escalado ou o controle de ponto não é feito via QR." },
      "attendance" => { icon: "bi-qr-code-scan",
                        text: "<strong>Paga pelas horas reais de presença</strong> registradas via QR code (check-in + check-out). Só aparecem colaboradores com os dois registros completos. Sem checkout = sem pagamento." },
      "manual"     => { icon: "bi-pencil-square",
                        text: "<strong>Lançamento manual de horários por data.</strong> Use quando não há registro QR ou ao corrigir horas. Selecione uma data, informe entrada e saída de cada colaborador e salve antes de pagar." }
    }
    info = basis_info[@basis]
  %>
  <% if info %>
    <div style="display:flex;align-items:flex-start;gap:0.6rem;padding:0.55rem 0.85rem;border-radius:8px;margin-top:0.65rem;background:#fefce8;border:1px solid #fde68a;">
      <i class="bi <%= info[:icon] %>" style="font-size:0.9rem;color:#92400e;margin-top:1px;flex-shrink:0;"></i>
      <span style="font-size:0.78rem;line-height:1.55;color:#78350f;"><%= info[:text].html_safe %></span>
    </div>
  <% end %>

</div>

<%# ── Botão pagar em lote (fora de qualquer bloco de base) ──────── %>
<% if @basis != "manual" && @rows.present? && @selected_date.present? && !current_event.closing_finalized_at? %>
  <% _pending_count = @rows.count { |r| r[:total_value].to_f > 0 && !@payment_by_user_date[[r[:user].id, @selected_date]] } %>
  <% _pending_total = @rows.select { |r| r[:total_value].to_f > 0 && !@payment_by_user_date[[r[:user].id, @selected_date]] }.sum { |r| r[:total_value] } %>
  <% if _pending_count > 0 %>
    <div style="display:flex; justify-content:flex-end; margin-bottom:0.75rem;">
      <button type="button" onclick="document.getElementById('batch-pay-modal').style.display='flex'"
              style="display:inline-flex;align-items:center;gap:6px;background:#18181b;color:#fff;border:none;border-radius:8px;padding:0.5rem 1.1rem;font-size:0.82rem;font-weight:700;cursor:pointer;">
        <i class="bi bi-lightning-fill"></i>
        Pagar todos os pendentes (<%= _pending_count %>) &mdash; R$ <%= "%.2f" % _pending_total %>
      </button>
    </div>
    <div id="batch-pay-modal"
         style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:9999;align-items:center;justify-content:center;">
      <div style="background:#fff;border-radius:12px;padding:1.5rem;width:100%;max-width:420px;box-shadow:0 8px 32px rgba(0,0,0,0.18);">
        <div style="font-size:1rem;font-weight:700;color:#18181b;margin-bottom:0.25rem;">Pagar todos os pendentes</div>
        <div style="font-size:0.8rem;color:#71717a;margin-bottom:1rem;">
          <strong><%= _pending_count %> colaborador<%= _pending_count == 1 ? "" : "es" %></strong>
          &middot; base: <strong><%= { "cross" => "Cruzamento", "attendance" => "Check-in/out", "shifts" => "Escalas" }[@basis] %></strong>
          &middot; data: <strong><%= l(Date.parse(@selected_date), format: :short) %></strong>
          &middot; total: <strong>R$ <%= "%.2f" % _pending_total %></strong>
        </div>
        <%= form_with url: reports_closing_batch_pay_path, method: :post, data: { turbo: false } do |f| %>
          <%= f.hidden_field :basis, value: @basis %>
          <%= f.hidden_field :date,  value: @selected_date %>
          <div style="margin-bottom:1rem;">
            <label style="font-size:0.78rem;font-weight:600;color:#52525b;display:block;margin-bottom:4px;">Método de pagamento</label>
            <%= f.select :payment_method,
                [["PIX", "pix"], ["Dinheiro", "cash"], ["Transferência Bancária", "bank_transfer"]],
                {},
                style: "width:100%;border:1px solid #e4e4e7;border-radius:7px;padding:0.45rem 0.65rem;font-size:0.82rem;color:#18181b;background:#fff;" %>
          </div>
          <div style="display:flex;gap:8px;">
            <%= f.submit "Confirmar pagamento em lote",
                style: "flex:1;background:#18181b;color:#fff;border:none;border-radius:7px;padding:0.55rem 0;font-size:0.82rem;font-weight:700;cursor:pointer;" %>
            <button type="button" onclick="document.getElementById('batch-pay-modal').style.display='none'"
                    style="background:#fff;color:#71717a;border:1px solid #e4e4e7;border-radius:7px;padding:0.55rem 1rem;font-size:0.82rem;cursor:pointer;">
              Cancelar
            </button>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>

<% if @basis == "manual" %>

<% if @rows.empty? %>
  <div class="content-card" style="text-align:center;padding:3rem;color:#a1a1aa;">
    <i class="bi bi-clipboard-x" style="font-size:2rem;display:block;margin-bottom:0.75rem;"></i>
    <p style="margin:0;font-size:0.9rem;">
      <%= @manual_date.present? ? "Nenhum colaborador escalado para #{l(Date.parse(@manual_date), format: :short)}." : "Nenhum colaborador escalado." %>
    </p>
  </div>
<% else %>
    <%# Resumo rápido %>
    <% qr_count         = @rows.count { |r| r[:has_qr] } %>
    <% manual_count     = @rows.count { |r| r[:has_manual] } %>
    <% no_record_count  = @rows.count { |r| !r[:has_qr] && !r[:has_manual] } %>
    <% manual_paid_rows    = @rows.select { |r| @payment_by_user_date[[r[:user].id, @selected_date]] } %>
    <% manual_pending_rows = @rows.reject { |r| @payment_by_user_date[[r[:user].id, @selected_date]] } %>
    <div class="content-card" style="padding:0.75rem 1.25rem;margin-bottom:1rem;display:flex;gap:1rem;flex-wrap:wrap;align-items:center;">
      <% if qr_count > 0 %>
        <span style="background:#dcfce7;color:#15803d;border:1px solid #86efac;border-radius:99px;font-size:0.72rem;font-weight:700;padding:3px 10px;">
          <i class="bi bi-qr-code-scan"></i> QR: <%= qr_count %>
        </span>
      <% end %>
      <% if manual_count > 0 %>
        <span style="background:#fef9c3;color:#92400e;border:1px solid #fde68a;border-radius:99px;font-size:0.72rem;font-weight:700;padding:3px 10px;">
          <i class="bi bi-pencil"></i> Manual: <%= manual_count %>
        </span>
      <% end %>
      <% if no_record_count > 0 %>
        <span style="background:#f4f4f5;color:#71717a;border:1px solid #e4e4e7;border-radius:99px;font-size:0.72rem;font-weight:700;padding:3px 10px;">
          <i class="bi bi-dash-circle"></i> Sem registro: <%= no_record_count %>
        </span>
      <% end %>
      <div style="color:#e4e4e7;">|</div>
      <div style="display:flex;align-items:center;gap:0.5rem;">
        <div style="width:10px;height:10px;border-radius:50%;background:#16a34a;"></div>
        <span style="font-size:0.8rem;color:#15803d;font-weight:700;"><%= manual_paid_rows.size %> pago<%= manual_paid_rows.size == 1 ? "" : "s" %></span>
        <span style="font-size:0.8rem;color:#15803d;">&middot; R$ <%= "%.2f" % manual_paid_rows.sum { |r| @payment_by_user_date[[r[:user].id, @selected_date]]&.amount.to_f } %></span>
      </div>
      <div style="color:#e4e4e7;">|</div>
      <div style="display:flex;align-items:center;gap:0.5rem;">
        <div style="width:10px;height:10px;border-radius:50%;background:#d97706;"></div>
        <span style="font-size:0.8rem;color:#b45309;font-weight:700;"><%= manual_pending_rows.size %> pendente<%= manual_pending_rows.size == 1 ? "" : "s" %></span>
        <span style="font-size:0.8rem;color:#b45309;">&middot; R$ <%= "%.2f" % manual_pending_rows.sum { |r| r[:total_value] } %></span>
      </div>
      <div style="display:flex;align-items:center;gap:0.4rem;margin-left:auto;">
        <span style="font-size:0.85rem;font-weight:700;color:#18181b;">Total: R$ <span id="manual-grand-total"><%= "%.2f" % @grand_total %></span></span>
        <span style="font-size:0.7rem;color:#a1a1aa;font-weight:400;">(estimativa pela base)</span>
      </div>
    </div>

    <% finalized = current_event.closing_finalized_at? %>
    <% if @rows_by_date %>
      <%# Vista agrupada por data %>
      <% @rows_by_date.each do |group| %>
        <div style="background:#f4f4f5;border-radius:8px;padding:0.45rem 0.85rem;margin-bottom:0.5rem;display:flex;align-items:center;gap:0.5rem;">
          <i class="bi bi-calendar-event" style="font-size:0.8rem;color:#71717a;"></i>
          <span style="font-size:0.82rem;font-weight:700;color:#3f3f46;"><%= l(group[:date], format: :long) %></span>
          <span style="font-size:0.75rem;color:#a1a1aa;margin-left:4px;"><%= group[:rows].size %> colaborador<%= group[:rows].size == 1 ? "" : "es" %></span>
        </div>
        <%= render partial: "reports/closing/manual_table",
                   locals: { rows: group[:rows], form_id: "manual-save-form-#{group[:date_str]}",
                              date_str: group[:date_str], finalized: finalized,
                              payment_by_user_date: @payment_by_user_date, sector_id: @sector_id } %>
      <% end %>
      <div style="margin-bottom:1.5rem;"></div>
    <% else %>
      <%# Vista de data única %>
      <%= render partial: "reports/closing/manual_table",
                 locals: { rows: @rows, form_id: "manual-save-form",
                            date_str: @manual_date, finalized: finalized,
                            payment_by_user_date: @payment_by_user_date, sector_id: @sector_id } %>
      <div style="margin-bottom:1.5rem;"></div>
    <% end %>
<% end %>

<script>
function calcManualHoras(uid, rate) {
  const startEl   = document.getElementById('entry_' + uid + '_start');
  const endEl     = document.getElementById('entry_' + uid + '_end');
  const hoursEl   = document.getElementById('hours_' + uid);
  const valueEl   = document.getElementById('value_' + uid);
  const amountEl  = document.getElementById('pay_amount_' + uid);
  const hoursHidEl = document.getElementById('pay_hours_' + uid);
  if (!startEl || !endEl || !hoursEl || !valueEl) return;
  const start = startEl.value, end = endEl.value;
  if (!start || !end) {
    hoursEl.textContent = '—';
    valueEl.textContent = '—';
    if (amountEl)   amountEl.value   = '0.00';
    if (hoursHidEl) hoursHidEl.value = '0.00';
    return;
  }
  const [sh, sm] = start.split(':').map(Number);
  const [eh, em] = end.split(':').map(Number);
  let startMin = sh * 60 + sm, endMin = eh * 60 + em;
  if (endMin <= startMin) endMin += 1440;
  const hours = (endMin - startMin) / 60;
  const value = hours * rate;
  hoursEl.textContent = hours.toFixed(2) + 'h';
  valueEl.textContent = 'R$ ' + value.toFixed(2).replace('.', ',');
  if (amountEl)   amountEl.value   = value.toFixed(2);
  if (hoursHidEl) hoursHidEl.value = hours.toFixed(2);
}
</script>

<% elsif @rows.empty? %>
  <div class="content-card" style="text-align:center;padding:3rem;color:#a1a1aa;">
    <i class="bi bi-clipboard-x" style="font-size:2rem;display:block;margin-bottom:0.75rem;"></i>
    <p style="margin:0;font-size:0.9rem;">
      <% if @basis == "cross" %>
        Nenhum dado de escala ou presença encontrado.
      <% elsif @basis == "attendance" %>
        Nenhum colaborador com check-in e check-out registrados.
      <% else %>
        Nenhum turno cadastrado para este evento.
      <% end %>
    </p>
  </div>
<% elsif @basis == "cross" %>

<%# ── Tabela de Cruzamento ──────────────────────────────────────── %>
<% paid_rows    = @rows.select { |r| @payment_by_user_date[[r[:user].id, @selected_date]] } %>
<% pending_rows = @rows.reject { |r| @payment_by_user_date[[r[:user].id, @selected_date]] || r[:status] == :absent } %>
<% present_rows     = @rows.select { |r| r[:status] == :present } %>
<% absent_rows      = @rows.select { |r| r[:status] == :absent } %>
<% unscheduled_rows = @rows.select { |r| r[:status] == :unscheduled } %>

<%# Resumo de status %>
<div class="content-card" style="padding:0.75rem 1.25rem;margin-bottom:1rem;display:flex;gap:1rem;flex-wrap:wrap;align-items:center;">
  <% if present_rows.any? %>
    <div style="display:flex;align-items:center;gap:0.4rem;">
      <div style="width:9px;height:9px;border-radius:50%;background:#16a34a;"></div>
      <span style="font-size:0.8rem;color:#15803d;font-weight:700;"><%= present_rows.size %> presente<%= present_rows.size == 1 ? "" : "s" %></span>
    </div>
    <div style="color:#e4e4e7;">|</div>
  <% end %>
  <% if absent_rows.any? %>
    <div style="display:flex;align-items:center;gap:0.4rem;">
      <div style="width:9px;height:9px;border-radius:50%;background:#ef4444;"></div>
      <span style="font-size:0.8rem;color:#dc2626;font-weight:700;"><%= absent_rows.size %> ausente<%= absent_rows.size == 1 ? "" : "s" %></span>
    </div>
    <div style="color:#e4e4e7;">|</div>
  <% end %>
  <% if unscheduled_rows.any? %>
    <div style="display:flex;align-items:center;gap:0.4rem;">
      <div style="width:9px;height:9px;border-radius:50%;background:#d97706;"></div>
      <span style="font-size:0.8rem;color:#b45309;font-weight:700;"><%= unscheduled_rows.size %> não escalado<%= unscheduled_rows.size == 1 ? "" : "s" %></span>
      <span style="font-size:0.72rem;color:#a1a1aa;">(revisão necessária)</span>
    </div>
    <div style="color:#e4e4e7;">|</div>
  <% end %>
  <div style="display:flex;align-items:center;gap:0.5rem;">
    <div style="width:10px;height:10px;border-radius:50%;background:#16a34a;"></div>
    <span style="font-size:0.8rem;color:#15803d;font-weight:700;"><%= paid_rows.size %> pago<%= paid_rows.size == 1 ? "" : "s" %></span>
    <span style="font-size:0.8rem;color:#15803d;">&middot; R$ <%= "%.2f" % paid_rows.sum { |r| @payment_by_user_date[[r[:user].id, @selected_date]]&.amount.to_f } %></span>
  </div>
  <div style="color:#e4e4e7;">|</div>
  <div style="display:flex;align-items:center;gap:0.5rem;">
    <div style="width:10px;height:10px;border-radius:50%;background:#d97706;"></div>
    <span style="font-size:0.8rem;color:#b45309;font-weight:700;"><%= pending_rows.size %> pendente<%= pending_rows.size == 1 ? "" : "s" %></span>
