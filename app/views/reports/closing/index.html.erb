            <% if payment %>
              <div style="display:flex;flex-direction:column;align-items:center;gap:2px;">
                <span style="font-size:0.72rem;font-weight:700;color:#7c3aed;background:#f5f3ff;border:1px solid #ddd6fe;border-radius:99px;padding:2px 9px;">
                  <%= payment.basis_label %>
                </span>
