<style>
@keyframes flashNextRow {
  0%   { background-color: inherit; }
  20%  { background-color: #fef9c3; }
  40%  { background-color: inherit; }
  60%  { background-color: #fef9c3; }
  80%  { background-color: inherit; }
  100% { background-color: #fef9c3; }
}
.flash-next-row {
  animation: flashNextRow 1.8s ease forwards;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var hash = window.location.hash;
  if (!hash || !hash.startsWith('#payment-row-')) return;

  var paidRow = document.querySelector(hash);
  if (!paidRow) return;

  var allRows = Array.from(document.querySelectorAll('tbody tr[id^="payment-row-"]'));
  var paidIndex = allRows.indexOf(paidRow);
  if (paidIndex === -1) return;

  var isPending = function (tr) { return tr.querySelector('.bi-hourglass-split'); };

  // Próximo pendente após a linha paga; se não achar, volta ao início
  var nextPending =
    allRows.slice(paidIndex + 1).find(isPending) ||
    allRows.slice(0, paidIndex).find(isPending);

  if (nextPending) {
    nextPending.classList.add('flash-next-row');
    setTimeout(function () {
      nextPending.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }, 300);
  }
});
</script>
