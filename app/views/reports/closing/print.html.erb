<%# helpers inline %>
<% is_cross      = @basis == "cross" %>
<% is_attendance = @basis == "attendance" %>
<% row_hours = ->(r) { (is_cross ? r[:payable_hours] : r[:total_hours]).to_f } %>

<%# Cabeçalho %>
<div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:16px; padding-bottom:10px; border-bottom:2px solid #18181b;">
  <div>
    <div style="font-size:16px; font-weight:800; color:#18181b; letter-spacing:-0.02em;">Relatório de Fechamento</div>
    <div style="font-size:9px; color:#52525b; margin-top:3px;">
      <%= @event.name %>
      <% if @event.location.present? %> · <%= @event.location %><% end %>
      · <%= l(@event.start_date, format: :short) %> → <%= l(@event.end_date, format: :short) %>
    </div>
    <div style="font-size:8px; color:#a1a1aa; margin-top:2px;">
      Base:
      <% if is_cross %>Cruzamento Escalas + Presença
      <% elsif is_attendance %>Check-in / Check-out
      <% else %>Escalas cadastradas
      <% end %>
    </div>
  </div>
  <div style="display:flex; align-items:center; gap:10px;">
    <% if @company %>
      <% if @company.logo.attached? %>
        <div style="width:40px; height:40px; border-radius:6px; overflow:hidden; background:#f4f4f5; flex-shrink:0;">
          <%= image_tag url_for(@company.logo), style:"width:100%; height:100%; object-fit:contain;" %>
        </div>
      <% end %>
      <div style="text-align:right;">
        <div style="font-size:10px; font-weight:700; color:#18181b;"><%= @company.name %></div>
        <div style="font-size:8px; color:#a1a1aa; margin-top:2px;">Gerado em <%= l(Date.today, format: :short) %></div>
      </div>
    <% else %>
      <div style="font-size:8px; color:#a1a1aa;">Gerado em <%= l(Date.today, format: :short) %></div>
    <% end %>
  </div>
</div>

<%# Resumo por função %>
<% by_function = @rows.group_by { |r| r[:function_name] }.sort_by { |fn, _| fn.to_s } %>
<table style="margin-bottom:14px; font-size:8px;">
  <thead>
    <tr>
      <th>Função</th>
      <th style="text-align:center;">Pessoas</th>
      <th style="text-align:right;">Horas</th>
      <th style="text-align:right;">R$/h (méd.)</th>
      <th style="text-align:right;">Total</th>
    </tr>
  </thead>
  <tbody>
    <% by_function.each do |fn_name, fn_rows| %>
      <% fn_hours = fn_rows.sum { |r| row_hours.call(r) } %>
      <% fn_total = fn_rows.sum { |r| r[:total_value].to_f } %>
      <% fn_rate  = fn_rows.map { |r| r[:hourly_rate].to_f }.reject(&:zero?).then { |rates| rates.any? ? rates.sum / rates.size : 0 } %>
      <tr>
        <td style="font-weight:600;"><%= fn_name %></td>
        <td style="text-align:center;"><%= fn_rows.size %></td>
        <td style="text-align:right;"><%= format_hours(fn_hours) %></td>
        <td style="text-align:right; color:#71717a;"><%= fn_rate > 0 ? "R$ #{"%.2f" % fn_rate}" : "—" %></td>
        <td style="text-align:right; font-weight:700;">R$ <%= "%.2f" % fn_total %></td>
      </tr>
    <% end %>
  </tbody>
  <tfoot>
    <tr>
      <td style="font-weight:700; background:#18181b; color:#fff;">Total geral</td>
      <td style="text-align:center; font-weight:700; background:#18181b; color:#fff;"><%= @rows.size %></td>
      <td style="text-align:right; font-weight:700; background:#18181b; color:#fff;"><%= format_hours(@rows.sum { |r| row_hours.call(r) }) %></td>
      <td style="background:#18181b;"></td>
      <td style="text-align:right; font-weight:700; background:#18181b; color:#fff;">R$ <%= "%.2f" % @grand_total %></td>
    </tr>
  </tfoot>
</table>

<%# Tabela %>
<table>
  <thead>
    <tr>
      <th style="width:22%;">Colaborador</th>
      <th style="width:13%;">CPF</th>
      <th style="width:12%;">Função</th>
      <% if is_cross %>
        <th style="width:8%; text-align:center;">Status</th>
        <th style="width:8%; text-align:right;">Escaladas</th>
        <th style="width:8%; text-align:right;">Reais</th>
        <th style="width:8%; text-align:right;">A Pagar</th>
      <% elsif is_attendance %>
        <th style="width:9%; text-align:center;">Data</th>
        <th style="width:9%; text-align:center;">Entrada</th>
        <th style="width:9%; text-align:center;">Saída</th>
        <th style="width:8%; text-align:right;">Horas</th>
      <% else %>
        <th style="width:20%;">Turnos</th>
        <th style="width:8%; text-align:right;">Horas</th>
      <% end %>
      <th style="width:7%; text-align:right;">R$/h</th>
      <th style="width:8%; text-align:right;">Total</th>
    </tr>
  </thead>
  <tbody>
    <% @rows.each_with_index do |row, idx| %>
      <tr style="<%= idx.odd? ? 'background:#fafafa;' : '' %>">
        <td style="font-weight:600;"><%= row[:user].name %></td>
        <td style="font-family:monospace; color:#71717a;"><%= row[:user].formatted_cpf %></td>
        <td style="color:#52525b;"><%= row[:function_name] %></td>

        <% if is_cross %>
          <% status_label = { present: "Presente", absent: "Ausente", unscheduled: "Não escalado" }[row[:status]] %>
          <% status_color = { present: "#15803d", absent: "#b91c1c", unscheduled: "#b45309" }[row[:status]] %>
          <td style="text-align:center; font-size:8px; font-weight:700; color:<%= status_color %>;"><%= status_label %></td>
          <td style="text-align:right; color:#71717a;"><%= format_hours(row[:scheduled_hours].to_f) %></td>
          <td style="text-align:right; color:#71717a;"><%= format_hours(row[:actual_hours].to_f) %></td>
          <td style="text-align:right; font-weight:700;"><%= format_hours(row[:payable_hours].to_f) %></td>

        <% elsif is_attendance %>
          <td style="text-align:center; color:#52525b;">
            <% row[:entries].each do |entry| %><div><%= entry[:date] %></div><% end %>
          </td>
          <td style="text-align:center;">
            <% row[:entries].each do |entry| %><div style="color:#15803d; font-weight:600;"><%= entry[:checked_in] %></div><% end %>
          </td>
          <td style="text-align:center;">
            <% row[:entries].each do |entry| %><div style="color:#b91c1c; font-weight:600;"><%= entry[:checked_out] %></div><% end %>
          </td>
          <td style="text-align:right; font-weight:700;"><%= format_hours(row[:total_hours].to_f) %></td>

        <% else %>
          <td style="color:#71717a; font-size:8px;">
            <% row[:entries].each do |entry| %>
              <div><%= entry[:label] %> · <%= format_hours(entry[:hours]) %></div>
            <% end %>
          </td>
          <td style="text-align:right; font-weight:700;"><%= format_hours(row[:total_hours].to_f) %></td>
        <% end %>

        <td style="text-align:right; color:#71717a;"><%= row[:hourly_rate].to_f > 0 ? "R$ #{"%.2f" % row[:hourly_rate]}" : "—" %></td>
        <td style="text-align:right; font-weight:700;"><%= row[:total_value].to_f > 0 ? "R$ #{"%.2f" % row[:total_value]}" : "—" %></td>
      </tr>
    <% end %>
  </tbody>
  <tfoot>
    <tr>
      <% if is_cross %>
        <td colspan="3" style="font-weight:700; background:#18181b; color:#fff;">Total · <%= @rows.size %> colaboradore<%= @rows.size == 1 ? "" : "s" %></td>
        <td style="background:#18181b;"></td>
        <td style="background:#18181b;"></td>
        <td style="background:#18181b;"></td>
        <td style="text-align:right; font-weight:700; background:#18181b; color:#fff;"><%= format_hours(@rows.sum { |r| r[:payable_hours].to_f }) %></td>
      <% elsif is_attendance %>
        <td colspan="3" style="font-weight:700; background:#18181b; color:#fff;">Total · <%= @rows.size %> colaboradore<%= @rows.size == 1 ? "" : "s" %></td>
        <td style="background:#18181b;"></td><td style="background:#18181b;"></td><td style="background:#18181b;"></td>
        <td style="text-align:right; font-weight:700; background:#18181b; color:#fff;"><%= format_hours(@rows.sum { |r| r[:total_hours].to_f }) %></td>
      <% else %>
        <td colspan="3" style="font-weight:700; background:#18181b; color:#fff;">Total · <%= @rows.size %> colaboradore<%= @rows.size == 1 ? "" : "s" %></td>
        <td style="background:#18181b;"></td>
        <td style="text-align:right; font-weight:700; background:#18181b; color:#fff;"><%= format_hours(@rows.sum { |r| r[:total_hours].to_f }) %></td>
      <% end %>
      <td style="background:#18181b;"></td>
      <td style="text-align:right; font-weight:700; background:#18181b; color:#fff;">R$ <%= "%.2f" % @grand_total %></td>
    </tr>
  </tfoot>
</table>

<%# Pendentes de checkout (só para attendance) %>
<% if is_attendance && @pending_rows.present? %>
  <div style="margin-top:14px; padding-top:8px; border-top:1px solid #e4e4e7;">
    <div style="font-size:8px; font-weight:700; color:#b45309; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.06em;">
      Aguardando checkout (<%= @pending_rows.size %>)
    </div>
    <table>
      <thead>
        <tr>
          <th>Colaborador</th>
          <th>Função</th>
          <th style="text-align:center;">Check-in</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% @pending_rows.each_with_index do |row, idx| %>
          <tr style="<%= idx.odd? ? 'background:#fafafa;' : '' %>">
            <td style="font-weight:600;"><%= row[:user].name %></td>
            <td style="color:#52525b;"><%= row[:function_name] %></td>
            <td style="text-align:center; color:#15803d; font-weight:600;"><%= l(row[:checked_in_at], format: :short) %></td>
            <td style="color:#b45309; font-weight:600;">Sem checkout</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<%# Rodapé centralizado %>
<div style="margin-top:20px; padding-top:10px; border-top:2px solid #18181b; text-align:center;">
  <% if @company %>
    <% if @company.logo.attached? %>
      <div style="margin-bottom:6px;">
        <%= image_tag url_for(@company.logo), style:"height:32px; object-fit:contain;" %>
      </div>
    <% end %>
    <div style="font-size:10px; font-weight:800; color:#18181b; letter-spacing:-0.01em;"><%= @company.name %></div>
    <% parts = [] %>
    <% parts << "CNPJ: #{@company.cnpj}" if @company.cnpj.present? %>
    <% parts << @company.address if @company.address.present? %>
    <% parts << [@company.city, @company.state].compact.join(" – ") if @company.city.present? %>
    <% parts << "Tel: #{@company.phone}" if @company.phone.present? %>
    <% parts << @company.email if @company.email.present? %>
    <% if parts.any? %>
      <div style="font-size:7px; color:#71717a; margin-top:3px;"><%= parts.join(" · ") %></div>
    <% end %>
  <% end %>
  <% owner = @company&.owner %>
  <% if owner %>
    <div style="margin-top:20px; display:inline-block; text-align:center;">
      <div style="width:220px; border-top:1px solid #18181b; padding-top:4px; margin:0 auto;">
        <div style="font-size:8px; font-weight:700; color:#18181b;"><%= owner.name %></div>
        <div style="font-size:7px; color:#71717a;">Responsável pela empresa</div>
      </div>
    </div>
  <% end %>
  <div style="font-size:6px; color:#a1a1aa; margin-top:10px; letter-spacing:0.05em;">
    Gerado pelo Backstage · <%= l(Time.current, format: :short) %>
  </div>
</div>
