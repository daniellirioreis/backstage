<%
  _title    = local_assigns[:title] || ""
  _subtitle = local_assigns[:subtitle] || @event&.name
  _company  = local_assigns[:company] || @event&.company
%>
<div class="page-header">
  <div>
    <h1><%= _title %></h1>
    <% if _subtitle.present? %>
      <div style="font-size:0.78rem; color:#71717a; margin-top:0.1rem;"><%= _subtitle %></div>
    <% end %>
  </div>
  <% if _company %>
    <div style="display:flex; align-items:center; gap:0.6rem;">
      <% if _company.logo.attached? %>
        <div style="width:36px; height:36px; border-radius:7px; overflow:hidden; background:#f4f4f5; flex-shrink:0; display:flex; align-items:center; justify-content:center;">
          <%= image_tag url_for(_company.logo), style:"max-width:100%; max-height:100%; object-fit:contain;" %>
        </div>
      <% end %>
      <span style="font-size:0.78rem; font-weight:600; color:#52525b;"><%= _company.name %></span>
    </div>
  <% end %>
</div>
