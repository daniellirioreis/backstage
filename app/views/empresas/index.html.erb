<div class="page-header">
  <h1>Empresas</h1>
  <%= link_to new_empresa_path, class: "btn-primary" do %>
    <i class="bi bi-plus"></i> Nova Empresa
  <% end %>
</div>

<% if @empresas.empty? %>
  <div class="content-card" style="text-align:center; padding:3rem; color:#a1a1aa;">
    <i class="bi bi-building" style="font-size:2rem; display:block; margin-bottom:0.5rem;"></i>
    <p style="margin:0; font-size:0.88rem;">Nenhuma empresa cadastrada.</p>
  </div>
<% else %>
  <div style="display:flex; flex-direction:column; gap:0.75rem;">
    <% @empresas.each do |empresa| %>
      <div class="content-card" style="padding:1rem 1.25rem; display:flex; align-items:center; gap:1rem;">
        <%# Logo %>
        <div style="width:48px; height:48px; border-radius:8px; background:#f4f4f5; border:1px solid #e4e4e7; display:flex; align-items:center; justify-content:center; overflow:hidden; flex-shrink:0;">
          <% if empresa.logo.attached? %>
            <%= image_tag empresa.logo, style:"width:100%;height:100%;object-fit:contain;" %>
          <% else %>
            <i class="bi bi-building" style="color:#a1a1aa; font-size:1.2rem;"></i>
          <% end %>
        </div>

        <%# Info %>
        <div style="flex:1; min-width:0;">
          <div style="font-size:0.95rem; font-weight:700; color:#18181b;"><%= empresa.name %></div>
          <div style="display:flex; gap:1rem; margin-top:3px; flex-wrap:wrap;">
            <% if empresa.cnpj.present? %>
              <span style="font-size:0.72rem; color:#71717a; font-family:monospace;"><%= empresa.cnpj %></span>
            <% end %>
            <% if empresa.city.present? %>
              <span style="font-size:0.72rem; color:#71717a;"><i class="bi bi-geo-alt"></i> <%= empresa.city %><%= empresa.state.present? ? ", #{empresa.state}" : "" %></span>
            <% end %>
            <span style="font-size:0.72rem; color:#71717a;"><i class="bi bi-calendar3"></i> <%= empresa.events.count %> evento<%= empresa.events.count == 1 ? "" : "s" %></span>
            <span style="font-size:0.72rem; color:#71717a;"><i class="bi bi-people"></i> <%= empresa.users.count %> usuário<%= empresa.users.count == 1 ? "" : "s" %></span>
          </div>
        </div>

        <%# Cor primária %>
        <div style="width:20px; height:20px; border-radius:50%; background:<%= empresa.primary_color %>; border:2px solid #e4e4e7; flex-shrink:0;" title="Cor primária: <%= empresa.primary_color %>"></div>

        <%# Ações %>
        <div style="display:flex; gap:0.5rem; flex-shrink:0;">
          <%= link_to empresa_path(empresa), class:"btn-secondary", style:"font-size:0.78rem; padding:0.3rem 0.6rem;" do %>
            <i class="bi bi-gear"></i> Configurações
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
