<%
  hour = Time.current.hour
  greeting = hour < 12 ? "Bom dia" : hour < 18 ? "Boa tarde" : "Boa noite"
%>

<%# ── Header ─────────────────────────────────────────────────────────────────── %>
<div class="page-header" style="margin-bottom:1.75rem;">
  <div>
    <h1 style="margin:0; font-size:1.4rem;"><%= greeting %>, <%= current_user.name.split.first %></h1>
    <div style="font-size:0.82rem; color:#71717a; margin-top:0.2rem;">
      <%= l(Date.today, format: :long) %> · visão geral da empresa
    </div>
  </div>
  <% if policy(Event).new? %>
    <%= link_to new_event_path, class: "btn-primary" do %>
      <i class="bi bi-plus"></i> Novo evento
    <% end %>
  <% end %>
</div>

<%# ── Métricas principais ─────────────────────────────────────────────────────── %>
<div style="display:grid; grid-template-columns:repeat(6,1fr); gap:0.85rem; margin-bottom:2rem;">

  <div class="metric-card" style="border-top:3px solid #18181b;">
    <div class="metric-label"><i class="bi bi-calendar-event"></i> Eventos</div>
    <div class="metric-value"><%= @total_events %></div>
    <div class="metric-sub">no total</div>
  </div>

  <div class="metric-card" style="border-top:3px solid #4ade80;">
    <div class="metric-label"><i class="bi bi-broadcast"></i> Ativos</div>
    <div class="metric-value metric-accent" style="font-size:1.75rem;"><%= @active_events %></div>
    <div class="metric-sub">em andamento</div>
  </div>

  <div class="metric-card" style="border-top:3px solid #60a5fa;">
    <div class="metric-label"><i class="bi bi-grid-3x3-gap"></i> Setores</div>
    <div class="metric-value metric-info" style="font-size:1.75rem;"><%= @total_sectors %></div>
    <div class="metric-sub">criados</div>
  </div>

  <div class="metric-card" style="border-top:3px solid #a78bfa;">
    <div class="metric-label"><i class="bi bi-people"></i> Equipes</div>
    <div class="metric-value" style="font-size:1.75rem; color:#7c3aed;"><%= @total_teams %></div>
    <div class="metric-sub">formadas</div>
  </div>

  <div class="metric-card" style="border-top:3px solid #f59e0b;">
    <div class="metric-label"><i class="bi bi-person-badge"></i> Colaboradores</div>
    <div class="metric-value metric-warn" style="font-size:1.75rem;"><%= @total_members %></div>
    <div class="metric-sub">escalados</div>
  </div>

  <div class="metric-card" style="border-top:3px solid #71717a;">
    <div class="metric-label"><i class="bi bi-car-front"></i> Veículos</div>
    <div class="metric-value" style="font-size:1.75rem; color:#52525b;"><%= @total_vehicles %></div>
    <div class="metric-sub">cadastrados</div>
  </div>

</div>

<%# ── Conteúdo principal ──────────────────────────────────────────────────────── %>
<div style="display:grid; grid-template-columns:1fr 280px; gap:1.5rem; align-items:start;">

  <%# ── Lista de eventos ──────────────────────────────────────────────────────── %>
  <div>
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:0.85rem;">
      <h2 style="font-size:0.95rem; font-weight:600; color:#18181b; margin:0;">Eventos</h2>
      <% if policy(Event).index? %>
        <%= link_to "Ver todos", events_path, class: "btn-secondary", style: "font-size:0.75rem; padding:0.25rem 0.6rem;" %>
      <% end %>
    </div>

    <% if @events.empty? %>
      <div class="content-card" style="text-align:center; color:#a1a1aa; font-size:0.85rem; padding:2.5rem;">
        <i class="bi bi-calendar-event" style="font-size:2rem; display:block; margin-bottom:0.75rem; color:#d4d4d8;"></i>
        Nenhum evento cadastrado ainda.
        <% if policy(Event).new? %>
          <div style="margin-top:0.75rem;">
            <%= link_to new_event_path, class: "btn-primary" do %><i class="bi bi-plus"></i> Criar evento<% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div style="display:flex; flex-direction:column; gap:0.65rem;">
        <% @events.each do |event|
             sectors_count = event.sectors.size
             teams_count   = event.sectors.sum { |s| s.teams.size }
             members_count = event.sectors.flat_map(&:teams).flat_map(&:team_memberships).map(&:user_id).uniq.size
             is_current    = event.id == current_event&.id
             status_color  = event.active? ? "#4ade80" : event.draft? ? "#d4d4d8" : "#27272a"
             days_label    = if event.start_date > Date.today
               diff = (event.start_date - Date.today).to_i
               diff == 1 ? "amanhã" : "em #{diff} dias"
             elsif event.end_date >= Date.today
               "em andamento"
             else
               diff = (Date.today - event.end_date).to_i
               diff == 1 ? "encerrado ontem" : "encerrado há #{diff} dias"
             end
        %>
          <div class="content-card" style="padding:0; overflow:hidden; <%= is_current ? 'box-shadow:0 0 0 2px #18181b;' : '' %>">
            <div style="height:4px; background:<%= status_color %>;"></div>
            <div style="padding:1rem 1.1rem;">
              <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:0.75rem; margin-bottom:0.75rem;">
                <div style="min-width:0;">
                  <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
                    <span style="font-size:0.9rem; font-weight:600; color:#18181b;"><%= event.name %></span>
                    <% if is_current %>
                      <span style="font-size:0.65rem; font-weight:700; background:#18181b; color:#fff; border-radius:4px; padding:0.1rem 0.4rem; letter-spacing:0.02em;">ATUAL</span>
                    <% end %>
                  </div>
                  <div style="display:flex; gap:0.75rem; margin-top:0.3rem; flex-wrap:wrap;">
                    <% if event.location.present? %>
                      <span style="font-size:0.73rem; color:#71717a;"><i class="bi bi-geo-alt"></i> <%= event.location %></span>
                    <% end %>
                    <span style="font-size:0.73rem; color:#71717a;"><i class="bi bi-calendar3"></i> <%= l(event.start_date, format: :short) %> → <%= l(event.end_date, format: :short) %></span>
                    <span style="font-size:0.73rem; color:<%= event.active? ? '#15803d' : event.draft? ? '#71717a' : '#a1a1aa' %>; font-style:italic;"><%= days_label %></span>
                  </div>
                </div>
                <div style="flex-shrink:0; display:flex; flex-direction:column; align-items:flex-end; gap:0.35rem;">
                  <span class="badge-status badge-<%= event.status %>"><%= t("event_statuses.#{event.status}") %></span>
                </div>
              </div>

              <%# Mini stats com barras %>
              <div style="display:flex; gap:1.25rem; padding-top:0.65rem; border-top:1px solid #f4f4f5;">
                <% [
                  ["bi-grid-3x3-gap", sectors_count, "setor", "setores"],
                  ["bi-people", teams_count, "equipe", "equipes"],
                  ["bi-person-badge", members_count, "colaborador", "colaboradores"]
                ].each do |icon, count, sing, plu| %>
                  <div style="display:flex; align-items:center; gap:0.35rem;">
                    <i class="bi <%= icon %>" style="font-size:0.82rem; color:#a1a1aa;"></i>
                    <span style="font-size:0.82rem; font-weight:600; color:#18181b;"><%= count %></span>
                    <span style="font-size:0.75rem; color:#a1a1aa;"><%= count == 1 ? sing : plu %></span>
                  </div>
                <% end %>

                <% if teams_count > 0 && members_count == 0 %>
                  <span style="margin-left:auto; font-size:0.7rem; color:#f59e0b; background:#fffbeb; border:1px solid #fde68a; border-radius:4px; padding:0.1rem 0.5rem;">
                    <i class="bi bi-exclamation-triangle"></i> sem colaboradores escalados
                  </span>
                <% elsif sectors_count > 0 && teams_count == 0 %>
                  <span style="margin-left:auto; font-size:0.7rem; color:#f59e0b; background:#fffbeb; border:1px solid #fde68a; border-radius:4px; padding:0.1rem 0.5rem;">
                    <i class="bi bi-exclamation-triangle"></i> sem equipes formadas
                  </span>
                <% elsif sectors_count == 0 %>
                  <span style="margin-left:auto; font-size:0.7rem; color:#a1a1aa; background:#f9f9f9; border:1px solid #e4e4e7; border-radius:4px; padding:0.1rem 0.5rem;">
                    <i class="bi bi-info-circle"></i> sem setores
                  </span>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# ── Coluna direita ──────────────────────────────────────────────────────── %>
  <div style="display:flex; flex-direction:column; gap:1rem;">

    <%# Status dos eventos (donut SVG) %>
    <div class="content-card" style="padding:1.25rem;">
      <h3 style="font-size:0.82rem; font-weight:600; color:#18181b; margin:0 0 1rem; text-transform:uppercase; letter-spacing:0.06em; color:#71717a;">
        <i class="bi bi-pie-chart"></i> Status dos eventos
      </h3>
      <%
        total_ev = @total_events.to_f
        circ     = 2 * Math::PI * 40   # ≈ 251.33
        statuses = [
          ["active",  @events_by_status["active"].to_i,  "#4ade80", "Ativos"],
          ["draft",   @events_by_status["draft"].to_i,   "#d4d4d8", "Rascunho"],
          ["closed",  @events_by_status["closed"].to_i,  "#27272a", "Encerrados"],
        ]
        offset = circ * 0.25  # start from top
      %>
      <% if @total_events > 0 %>
        <div style="display:flex; align-items:center; gap:1.25rem;">
          <svg viewBox="0 0 100 100" width="90" height="90" style="flex-shrink:0; transform:rotate(-90deg);">
            <circle cx="50" cy="50" r="40" fill="none" stroke="#f4f4f5" stroke-width="14"/>
            <% statuses.each do |_key, count, color, _label|
                 next if count == 0
                 dash = (count / total_ev) * circ
            %>
              <circle cx="50" cy="50" r="40" fill="none"
                      stroke="<%= color %>" stroke-width="14"
                      stroke-dasharray="<%= dash.round(2) %> <%= circ.round(2) %>"
                      stroke-dashoffset="<%= offset.round(2) %>"/>
            <% offset -= (count / total_ev) * circ rescue nil %>
            <% end %>
          </svg>
          <div style="display:flex; flex-direction:column; gap:0.5rem; flex:1;">
            <% statuses.each do |_key, count, color, label| %>
              <div style="display:flex; align-items:center; gap:0.5rem;">
                <div style="width:10px; height:10px; border-radius:2px; background:<%= color %>; flex-shrink:0;"></div>
                <span style="font-size:0.78rem; color:#52525b; flex:1;"><%= label %></span>
                <span style="font-size:0.85rem; font-weight:700; color:#18181b;"><%= count %></span>
              </div>
            <% end %>
          </div>
        </div>
      <% else %>
        <div style="text-align:center; color:#a1a1aa; font-size:0.82rem; padding:1rem 0;">Nenhum evento.</div>
      <% end %>
    </div>

    <%# Resumo rápido %>
    <div class="content-card" style="padding:1.25rem;">
      <h3 style="font-size:0.82rem; font-weight:600; margin:0 0 0.85rem; text-transform:uppercase; letter-spacing:0.06em; color:#71717a;">
        <i class="bi bi-lightning"></i> Resumo
      </h3>
      <div style="display:flex; flex-direction:column; gap:0.6rem;">
        <% [
          ["bi-people-fill",     @total_users,    "colaboradores na empresa",  "#2563eb"],
          ["bi-car-front-fill",  @total_vehicles, "veículos",                  "#52525b"],
          ["bi-grid-3x3-gap-fill", @total_sectors, "setores no total",         "#7c3aed"],
        ].each do |icon, value, label, color| %>
          <div style="display:flex; align-items:center; gap:0.6rem; padding:0.55rem 0.7rem; background:#f9f9f9; border-radius:8px;">
            <div style="width:2rem; height:2rem; background:<%= color %>1a; border-radius:6px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <i class="bi <%= icon %>" style="font-size:0.88rem; color:<%= color %>;"></i>
            </div>
            <div>
              <div style="font-size:1rem; font-weight:700; color:#18181b; line-height:1;"><%= value %></div>
              <div style="font-size:0.72rem; color:#a1a1aa; margin-top:1px;"><%= label %></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Ações rápidas %>
    <div class="content-card" style="padding:1.25rem;">
      <h3 style="font-size:0.82rem; font-weight:600; margin:0 0 0.85rem; text-transform:uppercase; letter-spacing:0.06em; color:#71717a;">
        <i class="bi bi-grid"></i> Ações rápidas
      </h3>
      <div style="display:flex; flex-direction:column; gap:0.4rem;">
        <% [
          [events_path,   "bi-calendar-event", "Eventos"],
          [sectors_path,  "bi-grid-3x3-gap",   "Setores"],
          [teams_path,    "bi-people",          "Equipes"],
          [users_path,    "bi-person-badge",    "Colaboradores"],
          [vehicles_path, "bi-car-front",       "Veículos"],
        ].each do |path, icon, label| %>
          <%= link_to path, style: "display:flex; align-items:center; gap:0.6rem; padding:0.5rem 0.7rem; border-radius:7px; text-decoration:none; color:#3f3f46; font-size:0.83rem; transition:background 0.1s;",
                onmouseover: "this.style.background='#f4f4f5'",
                onmouseout:  "this.style.background='transparent'" do %>
            <i class="bi <%= icon %>" style="color:#71717a; font-size:0.9rem; width:1.1rem; text-align:center;"></i>
            <%= label %>
            <i class="bi bi-chevron-right" style="margin-left:auto; font-size:0.7rem; color:#d4d4d8;"></i>
          <% end %>
        <% end %>
      </div>
    </div>

  </div>
</div>
