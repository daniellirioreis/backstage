<%
  hour     = Time.current.hour
  greeting = hour < 12 ? "Bom dia" : hour < 18 ? "Boa tarde" : "Boa noite"
  company_without_plan = !current_user.admin? && current_event&.company && current_event.company.plan.nil?
%>

<% if company_without_plan %>
  <div style="background:#fef2f2;border:1px solid #fca5a5;border-radius:10px;padding:1rem 1.25rem;margin-bottom:1.5rem;display:flex;align-items:flex-start;gap:0.85rem;">
    <i class="bi bi-exclamation-circle-fill" style="color:#dc2626;font-size:1.3rem;flex-shrink:0;margin-top:1px;"></i>
    <div>
      <div style="font-size:0.9rem;font-weight:700;color:#991b1b;margin-bottom:0.2rem;">Empresa sem plano ativo</div>
      <div style="font-size:0.82rem;color:#b91c1c;line-height:1.5;">
        A empresa <strong><%= current_event.company.name %></strong> não possui um plano vinculado.
        As funcionalidades do sistema estão bloqueadas até que um plano seja contratado.
      </div>
    </div>
  </div>
<% end %>

<%# ── Header ──────────────────────────────────────────────────────────────── %>
<div class="page-header" style="margin-bottom:1.5rem;">
  <div>
    <h1 style="margin:0;"><%= greeting %>, <%= current_user.name.split.first %> 👋</h1>
    <div style="font-size:0.82rem;color:#71717a;margin-top:0.2rem;">
      <%= l(Date.today, format: :long) %>
    </div>
  </div>
  <% if policy(Event).new? %>
    <%= link_to new_event_path, class: "btn-primary" do %>
      <i class="bi bi-plus"></i> Novo evento
    <% end %>
  <% end %>
</div>

<%# ── Painel do evento atual ──────────────────────────────────────────────── %>
<% if current_event %>
  <%
    ev_status_color = current_event.active? ? "#4ade80" : current_event.draft? ? "#a1a1aa" : "#71717a"
    ev_status_bg    = current_event.active? ? "#052e16" : current_event.draft? ? "#27272a" : "#18181b"
  %>
  <div style="background:#18181b;border-radius:14px;padding:0;margin-bottom:1.5rem;overflow:hidden;">

    <%# Cabeçalho do evento %>
    <div style="padding:1.25rem 1.5rem;border-bottom:1px solid #27272a;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
      <div style="min-width:0;">
        <div style="display:flex;align-items:center;gap:0.6rem;flex-wrap:wrap;margin-bottom:0.3rem;">
          <span style="font-size:1.1rem;font-weight:700;color:#f4f4f5;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= current_event.name %></span>
          <span style="font-size:0.65rem;font-weight:700;background:<%= ev_status_color %>22;border:1px solid <%= ev_status_color %>55;color:<%= ev_status_color %>;border-radius:5px;padding:2px 8px;letter-spacing:0.06em;text-transform:uppercase;">
            <%= t("event_statuses.#{current_event.status}") %>
          </span>
          <% if current_event.closing_finalized_at? %>
            <span style="font-size:0.65rem;font-weight:700;background:#dcfce7;border:1px solid #86efac;color:#15803d;border-radius:5px;padding:2px 8px;letter-spacing:0.04em;display:inline-flex;align-items:center;gap:3px;">
              <i class="bi bi-check-circle-fill"></i> Fechamento finalizado
            </span>
          <% end %>
        </div>
        <div style="display:flex;gap:1rem;flex-wrap:wrap;">
          <span style="font-size:0.75rem;color:#71717a;">
            <i class="bi bi-calendar3"></i>
            <%= l(current_event.start_date, format: :short) %> → <%= l(current_event.end_date, format: :short) %>
          </span>
          <% if current_event.location.present? %>
            <span style="font-size:0.75rem;color:#71717a;">
              <i class="bi bi-geo-alt"></i> <%= current_event.location %>
            </span>
          <% end %>
        </div>
      </div>
      <%= link_to event_path(current_event), style: "font-size:0.78rem;color:#71717a;text-decoration:none;display:flex;align-items:center;gap:0.3rem;white-space:nowrap;flex-shrink:0;" do %>
        Ver evento <i class="bi bi-arrow-right"></i>
      <% end %>
    </div>

    <%# Stats contextuais por status %>
    <% if current_event.active? %>
      <%# Stats de presença (evento ativo) %>
      <div class="ev-stats-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:0;">
        <% [
          ["bi-box-arrow-in-right", @ev_checkins_today,  "check-ins hoje",  "#4ade80", "#052e16"],
          ["bi-person-check-fill",  @ev_inside_now,      "dentro agora",    "#60a5fa", "#0c1a2e"],
          ["bi-box-arrow-right",    @ev_checkouts_today, "checkouts",       "#a78bfa", "#1a0f2e"],
          ["bi-calendar-week",      @ev_expected_today,  "escalados hoje",  "#f59e0b", "#1c1004"],
        ].each do |icon, val, label, color, bg| %>
          <div style="padding:1.1rem 1rem;text-align:center;background:<%= bg %>;border-right:1px solid #27272a;">
            <div style="font-size:1.6rem;font-weight:800;color:<%= color %>;line-height:1;"><%= val %></div>
            <div style="font-size:0.68rem;color:#52525b;margin-top:4px;white-space:nowrap;"><i class="bi <%= icon %>" style="color:<%= color %>;opacity:0.7;"></i> <%= label %></div>
          </div>
        <% end %>
      </div>

    <% elsif current_event.draft? %>
      <%# Stats de configuração (rascunho) %>
      <div class="ev-stats-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:0;">
        <% [
          ["bi-grid-3x3-gap", @ev_sectors, "setores",      "#60a5fa"],
          ["bi-people",       @ev_teams,   "equipes",      "#a78bfa"],
          ["bi-person-badge", @ev_members, "colaboradores","#4ade80"],
          ["bi-cash-stack",   nil,         "custo est.",   "#f59e0b"],
        ].each_with_index do |(icon, val, label, color), i| %>
          <div style="padding:1.1rem 1rem;text-align:center;border-right:1px solid #27272a;">
            <% if i == 3 %>
              <div style="font-size:1.1rem;font-weight:800;color:<%= color %>;line-height:1;">
                <%= number_to_currency(@ev_cost, unit:"R$", separator:",", delimiter:".", precision:0) %>
              </div>
            <% else %>
              <div style="font-size:1.6rem;font-weight:800;color:<%= color %>;line-height:1;"><%= val %></div>
            <% end %>
            <div style="font-size:0.68rem;color:#52525b;margin-top:4px;"><i class="bi <%= icon %>" style="color:<%= color %>;opacity:0.7;"></i> <%= label %></div>
          </div>
        <% end %>
      </div>

    <% elsif current_event.closed? %>
      <%# Stats de fechamento %>
      <div class="ev-stats-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:0;">
        <% [
          ["bi-people",           @ev_members,         "colaboradores",   "#60a5fa"],
          ["bi-person-check",     @ev_present.to_i,    "compareceram",    "#4ade80"],
          ["bi-receipt",          @ev_total_checkins.to_i, "check-ins",   "#a78bfa"],
          ["bi-cash-stack",       nil,                 "pago",            "#f59e0b"],
        ].each_with_index do |(icon, val, label, color), i| %>
          <div style="padding:1.1rem 1rem;text-align:center;border-right:1px solid #27272a;">
            <% if i == 3 %>
              <div style="font-size:1.1rem;font-weight:800;color:<%= color %>;line-height:1;">
                <%= number_to_currency(@ev_paid.to_f, unit:"R$", separator:",", delimiter:".", precision:0) %>
              </div>
            <% else %>
              <div style="font-size:1.6rem;font-weight:800;color:<%= color %>;line-height:1;"><%= val %></div>
            <% end %>
            <div style="font-size:0.68rem;color:#52525b;margin-top:4px;"><i class="bi <%= icon %>" style="color:<%= color %>;opacity:0.7;"></i> <%= label %></div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Ações rápidas %>
    <div style="padding:0.85rem 1.25rem;border-top:1px solid #27272a;display:flex;gap:0.5rem;flex-wrap:wrap;">
      <% if current_event.active? %>
        <% if policy(:attendance).scan? %>
          <%= link_to scan_attendances_path, style: "display:inline-flex;align-items:center;gap:0.4rem;background:#4ade80;color:#052e16;font-size:0.78rem;font-weight:700;border-radius:7px;padding:0.4rem 0.9rem;text-decoration:none;" do %>
            <i class="bi bi-qr-code-scan"></i> Check-in
          <% end %>
        <% end %>
        <% if policy(:attendance).index? %>
          <%= link_to attendances_path, style: "display:inline-flex;align-items:center;gap:0.4rem;background:#1f1f1f;color:#a1a1aa;font-size:0.78rem;font-weight:600;border-radius:7px;padding:0.4rem 0.9rem;text-decoration:none;" do %>
            <i class="bi bi-person-check"></i> Presenças
          <% end %>
        <% end %>
        <% if policy(Team).index? %>
          <%= link_to teams_path, style: "display:inline-flex;align-items:center;gap:0.4rem;background:#1f1f1f;color:#a1a1aa;font-size:0.78rem;font-weight:600;border-radius:7px;padding:0.4rem 0.9rem;text-decoration:none;" do %>
            <i class="bi bi-people"></i> Equipes
          <% end %>
        <% end %>
      <% elsif current_event.draft? %>
        <% if policy(Sector).index? %>
          <%= link_to sectors_path, style: "display:inline-flex;align-items:center;gap:0.4rem;background:#60a5fa22;color:#60a5fa;border:1px solid #60a5fa44;font-size:0.78rem;font-weight:600;border-radius:7px;padding:0.4rem 0.9rem;text-decoration:none;" do %>
            <i class="bi bi-diagram-3"></i> Setores
          <% end %>
        <% end %>
        <% if policy(Team).index? %>
          <%= link_to teams_path, style: "display:inline-flex;align-items:center;gap:0.4rem;background:#a78bfa22;color:#a78bfa;border:1px solid #a78bfa44;font-size:0.78rem;font-weight:600;border-radius:7px;padding:0.4rem 0.9rem;text-decoration:none;" do %>
            <i class="bi bi-people"></i> Equipes
          <% end %>
        <% end %>
        <% if policy(Shift).index? %>
          <%= link_to timeline_shifts_path, style: "display:inline-flex;align-items:center;gap:0.4rem;background:#4ade8022;color:#4ade80;border:1px solid #4ade8044;font-size:0.78rem;font-weight:600;border-radius:7px;padding:0.4rem 0.9rem;text-decoration:none;" do %>
            <i class="bi bi-calendar-range"></i> Escalas
          <% end %>
        <% end %>
        <% if policy(current_event).edit? %>
          <%= link_to edit_event_path(current_event), style: "display:inline-flex;align-items:center;gap:0.4rem;background:#1f1f1f;color:#71717a;font-size:0.78rem;font-weight:600;border-radius:7px;padding:0.4rem 0.9rem;text-decoration:none;" do %>
            <i class="bi bi-pencil"></i> Editar evento
          <% end %>
        <% end %>
      <% elsif current_event.closed? %>
        <% if current_event.closing_finalized_at? %>
          <span style="display:inline-flex;align-items:center;gap:0.4rem;background:#dcfce7;border:1px solid #86efac;color:#15803d;font-size:0.78rem;font-weight:700;border-radius:7px;padding:0.4rem 0.9rem;">
            <i class="bi bi-check-circle-fill"></i> Fechamento concluído
          </span>
        <% elsif policy(:report).closing? %>
          <%= link_to reports_closing_path, style: "display:inline-flex;align-items:center;gap:0.4rem;background:#f59e0b;color:#1c1004;font-size:0.78rem;font-weight:700;border-radius:7px;padding:0.4rem 0.9rem;text-decoration:none;" do %>
            <i class="bi bi-receipt"></i> Relatório de fechamento
          <% end %>
        <% end %>
        <%= link_to reports_closing_path, style: "display:inline-flex;align-items:center;gap:0.4rem;background:#1f1f1f;color:#71717a;font-size:0.78rem;font-weight:600;border-radius:7px;padding:0.4rem 0.9rem;text-decoration:none;" do %>
          <i class="bi bi-receipt"></i> <%= current_event.closing_finalized_at? ? "Ver fechamento" : "Relatório de fechamento" %>
        <% end %>
        <%= link_to reports_closing_export_path(basis: "cross"), style: "display:inline-flex;align-items:center;gap:0.4rem;background:#1f1f1f;color:#71717a;font-size:0.78rem;font-weight:600;border-radius:7px;padding:0.4rem 0.9rem;text-decoration:none;" do %>
          <i class="bi bi-file-earmark-spreadsheet"></i> Exportar CSV
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<%# ── Cards de métricas globais ───────────────────────────────────────────── %>
<div class="dash-metrics-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:0.75rem;margin-bottom:1.75rem;">
  <div class="metric-card" style="border-top:3px solid #18181b;">
    <div class="metric-label"><i class="bi bi-calendar-event"></i> Eventos</div>
    <div class="metric-value"><%= @total_events %></div>
    <div class="metric-sub">no total</div>
  </div>
  <div class="metric-card" style="border-top:3px solid #4ade80;">
    <div class="metric-label"><i class="bi bi-broadcast"></i> Ativos</div>
    <div class="metric-value metric-accent"><%= @active_events %></div>
    <div class="metric-sub">em andamento</div>
  </div>
  <div class="metric-card" style="border-top:3px solid #f59e0b;">
    <div class="metric-label"><i class="bi bi-person-badge"></i> Colaboradores</div>
    <div class="metric-value metric-warn"><%= @total_users %></div>
    <div class="metric-sub">cadastrados</div>
  </div>
  <div class="metric-card" style="border-top:3px solid #16a34a;">
    <div class="metric-label"><i class="bi bi-cash-stack"></i> Custo médio</div>
    <div class="metric-value" style="font-size:1.1rem;color:#15803d;">
      <%= number_to_currency(@total_events > 0 ? @total_cost / @total_events : 0, unit:"R$", separator:",", delimiter:".", precision:0) %>
    </div>
    <div class="metric-sub">por evento</div>
  </div>
</div>

<%# ── Layout em duas colunas ─────────────────────────────────────────────── %>
<div class="dash-main-grid" style="display:grid;grid-template-columns:1fr 260px;gap:1.25rem;align-items:start;">

  <%# ── Lista de eventos ──────────────────────────────────────────────────── %>
  <div>
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
      <h2 style="font-size:0.9rem;font-weight:700;color:#18181b;margin:0;text-transform:uppercase;letter-spacing:0.05em;">
        <i class="bi bi-calendar-event" style="color:#a1a1aa;"></i> Eventos
      </h2>
      <% if policy(Event).index? %>
        <%= link_to "Ver todos →", events_path, style: "font-size:0.75rem;color:#71717a;text-decoration:none;" %>
      <% end %>
    </div>

    <% if @events.empty? %>
      <div class="content-card" style="text-align:center;color:#a1a1aa;font-size:0.85rem;padding:2.5rem;">
        <i class="bi bi-calendar-event" style="font-size:2rem;display:block;margin-bottom:0.75rem;color:#d4d4d8;"></i>
        Nenhum evento cadastrado ainda.
        <% if policy(Event).new? %>
          <div style="margin-top:0.75rem;">
            <%= link_to new_event_path, class: "btn-primary" do %><i class="bi bi-plus"></i> Criar evento<% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div style="display:flex;flex-direction:column;gap:0.5rem;">
        <% @events.each do |event|
             sectors_count = event.sectors.size
             teams_count   = event.sectors.sum { |s| s.teams.size }
             members_count = event.sectors.flat_map(&:teams).flat_map(&:team_memberships).map(&:user_id).uniq.size
             is_current    = event.id == current_event&.id
             status_color  = event.active? ? "#4ade80" : event.draft? ? "#d4d4d8" : "#27272a"
             days_label    = if event.start_date > Date.today
               diff = (event.start_date - Date.today).to_i
               diff == 1 ? "amanhã" : "em #{diff} dias"
             elsif event.end_date >= Date.today
               "em andamento"
             else
               diff = (Date.today - event.end_date).to_i
               diff == 1 ? "ontem" : "há #{diff} dias"
             end
        %>
          <%= link_to event_path(event), style: "text-decoration:none;display:block;" do %>
            <div class="content-card" style="padding:0;overflow:hidden;<%= is_current ? 'box-shadow:0 0 0 2px #18181b;' : '' %>;transition:box-shadow 0.15s;">
              <div style="height:3px;background:<%= status_color %>;"></div>
              <div style="padding:0.85rem 1rem;display:flex;align-items:center;gap:1rem;">
                <div style="flex:1;min-width:0;">
                  <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.25rem;">
                    <span style="font-size:0.88rem;font-weight:600;color:#18181b;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= event.name %></span>
                    <% if is_current %>
                      <span style="font-size:0.6rem;font-weight:700;background:#18181b;color:#fff;border-radius:3px;padding:1px 5px;letter-spacing:0.04em;">ATUAL</span>
                    <% end %>
                  </div>
                  <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
                    <span style="font-size:0.72rem;color:#a1a1aa;"><i class="bi bi-calendar3"></i> <%= l(event.start_date, format: :short) %> → <%= l(event.end_date, format: :short) %></span>
                    <span style="font-size:0.72rem;color:#a1a1aa;font-style:italic;"><%= days_label %></span>
                  </div>
                </div>
                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:0.4rem;flex-shrink:0;">
                  <div style="display:flex;align-items:center;gap:0.35rem;flex-wrap:wrap;justify-content:flex-end;">
                    <span class="badge-status badge-<%= event.status %>"><%= t("event_statuses.#{event.status}") %></span>
                    <% if event.closing_finalized_at? %>
                      <span style="font-size:0.6rem;font-weight:700;background:#dcfce7;border:1px solid #86efac;color:#15803d;border-radius:4px;padding:1px 6px;display:inline-flex;align-items:center;gap:2px;">
                        <i class="bi bi-check-circle-fill"></i> Fechamento ok
                      </span>
                    <% end %>
                  </div>
                  <div style="display:flex;gap:0.75rem;">
                    <span style="font-size:0.72rem;color:#a1a1aa;"><i class="bi bi-grid-3x3-gap"></i> <%= sectors_count %></span>
                    <span style="font-size:0.72rem;color:#a1a1aa;"><i class="bi bi-people"></i> <%= teams_count %></span>
                    <span style="font-size:0.72rem;color:#a1a1aa;"><i class="bi bi-person-badge"></i> <%= members_count %></span>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# ── Coluna direita ─────────────────────────────────────────────────────── %>
  <div style="display:flex;flex-direction:column;gap:1rem;">

    <%# Distribuição de status %>
    <div class="content-card" style="padding:1.1rem;">
      <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#a1a1aa;margin-bottom:0.85rem;">
        <i class="bi bi-pie-chart"></i> Status dos eventos
      </div>
      <% if @total_events > 0
           total_ev = @total_events.to_f
           circ     = 2 * Math::PI * 40
           statuses = [
             ["active",  @events_by_status["active"].to_i,  "#4ade80", "Ativos"],
             ["draft",   @events_by_status["draft"].to_i,   "#d4d4d8", "Rascunho"],
             ["closed",  @events_by_status["closed"].to_i,  "#27272a", "Encerrados"],
           ]
           offset = circ * 0.25
      %>
        <div style="display:flex;align-items:center;gap:1rem;">
          <svg viewBox="0 0 100 100" width="80" height="80" style="flex-shrink:0;transform:rotate(-90deg);">
            <circle cx="50" cy="50" r="40" fill="none" stroke="#f4f4f5" stroke-width="16"/>
            <% statuses.each do |_key, count, color, _label|
                 next if count == 0
                 dash = (count / total_ev) * circ %>
              <circle cx="50" cy="50" r="40" fill="none" stroke="<%= color %>" stroke-width="16"
                      stroke-dasharray="<%= dash.round(2) %> <%= circ.round(2) %>"
                      stroke-dashoffset="<%= offset.round(2) %>"/>
            <% offset -= (count / total_ev) * circ rescue nil %>
            <% end %>
          </svg>
          <div style="display:flex;flex-direction:column;gap:0.45rem;flex:1;">
            <% statuses.each do |_key, count, color, label| %>
              <div style="display:flex;align-items:center;gap:0.4rem;">
                <div style="width:8px;height:8px;border-radius:2px;background:<%= color %>;flex-shrink:0;"></div>
                <span style="font-size:0.75rem;color:#52525b;flex:1;"><%= label %></span>
                <span style="font-size:0.82rem;font-weight:700;color:#18181b;"><%= count %></span>
              </div>
            <% end %>
          </div>
        </div>
      <% else %>
        <div style="text-align:center;color:#a1a1aa;font-size:0.82rem;padding:0.5rem 0;">Nenhum evento.</div>
      <% end %>
    </div>

    <%# Gasto médio por tipo de setor %>
    <% if @sectors_by_type.any? %>
      <div class="content-card" style="padding:1.1rem;">
        <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#a1a1aa;margin-bottom:0.85rem;">
          <i class="bi bi-grid-3x3-gap"></i> Gasto médio por tipo de setor
        </div>
        <div style="display:flex;flex-direction:column;gap:0.4rem;">
          <% @sectors_by_type
               .sort_by { |type, _| -(@cost_by_sector_type[type] || 0) }
               .each do |type, count| %>
            <% total = @cost_by_sector_type[type].to_f %>
            <% avg   = count > 0 ? total / count : 0 %>
            <% max_avg = @sectors_by_type.keys.map { |t| @cost_by_sector_type[t].to_f / @sectors_by_type[t] }.max.to_f %>
            <% pct = max_avg > 0 ? [(avg / max_avg * 100).round, 100].min : 0 %>
            <div style="padding:0.45rem 0.65rem;background:#f9f9f9;border-radius:7px;">
              <div style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem;margin-bottom:3px;">
                <span style="font-size:0.75rem;font-weight:600;color:#18181b;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                  <%= I18n.t("sector_types.#{type}", default: type.humanize) %>
                </span>
                <span style="font-size:0.7rem;color:#a1a1aa;flex-shrink:0;"><%= count %> setor<%= count == 1 ? "" : "es" %></span>
              </div>
              <div style="display:flex;align-items:center;gap:0.5rem;">
                <div style="flex:1;height:4px;background:#e4e4e7;border-radius:99px;overflow:hidden;">
                  <div style="height:100%;width:<%= pct %>%;background:#18181b;border-radius:99px;"></div>
                </div>
                <span style="font-size:0.72rem;font-weight:700;color:#18181b;flex-shrink:0;min-width:52px;text-align:right;">
                  <%= number_to_currency(avg, unit:"R$", separator:",", delimiter:".", precision:0) %>
                </span>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

  </div>
</div>
