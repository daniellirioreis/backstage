<div class="auth-card">
  <div style="display:flex; flex-direction:column; align-items:center; margin-bottom:1.75rem;">
    <%= render "shared/logo", size: :lg, stacked: true, dark: true %>
  </div>
  <div class="auth-subtitle">Faça login para continuar</div>

  <%= render "devise/shared/error_messages", resource: resource %>

  <% if flash[:notice] %>
    <div class="flash-notice" style="margin-bottom:1rem;">
      <i class="bi bi-check-circle"></i> <%= flash[:notice] %>
    </div>
  <% end %>

  <% if flash[:alert] %>
    <div class="flash-alert" style="margin-bottom:1rem;">
      <i class="bi bi-exclamation-circle"></i> <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { data: { turbo: false } }) do |f| %>
    <div class="mb-3">
      <%= f.label :email, "E-mail", class: "form-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
    </div>
    <div class="mb-3">
      <%= f.label :password, "Senha", class: "form-label" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "form-control" %>
    </div>
    <div class="mb-4" style="display: flex; align-items: center; gap: 0.5rem;">
      <%= f.check_box :remember_me, class: "form-check-input", style: "margin: 0;" %>
      <%= f.label :remember_me, "Lembrar de mim", class: "form-label", style: "margin: 0; cursor: pointer;" %>
    </div>
    <%= f.submit "Entrar", class: "btn-primary" %>
  <% end %>

  <% if devise_mapping.recoverable? %>
    <div style="text-align: center; margin-top: 1.25rem;">
      <%= link_to "Esqueceu sua senha?", new_password_path(resource_name) %>
    </div>
  <% end %>
</div>
