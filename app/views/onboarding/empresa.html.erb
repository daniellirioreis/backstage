<%# Progress %>
<div style="display:flex; gap:0.5rem; margin-bottom:1.75rem;">
  <% [["Empresa", true], ["Plano", false], ["Evento", false], ["Concluído", false]].each_with_index do |(label, active), i| %>
    <div style="flex:1; text-align:center;">
      <div style="font-size:0.7rem; font-weight:<%= active ? 700 : 400 %>; color:<%= active ? '#18181b' : '#a1a1aa' %>; margin-bottom:0.35rem;"><%= label %></div>
      <div style="height:3px; border-radius:2px; background:<%= active ? '#18181b' : '#e4e4e7' %>;"></div>
    </div>
  <% end %>
</div>

<h2 style="font-size:1.1rem; font-weight:700; color:#18181b; margin:0 0 0.25rem;">Sua empresa</h2>
<p style="font-size:0.83rem; color:#71717a; margin:0 0 1.5rem;">Essas informações identificam sua empresa no sistema. Pode editar depois.</p>

<%= form_with url: url_for(action: :save_empresa), method: :post do |f| %>
  <div style="display:flex; flex-direction:column; gap:1rem;">
    <div>
      <label style="display:block; font-size:0.8rem; font-weight:500; color:#374151; margin-bottom:0.3rem;">Nome da empresa <span style="color:#dc2626;">*</span></label>
      <input type="text" name="company[name]" required
             value="<%= @company&.name %>"
             style="width:100%; box-sizing:border-box; border:1px solid #d1d5db; border-radius:8px; padding:0.55rem 0.75rem; font-size:0.875rem; color:#18181b; outline:none;"
             placeholder="Ex: AX Produções" />
      <% if @company&.errors&.[](:name)&.any? %>
        <p style="font-size:0.75rem; color:#dc2626; margin:0.25rem 0 0;"><%= @company.errors[:name].first %></p>
      <% else %>
        <p style="font-size:0.75rem; color:#71717a; margin:0.25rem 0 0;"><i class="bi bi-info-circle"></i> Aparece em relatórios, credenciais e na lista de eventos.</p>
      <% end %>
    </div>

    <div>
      <label style="display:block; font-size:0.8rem; font-weight:500; color:#374151; margin-bottom:0.3rem;">CNPJ <span style="color:#a1a1aa; font-weight:400;">(opcional)</span></label>
      <input type="text" name="company[cnpj]"
             value="<%= @company&.cnpj %>"
             style="width:100%; box-sizing:border-box; border:1px solid #d1d5db; border-radius:8px; padding:0.55rem 0.75rem; font-size:0.875rem; color:#18181b; outline:none;"
             placeholder="00.000.000/0000-00" />
      <p style="font-size:0.75rem; color:#71717a; margin:0.25rem 0 0;"><i class="bi bi-info-circle"></i> Usado só para identificação fiscal — pode preencher depois.</p>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
      <div>
        <label style="display:block; font-size:0.8rem; font-weight:500; color:#374151; margin-bottom:0.3rem;">Cidade</label>
        <input type="text" name="company[city]"
               value="<%= @company&.city %>"
               style="width:100%; box-sizing:border-box; border:1px solid #d1d5db; border-radius:8px; padding:0.55rem 0.75rem; font-size:0.875rem; color:#18181b; outline:none;"
               placeholder="São Paulo" />
      </div>
      <div>
        <label style="display:block; font-size:0.8rem; font-weight:500; color:#374151; margin-bottom:0.3rem;">Estado</label>
        <input type="text" name="company[state]" maxlength="2"
               value="<%= @company&.state %>"
               style="width:100%; box-sizing:border-box; border:1px solid #d1d5db; border-radius:8px; padding:0.55rem 0.75rem; font-size:0.875rem; color:#18181b; outline:none;"
               placeholder="SP" />
      </div>
    </div>
    <p style="font-size:0.75rem; color:#71717a; margin:0.25rem 0 0;"><i class="bi bi-info-circle"></i> Opcional — ajuda a organizar eventos por região.</p>

    <button type="submit"
            style="width:100%; background:#18181b; color:#fff; border:none; border-radius:8px; padding:0.65rem; font-size:0.875rem; font-weight:600; cursor:pointer; margin-top:0.25rem;">
      Criar empresa e continuar →
    </button>
  </div>
<% end %>
