<%# Progress %>
<div style="display:flex; gap:0.5rem; margin-bottom:1.75rem;">
  <% [["Empresa", false], ["Plano", false], ["Pagamento", false], ["Evento", true], ["Concluído", false]].each_with_index do |(label, active), i| %>
    <div style="flex:1; text-align:center;">
      <div style="font-size:0.7rem; font-weight:<%= active ? 700 : 400 %>; color:<%= active ? '#18181b' : '#a1a1aa' %>; margin-bottom:0.35rem;"><%= label %></div>
      <div style="height:3px; border-radius:2px; background:<%= active ? '#18181b' : (i == 0 ? '#18181b' : '#e4e4e7') %>;"></div>
    </div>
  <% end %>
</div>

<% if @preset_events&.any? %>
  <%# Empresa já tem eventos — somente leitura %>
  <div style="text-align:center; padding:0.5rem 0 1.25rem;">
    <div style="width:3.5rem; height:3.5rem; background:#f0fdf4; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1rem;">
      <i class="bi bi-calendar-check" style="font-size:1.5rem; color:#16a34a;"></i>
    </div>
    <h2 style="font-size:1.1rem; font-weight:700; color:#18181b; margin:0 0 0.4rem;">Eventos já cadastrados</h2>
    <p style="font-size:0.83rem; color:#71717a; margin:0 0 1.25rem; line-height:1.5;">
      A empresa já possui eventos. Você pode acessar o sistema agora.
    </p>
  </div>

  <div style="display:flex; flex-direction:column; gap:0.5rem; margin-bottom:1.5rem;">
    <% @preset_events.first(3).each do |ev| %>
      <div style="background:#f4f4f5; border:1px solid #e4e4e7; border-radius:8px; padding:0.7rem 1rem; display:flex; align-items:center; gap:0.75rem;">
        <i class="bi bi-calendar3" style="color:#71717a; font-size:0.95rem;"></i>
        <div>
          <div style="font-size:0.85rem; font-weight:600; color:#18181b;"><%= ev.name %></div>
          <div style="font-size:0.72rem; color:#71717a;"><%= I18n.l(ev.start_date, format: :short) %> – <%= I18n.l(ev.end_date, format: :short) %></div>
        </div>
        <i class="bi bi-lock-fill" style="color:#a1a1aa; font-size:0.8rem; margin-left:auto;"></i>
      </div>
    <% end %>
  </div>

  <%= button_to onboarding_evento_path, method: :post,
        style: "width:100%; background:#18181b; color:#fff; border:none; border-radius:8px; padding:0.65rem; font-size:0.875rem; font-weight:600; cursor:pointer; text-align:center;" do %>
    Acessar o sistema →
  <% end %>

<% else %>

<%# Pergunta inicial %>
<div id="panel-pergunta">
  <div style="text-align:center; padding:0.5rem 0 1.5rem;">
    <div style="width:3.5rem; height:3.5rem; background:#f4f4f5; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1rem;">
      <i class="bi bi-calendar-event" style="font-size:1.5rem; color:#18181b;"></i>
    </div>
    <h2 style="font-size:1.1rem; font-weight:700; color:#18181b; margin:0 0 0.5rem;">Deseja criar um evento agora?</h2>
    <p style="font-size:0.83rem; color:#71717a; margin:0 0 1.75rem; line-height:1.5;">
      Você pode cadastrar seu primeiro evento agora ou fazer isso depois — nada muda no acesso ao sistema.
    </p>

    <div style="display:flex; flex-direction:column; gap:0.65rem;">
      <button type="button" onclick="mostrarFormulario()"
              style="width:100%; background:#18181b; color:#fff; border:none; border-radius:8px; padding:0.7rem; font-size:0.875rem; font-weight:600; cursor:pointer;">
        <i class="bi bi-plus-circle"></i> Sim, criar evento agora
      </button>

      <%= button_to onboarding_skip_evento_path,
            method: :post,
            style: "width:100%; background:#fff; color:#71717a; border:1px solid #d1d5db; border-radius:8px; padding:0.7rem; font-size:0.875rem; font-weight:500; cursor:pointer; text-align:center;" do %>
        Não, fazer isso depois
      <% end %>
    </div>
  </div>
</div>

<%# Formulário de criação do evento (oculto inicialmente) %>
<div id="panel-formulario" style="display:none;">
  <h2 style="font-size:1.1rem; font-weight:700; color:#18181b; margin:0 0 0.25rem;">Primeiro evento</h2>
  <p style="font-size:0.83rem; color:#71717a; margin:0 0 1.25rem;">Pode editar todas as informações depois, na aba <strong>Dados do evento</strong>.</p>

  <%= form_with model: @event, url: url_for(action: :save_evento), method: :post do |f| %>
    <div style="display:flex; flex-direction:column; gap:1rem;">

      <div>
        <label style="display:block; font-size:0.8rem; font-weight:500; color:#374151; margin-bottom:0.3rem;">Nome do evento <span style="color:#dc2626;">*</span></label>
        <%= f.text_field :name, required: true,
              style: "width:100%; box-sizing:border-box; border:1px solid #d1d5db; border-radius:8px; padding:0.55rem 0.75rem; font-size:0.875rem; color:#18181b; outline:none;",
              placeholder: "Ex: Festival Boombay 2026" %>
        <% if @event.errors[:name].any? %>
          <p style="font-size:0.75rem; color:#dc2626; margin:0.25rem 0 0;"><%= @event.errors[:name].first %></p>
        <% else %>
          <p style="font-size:0.75rem; color:#71717a; margin:0.25rem 0 0;"><i class="bi bi-info-circle"></i> Use um nome que a equipe reconheça facilmente.</p>
        <% end %>
      </div>

      <div>
        <label style="display:block; font-size:0.8rem; font-weight:500; color:#374151; margin-bottom:0.3rem;">Tipo de evento <span style="color:#dc2626;">*</span></label>
        <% event_type_groups = {
          "Shows e Cultura"  => %w[show festival concert theater dance circus opera stand_up],
          "Esportivo"        => %w[sports race tournament championship],
          "Corporativo"      => %w[corporate conference seminar workshop hackathon trade_show product_launch award_ceremony],
          "Social"           => %w[wedding graduation birthday debutante social_gathering new_year carnival],
          "Cultural"         => %w[cultural art_exhibition gastronomy religious church_service],
          "Educacional"      => %w[educational lecture governmental],
          "Outro"            => %w[other]
        } %>
        <%= f.select :event_type,
              event_type_groups.flat_map { |group, types|
                [["── #{group} ──", nil, { disabled: true }]] +
                types.map { |t| [I18n.t("event_types.#{t}", default: t.humanize), t] }
              },
              { include_blank: "Selecione o tipo..." },
              required: true,
              style: "width:100%; box-sizing:border-box; border:1px solid #d1d5db; border-radius:8px; padding:0.55rem 0.75rem; font-size:0.875rem; color:#18181b; outline:none; background:#fff;" %>
        <% if @event.errors[:event_type].any? %>
          <p style="font-size:0.75rem; color:#dc2626; margin:0.25rem 0 0;"><%= @event.errors[:event_type].first %></p>
        <% end %>
      </div>

      <div>
        <label style="display:block; font-size:0.8rem; font-weight:500; color:#374151; margin-bottom:0.3rem;">Local <span style="color:#dc2626;">*</span></label>
        <%= f.text_field :location, required: true,
              style: "width:100%; box-sizing:border-box; border:1px solid #d1d5db; border-radius:8px; padding:0.55rem 0.75rem; font-size:0.875rem; color:#18181b; outline:none;",
              placeholder: "Ex: Parque Olímpico, Rio de Janeiro" %>
        <% if @event.errors[:location].any? %>
          <p style="font-size:0.75rem; color:#dc2626; margin:0.25rem 0 0;"><%= @event.errors[:location].first %></p>
        <% end %>
      </div>

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
        <div>
          <label style="display:block; font-size:0.8rem; font-weight:500; color:#374151; margin-bottom:0.3rem;">Data de início <span style="color:#dc2626;">*</span></label>
          <%= f.date_field :start_date, required: true,
                style: "width:100%; box-sizing:border-box; border:1px solid #d1d5db; border-radius:8px; padding:0.55rem 0.75rem; font-size:0.875rem; color:#18181b; outline:none;" %>
        </div>
        <div>
          <label style="display:block; font-size:0.8rem; font-weight:500; color:#374151; margin-bottom:0.3rem;">Data de término <span style="color:#dc2626;">*</span></label>
          <%= f.date_field :end_date, required: true,
                style: "width:100%; box-sizing:border-box; border:1px solid #d1d5db; border-radius:8px; padding:0.55rem 0.75rem; font-size:0.875rem; color:#18181b; outline:none;" %>
        </div>
      </div>
      <% if @event.errors[:end_date].any? %>
        <p style="font-size:0.75rem; color:#dc2626; margin:0.25rem 0 0;"><%= @event.errors[:end_date].first %></p>
      <% else %>
        <p style="font-size:0.75rem; color:#71717a; margin:0.25rem 0 0;"><i class="bi bi-info-circle"></i> As datas geram os dias disponíveis para configurar as escalas.</p>
      <% end %>

      <% if @event.errors.any? %>
        <div style="background:#fef2f2; border:1px solid #fca5a5; border-radius:8px; padding:0.65rem 1rem; font-size:0.82rem; color:#dc2626;">
          <% @event.errors.full_messages.each do |msg| %><div><%= msg %></div><% end %>
        </div>
      <% end %>

      <button type="submit"
              style="width:100%; background:#18181b; color:#fff; border:none; border-radius:8px; padding:0.65rem; font-size:0.875rem; font-weight:600; cursor:pointer; margin-top:0.25rem;">
        Criar evento e continuar →
      </button>

      <button type="button" onclick="voltarPergunta()"
              style="background:none; border:none; font-size:0.8rem; color:#71717a; cursor:pointer; padding:0;">
        ← Voltar
      </button>
    </div>
  <% end %>
</div>

<script>
  function mostrarFormulario() {
    document.getElementById("panel-pergunta").style.display  = "none";
    document.getElementById("panel-formulario").style.display = "block";
  }
  function voltarPergunta() {
    document.getElementById("panel-formulario").style.display = "none";
    document.getElementById("panel-pergunta").style.display   = "block";
  }
  // Se voltou com erro de validação, mostra o formulário direto
  <% if @event&.errors&.any? %>
    document.addEventListener("DOMContentLoaded", mostrarFormulario);
  <% end %>
</script>

<% end %>
