<%# Progress %>
<div style="display:flex; gap:0.5rem; margin-bottom:1.75rem;">
  <% [["Empresa", false], ["Plano", false], ["Pagamento", false], ["Evento", false], ["Concluído", true]].each do |label, active| %>
    <div style="flex:1; text-align:center;">
      <div style="font-size:0.7rem; font-weight:<%= active ? 700 : 400 %>; color:<%= active ? '#18181b' : '#a1a1aa' %>; margin-bottom:0.35rem;"><%= label %></div>
      <div style="height:3px; border-radius:2px; background:#18181b;"></div>
    </div>
  <% end %>
</div>

<div style="text-align:center; padding:0.5rem 0 1rem;">
  <div style="width:4rem; height:4rem; background:#f0fdf4; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1rem;">
    <i class="bi bi-rocket-takeoff-fill" style="font-size:1.8rem; color:#16a34a;"></i>
  </div>

  <% is_manager_or_owner = current_user.admin? ||
                           current_user.role&.name.in?(%w[admin gerente]) ||
                           current_user.company_users.where(role: "owner").exists? %>

  <h2 style="font-size:1.2rem; font-weight:700; color:#18181b; margin:0 0 0.5rem;">Tudo pronto, <%= current_user.name.split.first %>!</h2>
  <p style="font-size:0.85rem; color:#71717a; margin:0 0 1.5rem; line-height:1.5;">
    <% if is_manager_or_owner %>
      Sua conta está ativa. Agora configure seu evento para começar a gerenciar a equipe.
    <% else %>
      Sua conta está ativa. Acesse o sistema para ver sua escala e informações do evento.
    <% end %>
  </p>

  <% if is_manager_or_owner %>
    <div style="background:#f4f4f5; border-radius:10px; padding:0.85rem 1rem; margin-bottom:1.75rem; text-align:left;">
      <div style="font-size:0.72rem; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; color:#71717a; margin-bottom:0.65rem;">
        Próximos passos
      </div>
      <div style="display:flex; flex-direction:column; gap:0;">
        <div style="display:flex; align-items:center; gap:0.65rem; padding:0.55rem 0; border-bottom:1px solid #e4e4e7;">
          <div style="width:22px; height:22px; border-radius:50%; background:#fff; border:1px solid #e4e4e7; display:flex; align-items:center; justify-content:center; font-size:0.7rem; font-weight:700; color:#52525b; flex-shrink:0;">1</div>
          <span style="font-size:0.83rem; color:#18181b;">Configure os <strong>setores e funções</strong> do evento</span>
        </div>
        <div style="display:flex; align-items:center; gap:0.65rem; padding:0.55rem 0; border-bottom:1px solid #e4e4e7;">
          <div style="width:22px; height:22px; border-radius:50%; background:#fff; border:1px solid #e4e4e7; display:flex; align-items:center; justify-content:center; font-size:0.7rem; font-weight:700; color:#52525b; flex-shrink:0;">2</div>
          <span style="font-size:0.83rem; color:#18181b;">Crie as <strong>equipes</strong> e convide colaboradores</span>
        </div>
        <div style="display:flex; align-items:center; gap:0.65rem; padding:0.55rem 0;">
          <div style="width:22px; height:22px; border-radius:50%; background:#fff; border:1px solid #e4e4e7; display:flex; align-items:center; justify-content:center; font-size:0.7rem; font-weight:700; color:#52525b; flex-shrink:0;">3</div>
          <span style="font-size:0.83rem; color:#18181b;">Monte as <strong>escalas</strong> de horários</span>
        </div>
      </div>
    </div>
  <% end %>

  <%= link_to root_path,
        style: "display:inline-block; background:#18181b; color:#fff; border-radius:8px; padding:0.7rem 2rem; font-size:0.9rem; font-weight:600; text-decoration:none;" do %>
    Ir para o dashboard <i class="bi bi-arrow-right"></i>
  <% end %>
</div>
