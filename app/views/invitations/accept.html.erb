<%# Cabeçalho: empresa + quem convidou %>
<% if @company %>
  <div style="text-align:center; margin-bottom:1.5rem;">
    <div style="width:60px; height:60px; border-radius:12px; background:#f4f4f5; border:1px solid #e4e4e7; display:flex; align-items:center; justify-content:center; overflow:hidden; margin:0 auto 0.75rem;">
      <% if @company.logo.attached? %>
        <%= image_tag @company.logo, style:"width:100%;height:100%;object-fit:contain;" %>
      <% else %>
        <i class="bi bi-building" style="color:#a1a1aa; font-size:1.5rem;"></i>
      <% end %>
    </div>
    <p style="font-size:0.7rem; color:#a1a1aa; font-weight:500; text-transform:uppercase; letter-spacing:0.07em; margin:0 0 2px;">
      <%= @company.name %>
    </p>
    <h2 style="font-size:1.15rem; font-weight:700; color:#18181b; margin:0;">te convidou para a equipe</h2>
  </div>

  <%# Quem convidou + cargo %>
  <div style="background:#f9f9f9; border:1px solid #e4e4e7; border-radius:10px; padding:0.75rem 1rem; margin-bottom:1.5rem; display:flex; align-items:center; gap:0.75rem;">
    <div style="width:34px; height:34px; border-radius:50%; background:#ede9fe; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
      <span style="font-size:0.7rem; font-weight:700; color:#7c3aed;">
        <% if @invited_by&.name.present? %>
          <%= @invited_by.name.split.map(&:first).first(2).join.upcase %>
        <% else %>
          <i class="bi bi-person" style="font-size:0.85rem;"></i>
        <% end %>
      </span>
    </div>
    <div style="flex:1; min-width:0;">
      <p style="font-size:0.7rem; color:#a1a1aa; margin:0;">Convite enviado por</p>
      <p style="font-size:0.82rem; font-weight:600; color:#18181b; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
        <%= @invited_by&.name || "Administrador" %>
      </p>
    </div>
    <% if @company_role.present? %>
      <span style="font-size:0.7rem; font-weight:700; padding:3px 10px; border-radius:99px; background:#ede9fe; color:#5b21b6; white-space:nowrap; flex-shrink:0;">
        <%= I18n.t("company_user.roles.#{@company_role}", default: @company_role.humanize) %>
      </span>
    <% end %>
  </div>
<% end %>

<p style="font-size:0.83rem; color:#71717a; margin:0 0 1.25rem;">Complete seus dados para ativar sua conta.</p>

<%= form_with url: confirm_invitation_path(token: params[:token]), method: :post do |f| %>
  <div style="display:flex; flex-direction:column; gap:0.9rem;">

    <div>
      <label style="display:block; font-size:0.8rem; font-weight:500; color:#374151; margin-bottom:0.3rem;">Nome</label>
      <input type="text" name="user[name]" required
             value="<%= @invited_user.name %>"
             style="width:100%; box-sizing:border-box; border:1px solid #d1d5db; border-radius:8px; padding:0.55rem 0.75rem; font-size:0.875rem; color:#18181b; outline:none;"
             placeholder="Seu nome completo" />
      <p style="font-size:0.72rem; color:#71717a; margin:0.2rem 0 0;"><i class="bi bi-info-circle"></i> Aparece na credencial e na escala.</p>
    </div>

    <div>
      <label style="display:block; font-size:0.8rem; font-weight:500; color:#374151; margin-bottom:0.3rem;">CPF</label>
      <input type="text" name="user[cpf]" required inputmode="numeric"
             data-mask="cpf"
             style="width:100%; box-sizing:border-box; border:1px solid #d1d5db; border-radius:8px; padding:0.55rem 0.75rem; font-size:0.875rem; color:#18181b; outline:none;"
             placeholder="000.000.000-00" />
    </div>

    <div>
      <label style="display:block; font-size:0.8rem; font-weight:500; color:#374151; margin-bottom:0.3rem;">Telefone</label>
      <input type="tel" name="user[phone]" required
             data-mask="phone"
             style="width:100%; box-sizing:border-box; border:1px solid #d1d5db; border-radius:8px; padding:0.55rem 0.75rem; font-size:0.875rem; color:#18181b; outline:none;"
             placeholder="(00) 00000-0000" />
    </div>

    <div style="border-top:1px solid #f4f4f5; padding-top:0.9rem;">
      <label style="display:block; font-size:0.8rem; font-weight:500; color:#374151; margin-bottom:0.3rem;">Senha</label>
      <input type="password" name="user[password]" required minlength="8"
             style="width:100%; box-sizing:border-box; border:1px solid #d1d5db; border-radius:8px; padding:0.55rem 0.75rem; font-size:0.875rem; color:#18181b; outline:none;"
             placeholder="Mínimo 8 caracteres" />
    </div>

    <div>
      <label style="display:block; font-size:0.8rem; font-weight:500; color:#374151; margin-bottom:0.3rem;">Confirmar senha</label>
      <input type="password" name="user[password_confirmation]" required minlength="8"
             style="width:100%; box-sizing:border-box; border:1px solid #d1d5db; border-radius:8px; padding:0.55rem 0.75rem; font-size:0.875rem; color:#18181b; outline:none;" />
    </div>

    <% if @invited_user.errors.any? %>
      <div style="background:#fef2f2; border:1px solid #fca5a5; border-radius:8px; padding:0.65rem 1rem; font-size:0.82rem; color:#dc2626;">
        <% @invited_user.errors.full_messages.each do |msg| %>
          <div><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <button type="submit"
            style="width:100%; background:#18181b; color:#fff; border:none; border-radius:8px; padding:0.65rem; font-size:0.875rem; font-weight:600; cursor:pointer; margin-top:0.1rem;">
      Ativar minha conta
    </button>

    <% if @days_left.present? %>
      <p style="font-size:0.72rem; color:#a1a1aa; text-align:center; margin:0;">
        <i class="bi bi-lock"></i> Link pessoal —
        <% if @days_left <= 1 %>
          <span style="color:#dc2626; font-weight:600;">expira hoje</span>
        <% else %>
          expira em <strong><%= @days_left %> dias</strong>
        <% end %>
      </p>
    <% end %>
  </div>
<% end %>
