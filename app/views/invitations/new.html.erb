<h2 style="font-size:1.2rem; font-weight:700; color:#18181b; margin:0 0 0.3rem;">Convidar colaborador</h2>
<p style="font-size:0.83rem; color:#71717a; margin:0 0 1.5rem;">Gere um link de convite para a pessoa acessar o Backstage pela primeira vez.</p>

<%= form_with url: invitations_path, method: :post, data: { turbo: false } do |f| %>
  <% if @invited_user&.errors&.any? %>
    <div style="background:#fef2f2; border:1px solid #fca5a5; border-radius:8px; padding:0.65rem 1rem; font-size:0.82rem; color:#dc2626; margin-bottom:0.5rem;">
      <% @invited_user.errors.full_messages.each do |msg| %>
        <div><%= msg %></div>
      <% end %>
    </div>
  <% end %>
  <div style="display:flex; flex-direction:column; gap:1rem;">

    <div>
      <label style="display:block; font-size:0.8rem; font-weight:500; color:#374151; margin-bottom:0.3rem;">Nome</label>
      <input type="text" name="name" required
             value="<%= @invited_user&.name %>"
             style="width:100%; box-sizing:border-box; border:1px solid #d1d5db; border-radius:8px; padding:0.55rem 0.75rem; font-size:0.875rem; color:#18181b; outline:none;"
             placeholder="Nome completo" />
    </div>

    <div>
      <label style="display:block; font-size:0.8rem; font-weight:500; color:#374151; margin-bottom:0.3rem;">E-mail</label>
      <input type="email" name="email" required
             value="<%= @invited_user&.email %>"
             style="width:100%; box-sizing:border-box; border:1px solid #d1d5db; border-radius:8px; padding:0.55rem 0.75rem; font-size:0.875rem; color:#18181b; outline:none;"
             placeholder="email@exemplo.com" />
    </div>

    <div>
      <label style="display:block; font-size:0.8rem; font-weight:500; color:#374151; margin-bottom:0.3rem;">Perfil</label>
      <select name="role_id" required
              style="width:100%; box-sizing:border-box; border:1px solid #d1d5db; border-radius:8px; padding:0.55rem 0.75rem; font-size:0.875rem; color:#18181b; background:#fff; outline:none;">
        <option value="">Selecione um perfil...</option>
        <% @roles.each do |role| %>
          <option value="<%= role.id %>"><%= role.name %></option>
        <% end %>
      </select>
    </div>

    <div>
      <label style="display:block; font-size:0.8rem; font-weight:500; color:#374151; margin-bottom:0.3rem;">Empresa <span style="color:#a1a1aa; font-weight:400;">(opcional)</span></label>
      <select name="company_id" id="invitation_company_id"
              onchange="updatePlanInfo(this)"
              style="width:100%; box-sizing:border-box; border:1px solid #d1d5db; border-radius:8px; padding:0.55rem 0.75rem; font-size:0.875rem; color:#18181b; background:#fff; outline:none;">
        <option value="">Sem empresa por enquanto</option>
        <% @companies.each do |company| %>
          <option value="<%= company.id %>"
                  data-plan="<%= company.plan&.name %>"
                  data-members="<%= company.current_members_count %>"
                  data-limit="<%= company.members_limit || '' %>"
                  data-at-limit="<%= !company.can_add_member? %>">
            <%= company.name %><%= company.plan ? " (#{company.plan.name})" : "" %>
          </option>
        <% end %>
      </select>

      <div id="plan-info" style="display:none; margin-top:0.5rem; padding:0.5rem 0.75rem; border-radius:7px; font-size:0.78rem;">
      </div>
    </div>

    <script>
      function updatePlanInfo(select) {
        var opt    = select.options[select.selectedIndex];
        var box    = document.getElementById("plan-info");
        var plan   = opt.dataset.plan;
        var used   = opt.dataset.members;
        var limit  = opt.dataset.limit;
        var atLimit = opt.dataset.atLimit === "true";

        if (!plan || !opt.value) { box.style.display = "none"; return; }

        var limitLabel = limit ? limit : "∞";
        var color = atLimit ? "#fef2f2" : "#f0fdf4";
        var textColor = atLimit ? "#dc2626" : "#16a34a";
        var icon = atLimit ? "⚠️" : "✓";

        box.style.display = "block";
        box.style.background = color;
        box.style.color = textColor;
        box.innerHTML = icon + " Plano <strong>" + plan + "</strong> · Colaboradores: " + used + " / " + limitLabel +
                        (atLimit ? " — <strong>limite atingido</strong>" : "");
      }
    </script>

    <button type="submit"
            style="width:100%; background:#18181b; color:#fff; border:none; border-radius:8px; padding:0.65rem; font-size:0.875rem; font-weight:600; cursor:pointer; margin-top:0.5rem;">
      Gerar link de convite
    </button>
  </div>
<% end %>
