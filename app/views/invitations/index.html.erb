<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem;">
  <div>
    <h1 style="font-size:1.25rem; font-weight:700; color:#18181b; margin:0 0 0.15rem;">Convites enviados</h1>
    <p style="font-size:0.82rem; color:#71717a; margin:0;">Usuários convidados para o sistema</p>
  </div>
  <% if policy(:invitation).create? %>
    <%= link_to new_invitation_path, class: "btn-primary" do %>
      <i class="bi bi-envelope-plus"></i> Novo convite
    <% end %>
  <% end %>
</div>

<div class="content-card" style="overflow:hidden; padding:0;">
  <% if @invitations.any? %>
    <table style="width:100%; border-collapse:collapse; font-size:0.85rem;">
      <thead>
        <tr style="background:#f9f9f9; border-bottom:1px solid #e4e4e7;">
          <th style="padding:0.65rem 1.25rem; text-align:left; font-size:0.72rem; font-weight:600; color:#71717a; text-transform:uppercase; letter-spacing:0.05em;">Usuário</th>
          <th style="padding:0.65rem 1rem; text-align:left; font-size:0.72rem; font-weight:600; color:#71717a; text-transform:uppercase; letter-spacing:0.05em;">Perfil</th>
          <th style="padding:0.65rem 1rem; text-align:left; font-size:0.72rem; font-weight:600; color:#71717a; text-transform:uppercase; letter-spacing:0.05em;">Empresa</th>
          <th style="padding:0.65rem 1rem; text-align:left; font-size:0.72rem; font-weight:600; color:#71717a; text-transform:uppercase; letter-spacing:0.05em;">Status</th>
          <th style="padding:0.65rem 1rem; text-align:left; font-size:0.72rem; font-weight:600; color:#71717a; text-transform:uppercase; letter-spacing:0.05em;">Enviado em</th>
          <th style="padding:0.65rem 1rem; text-align:left; font-size:0.72rem; font-weight:600; color:#71717a; text-transform:uppercase; letter-spacing:0.05em;">Link</th>
        </tr>
      </thead>
      <tbody>
        <% @invitations.each do |u| %>
          <tr style="border-bottom:1px solid #f4f4f5;">
            <td style="padding:0.75rem 1.25rem;">
              <div style="font-weight:600; color:#18181b;"><%= u.name %></div>
              <div style="font-size:0.75rem; color:#71717a;"><%= u.email %></div>
            </td>
            <td style="padding:0.75rem 1rem; color:#52525b;"><%= u.role&.name&.humanize || "—" %></td>
            <td style="padding:0.75rem 1rem; color:#52525b;"><%= u.companies.first&.name || "—" %></td>
            <td style="padding:0.75rem 1rem;">
              <% if u.invitation_accepted_at? %>
                <span style="background:#f0fdf4; color:#16a34a; font-size:0.7rem; font-weight:700; padding:2px 8px; border-radius:4px;">Aceito</span>
              <% else %>
                <span style="background:#fef9c3; color:#ca8a04; font-size:0.7rem; font-weight:700; padding:2px 8px; border-radius:4px;">Pendente</span>
              <% end %>
            </td>
            <td style="padding:0.75rem 1rem; color:#71717a; font-size:0.8rem;">
              <%= I18n.l(u.created_at, format: :short) %>
            </td>
            <td style="padding:0.75rem 1rem;">
              <% unless u.invitation_accepted_at? %>
                <% url = accept_invitation_url(token: u.invitation_token) %>
                <button onclick="navigator.clipboard.writeText('<%= url %>'); this.innerHTML='<i class=\'bi bi-check-lg\'></i> Copiado'; setTimeout(() => this.innerHTML='<i class=\'bi bi-link-45deg\'></i> Copiar link', 2000)"
                        style="background:none; border:1px solid #e4e4e7; border-radius:6px; padding:3px 10px; font-size:0.75rem; color:#52525b; cursor:pointer; display:flex; align-items:center; gap:4px;">
                  <i class="bi bi-link-45deg"></i> Copiar link
                </button>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div style="text-align:center; padding:3rem 1rem; color:#a1a1aa;">
      <i class="bi bi-envelope" style="font-size:2rem; display:block; margin-bottom:0.75rem;"></i>
      <div style="font-size:0.875rem;">Nenhum convite enviado ainda.</div>
    </div>
  <% end %>
</div>
