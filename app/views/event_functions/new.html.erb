<div class="page-header">
  <h1>Nova função</h1>
</div>

<div class="content-card" style="max-width:480px;">
  <%= form_with model: @event_function, url: event_functions_path, local: true do |f| %>
    <%= render "shared/error_messages", object: @event_function %>

    <div style="margin-bottom:1rem;">
      <%= f.label :name, "Nome da função", class: "form-label" %>
      <%= f.text_field :name, class: "form-control", placeholder: "Ex: Assistente de palco", autocomplete: "off" %>
    </div>

    <div style="margin-bottom:1.5rem;">
      <%= f.label :hourly_rate, "Valor por hora (R$)", class: "form-label" %>
      <div style="position:relative;">
        <span style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#71717a;font-size:0.85rem;pointer-events:none;">R$</span>
        <%= f.number_field :hourly_rate, class: "form-control", placeholder: "0,00", step: "0.01", min: 0, style: "padding-left:2rem;" %>
      </div>
    </div>

    <div style="display:flex;gap:0.5rem;">
      <%= link_to event_functions_path, class: "btn-secondary" do %>Cancelar<% end %>
      <%= f.submit "Salvar", class: "btn-primary" %>
    </div>
  <% end %>
</div>
