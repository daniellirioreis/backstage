<div class="content-card" style="max-width: 700px;">
  <%= form_with model: sector do |f| %>
    <%= render "shared/error_messages", object: sector %>

    <%= f.hidden_field :event_id %>

    <div style="margin-bottom: 1.25rem;">
      <%= f.label :sector_type, Sector.human_attribute_name(:sector_type), class: "form-label" %>
      <%= f.select :sector_type,
            Sector::TYPES.map { |t| [I18n.t("sector_types.#{t}"), t] }.sort_by(&:first),
            { include_blank: "— Selecione um tipo (opcional) —" },
            class: "form-control",
            id: "sector_sector_type",
            data: { controller: "tom-select", placeholder: "Buscar tipo de setor..." } %>
    </div>

    <%# ── Painel de análise histórica por tipo de setor ──────────────────── %>
    <div id="sector-type-stats-panel" style="display:none;margin-top:-0.5rem;margin-bottom:1.25rem;">
      <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:1rem 1.1rem;">

        <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.85rem;">
          <i class="bi bi-bar-chart-line" style="color:#15803d;font-size:0.9rem;"></i>
          <span style="font-size:0.8rem;font-weight:700;color:#15803d;">
            Histórico — <span id="sts-tipo-label"></span>
          </span>
          <span id="sts-sec-count" style="margin-left:auto;font-size:0.7rem;background:#dcfce7;color:#15803d;border:1px solid #bbf7d0;border-radius:6px;padding:2px 8px;font-weight:600;"></span>
        </div>

        <%# Métricas %>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;margin-bottom:0.85rem;">
          <div style="background:white;border-radius:8px;padding:0.65rem 0.75rem;border:1px solid #d1fae5;">
            <div style="font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#16a34a;margin-bottom:3px;">Colaboradores</div>
            <div id="sts-avg-collab" style="font-size:1.2rem;font-weight:700;color:#18181b;"></div>
            <div id="sts-range-collab" style="font-size:0.65rem;color:#71717a;"></div>
          </div>
          <div style="background:white;border-radius:8px;padding:0.65rem 0.75rem;border:1px solid #d1fae5;">
            <div style="font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#16a34a;margin-bottom:3px;">Funções identificadas</div>
            <div id="sts-fn-count" style="font-size:1.2rem;font-weight:700;color:#18181b;"></div>
            <div style="font-size:0.65rem;color:#71717a;">tipos distintos</div>
          </div>
        </div>

        <%# Funções mais usadas %>
        <div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#71717a;margin-bottom:6px;">
          Funções mais usadas neste tipo de setor
        </div>
        <div id="sts-functions-chart"></div>

        <div style="margin-top:0.65rem;padding-top:0.55rem;border-top:1px solid #bbf7d0;font-size:0.65rem;color:#16a34a;">
          <i class="bi bi-info-circle"></i>
          Qtd. média planejada por setor, baseada em setores similares já cadastrados.
        </div>
      </div>
    </div>

    <div style="margin-bottom: 1.25rem;">
      <%= f.label :name, Sector.human_attribute_name(:name), class: "form-label" %>
      <%= f.text_field :name, class: "form-control", id: "sector_name" %>
    </div>


    <%# ── Funções planejadas ──────────────────────────────────────────────── %>
    <div style="margin-bottom: 1.25rem;">
      <div class="form-label" style="margin-bottom: 0.75rem;">
        <i class="bi bi-clipboard-check"></i> Funções planejadas
      </div>

      <% if @event_functions.blank? %>
        <p style="font-size:0.82rem; color:#a1a1aa; margin:0;">
          Nenhuma função cadastrada neste evento.
          <%= link_to "Adicione funções ao evento", edit_event_path(sector.event_id), style: "color:#6d28d9;" %> primeiro.
        </p>
      <% else %>
        <% cols = "1fr 62px 76px 80px 96px 110px 36px" %>
        <div style="border:1px solid #e4e4e7; border-radius:8px; margin-bottom:0.75rem; overflow:hidden;">
          <%# Cabeçalho %>
          <div style="display:grid; grid-template-columns:<%= cols %>; gap:0.5rem; padding:0.4rem 0.75rem; background:#f9fafb; border-bottom:1px solid #e4e4e7;">
            <span style="font-size:0.7rem; font-weight:600; color:#71717a; text-transform:uppercase; letter-spacing:0.05em;">Função</span>
            <span style="font-size:0.7rem; font-weight:600; color:#71717a; text-transform:uppercase; letter-spacing:0.05em;">Qtd.</span>
            <span style="font-size:0.7rem; font-weight:600; color:#6d28d9; text-transform:uppercase; letter-spacing:0.05em;">Atribuído</span>
            <span style="font-size:0.7rem; font-weight:600; color:#71717a; text-transform:uppercase; letter-spacing:0.05em;">Taxa/h</span>
            <span style="font-size:0.7rem; font-weight:600; color:#71717a; text-transform:uppercase; letter-spacing:0.05em;">Custo/h</span>
            <span style="font-size:0.7rem; font-weight:600; color:#71717a; text-transform:uppercase; letter-spacing:0.05em;">Estimativa</span>
            <span></span>
          </div>

          <%# Linhas existentes %>
          <div id="sf-rows">
            <%= f.fields_for :sector_functions do |ff| %>
              <%
                fn_id    = ff.object.event_function_id.to_s
                planned  = ff.object.quantity.to_i
                done     = (@assigned_fn_counts || {})[fn_id] || 0
                a_color  = done >= planned && planned > 0 ? '#15803d' : done > 0 ? '#92400e' : '#71717a'
                a_bg     = done >= planned && planned > 0 ? '#dcfce7' : done > 0 ? '#fef3c7' : '#f4f4f5'
              %>
              <div class="sf-row" style="display:grid; grid-template-columns:<%= cols %>; gap:0.5rem; align-items:center; padding:0.45rem 0.75rem; border-bottom:1px solid #f4f4f5;">
                <%= ff.collection_select :event_function_id, @event_functions, :id, :name,
                      { include_blank: "— Selecione —" },
                      class: "form-control sf-fn-select", style: "font-size:0.82rem;" %>
                <%= ff.number_field :quantity, min: 1,
                      class: "form-control sf-qty-input", style: "font-size:0.82rem;" %>
                <span class="sf-assigned" data-done="<%= done %>" data-server-rendered="1"
                      style="font-size:0.75rem; font-weight:700; color:<%= a_color %>; background:<%= a_bg %>; border-radius:4px; padding:2px 6px; text-align:center; white-space:nowrap;">
                  <%= done %>/<%= planned > 0 ? planned : '?' %>
                </span>
                <span class="sf-rate" style="font-size:0.78rem; color:#71717a;">—</span>
                <span class="sf-cost" style="font-size:0.78rem; font-weight:600; color:#18181b;">—</span>
                <span class="sf-est"  style="font-size:0.78rem; font-weight:600; color:#15803d;">—</span>
                <div style="display:flex; justify-content:center;">
                  <% if ff.object.persisted? %>
                    <%= ff.check_box :_destroy, { style: "display:none;", class: "sf-destroy-cb" }, "1", "0" %>
                    <button type="button" onclick="toggleSfDestroy(this)"
                            class="btn-danger" style="padding:0.25rem 0.45rem; font-size:0.75rem; width:30px;">
                      <i class="bi bi-x"></i>
                    </button>
                  <% else %>
                    <button type="button" onclick="this.closest('.sf-row').remove(); updateSfTotals();"
                            class="btn-danger" style="padding:0.25rem 0.45rem; font-size:0.75rem; width:30px;">
                      <i class="bi bi-x"></i>
                    </button>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>

          <%# Rodapé de totais %>
          <div id="sf-totals" style="display:none; grid-template-columns:<%= cols %>; gap:0.5rem; padding:0.45rem 0.75rem; background:#f9fafb; border-top:2px solid #e4e4e7;">
            <span style="font-size:0.75rem; font-weight:700; color:#71717a; grid-column:1/3;">Total estimado</span>
            <span></span>
            <span></span>
            <span id="sf-total-cost" style="font-size:0.82rem; font-weight:700; color:#18181b;"></span>
            <span id="sf-total-est"  style="font-size:0.82rem; font-weight:700; color:#15803d;"></span>
            <span></span>
          </div>
        </div>

        <%# Template para nova linha %>
        <template id="sf-template">
          <div class="sf-row" style="display:grid; grid-template-columns:<%= cols %>; gap:0.5rem; align-items:center; padding:0.45rem 0.75rem; border-bottom:1px solid #f4f4f5;">
            <select class="form-control sf-fn-select" name="sector[sector_functions_attributes][NEW_IDX][event_function_id]" style="font-size:0.82rem;">
              <option value="">— Selecione —</option>
              <% @event_functions.each do |ef| %>
                <option value="<%= ef.id %>"><%= ef.name %></option>
              <% end %>
            </select>
            <input type="number" class="form-control sf-qty-input"
                   name="sector[sector_functions_attributes][NEW_IDX][quantity]"
                   min="1" value="1" style="font-size:0.82rem;">
            <span class="sf-assigned" data-done="0"
                  style="font-size:0.75rem; font-weight:700; color:#71717a; background:#f4f4f5; border-radius:4px; padding:2px 6px; text-align:center;">—</span>
            <span class="sf-rate" style="font-size:0.78rem; color:#71717a;">—</span>
            <span class="sf-cost" style="font-size:0.78rem; font-weight:600; color:#18181b;">—</span>
            <span class="sf-est"  style="font-size:0.78rem; font-weight:600; color:#15803d;">—</span>
            <div style="display:flex; justify-content:center;">
              <button type="button" onclick="this.closest('.sf-row').remove(); updateSfTotals();"
                      class="btn-danger" style="padding:0.25rem 0.45rem; font-size:0.75rem; width:30px;">
                <i class="bi bi-x"></i>
              </button>
            </div>
          </div>
        </template>

        <button type="button" onclick="addSfRow()" class="btn-secondary" style="font-size:0.82rem;">
          <i class="bi bi-plus"></i> Adicionar função
        </button>
      <% end %>
    </div>

    <div style="display: flex; gap: 0.75rem; border-top: 1px solid #f4f4f5; padding-top: 1.25rem; margin-top: 1.25rem;">
      <%= f.submit t("actions.save"), class: "btn-primary" %>
      <%= link_to t("actions.cancel"), sectors_path, class: "btn-secondary" %>
    </div>
  <% end %>
</div>

<script>
  (function () {
    var typeSelect = document.getElementById("sector_sector_type");
    var nameInput  = document.getElementById("sector_name");
    var STS_URL    = "<%= sector_type_stats_sectors_path %>";

    function stsBuildBars(rows) {
      if (!rows || !rows.length) return '<div style="font-size:0.72rem;color:#a1a1aa;">Sem dados suficientes.</div>';
      var max = rows[0].avg_qty;
      if (!max) return '<div style="font-size:0.72rem;color:#a1a1aa;">Sem dados suficientes.</div>';
      return rows.map(function(r) {
        var pct = Math.round(r.avg_qty / max * 100);
        return '<div style="display:grid;grid-template-columns:140px 1fr 60px;align-items:center;gap:6px;margin-bottom:5px;">'
          + '<div style="font-size:0.72rem;color:#374151;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="' + r.label + '">' + r.label + '</div>'
          + '<div style="background:#d1fae5;border-radius:4px;height:10px;overflow:hidden;">'
          +   '<div style="width:' + pct + '%;height:100%;background:#16a34a;border-radius:4px;"></div>'
          + '</div>'
          + '<div style="font-size:0.72rem;font-weight:700;color:#15803d;text-align:right;white-space:nowrap;">' + r.avg_qty + ' col.</div>'
          + '</div>';
      }).join('');
    }

    function loadSectorTypeStats(sectorType) {
      var panel = document.getElementById('sector-type-stats-panel');
      if (!sectorType) { panel.style.display = 'none'; return; }

      fetch(STS_URL + '?sector_type=' + encodeURIComponent(sectorType), {
        headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
      })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (!d.total_sectors) { panel.style.display = 'none'; return; }

        var label = typeSelect.options[typeSelect.selectedIndex].text;
        document.getElementById('sts-tipo-label').textContent   = label;
        document.getElementById('sts-sec-count').textContent    = d.total_sectors + ' setor' + (d.total_sectors > 1 ? 'es' : '');
        document.getElementById('sts-avg-collab').textContent   = d.avg_collaborators;
        document.getElementById('sts-range-collab').textContent = 'mín ' + d.min_collaborators + ' · máx ' + d.max_collaborators;
        document.getElementById('sts-fn-count').textContent     = d.functions.length;
        document.getElementById('sts-functions-chart').innerHTML = stsBuildBars(d.functions);
        panel.style.display = '';
      })
      .catch(function() { panel.style.display = 'none'; });
    }

    if (typeSelect && nameInput) {
      typeSelect.addEventListener("change", function () {
        var selected = typeSelect.options[typeSelect.selectedIndex];
        if (selected && selected.value && !nameInput.value.trim()) {
          nameInput.value = selected.text;
        }
        loadSectorTypeStats(selected ? selected.value : '');
      });
    }

    // Carrega ao editar setor que já tem tipo definido
    (function() {
      if (typeSelect && typeSelect.value) loadSectorTypeStats(typeSelect.value);
    })();

    // ── Funções planejadas ──────────────────────────────────────────────────
    var sfIdx    = Date.now();
    var FN_RATES = <%= raw(@event_functions.each_with_object({}) { |ef, h| h[ef.id.to_s] = ef.hourly_rate.to_f }.to_json) %>;
    var EVENT_HOURS = <%= @event_days || 8.0 %>;
    var ASSIGNED = <%= raw((@assigned_fn_counts || {}).to_json) %>;

    function formatBRL(n) {
      return "R$" + n.toFixed(2).replace(".", ",").replace(/\B(?=(\d{3})+(?!\d))/g, ".");
    }

    function updateRowCost(row) {
      var sel  = row.querySelector(".sf-fn-select");
      var qty  = parseFloat(row.querySelector(".sf-qty-input")?.value) || 0;
      var fnId = sel ? sel.value : "";
      var rate = fnId ? (FN_RATES[fnId] || 0) : 0;
      var costH = qty * rate;
      var est   = costH * EVENT_HOURS;

      var rateEl     = row.querySelector(".sf-rate");
      var costEl     = row.querySelector(".sf-cost");
      var estEl      = row.querySelector(".sf-est");
      var assignedEl = row.querySelector(".sf-assigned");

      if (rateEl) rateEl.textContent = rate  > 0 ? formatBRL(rate)  + "/h" : "—";
      if (costEl) costEl.textContent = costH > 0 ? formatBRL(costH) + "/h" : "—";
      if (estEl)  estEl.textContent  = est   > 0 ? formatBRL(est)         : "—";

      // Atualiza coluna Atribuído apenas em linhas novas (sem valor data-done fixo do server)
      if (assignedEl && fnId && assignedEl.dataset.serverRendered !== "1") {
        var done    = ASSIGNED[fnId] || 0;
        var planned = qty || 0;
        var color   = done >= planned && planned > 0 ? "#15803d" : done > 0 ? "#92400e" : "#71717a";
        var bg      = done >= planned && planned > 0 ? "#dcfce7" : done > 0 ? "#fef3c7" : "#f4f4f5";
        assignedEl.textContent   = done + "/" + (planned > 0 ? planned : "?");
        assignedEl.style.color   = color;
        assignedEl.style.background = bg;
      }
    }

    function updateSfTotals() {
      var totalsEl  = document.getElementById("sf-totals");
      var totalCost = document.getElementById("sf-total-cost");
      var totalEst  = document.getElementById("sf-total-est");
      var rows = document.querySelectorAll("#sf-rows .sf-row");
      var sumCost = 0, sumEst = 0, hasAny = false;

      rows.forEach(function (row) {
        var cb = row.querySelector(".sf-destroy-cb");
        if (cb && cb.checked) return;
        var sel  = row.querySelector(".sf-fn-select");
        var qty  = parseFloat(row.querySelector(".sf-qty-input")?.value) || 0;
        var rate = sel && sel.value ? (FN_RATES[sel.value] || 0) : 0;
        if (rate > 0 && qty > 0) {
          sumCost += qty * rate;
          sumEst  += qty * rate * EVENT_HOURS;
          hasAny = true;
        }
      });

      if (totalsEl) {
        totalsEl.style.display = hasAny ? "grid" : "none";
        if (totalCost) totalCost.textContent = formatBRL(sumCost) + "/h";
        if (totalEst)  totalEst.textContent  = formatBRL(sumEst);
      }
    }

    // Delegação de eventos nas linhas existentes e futuras
    document.getElementById("sf-rows")?.addEventListener("change", function (e) {
      var row = e.target.closest(".sf-row");
      if (row) { updateRowCost(row); updateSfTotals(); }
    });
    document.getElementById("sf-rows")?.addEventListener("input", function (e) {
      var row = e.target.closest(".sf-row");
      if (row) { updateRowCost(row); updateSfTotals(); }
    });

    // Calcula ao carregar (linhas existentes)
    document.querySelectorAll("#sf-rows .sf-row").forEach(function (row) { updateRowCost(row); });
    updateSfTotals();

    window.addSfRow = function () {
      var tpl = document.getElementById("sf-template");
      if (!tpl) return;
      var clone = tpl.content.cloneNode(true);
      var row   = clone.querySelector(".sf-row");
      var idx   = sfIdx++;
      row.querySelectorAll("select, input").forEach(function (el) {
        if (el.name) el.name = el.name.replace("NEW_IDX", idx);
      });
      document.getElementById("sf-rows").appendChild(row);
    };

    window.toggleSfDestroy = function (btn) {
      var row = btn.closest(".sf-row");
      var cb  = row.querySelector(".sf-destroy-cb");
      cb.checked        = !cb.checked;
      row.style.opacity = cb.checked ? "0.4" : "1";
      btn.innerHTML     = cb.checked
        ? '<i class="bi bi-arrow-counterclockwise"></i>'
        : '<i class="bi bi-x"></i>';
      updateSfTotals();
    };

    window.updateSfTotals = updateSfTotals;
  })();
</script>
