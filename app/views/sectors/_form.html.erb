<%= form_with model: sector, class: "mt-3" do |f| %>
  <%= render "shared/error_messages", object: sector %>

  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <%= f.label :name, Sector.human_attribute_name(:name), class: "form-label" %>
      <%= f.text_field :name, class: "form-control" %>
    </div>
    <div class="col-md-6">
      <%= f.label :team_id, Team.model_name.human, class: "form-label" %>
      <%= f.collection_select :team_id,
          Team.includes(:event).order("events.name, teams.name").references(:event),
          :id, ->(t) { "#{t.event.name} › #{t.name}" },
          { include_blank: "— Selecione —" }, class: "form-select" %>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit t("actions.save"), class: "btn btn-primary" %>
    <%= link_to t("actions.cancel"), sectors_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
