<div class="page-header">
  <h1><%= Sector.model_name.human(count: 2) %></h1>
  <div style="display: flex; gap: 0.5rem; align-items: center;">
    <% if policy(Sector).new? %>
      <%= link_to new_sector_path, class: "btn-primary" do %>
        <i class="bi bi-plus"></i> <%= t("actions.new", model: Sector.model_name.human) %>
      <% end %>
    <% end %>
  </div>
</div>

<%= form_with url: sectors_path, method: :get, local: true do %>
  <div class="content-card" style="margin-bottom:0.75rem; padding:0.6rem 1rem; display:flex; align-items:center; gap:0.6rem;">
    <i class="bi bi-search" style="color:#a1a1aa; font-size:0.9rem; flex-shrink:0;"></i>
    <input type="text" name="q" value="<%= @q %>" placeholder="Buscar setor..." autocomplete="off"
           style="flex:1; border:none; outline:none; font-size:0.85rem; color:#18181b; background:transparent;">
    <% if @q.present? %>
      <%= link_to "×", sectors_path, style:"color:#a1a1aa; text-decoration:none; font-size:1.1rem; line-height:1;" %>
    <% end %>
    <button type="submit" class="btn-primary" style="padding:0.3rem 0.8rem; font-size:0.8rem;">Filtrar</button>
  </div>
<% end %>

<% if @sectors.empty? %>
  <div class="content-card">
    <%= render "shared/empty_state",
          icon: "bi-diagram-3",
          title: "Nenhum setor cadastrado",
          description: "Crie os setores do evento (palco, segurança, portaria…) para organizar as equipes.",
          action_label: "Novo setor",
          action_path: new_sector_path,
          action_policy: policy(Sector).new? %>
  </div>
<% else %>
<table class="data-table">
  <thead>
    <tr>
      <th><%= Sector.human_attribute_name(:name) %></th>
      <th><%= Sector.human_attribute_name(:sector_type) %></th>
      <th>Equipes</th>
      <th>Preenchimento</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @sectors.each do |sector|
         scaled_count = sector.teams.flat_map(&:users).uniq.size
         expected     = sector.planned_headcount
    %>
      <tr>
        <td><%= link_to sector.name, edit_sector_path(sector), style: "color: #18181b; font-weight: 500; text-decoration: none;" %></td>
        <td>
          <% if sector.sector_type.present? %>
            <span style="display:inline-block; background:#f4f4f5; border-radius:5px; padding:2px 8px; font-size:0.72rem; color:#52525b;">
              <%= sector.sector_type_label %>
            </span>
          <% else %>
            <span style="color:#a1a1aa; font-size:0.82rem;">—</span>
          <% end %>
        </td>
        <td style="color: #71717a;"><%= sector.teams.size %></td>
        <td style="min-width: 140px;">
          <% if expected > 0
               pct       = [(scaled_count * 100.0 / expected).round, 100].min
               bar_color = pct >= 100 ? '#4ade80' : pct >= 60 ? '#fb923c' : '#f87171'
               txt_color = pct >= 100 ? '#15803d' : pct >= 60 ? '#92400e' : '#991b1b'
          %>
            <div style="display:flex; align-items:center; gap:0.5rem;">
              <div style="flex:1; height:5px; background:#e4e4e7; border-radius:99px; overflow:hidden;">
                <div style="height:100%; width:<%= pct %>%; background:<%= bar_color %>; border-radius:99px;"></div>
              </div>
              <span style="font-size:0.75rem; font-weight:700; color:<%= txt_color %>; white-space:nowrap;">
                <%= scaled_count %>/<%= expected %>
              </span>
            </div>
          <% else %>
            <span style="color:#a1a1aa; font-size:0.82rem;">—</span>
          <% end %>
        </td>
        <td class="td-actions">
          <div style="display: flex; gap: 0.4rem; justify-content: flex-end;">
            <% if policy(sector).edit? %>
              <%= link_to edit_sector_path(sector), class: "btn-secondary" do %><i class="bi bi-pencil"></i><% end %>
            <% end %>
            <% if policy(sector).destroy? %>
              <%= button_to sector_path(sector), method: :delete,
                  form: { data: { turbo_confirm: t("confirms.delete") } },
                  class: "btn-danger" do %><i class="bi bi-trash"></i><% end %>
            <% end %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
<% end %>

<% if @sectors.total_pages > 1 %>
  <div style="display:flex; justify-content:center; align-items:center; gap:0.4rem; margin-top:1.5rem;">
    <%= will_paginate @sectors,
        previous_label: "‹ Anterior",
        next_label:     "Próximo ›",
        inner_window:   2,
        outer_window:   1,
        renderer:       "BackstagePaginationRenderer" %>
  </div>
<% end %>
