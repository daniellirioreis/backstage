<div class="d-flex justify-content-between align-items-center mb-3">
  <h1><%= Sector.model_name.human(count: 2) %></h1>
  <% if policy(Sector).new? %>
    <%= link_to t("actions.new", model: Sector.model_name.human), new_sector_path, class: "btn btn-primary" %>
  <% end %>
</div>

<table class="table table-hover">
  <thead class="table-dark">
    <tr>
      <th><%= Sector.human_attribute_name(:name) %></th>
      <th><%= Team.model_name.human %></th>
      <th><%= Event.model_name.human %></th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @sectors.each do |sector| %>
      <tr>
        <td><%= link_to sector.name, sector_path(sector) %></td>
        <td><%= sector.team.name %></td>
        <td><%= sector.team.event.name %></td>
        <td class="text-end">
          <% if policy(sector).edit? %>
            <%= link_to t("actions.edit"), edit_sector_path(sector), class: "btn btn-sm btn-outline-secondary" %>
          <% end %>
          <% if policy(sector).destroy? %>
            <%= button_to t("actions.delete"), sector_path(sector), method: :delete,
                form: { data: { turbo_confirm: t("confirms.delete") } },
                class: "btn btn-sm btn-outline-danger" %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
