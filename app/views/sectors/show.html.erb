<div class="d-flex justify-content-between align-items-center mb-3">
  <h1><%= @sector.name %></h1>
  <div class="d-flex gap-2">
    <% if policy(@sector).edit? %>
      <%= link_to t("actions.edit"), edit_sector_path(@sector), class: "btn btn-outline-secondary" %>
    <% end %>
    <%= link_to t("actions.cancel"), sectors_path, class: "btn btn-outline-secondary" %>
  </div>
</div>

<p>
  <strong><%= Team.model_name.human %>:</strong> <%= link_to @sector.team.name, team_path(@sector.team) %>
  &nbsp;|&nbsp;
  <strong><%= Event.model_name.human %>:</strong> <%= @sector.team.event.name %>
</p>

<div class="d-flex justify-content-between align-items-center mb-2">
  <h2 class="h5"><%= Shift.model_name.human(count: 2) %></h2>
  <% if policy(Shift).new? %>
    <%= link_to t("actions.new", model: Shift.model_name.human), new_shift_path(sector_id: @sector.id), class: "btn btn-sm btn-primary" %>
  <% end %>
</div>
<table class="table table-sm">
  <thead class="table-light">
    <tr>
      <th><%= Shift.human_attribute_name(:date) %></th>
      <th><%= Shift.human_attribute_name(:start_time) %></th>
      <th><%= Shift.human_attribute_name(:end_time) %></th>
      <th><%= User.model_name.human %></th>
      <th><%= Shift.human_attribute_name(:has_radio) %></th>
    </tr>
  </thead>
  <tbody>
    <% @shifts.each do |shift| %>
      <tr>
        <td><%= l(shift.date, format: :short) %></td>
        <td><%= shift.start_time.strftime("%H:%M") %></td>
        <td><%= shift.end_time.strftime("%H:%M") %></td>
        <td><%= shift.user.name %></td>
        <td><%= shift.has_radio? ? "✓" : "—" %></td>
      </tr>
    <% end %>
  </tbody>
</table>
