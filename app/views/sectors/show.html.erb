<div class="page-header">
  <div style="display: flex; align-items: center; gap: 0.75rem;">
    <%= link_to event_path(@sector.event), class: "btn-secondary", style: "padding: 0.35rem 0.6rem;" do %>
      <i class="bi bi-arrow-left"></i>
    <% end %>
    <div>
      <h1 style="margin: 0;"><%= @sector.name %></h1>
      <div style="font-size: 0.82rem; color: #71717a; margin-top: 0.2rem; display:flex; align-items:center; gap:0.5rem;">
        <span><i class="bi bi-calendar-event"></i> <%= @sector.event.name %></span>
        <% if @sector.sector_type.present? %>
          <span style="background:#f4f4f5; border-radius:5px; padding:1px 7px; font-size:0.7rem; color:#52525b;">
            <%= @sector.sector_type_label %>
          </span>
        <% end %>
      </div>
    </div>
  </div>
  <div style="display: flex; gap: 0.5rem;">
    <% if policy(@sector).edit? %>
      <%= link_to edit_sector_path(@sector), class: "btn-secondary" do %>
        <i class="bi bi-pencil"></i> <%= t("actions.edit") %>
      <% end %>
    <% end %>
    <% if policy(@sector).destroy? %>
      <%= button_to sector_path(@sector), method: :delete,
          form: { data: { turbo_confirm: t("confirms.delete") } },
          class: "btn-danger" do %>
        <i class="bi bi-trash"></i> <%= t("actions.delete") %>
      <% end %>
    <% end %>
  </div>
</div>

<%# Equipes do setor %>
<div class="content-card">
  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
    <h2 style="font-size: 0.9rem; font-weight: 600; color: #18181b; margin: 0;">
      <i class="bi bi-people"></i> <%= Team.model_name.human(count: 2) %>
      <span style="font-size: 0.8rem; font-weight: 400; color: #a1a1aa; margin-left: 0.25rem;">(<%= @sector.teams.size %>)</span>
    </h2>
    <% if policy(Team).new? %>
      <%= link_to new_team_path(sector_id: @sector.id), class: "btn-primary" do %>
        <i class="bi bi-plus"></i> <%= t("actions.new", model: Team.model_name.human) %>
      <% end %>
    <% end %>
  </div>

  <% if @sector.teams.any? %>
    <table class="data-table">
      <thead>
        <tr>
          <th><%= Team.human_attribute_name(:name) %></th>
          <th>Coordenador</th>
          <th>Canal Rádio</th>
          <th>Colaboradores</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @sector.teams.each do |team| %>
          <tr>
            <td style="font-weight: 500;"><%= team.name %></td>
            <td style="color: #15803d; font-size: 0.82rem;">
              <%= team.coordinator&.name || "—" %>
            </td>
            <td>
              <% if team.radio_channel.present? %>
                <span style="display: inline-flex; align-items: center; gap: 0.25rem; background: #fef3c7; border: 1px solid #fcd34d; border-radius: 5px; padding: 1px 7px; font-size: 0.7rem; font-weight: 600; color: #92400e;">
                  <i class="bi bi-broadcast"></i> <%= team.radio_channel %>
                </span>
              <% else %>
                <span style="color: #a1a1aa;">—</span>
              <% end %>
            </td>
            <td style="color: #71717a;"><%= team.users.size %></td>
            <td class="td-actions">
              <%= link_to team_path(team), class: "btn-secondary" do %><i class="bi bi-eye"></i><% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div style="text-align: center; padding: 2rem; color: #a1a1aa; font-size: 0.88rem;">
      Nenhuma equipe cadastrada neste setor.
    </div>
  <% end %>
</div>
