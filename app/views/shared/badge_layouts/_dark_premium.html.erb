<%# Locals: user, event, team, cfg, is_coordinator, avatar_base64, credential_code, chip_label %>
<% acc = cfg.event_name_color; hdr = cfg.header_footer_color %>
<div class="badge" style="overflow:hidden;border-radius:14px;font-family:Arial,sans-serif;background:<%= hdr %>;border:1px solid #27272a;display:flex;flex-direction:column;min-height:400px;">
  <%# ── Faixa topo accent ───────────────────────────────────── %>
  <div style="height:3px;background:<%= acc %>;"></div>

  <%# ── Empresa centralizada ────────────────────────────────── %>
  <div style="padding:10px 14px 0;text-align:center;">
    <span style="font-size:7px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:#3f3f46;"><%= event&.company&.name || "Backstage" %></span>
    <div style="width:80px;height:0.5px;background:#27272a;margin:6px auto 0;"></div>
  </div>

  <%# ── Foto com anel duplo ─────────────────────────────────── %>
  <div style="display:flex;justify-content:center;padding:12px 0 10px;">
    <div style="position:relative;width:86px;height:86px;">
      <%# Anel externo (borda escura) %>
      <div style="position:absolute;inset:0;border-radius:50%;background:#27272a;"></div>
      <%# Anel accent (verde) %>
      <div style="position:absolute;inset:3px;border-radius:50%;background:<%= acc %>;"></div>
      <%# Anel escuro interno %>
      <div style="position:absolute;inset:5px;border-radius:50%;background:#1a1a1a;"></div>
      <%# Foto %>
      <div style="position:absolute;inset:8px;border-radius:50%;overflow:hidden;background:#27272a;display:flex;align-items:center;justify-content:center;">
        <% if avatar_base64 %>
          <img src="<%= avatar_base64 %>" style="width:100%;height:100%;object-fit:cover;">
        <% else %>
          <span style="font-size:20px;font-weight:700;color:#52525b;"><%= user.name.split.map(&:first).first(2).join.upcase %></span>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── Linha decorativa + nome ─────────────────────────────── %>
  <div style="display:flex;align-items:center;gap:8px;padding:0 20px;margin-bottom:8px;">
    <div style="flex:1;height:0.5px;background:<%= acc %>;"></div>
    <div style="width:4px;height:4px;border-radius:50%;background:<%= acc %>;"></div>
    <div style="flex:1;height:0.5px;background:<%= acc %>;"></div>
  </div>

  <div style="padding:0 14px;text-align:center;flex:1;display:flex;flex-direction:column;justify-content:center;">
    <div style="font-size:<%= cfg.name_font_size %>px;font-weight:800;color:<%= cfg.name_color %>;line-height:1.2;"><%= user.name %></div>
    <div style="margin-top:5px;font-size:<%= cfg.role_chip_font_size %>px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:<%= acc %>;"><%= chip_label %></div>
    <div style="width:0.5px;background:#27272a;height:28px;margin:8px auto;"></div>
    <% if event %>
      <div style="font-size:8.5px;font-weight:700;color:<%= cfg.team_info_color %>;text-transform:uppercase;letter-spacing:0.06em;"><%= event.name %></div>
      <div style="font-size:6px;color:<%= cfg.team_info_color %>;opacity:0.6;margin-top:1px;"><%= l(event.start_date, format: :short) %> a <%= l(event.end_date, format: :short) %><% if event.location.present? %> &middot; <%= event.location %><% end %></div>
    <% end %>
    <% if team %>
      <div style="margin-top:5px;font-size:<%= cfg.team_info_font_size %>px;color:<%= cfg.team_info_color %>;"><strong><%= team.sector.name %></strong> &middot; <%= team.name %></div>
    <% end %>
    <div style="font-size:8px;color:#27272a;font-family:monospace;margin-top:2px;"><%= user.formatted_cpf %></div>
  </div>

  <%# ── Footer com QR elegante ──────────────────────────────── %>
  <div style="height:0.5px;background:#27272a;margin-top:10px;"></div>
  <div style="padding:8px 14px;display:flex;align-items:center;justify-content:space-between;gap:8px;">
    <%= badge_qr_svg(credential_code.presence || "BST#{user.id}", pixel_size: 40, color: acc, bg: hdr) %>
    <div style="text-align:right;">
      <% if credential_code.present? %>
        <div style="font-size:6px;text-transform:uppercase;letter-spacing:0.1em;color:#3f3f46;">Credencial</div>
        <div style="font-size:<%= cfg.credential_code_font_size %>px;color:<%= cfg.credential_code_color %>;font-family:monospace;font-weight:700;"><%= credential_code %></div>
      <% end %>
      <div style="font-size:6px;text-transform:uppercase;letter-spacing:0.1em;color:#3f3f46;margin-top:2px;">Acesso</div>
      <div style="font-size:8px;color:#a1a1aa;font-family:monospace;">Todos os dias</div>
    </div>
  </div>
  <div style="height:3px;background:<%= acc %>;"></div>
</div>
