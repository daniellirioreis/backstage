<%# Locals: user, event, team, cfg, is_coordinator, avatar_base64, credential_code, chip_label %>
<% acc = cfg.event_name_color; hdr = cfg.header_footer_color; bod = cfg.body_color %>
<div style="font-family:Arial,sans-serif;overflow:hidden;border-radius:14px;display:flex;flex-direction:column;background:<%= hdr %>;min-height:400px;">

  <%# ── Header diagonal ─────────────────────────────────────────── %>
  <div style="position:relative;background:<%= acc %>;height:90px;flex-shrink:0;">
    <%# Bloco escuro com corte diagonal cobrindo a maior parte do header %>
    <div style="position:absolute;inset:0;background:<%= hdr %>;clip-path:polygon(0 0,100% 0,100% 48%,0 100%);"></div>
    <div style="position:relative;padding:12px 14px 0;display:flex;justify-content:space-between;align-items:flex-start;">
      <% if event %>
        <div>
          <div style="font-size:<%= cfg.event_name_font_size %>px;font-weight:800;color:<%= acc %>;text-transform:uppercase;letter-spacing:0.06em;"><%= event.name %></div>
          <div style="font-size:<%= cfg.event_date_font_size %>px;color:#71717a;margin-top:2px;"><%= l(event.start_date, format: :short) %> a <%= l(event.end_date, format: :short) %><% if event.location.present? %> &middot; <%= event.location %><% end %></div>
        </div>
      <% end %>
      <span style="font-size:6.5px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#52525b;white-space:nowrap;"><%= event&.company&.name || "Backstage" %></span>
    </div>
  </div>

  <%# ── Foto em losango (sobreposta entre header e body) ────────── %>
  <div style="display:flex;justify-content:center;margin:-30px 0 0;position:relative;z-index:2;flex-shrink:0;">
    <div style="position:relative;width:<%= cfg.photo_size %>px;height:<%= cfg.photo_size %>px;">
      <%# Borda accent %>
      <div style="position:absolute;inset:0;background:<%= acc %>;clip-path:polygon(50% 0%,100% 50%,50% 100%,0% 50%);"></div>
      <%# Imagem %>
      <div style="position:absolute;inset:4px;clip-path:polygon(50% 0%,100% 50%,50% 100%,0% 50%);overflow:hidden;background:#1a1a1a;display:flex;align-items:center;justify-content:center;">
        <% if avatar_base64 %>
          <img src="<%= avatar_base64 %>" style="width:130%;height:130%;object-fit:cover;margin:-15%;">
        <% else %>
          <span style="font-size:<%= [(cfg.photo_size * 0.22).round, 10].max %>px;font-weight:700;color:#52525b;"><%= user.name.split.map(&:first).first(2).join.upcase %></span>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── Corpo ───────────────────────────────────────────────────── %>
  <div style="flex:1;background:<%= bod %>;padding:10px 16px 16px;display:flex;flex-direction:column;align-items:center;gap:6px;justify-content:center;">
    <div style="font-size:<%= cfg.name_font_size %>px;font-weight:800;color:<%= cfg.name_color %>;line-height:1.2;text-align:center;"><%= user.name %></div>
    <div style="font-size:<%= cfg.role_chip_font_size %>px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:<%= acc %>;text-align:center;"><%= chip_label %></div>
    <div style="width:36px;height:2px;background:<%= acc %>;opacity:0.45;border-radius:1px;margin:2px 0;"></div>
    <% if team %>
      <div style="font-size:<%= cfg.team_info_font_size %>px;color:<%= cfg.team_info_color %>;text-align:center;line-height:1.3;"><strong><%= team.sector.name %></strong> &middot; <%= team.name %></div>
    <% end %>
    <div style="font-size:8px;color:#3f3f46;font-family:monospace;margin-top:2px;"><%= user.formatted_cpf %></div>
  </div>

  <%# ── Transição diagonal para footer ─────────────────────────── %>
  <div style="position:relative;height:22px;background:<%= bod %>;flex-shrink:0;overflow:hidden;">
    <div style="position:absolute;bottom:0;left:0;right:0;height:44px;background:<%= acc %>;clip-path:polygon(0 55%,100% 0,100% 100%,0 100%);"></div>
  </div>

  <%# ── Footer accent ────────────────────────────────────────────── %>
  <div style="background:<%= acc %>;padding:8px 14px 12px;display:flex;align-items:center;justify-content:space-between;gap:8px;flex-shrink:0;">
    <%= badge_qr_svg(credential_code.presence || "BST#{user.id}", pixel_size: 40, color: hdr, bg: acc) %>
    <div style="text-align:right;">
      <% if credential_code.present? %>
        <div style="font-size:6px;text-transform:uppercase;letter-spacing:0.08em;color:<%= hdr %>;opacity:0.7;">Credencial</div>
        <div style="font-size:<%= cfg.credential_code_font_size %>px;color:<%= cfg.credential_code_color %>;font-family:monospace;font-weight:800;letter-spacing:0.05em;"><%= credential_code %></div>
      <% end %>
      <div style="font-size:6px;text-transform:uppercase;letter-spacing:0.08em;color:<%= hdr %>;opacity:0.7;margin-top:3px;">Acesso</div>
      <div style="font-size:8px;color:<%= hdr %>;font-family:monospace;font-weight:700;">Todos os dias</div>
    </div>
  </div>

</div>
